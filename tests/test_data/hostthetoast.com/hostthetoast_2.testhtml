overnight-cinnamon-roll-french-toast-casserole\/"]}]},{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/hostthetoast.com\/overnight-cinnamon-roll-french-toast-casserole\/#primaryimage","url":"https:\/\/hostthetoast.com\/wp-content\/uploads\/2025\/12\/Cinnamon-Roll-French-Toast-Casserole-2.jpg","contentUrl":"https:\/\/hostthetoast.com\/wp-content\/uploads\/2025\/12\/Cinnamon-Roll-French-Toast-Casserole-2.jpg","width":1200,"height":1798},{"@type":"BreadcrumbList","@id":"https:\/\/hostthetoast.com\/overnight-cinnamon-roll-french-toast-casserole\/#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https:\/\/hostthetoast.com\/"},{"@type":"ListItem","position":2,"name":"Breakfast","item":"https:\/\/hostthetoast.com\/category\/breakfast\/"},{"@type":"ListItem","position":3,"name":"Overnight Cinnamon Roll French Toast Casserole"}]},{"@type":"WebSite","@id":"https:\/\/hostthetoast.com\/#website","url":"https:\/\/hostthetoast.com\/","name":"Host The Toast","description":"a Kitchen Kapers blog","publisher":{"@id":"https:\/\/hostthetoast.com\/#organization"},"potentialAction":[{"@type":"SearchAction","target":{"@type":"EntryPoint","urlTemplate":"https:\/\/hostthetoast.com\/?s={search_term_string}"},"query-input":{"@type":"PropertyValueSpecification","valueRequired":true,"valueName":"search_term_string"}}],"inLanguage":"en-US"},{"@type":"Organization","@id":"https:\/\/hostthetoast.com\/#organization","name":"Host the Toast","url":"https:\/\/hostthetoast.com\/","logo":{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/hostthetoast.com\/#\/schema\/logo\/image\/","url":"https:\/\/hostthetoast.com\/wp-content\/uploads\/2017\/03\/HOST-THE-TOAST-horizontal-logo-and-tagline-transparent-FINAL.png","contentUrl":"https:\/\/hostthetoast.com\/wp-content\/uploads\/2017\/03\/HOST-THE-TOAST-horizontal-logo-and-tagline-transparent-FINAL.png","width":449,"height":101,"caption":"Host the Toast"},"image":{"@id":"https:\/\/hostthetoast.com\/#\/schema\/logo\/image\/"},"sameAs":["http:\/\/facebook.com\/hostthetoast","https:\/\/x.com\/hostthetoast","http:\/\/instagram.com\/hostthetoast","http:\/\/pinterest.com\/hostthetoast"]},{"@type":"Person","@id":"https:\/\/hostthetoast.com\/#\/schema\/person\/420eb5afe64ded22618e6cd83ae141c3","name":"Morgan","image":{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/secure.gravatar.com\/avatar\/8d42b478ff14c4bab436402acf88dca5bf390a9618fef19c6d4f3682fb94d4e1?s=96&d=mm&r=g","url":"https:\/\/secure.gravatar.com\/avatar\/8d42b478ff14c4bab436402acf88dca5bf390a9618fef19c6d4f3682fb94d4e1?s=96&d=mm&r=g","contentUrl":"https:\/\/secure.gravatar.com\/avatar\/8d42b478ff14c4bab436402acf88dca5bf390a9618fef19c6d4f3682fb94d4e1?s=96&d=mm&r=g","caption":"Morgan"},"sameAs":["http:\/\/hostthetoast.com"]},{"@context":"https:\/\/schema.org\/","@type":"Recipe","name":"Overnight Cinnamon Roll French Toast Casserole","description":"","author":{"@type":"Person","name":"Morgan"},"image":["https:\/\/hostthetoast.com\/wp-content\/uploads\/2025\/12\/Cinnamon-Roll-French-Toast-Casserole-5-225x225.jpg","https:\/\/hostthetoast.com\/wp-content\/uploads\/2025\/12\/Cinnamon-Roll-French-Toast-Casserole-5-260x195.jpg","https:\/\/hostthetoast.com\/wp-content\/uploads\/2025\/12\/Cinnamon-Roll-French-Toast-Casserole-5-320x180.jpg","https:\/\/hostthetoast.com\/wp-content\/uploads\/2025\/12\/Cinnamon-Roll-French-Toast-Casserole-5.jpg"],"url":"https:\/\/hostthetoast.com\/overnight-cinnamon-roll-french-toast-casserole\/","recipeIngredient":["½ cup (1 stick) unsalted butter, very soft","¾ cup packed brown sugar","2 teaspoons ground cinnamon","½ teaspoon vanilla extract","Pinch of salt","1 large loaf brioche bread (about 14-16 thick slices), slightly stale preferred","6 large eggs","1 cup whole milk","1 cup heavy cream","⅓ cup granulated sugar","1 teaspoon ground cinnamon","1 tablespoon vanilla extract","¼ teaspoon salt","4 ounces cream cheese, softened","2 tablespoons unsalted butter, softened","1 cup powdered sugar, plus more to top, if desired","1 teaspoon vanilla extract","2–4 tablespoons milk or heavy cream"],"recipeInstructions":[{"@type":"HowToStep","text":"Make the cinnamon sugar butter. In a medium-sized bowl, mix the butter, brown sugar, cinnamon, vanilla, and salt until smooth and spreadable. Set aside.","url":"https:\/\/hostthetoast.com\/overnight-cinnamon-roll-french-toast-casserole\/#instruction-step-1"},{"@type":"HowToStep","text":"Prepare the brioche. Grease a 9×13-inch baking dish. If your bread is fresh, toast it lightly first to help it dry out a bit. Spread the cinnamon sugar butter evenly over one side of half of the brioche slices. Top with the remaining slices to form sandwiches, then cut them into 2-inch cubes. Loosely scatter the cubes into the prepared baking dish.","url":"https:\/\/hostthetoast.com\/overnight-cinnamon-roll-french-toast-casserole\/#instruction-step-2"},{"@type":"HowToStep","text":"Make the custard. In a large bowl, whisk together the eggs, milk, cream, sugar, cinnamon, vanilla, and salt until fully combined. Pour the custard evenly over the bread cubes and gently press them down so everything is fully coated.","url":"https:\/\/hostthetoast.com\/overnight-cinnamon-roll-french-toast-casserole\/#instruction-step-3"},{"@type":"HowToStep","text":"Rest the casserole. For the overnight version, cover and refrigerate for 6–10 hours. Avoid soaking longer than 12 hours to prevent a mushy texture. For a same-day version, let the casserole rest at room temperature for 30–60 minutes before baking.","url":"https:\/\/hostthetoast.com\/overnight-cinnamon-roll-french-toast-casserole\/#instruction-step-4"},{"@type":"HowToStep","text":"Bake. Preheat the oven to 350°F. If refrigerated, let the casserole sit at room temperature for 15–20 minutes. Cover with foil and bake for 30 minutes, then uncover and bake for 20–35 minutes more, until puffed, golden brown, and set in the center.","url":"https:\/\/hostthetoast.com\/overnight-cinnamon-roll-french-toast-casserole\/#instruction-step-5"},{"@type":"HowToStep","text":"Make the glaze. While the casserole bakes, whisk together the cream cheese, butter, powdered sugar, vanilla, and milk until smooth and pourable.","url":"https:\/\/hostthetoast.com\/overnight-cinnamon-roll-french-toast-casserole\/#instruction-step-6"},{"@type":"HowToStep","text":"When the caserole is finished baking, let it rest until set and slightly cooled (still warm, just not super hot!), about 15 minutes. Drizzle the glaze all over the casserole and serve with powdered sugar or maple syrup, if desired.","name":"Finish and serve","url":"https:\/\/hostthetoast.com\/overnight-cinnamon-roll-french-toast-casserole\/#instruction-step-7"}],"prepTime":"PT1H","cookTime":"PT1H","totalTime":"PT2H","recipeYield":["12","12 servings"],"datePublished":"2025-12-24","@id":"https:\/\/hostthetoast.com\/overnight-cinnamon-roll-french-toast-casserole\/#recipe","isPartOf":{"@id":"https:\/\/hostthetoast.com\/overnight-cinnamon-roll-french-toast-casserole\/#article"},"mainEntityOfPage":"https:\/\/hostthetoast.com\/overnight-cinnamon-roll-french-toast-casserole\/"}]}</script>

"inLanguage":"en-US","potentialAction":[{"@type":"ReadAction","target":["https://www.castironskilletcooking.com/elk-steak-stroganoff/"]}]},{"@type":"ImageObject","inLanguage":"en-US","@id":"https://www.castironskilletcooking.com/elk-steak-stroganoff/#primaryimage","url":"https://www.castironskilletcooking.com/wp-content/uploads/2024/02/elk-steak-stroganoff-4.jpg","contentUrl":"https://www.castironskilletcooking.com/wp-content/uploads/2024/02/elk-steak-stroganoff-4.jpg","width":800,"height":1200,"caption":"Elk steak stroganoff with a creamy sauce over egg noodles on a white plate."},{"@type":"BreadcrumbList","@id":"https://www.castironskilletcooking.com/elk-steak-stroganoff/#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://www.castironskilletcooking.com/"},{"@type":"ListItem","position":2,"name":"Posts","item":"https://www.castironskilletcooking.com/posts/"},{"@type":"ListItem","position":3,"name":"Elk Steak Stroganoff"}]},{"@type":"WebSite","@id":"https://www.castironskilletcooking.com/#website","url":"https://www.castironskilletcooking.com/","name":"Cast Iron Skillet Cooking","description":"Venison Recipes, Fresh Milled Flour Recipes, and Cast Iron Cooking","publisher":{"@id":"https://www.castironskilletcooking.com/#organization"},"potentialAction":[{"@type":"SearchAction","target":{"@type":"EntryPoint","urlTemplate":"https://www.castironskilletcooking.com/?s={search_term_string}"},"query-input":{"@type":"PropertyValueSpecification","valueRequired":true,"valueName":"search_term_string"}}],"inLanguage":"en-US"},{"@type":"Organization","@id":"https://www.castironskilletcooking.com/#organization","name":"Cast Iron Skillet Cooking","url":"https://www.castironskilletcooking.com/","logo":{"@type":"ImageObject","inLanguage":"en-US","@id":"https://www.castironskilletcooking.com/#/schema/logo/image/","url":"https://www.castironskilletcooking.com/wp-content/uploads/2023/03/Cast-Iron-Skillet-Cooking-Logo.png","contentUrl":"https://www.castironskilletcooking.com/wp-content/uploads/2023/03/Cast-Iron-Skillet-Cooking-Logo.png","width":696,"height":696,"caption":"Cast Iron Skillet Cooking"},"image":{"@id":"https://www.castironskilletcooking.com/#/schema/logo/image/"},"sameAs":["https://www.facebook.com/castironskilletcookingNA","https://www.pinterest.com/castironskilletcooking/","https://www.youtube.com/channel/UC6dh4NzfPHG-XphnqNwzliA"]},{"@type":"Person","@id":"https://www.castironskilletcooking.com/#/schema/person/11dcf8f639e927742e8507aac0a21ca9","name":"Laura","sameAs":["https://www.castironskilletcooking.com/about/","https://www.facebook.com/castironskilletcookingNA","https://www.instagram.com/castironskilletcooking/","https://www.pinterest.com/castironskilletcooking/"],"url":"https://www.castironskilletcooking.com/author/nathanascher/"},{"@type":"Recipe","name":"Elk Steak Stroganoff","author":{"@id":"https://www.castironskilletcooking.com/#/schema/person/11dcf8f639e927742e8507aac0a21ca9"},"description":"Homemade elk steak stroganoff with a creamy mushroom sauce.","datePublished":"2024-02-29T15:20:35+00:00","image":["https://www.castironskilletcooking.com/wp-content/uploads/2024/02/elk-steak-stroganoff-2.jpg","https://www.castironskilletcooking.com/wp-content/uploads/2024/02/elk-steak-stroganoff-2-500x500.jpg","https://www.castironskilletcooking.com/wp-content/uploads/2024/02/elk-steak-stroganoff-2-500x375.jpg","https://www.castironskilletcooking.com/wp-content/uploads/2024/02/elk-steak-stroganoff-2-480x270.jpg"],"recipeYield":["8"],"prepTime":"PT5M","cookTime":"PT15M","totalTime":"PT20M","recipeIngredient":["2 lb elk steaks","2 tablespoons of cooking oil (olive oil or similar)","1 teaspoon salt (sea salt work well)","1/2 teaspoon ground black pepper","1  yellow onion (diced)","10 oz white mushrooms (sliced)","4 tablespoons butter","3 tablespoons all-purpose flour (or sub for cornstarch)","2 cups beef broth","1/2 cup heavy whipping cream","1 tablespoon Dijon mustard","egg noodles for serving"],"recipeInstructions":[{"@type":"HowToStep","text":"Slice elk steaks into thin strips and season with salt and pepper.","name":"Slice elk steaks into thin strips and season with salt and pepper.","url":"https://www.castironskilletcooking.com/elk-steak-stroganoff/#wprm-recipe-16019-step-0-0"},{"@type":"HowToStep","text":"Sear elk strips in a hot skillet for 2 minutes, flipping every 30 seconds. Set aside.","name":"Sear elk strips in a hot skillet for 2 minutes, flipping every 30 seconds. Set aside.","url":"https://www.castironskilletcooking.com/elk-steak-stroganoff/#wprm-recipe-16019-step-0-1"},{"@type":"HowToStep","text":"Saute onions in butter until soft, then add mushrooms and cook until browned.","name":"Saute onions in butter until soft, then add mushrooms and cook until browned.","url":"https://www.castironskilletcooking.com/elk-steak-stroganoff/#wprm-recipe-16019-step-0-2"},{"@type":"HowToStep","text":"Stir in flour, then add beef broth, heavy cream, and Dijon mustard. Mix well.","name":"Stir in flour, then add beef broth, heavy cream, and Dijon mustard. Mix well.","url":"https://www.castironskilletcooking.com/elk-steak-stroganoff/#wprm-recipe-16019-step-0-3"},{"@type":"HowToStep","text":"Return elk strips to the skillet, bring to a simmer, then reduce heat to thicken sauce and finish cooking meat.","name":"Return elk strips to the skillet, bring to a simmer, then reduce heat to thicken sauce and finish cooking meat.","url":"https://www.castironskilletcooking.com/elk-steak-stroganoff/#wprm-recipe-16019-step-0-4"},{"@type":"HowToStep","text":"Salt and pepper to taste.","name":"Salt and pepper to taste.","url":"https://www.castironskilletcooking.com/elk-steak-stroganoff/#wprm-recipe-16019-step-0-5"},{"@type":"HowToStep","text":"Serve over egg noodles or rice.","name":"Serve over egg noodles or rice.","url":"https://www.castironskilletcooking.com/elk-steak-stroganoff/#wprm-recipe-16019-step-0-6"}],"aggregateRating":{"@type":"AggregateRating","ratingValue":"4.8","ratingCount":"5","reviewCount":"1"},"review":[{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"4"},"reviewBody":"I absolutely love this elk stroganoff it's easy to cook easy to prep and it's sticks to your bones","author":{"@type":"Person","name":"Kary"},"datePublished":"2025-12-10"}],"recipeCategory":["main"],"recipeCuisine":["American"],"keywords":"easy, one dish, Elk Steak Stroganoff","nutrition":{"@type":"NutritionInformation","calories":"271 kcal","carbohydrateContent":"5 g","proteinContent":"25 g","fatContent":"17 g","saturatedFatContent":"9 g","transFatContent":"0.3 g","cholesterolContent":"32 mg","sodiumContent":"635 mg","fiberContent":"1 g","sugarContent":"2 g","unsaturatedFatContent":"8 g","servingSize":"1 serving"},"@id":"https://www.castironskilletcooking.com/elk-steak-stroganoff/#recipe","isPartOf":{"@id":"https://www.castironskilletcooking.com/elk-steak-stroganoff/#article"},"mainEntityOfPage":"https://www.castironskilletcooking.com/elk-steak-stroganoff/"}]}</script>

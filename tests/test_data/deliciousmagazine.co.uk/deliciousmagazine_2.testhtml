        "@context": "https://web.archive.org/web/20250216023536/http://schema.org/",
        "name": "Double lemon chicken with charred leeks and dill polenta",
        "author": {
            "@type": "Person",
            "name": "delicious. magazine",
                        "image" : [
                {
                    "@type" : "ImageObject",

						<span class="date">January 29, 2019</span>
						at						<span class="time">5:17 pm</span>
					</a>
				</time>

				<span class="edit-link">
									</span>

				<span class="reply-link">
					<a rel="nofollow" class="comment-reply-link" href="https://smittenkitchen.com/2015/03/baked-chickpeas-with-pita-chips-and-yogurt/?replytocom=1360627#respond" data-commentid="1360627" data-postid="14933" data-belowelement="comment-1360627" data-respondelement="respond" data-replyto="Reply to Peggy" aria-label="Reply to Peggy">Reply</a>				</span><!-- .reply -->

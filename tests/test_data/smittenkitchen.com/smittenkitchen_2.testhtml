					</a>
				</time>

				<span class="edit-link">
									</span>

				<span class="reply-link">
					<a rel="nofollow" class="comment-reply-link" href="https://smittenkitchen.com/2015/03/baked-chickpeas-with-pita-chips-and-yogurt/?replytocom=1037915#respond" data-commentid="1037915" data-postid="14933" data-belowelement="comment-1037915" data-respondelement="respond" data-replyto="Reply to deb" aria-label="Reply to deb">Reply</a>				</span><!-- .reply -->

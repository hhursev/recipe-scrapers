						<span class="date">March 25, 2015</span>
						at						<span class="time">10:41 am</span>
					</a>
				</time>

				<span class="edit-link">
									</span>

				<span class="reply-link">
					<a rel="nofollow" class="comment-reply-link" href="https://smittenkitchen.com/2015/03/baked-chickpeas-with-pita-chips-and-yogurt/?replytocom=816456#respond" data-commentid="816456" data-postid="14933" data-belowelement="comment-816456" data-respondelement="respond" data-replyto="Reply to Shireen" aria-label="Reply to Shireen">Reply</a>				</span><!-- .reply -->

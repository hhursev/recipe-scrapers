					</a>
				</time>

				<span class="edit-link">
									</span>

				<span class="reply-link">
					<a rel="nofollow" class="comment-reply-link" href="https://smittenkitchen.com/2015/03/baked-chickpeas-with-pita-chips-and-yogurt/?replytocom=816477#respond" data-commentid="816477" data-postid="14933" data-belowelement="comment-816477" data-respondelement="respond" data-replyto="Reply to Matea" aria-label="Reply to Matea">Reply</a>				</span><!-- .reply -->

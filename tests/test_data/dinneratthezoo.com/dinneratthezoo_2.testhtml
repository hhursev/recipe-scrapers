":"https:\/\/www.dinneratthezoo.com\/wp-content\/uploads\/2026\/04\/DatZ-logo-stacked-color-RGB-SQUARE-YOAST_696.jpg","width":696,"height":696,"caption":"Dinner at the Zoo"},"image":{"@id":"https:\/\/www.dinneratthezoo.com\/#\/schema\/logo\/image\/"},"sameAs":["http:\/\/www.facebook.com\/dinneratthezoo","https:\/\/x.com\/dinneratthezoo","http:\/\/www.instagram.com\/dinneratthezoo","http:\/\/www.pinterest.com\/dinneratthezoo"]},{"@type":"Person","@id":"https:\/\/www.dinneratthezoo.com\/#\/schema\/person\/3874ff1c9d558166e703ec4f11f11190","name":"Sara Welch","image":{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/secure.gravatar.com\/avatar\/008b9a079f72a6cc33350130cf7f24feb9662a4ff3c0b86432495a1547c4addf?s=96&d=mm&r=g","url":"https:\/\/secure.gravatar.com\/avatar\/008b9a079f72a6cc33350130cf7f24feb9662a4ff3c0b86432495a1547c4addf?s=96&d=mm&r=g","contentUrl":"https:\/\/secure.gravatar.com\/avatar\/008b9a079f72a6cc33350130cf7f24feb9662a4ff3c0b86432495a1547c4addf?s=96&d=mm&r=g","caption":"Sara Welch"},"sameAs":["https:\/\/www.dinneratthezoo.com\/about-me-contact-info\/"]},{"@type":"Question","@id":"https:\/\/www.dinneratthezoo.com\/pink-cupcakes\/#faq-question-1709235805226","position":1,"url":"https:\/\/www.dinneratthezoo.com\/pink-cupcakes\/#faq-question-1709235805226","name":"Can I put sprinkles on cupcakes the day before?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"You can put your sprinkles on cupcakes the day before you plan to serve them. I recommend adding the sprinkles as soon as you place the frosting on the cupcakes so that the sprinkles will stick before the frosting has time to harden.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https:\/\/www.dinneratthezoo.com\/pink-cupcakes\/#faq-question-1709238346152","position":2,"url":"https:\/\/www.dinneratthezoo.com\/pink-cupcakes\/#faq-question-1709238346152","name":"What is the secret to moist cupcakes?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"To get the moist cake, I recommend adding some oil to your batter. Oil tends to add more moisture than butter. I typically use a combination of both oil and butter, for the perfect balance of moisture and rich flavor.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Recipe","name":"Pink Cupcakes","author":{"@id":"https:\/\/www.dinneratthezoo.com\/#\/schema\/person\/3874ff1c9d558166e703ec4f11f11190"},"description":"These pink cupcakes are light and fluffy pink velvet cake topped with a swirl of homemade cream cheese frosting and sprinkles. An easy and delicious dessert that&#39;s perfect for parties!","datePublished":"2026-02-09T11:25:57+00:00","image":["https:\/\/www.dinneratthezoo.com\/wp-content\/uploads\/2024\/02\/pink-cupcakes-final-1.jpg","https:\/\/www.dinneratthezoo.com\/wp-content\/uploads\/2024\/02\/pink-cupcakes-final-1-500x500.jpg","https:\/\/www.dinneratthezoo.com\/wp-content\/uploads\/2024\/02\/pink-cupcakes-final-1-500x375.jpg","https:\/\/www.dinneratthezoo.com\/wp-content\/uploads\/2024\/02\/pink-cupcakes-final-1-480x270.jpg"],"recipeYield":["12"],"prepTime":"PT25M","cookTime":"PT20M","totalTime":"PT60M","recipeIngredient":["1 ½ cups all purpose flour","½ teaspoon baking powder","½ teaspoon baking soda","½ teaspoon salt","1 cup granulated sugar","3\/4 cup buttermilk","1\/3 cup unsalted butter (softened)","3 tablespoons vegetable oil","1  extra large egg","1 teaspoon vanilla extract","½ teaspoon white vinegar","1\/4 teaspoon pink gel food coloring","1 cup unsalted butter (softened)","8 ounces cream cheese (cubed and softened)","4 cups powdered sugar","1 teaspoon vanilla extract","pink gel food coloring","¼ cup pink sprinkles"],"recipeInstructions":[{"@type":"HowToSection","name":"For the cake","itemListElement":[{"@type":"HowToStep","text":"Preheat the oven to 350 degrees F. Line a 12 cup muffin tin with pink cupcake liners.","name":"Preheat the oven to 350 degrees F. Line a 12 cup muffin tin with pink cupcake liners.","url":"https:\/\/www.dinneratthezoo.com\/pink-cupcakes\/#wprm-recipe-48107-step-0-0"},{"@type":"HowToStep","text":"Sieve the flour, baking powder, baking soda, and salt into a large bowl then stir in the sugar.","name":"Sieve the flour, baking powder, baking soda, and salt into a large bowl then stir in the sugar.","url":"https:\/\/www.dinneratthezoo.com\/pink-cupcakes\/#wprm-recipe-48107-step-0-1"},{"@type":"HowToStep","text":"In a separate bowl, use a whisk to combine the buttermilk, melted butter, vegetable oil, egg, vanilla, vinegar, and pink food coloring.","name":"In a separate bowl, use a whisk to combine the buttermilk, melted butter, vegetable oil, egg, vanilla, vinegar, and pink food coloring.","url":"https:\/\/www.dinneratthezoo.com\/pink-cupcakes\/#wprm-recipe-48107-step-0-2"},{"@type":"HowToStep","text":"Slowly mix the wet ingredients into the dry ingredients until the mixture is just combined. Be careful not to overmix your batter.","name":"Slowly mix the wet ingredients into the dry ingredients until the mixture is just combined. Be careful not to overmix your batter.","url":"https:\/\/www.dinneratthezoo.com\/pink-cupcakes\/#wprm-recipe-48107-step-0-3"},{"@type":"HowToStep","text":"Divide the batter evenly among the 12 cupcake liners. They will be filled 2\/3rds of the way full.","name":"Divide the batter evenly among the 12 cupcake liners. They will be filled 2\/3rds of the way full.","url":"https:\/\/www.dinneratthezoo.com\/pink-cupcakes\/#wprm-recipe-48107-step-0-4"},{"@type":"HowToStep","text":"Bake for 20-23 minutes, or until lightly browned and a toothpick inserted in the center of a cupcake comes out clean.","name":"Bake for 20-23 minutes, or until lightly browned and a toothpick inserted in the center of a cupcake comes out clean.","url":"https:\/\/www.dinneratthezoo.com\/pink-cupcakes\/#wprm-recipe-48107-step-0-5"},{"@type":"HowToStep","text":"Cool for 5 minutes in the pan, then transfer the cupcakes to a wire rack to cool completely.","name":"Cool for 5 minutes in the pan, then transfer the cupcakes to a wire rack to cool completely.","url":"https:\/\/www.dinneratthezoo.com\/pink-cupcakes\/#wprm-recipe-48107-step-0-6"}]},{"@type":"HowToSection","name":"For the frosting","itemListElement":[{"@type":"HowToStep","text":"Beat the butter and vanilla extract together with a stand mixer or electric mixer for 1-2 minutes or until light and fluffy.","name":"Beat the butter and vanilla extract together with a stand mixer or electric mixer for 1-2 minutes or until light and fluffy.","url":"https:\/\/www.dinneratthezoo.com\/pink-cupcakes\/#wprm-recipe-48107-step-1-0"},{"@type":"HowToStep","text":"Reduce the mixer speed to low and add the powdered sugar, 1 cup at a time, until everything is combined.","name":"Reduce the mixer speed to low and add the powdered sugar, 1 cup at a time, until everything is combined.","url":"https:\/\/www.dinneratthezoo.com\/pink-cupcakes\/#wprm-recipe-48107-step-1-1"},{"@type":"HowToStep","text":"In a separate bowl beat the cream cheese until smooth. This ensures there are no lumps of cream cheese in the frosting.","name":"In a separate bowl beat the cream cheese until smooth. This ensures there are no lumps of cream cheese in the frosting.","url":"https:\/\/www.dinneratthezoo.com\/pink-cupcakes\/#wprm-recipe-48107-step-1-2"},{"@type":"HowToStep","text":"Add the cream cheese to the frosting mixture and beat until combined. It should be smooth and creamy and have a medium consistency.","name":"Add the cream cheese to the frosting mixture and beat until combined. It should be smooth and creamy and have a medium consistency.","url":"https:\/\/www.dinneratthezoo.com\/pink-cupcakes\/#wprm-recipe-48107-step-1-3"},{"@type":"HowToStep","text":"Dip a toothpick into pink food coloring and use to tint the frosting a pale pink shade. Beat well until combined.","name":"Dip a toothpick into pink food coloring and use to tint the frosting a pale pink shade. Beat well until combined.","url":"https:\/\/www.dinneratthezoo.com\/pink-cupcakes\/#wprm-recipe-48107-step-1-4"}]},{"@type":"HowToSection","name":"For the decorations","itemListElement":[{"@type":"HowToStep","text":"Place the frosting in a piping bag fitted with a large star tip. Pipe a peak of frosting in the center of a cupcake, then pipe around it three times moving closer to the center after each circle. Pull the piping tip away as you release the pressure on the bag.","name":"Place the frosting in a piping bag fitted with a large star tip. Pipe a peak of frosting in the center of a cupcake, then pipe around it three times moving closer to the center after each circle. Pull the piping tip away as you release the pressure on the bag.","url":"https:\/\/www.dinneratthezoo.com\/pink-cupcakes\/#wprm-recipe-48107-step-2-0"},{"@type":"HowToStep","text":"Repeat on the remaining cupcakes, then top each cupcake with sprinkles. Serve.","name":"Repeat on the remaining cupcakes, then top each cupcake with sprinkles. Serve.","url":"https:\/\/www.dinneratthezoo.com\/pink-cupcakes\/#wprm-recipe-48107-step-2-1"}]}],"recipeCategory":["Dessert"],"recipeCuisine":["American"],"keywords":"pink cupcakes, pink velvet cupcakes","nutrition":{"@type":"NutritionInformation","calories":"460 kcal","carbohydrateContent":"60 g","proteinContent":"4 g","fatContent":"18 g","saturatedFatContent":"14 g","transFatContent":"1 g","cholesterolContent":"89 mg","sodiumContent":"227 mg","fiberContent":"0.4 g","sugarContent":"57 g","unsaturatedFatContent":"8 g","servingSize":"1 serving"},"@id":"https:\/\/www.dinneratthezoo.com\/pink-cupcakes\/#recipe","isPartOf":{"@id":"https:\/\/www.dinneratthezoo.com\/pink-cupcakes\/#article"},"mainEntityOfPage":"https:\/\/www.dinneratthezoo.com\/pink-cupcakes\/"}]}</script>

e(this)" onblur="window.WPRecipeMaker.userRating.leave(this)" onclick="window.WPRecipeMaker.userRating.click(this, event)" onkeypress="window.WPRecipeMaker.userRating.click(this, event)" style="font-size: 1em;"><svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" x="0px" y="0px" width="16px" height="16px" viewBox="0 0 24 24"><g  transform="translate(0, 0)"><polygon fill="none" stroke="#c8b358" stroke-width="2" stroke-linecap="square" stroke-miterlimit="10" points="12,2.6 15,9 21.4,9 16.7,13.9 18.6,21.4 12,17.6 5.4,21.4 7.3,13.9 2.6,9 9,9 " stroke-linejoin="miter"/></g></svg></span><div class="wprm-recipe-rating-details wprm-block-text-faded"><span class="wprm-recipe-rating-average">5</span> from 1 vote</div></div></div><div class="dpsp-post-pinterest-image-hidden" style="display: none;"><img width="683" height="1024" src="data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20viewBox='0%200%20683%201024'%3E%3C/svg%3E" data-pin-media="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-pinterest-1.jpg"    alt="Pinterest image for tandoori salmon." class="dpsp-post-pinterest-image-hidden-inner" data-lazy-src="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-pinterest-1-683x1024.jpg" /><noscript><img width="683" height="1024" src="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-pinterest-1-683x1024.jpg" data-pin-media="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-pinterest-1.jpg"    alt="Pinterest image for tandoori salmon." class="dpsp-post-pinterest-image-hidden-inner" loading="lazy" /></noscript></div><div class="dpsp-post-pinterest-image-hidden" style="display: none;"><img width="683" height="1024" src="data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20viewBox='0%200%20683%201024'%3E%3C/svg%3E" data-pin-media="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-pinterest-2.jpg"    alt="Pinterest image for tandoori salmon." class="dpsp-post-pinterest-image-hidden-inner" data-lazy-src="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-pinterest-2-683x1024.jpg" /><noscript><img width="683" height="1024" src="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-pinterest-2-683x1024.jpg" data-pin-media="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-pinterest-2.jpg"    alt="Pinterest image for tandoori salmon." class="dpsp-post-pinterest-image-hidden-inner" loading="lazy" /></noscript></div><span id="dpsp-post-content-markup" data-image-pin-it="true"></span>
<p>This <strong>Broiled Sheet Pan Tandoori Salmon</strong> features skinless salmon filets coated in a tandoori spiced yogurt mixture, broiled along with cherry tomatoes and garlic. Broiled tandoori salmon could not be easier to make &ndash; or faster &ndash; at only <strong>20 minutes total</strong> for the whole meal. You&rsquo;re going to love this incredibly flavor-packed Indian inspired recipe that&rsquo;s easy enough for a weeknight but delicious enough for special occasions!</p>



<figure class="wp-block-image size-full"><img decoding="async" width="1200" height="1800" src="data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20viewBox='0%200%201200%201800'%3E%3C/svg%3E" alt="Sheet pan tandoori salmon with cherry tomatoes after cooking under the broiler, with deep char marks, topped with cilantro." class="wp-image-29041" data-lazy-srcset="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-1.jpg 1200w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-1-200x300.jpg 200w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-1-683x1024.jpg 683w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-1-768x1152.jpg 768w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-1-1024x1536.jpg 1024w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-1-560x840.jpg 560w" data-lazy-sizes="(max-width: 1200px) 100vw, 1200px" data-pin-media="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-1.jpg" data-lazy-src="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-1.jpg"><noscript><img decoding="async" width="1200" height="1800" src="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-1.jpg" alt="Sheet pan tandoori salmon with cherry tomatoes after cooking under the broiler, with deep char marks, topped with cilantro." class="wp-image-29041" srcset="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-1.jpg 1200w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-1-200x300.jpg 200w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-1-683x1024.jpg 683w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-1-768x1152.jpg 768w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-1-1024x1536.jpg 1024w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-1-560x840.jpg 560w" sizes="(max-width: 1200px) 100vw, 1200px" data-pin-media="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-1.jpg"></noscript></figure>    <div class="dpsp-email-save-this-tool ">        <div class="hubbub-save-this-form-wrapper"><h3 class="hubbub-save-this-heading">Would you like to email yourself this recipe?</h3><div class="hubbub-save-this-message"><p>I'll send this post to you, so you can come back to it later!</p></div><div class="hubbub-save-this-form-only-wrapper"><form name="hubbub-save-this-form" method="post" action="">                    <input type="text" name="hubbub-save-this-snare" class="hubbub-save-this-snare hubbub-block-save-this-snare"><p class="hubbub-save-this-emailaddress-paragraph-wrapper"><input aria-label="Email Address" type="email" placeholder="Email Address" name="hubbub-save-this-emailaddress" value="" class="hubbub-block-save-this-text-control hubbub-save-this-emailaddress" required></p><p class="hubbub-save-this-submit-button-paragraph-wrapper"><input type="submit" style="background-color:#53707d;" value="Send Recipe" class="hubbub-block-save-this-submit-button" name="hubbub-block-save-this-submit-button"></p><input type="hidden" name="hubbub-save-this-postid" class="hubbub-save-this-postid" value="28990">                    <input type="hidden" name="hubbub-save-this-posturl" class="hubbub-save-this-posturl" value="https://www.bowlofdelicious.com/tandoori-salmon/">                    <input type="hidden" name="hubbub-save-this-posttitle" class="hubbub-save-this-posttitle" value="Sheet Pan Tandoori Salmon with Burst Cherry Tomatoes">                    <input type="hidden" name="hubbub-save-this-success-redirect-url" class="hubbub-save-this-success-redirect-url" value=""></form>            </div></div>    </div>



<p>Tandoori refers to an Indian method of cooking in a <a href="https://en.wikipedia.org/wiki/Tandoor" target="_blank" rel="noreferrer noopener">tandoor</a>, which yields high heat. A broiler is a great substitute for a tandoor and yields a beautiful dark char on top of the salmon and the tomatoes which gives it so much flavor. But flavor aside&hellip; my favorite thing about using the broiler? How FAST it is! </p>



<p>Lately I&rsquo;ve taken to using my broiler more and more. Part of this was because my oven broke for a few weeks and my &ldquo;bake&rdquo; setting didn&rsquo;t work. But what I discovered was that broiling some veggies like asparagus and broccoli, and proteins like chicken thighs and fish, was far better than roasting. It&rsquo;s like taking a grill indoors. You get gorgeous charred spots and a deeper flavor.</p>



<p>BUT BUT BUT. Also. It&rsquo;s SO FAST! There&rsquo;s no significant preheating necessary, for one thing. I usually give my broiler a few minutes to warm up for good measure. But unlike roasting, you won&rsquo;t be waiting for like half an hour for the oven to get warm. And because of the high heat, it cooks much faster! This entire sheet pan of salmon and tomatoes only needs about 10 minutes to cook.</p>



<p>You do have to keep a close eye on it <em>(due to the fast cooking at high heat)</em> and broiling won&rsquo;t be a good substitute for everything. But for this tandoori salmon, it&rsquo;s literal perfection. Let&rsquo;s get to it!</p>



<figure class="wp-block-image size-full"><img decoding="async" width="1200" height="1800" src="data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20viewBox='0%200%201200%201800'%3E%3C/svg%3E" alt="Tandoori salmon and cherry tomatoes on a plate topped with cilantro and pickled red onions with naan on the side." class="wp-image-29042" data-lazy-srcset="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-2.jpg 1200w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-2-200x300.jpg 200w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-2-683x1024.jpg 683w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-2-768x1152.jpg 768w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-2-1024x1536.jpg 1024w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-2-560x840.jpg 560w" data-lazy-sizes="(max-width: 1200px) 100vw, 1200px" data-pin-media="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-2.jpg" data-lazy-src="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-2.jpg"><noscript><img decoding="async" width="1200" height="1800" src="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-2.jpg" alt="Tandoori salmon and cherry tomatoes on a plate topped with cilantro and pickled red onions with naan on the side." class="wp-image-29042" srcset="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-2.jpg 1200w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-2-200x300.jpg 200w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-2-683x1024.jpg 683w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-2-768x1152.jpg 768w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-2-1024x1536.jpg 1024w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-2-560x840.jpg 560w" sizes="(max-width: 1200px) 100vw, 1200px" data-pin-media="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-2.jpg"></noscript></figure>



<h2 class="wp-block-heading" id="h-ingredients-and-substitutions">Ingredients and Substitutions</h2>



<ul class="wp-block-list">
<li><strong>Salmon &ndash; </strong>the star of the show, though this could also be made with other fish like cod <em>(keeping in mind that different types of fish cook differently)</em>. </li>



<li><strong>Tandoori Masala &ndash; </strong>This is a spice mix that can be found at grocery stores or online &ndash; I personally use the <a href="https://shareasale.com/r.cfm?b=2508699&amp;u=1049855&amp;m=96649&amp;urllink=&amp;afftrack=" target="_blank" rel="noreferrer noopener sponsored nofollow">Diaspora Co. Tandoori Masala</a>. Try to find one with NO sodium/salt in it. You can also make your own <a href="https://www.allrecipes.com/recipe/241875/tandoori-masala-spice-mix/">tandoori masala</a>. It&rsquo;s mild; not spicy.</li>



<li><strong>Plain Greek yogurt &ndash; </strong>preferably full fat.</li>



<li><strong>Cherry or grape tomatoes</strong> &ndash; The tomatoes really are a star here, but I think this whole recipe would be really nice with cauliflower or a similar quick-cooking veggie with or instead of the tomatoes.</li>



<li><strong>Garlic</strong></li>



<li><strong>Cilantro &ndash; </strong>leave this out if you don&rsquo;t like it.</li>



<li><strong>Lemon wedges &ndash; </strong>for serving, optional but reallllly nice.</li>



<li><strong>Pickled red onions &ndash; </strong>again, optional, but realllllllly nice. It&rsquo;s easy to <a href="https://www.bowlofdelicious.com/pickled-red-onions/">make your own pickled red onions</a>!</li>



<li><strong>Salt, Pepper, Olive oil</strong></li>
</ul>



<h2 class="wp-block-heading" id="h-how-to-make-tandoori-salmon-with-burst-tomatoes">How to make Tandoori Salmon with Burst Tomatoes</h2>



<p>First, you&rsquo;ll <strong>marinate the salmon </strong>in a mixture of yogurt, tandoori masala spices, olive oil, and salt. The mixture will be quite thick &ndash; make sure the salmon is coated really well. For best results, let it marinate in the fridge for 1-6 hours. But if you don&rsquo;t have time, you can just cook it right away.</p>



<figure class="wp-block-image size-full"><img decoding="async" width="1200" height="1600" data-pin-nopin="true" src="data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20viewBox='0%200%201200%201600'%3E%3C/svg%3E" alt="Salmon filets being marinated in a tandoori spiced yogurt mixture." class="wp-image-29046" data-lazy-srcset="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-marinating.jpg 1200w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-marinating-225x300.jpg 225w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-marinating-768x1024.jpg 768w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-marinating-1152x1536.jpg 1152w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-marinating-560x747.jpg 560w" data-lazy-sizes="(max-width: 1200px) 100vw, 1200px" data-pin-media="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-marinating.jpg" data-lazy-src="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-marinating.jpg"><noscript><img decoding="async" width="1200" height="1600" data-pin-nopin="true" src="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-marinating.jpg" alt="Salmon filets being marinated in a tandoori spiced yogurt mixture." class="wp-image-29046" srcset="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-marinating.jpg 1200w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-marinating-225x300.jpg 225w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-marinating-768x1024.jpg 768w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-marinating-1152x1536.jpg 1152w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-marinating-560x747.jpg 560w" sizes="(max-width: 1200px) 100vw, 1200px" data-pin-media="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-marinating.jpg"></noscript></figure>



<p>In a bowl, mix together cherry tomatoes, roughly chopped garlic, olive oil, and salt. Dump that onto a sheet pan and move everything to the edges, leaving a nice oil coating in the middle. Then, add the yogurt covered salmon to the middle of the sheet pan, using a spatula or spoon to get any excess yogurt and spread it evenly on top of the fish.</p>



<figure class="wp-block-image size-full"><img decoding="async" width="1200" height="1600" data-pin-nopin="true" src="data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20viewBox='0%200%201200%201600'%3E%3C/svg%3E" alt="A sheet pan with cherry tomatoes and yogurt marinated tandoori salmon before cooking." class="wp-image-29045" data-lazy-srcset="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-before-cooking.jpg 1200w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-before-cooking-225x300.jpg 225w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-before-cooking-768x1024.jpg 768w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-before-cooking-1152x1536.jpg 1152w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-before-cooking-560x747.jpg 560w" data-lazy-sizes="(max-width: 1200px) 100vw, 1200px" data-pin-media="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-before-cooking.jpg" data-lazy-src="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-before-cooking.jpg"><noscript><img decoding="async" width="1200" height="1600" data-pin-nopin="true" src="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-before-cooking.jpg" alt="A sheet pan with cherry tomatoes and yogurt marinated tandoori salmon before cooking." class="wp-image-29045" srcset="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-before-cooking.jpg 1200w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-before-cooking-225x300.jpg 225w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-before-cooking-768x1024.jpg 768w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-before-cooking-1152x1536.jpg 1152w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-before-cooking-560x747.jpg 560w" sizes="(max-width: 1200px) 100vw, 1200px" data-pin-media="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-before-cooking.jpg"></noscript></figure>



<p>Finally, cook it on the top rack of the oven, about 8-10 inches under the broiler for about 10 minutes. You&rsquo;ll need to keep a close eye on it! Depending on your oven, its age, and whether its gas or electric, the broiler may yield stronger or weaker heat. </p>



<p>Once the top of the fish gets nice, even char marks and the tomatoes have burst and blackened on top a bit, you can move it to the lower rack in the oven if the salmon isn&rsquo;t cooked yet. I cook until the salmon reads 125 &ndash; 130 degrees F in the middle of the thickest part <em>(though the FDA recommendation is 145 degrees, which can yield a dry texture &ndash; this all depends on your risk tolerance).</em> A <a href="https://alnk.to/6IH7dCI" target="_blank" rel="noreferrer noopener sponsored nofollow">quick read meat thermometer</a> makes easy work of this.</p>



<figure class="wp-block-image size-full"><img decoding="async" width="1200" height="1600" src="data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20viewBox='0%200%201200%201600'%3E%3C/svg%3E" alt="Tandoori salmon and cherry tomatoes on a sheet pan after being broiled in the oven." class="wp-image-29044" data-lazy-srcset="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-after-cooking.jpg 1200w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-after-cooking-225x300.jpg 225w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-after-cooking-768x1024.jpg 768w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-after-cooking-1152x1536.jpg 1152w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-after-cooking-560x747.jpg 560w" data-lazy-sizes="(max-width: 1200px) 100vw, 1200px" data-pin-media="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-after-cooking.jpg" data-lazy-src="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-after-cooking.jpg"><noscript><img decoding="async" width="1200" height="1600" src="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-after-cooking.jpg" alt="Tandoori salmon and cherry tomatoes on a sheet pan after being broiled in the oven." class="wp-image-29044" srcset="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-after-cooking.jpg 1200w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-after-cooking-225x300.jpg 225w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-after-cooking-768x1024.jpg 768w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-after-cooking-1152x1536.jpg 1152w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-after-cooking-560x747.jpg 560w" sizes="(max-width: 1200px) 100vw, 1200px" data-pin-media="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-after-cooking.jpg"></noscript></figure>



<p>Serve the salmon and tomatoes sprinkled with fresh cilantro, a squeeze of lemon, and pickled red onions, atop rice or with naan for soaking up all of the delicious juices!</p>



<h2 class="wp-block-heading" id="h-tips-and-tricks">Tips and Tricks</h2>



<ul class="wp-block-list">
<li>Don&rsquo;t let the salmon marinate for too long, otherwise the acids in the yogurt will start to break down the fish <em>(similarly to how lime juice works in ceviche).</em></li>



<li>Ask your fish person at the grocery store to cut a center piece of salmon into four evenly sized filets at 6 oz. each and take the skin off &ndash; it will make your life much easier to have this already prepared!</li>



<li>If you HAVE to use a tandoori masala mix that has salt in it, bear in mind it may be quite salty. I recommend eliminating added salt from the yogurt marinade and maybe only using half the amount of the spice mix.</li>
</ul>



<figure class="wp-block-image size-full"><img decoding="async" width="1200" height="1800" src="data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20viewBox='0%200%201200%201800'%3E%3C/svg%3E" alt="A plate with tandoori salmon that's been flaked apart with cherry tomatoes, topped with pickled red onions and a fork alongside." class="wp-image-29043" data-lazy-srcset="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-3.jpg 1200w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-3-200x300.jpg 200w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-3-683x1024.jpg 683w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-3-768x1152.jpg 768w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-3-1024x1536.jpg 1024w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-3-560x840.jpg 560w" data-lazy-sizes="(max-width: 1200px) 100vw, 1200px" data-pin-media="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-3.jpg" data-lazy-src="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-3.jpg"><noscript><img decoding="async" width="1200" height="1800" src="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-3.jpg" alt="A plate with tandoori salmon that's been flaked apart with cherry tomatoes, topped with pickled red onions and a fork alongside." class="wp-image-29043" srcset="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-3.jpg 1200w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-3-200x300.jpg 200w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-3-683x1024.jpg 683w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-3-768x1152.jpg 768w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-3-1024x1536.jpg 1024w, https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-3-560x840.jpg 560w" sizes="(max-width: 1200px) 100vw, 1200px" data-pin-media="https://www.bowlofdelicious.com/wp-content/uploads/2025/05/tandoori-salmon-3.jpg"></noscript></figure>




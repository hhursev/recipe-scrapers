s" data-pin-nopin="true" data-pin-description="" alt="Cornbread slices in a skillet" srcset="https://i2.wp.com/bakerbettie.com/wp-content/uploads/2017/09/moist-cornbread-recipe4-720x720.jpg 720w, https://i2.wp.com/bakerbettie.com/wp-content/uploads/2017/09/moist-cornbread-recipe4-280x280.jpg 280w, https://i2.wp.com/bakerbettie.com/wp-content/uploads/2017/09/moist-cornbread-recipe4-620x620.jpg 620w, https://i2.wp.com/bakerbettie.com/wp-content/uploads/2017/09/moist-cornbread-recipe4-768x768.jpg 768w, https://i2.wp.com/bakerbettie.com/wp-content/uploads/2017/09/moist-cornbread-recipe4-700x700.jpg 700w, https://i2.wp.com/bakerbettie.com/wp-content/uploads/2017/09/moist-cornbread-recipe4-560x560.jpg 560w, https://i2.wp.com/bakerbettie.com/wp-content/uploads/2017/09/moist-cornbread-recipe4-350x350.jpg 350w, https://i2.wp.com/bakerbettie.com/wp-content/uploads/2017/09/moist-cornbread-recipe4-175x175.jpg 175w, https://i2.wp.com/bakerbettie.com/wp-content/uploads/2017/09/moist-cornbread-recipe4-200x200.jpg 200w, https://i2.wp.com/bakerbettie.com/wp-content/uploads/2017/09/moist-cornbread-recipe4-320x320.jpg 320w, https://i2.wp.com/bakerbettie.com/wp-content/uploads/2017/09/moist-cornbread-recipe4-480x480.jpg 480w, https://i2.wp.com/bakerbettie.com/wp-content/uploads/2017/09/moist-cornbread-recipe4-735x735.jpg 735w" sizes="(max-width: 720px) 100vw, 720px" data-pin-media="https://i2.wp.com/bakerbettie.com/wp-content/uploads/2017/09/moist-cornbread-recipe4.jpg"></noscript>	<form class="mv-create-print-form">

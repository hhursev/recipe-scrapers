    flex-wrap: wrap;
    gap: 5px;
    align-items: center;
}

.epr-meta-label {
    font-weight: 400;
}

.epr-meta-separator {
    margin: 0 3px;
    color: var(--primary-light);
}

.epr-author-link {
    font-family: var(--font-family);
    color: var(--dark);
    opacity: 0.65;
    text-decoration: none;
    border-bottom: 1px solid var(--primary);
    transition: color 0.2s ease, opacity 0.2s ease;
}

.epr-author-link:hover {

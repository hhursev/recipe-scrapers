:"https://www.empirecipes.com/caramel-apple-cookies/","name":"Caramel Apple Cookies"}}]},{"@type":"WebPage","@id":"https://www.empirecipes.com/caramel-apple-cookies/#webpage","url":"https://www.empirecipes.com/caramel-apple-cookies/","name":"Soft Caramel Apple Cookies With Oats &amp; Spices","datePublished":"2026-03-12T03:03:13+00:00","dateModified":"2026-03-15T22:26:45+00:00","isPartOf":{"@id":"https://www.empirecipes.com/#website"},"primaryImageOfPage":{"@id":"https://www.empirecipes.com/wp-content/uploads/2026/03/Easy-Caramel-Apple-Cookies.webp"},"inLanguage":"en-US","breadcrumb":{"@id":"https://www.empirecipes.com/caramel-apple-cookies/#breadcrumb"}},{"@type":"Person","@id":"https://www.empirecipes.com/author/carmen/","name":"Camelea Gohier","url":"https://www.empirecipes.com/author/carmen/","image":{"@type":"ImageObject","@id":"https://www.empirecipes.com/wp-content/uploads/2025/11/Carmen_rebenson_author_202511191807-96x96.jpg","url":"https://www.empirecipes.com/wp-content/uploads/2025/11/Carmen_rebenson_author_202511191807-96x96.jpg","caption":"Camelea Gohier","inLanguage":"en-US"}},{"@type":"BlogPosting","headline":"Soft Caramel Apple Cookies With Oats &amp; Spices","keywords":"Caramel Apple Cookies","datePublished":"2026-03-12T03:03:13+00:00","dateModified":"2026-03-15T22:26:45+00:00","articleSection":"30-Minute Meals, All Recipes, American, Cookies &amp; Biscuits, Dessert, Grains, Sheet Pan, Vegetarian","author":{"@id":"https://www.empirecipes.com/author/carmen/","name":"Camelea Gohier"},"publisher":{"@id":"https://www.empirecipes.com/#person"},"description":"These delicious Caramel Apple Cookies combine sweet caramel bits with tart Granny Smith apples in a soft, spiced cookie. Perfect for fall baking with only 32 minutes total time.","name":"Soft Caramel Apple Cookies With Oats &amp; Spices","@id":"https://www.empirecipes.com/caramel-apple-cookies/#richSnippet","isPartOf":{"@id":"https://www.empirecipes.com/caramel-apple-cookies/#webpage"},"image":{"@id":"https://www.empirecipes.com/wp-content/uploads/2026/03/Easy-Caramel-Apple-Cookies.webp"},"inLanguage":"en-US","mainEntityOfPage":{"@id":"https://www.empirecipes.com/caramel-apple-cookies/#webpage"}},{"@type":"Recipe","name":"Caramel Apple Cookies","author":{"@type":"Person","name":"Camelea Gohier"},"description":"These delicious Caramel Apple Cookies combine sweet caramel bits with tart Granny Smith apples in a soft, spiced cookie. Perfect for fall baking.","datePublished":"2026-03-12T03:03:13+00:00","recipeYield":["36","36 cookies"],"prepTime":"PT20M","cookTime":"PT12M","totalTime":"PT32M","recipeIngredient":["2 cups all-purpose flour","1 teaspoon baking soda","1/2 teaspoon salt","1 teaspoon ground cinnamon","1/2 teaspoon ground nutmeg","1 cup unsalted butter (softened)","1 cup packed light brown sugar","1/2 cup granulated sugar","2  large eggs (room temperature)","2 teaspoons vanilla extract","1 cup old-fashioned rolled oats","1 1/2 cups chopped Granny Smith apples","1 cup caramel bits"],"recipeInstructions":[{"@type":"HowToStep","text":"Preheat your oven to 350\u00b0F (175\u00b0C) and line two baking sheets with parchment paper.","name":"Step 1","url":"https://www.empirecipes.com/caramel-apple-cookies/#wprm-recipe-24844-step-0-0"},{"@type":"HowToStep","text":"In a medium bowl, whisk together the all-purpose flour, baking soda, salt, cinnamon, and nutmeg until well combined.","name":"Step 2","url":"https://www.empirecipes.com/caramel-apple-cookies/#wprm-recipe-24844-step-0-1"},{"@type":"HowToStep","text":"In a large bowl using an electric mixer, cream together the softened butter, brown sugar, and granulated sugar on medium speed until light and fluffy, about 3-4 minutes.","name":"Step 3","url":"https://www.empirecipes.com/caramel-apple-cookies/#wprm-recipe-24844-step-0-2"},{"@type":"HowToStep","text":"Beat in the eggs one at a time until fully incorporated, then mix in the vanilla extract.","name":"Step 4","url":"https://www.empirecipes.com/caramel-apple-cookies/#wprm-recipe-24844-step-0-3"},{"@type":"HowToStep","text":"Gradually add the flour mixture to the wet ingredients, mixing on low speed until just combined\u2014be careful not to overmix.","name":"Step 5","url":"https://www.empirecipes.com/caramel-apple-cookies/#wprm-recipe-24844-step-0-4"},{"@type":"HowToStep","text":"Fold in the rolled oats, chopped apples, and caramel bits using a spatula until evenly distributed throughout the cookie dough.","name":"Step 6","url":"https://www.empirecipes.com/caramel-apple-cookies/#wprm-recipe-24844-step-0-5"},{"@type":"HowToStep","text":"Drop rounded tablespoons of dough onto the prepared baking sheets, spacing them about 2 inches apart to allow for spreading.","name":"Step 7","url":"https://www.empirecipes.com/caramel-apple-cookies/#wprm-recipe-24844-step-0-6"},{"@type":"HowToStep","text":"Bake for 10-12 minutes until the edges are golden brown and the centers look set. Let cookies cool on the baking sheet for 5 minutes before transferring to a wire rack to cool completely.","name":"Step 8","url":"https://www.empirecipes.com/caramel-apple-cookies/#wprm-recipe-24844-step-0-7"}],"recipeCategory":["Dessert"],"recipeCuisine":["American"],"keywords":"caramel apple, cookies, fall baking","nutrition":{"@type":"NutritionInformation","calories":"130 kcal","carbohydrateContent":"19 g","proteinContent":"1.5 g","fatContent":"5.5 g","saturatedFatContent":"3.5 g","cholesterolContent":"20 mg","sodiumContent":"85 mg","fiberContent":"0.6 g","sugarContent":"11 g","unsaturatedFatContent":"1.8 g","servingSize":"1 serving"},"@id":"https://www.empirecipes.com/caramel-apple-cookies/#recipe","mainEntityOfPage":"https://www.empirecipes.com/caramel-apple-cookies/#webpage","isPartOf":{"@id":"https://www.empirecipes.com/caramel-apple-cookies/#richSnippet"}}]}</script> <link rel='dns-prefetch' href='//cdnjs.cloudflare.com' /><link rel='dns-prefetch' href='//maps.googleapis.com' /><link rel='dns-prefetch' href='//maps.gstatic.com' /><link rel='dns-prefetch' 
 <script type="pmdelayedscript" data-perfmatters-type="litespeed/javascript" data-cfasync="false" data-no-optimize="1" data-no-defer="1" data-no-minify="1">(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=!0;j.src='https://www.empirecipes.com/wp-content/litespeed/localres/aHR0cHM6Ly93d3cuZ29vZ2xldGFnbWFuYWdlci5jb20vZ3RtLmpz?id='+i+dl;f.parentNode.insertBefore(j,f)})(window,document,'script','dataLayer','GTM-KFGPTFMH')</script>  <script type="pmdelayedscript" data-src="https://www.empirecipes.com/wp-content/litespeed/localres/aHR0cHM6Ly93d3cuZ29vZ2xldGFnbWFuYWdlci5jb20vZ3RhZy9qcw==?id=G-2KV0LKNB19" data-perfmatters-type="litespeed/javascript" data-cfasync="false" data-no-optimize="1" data-no-defer="1" data-no-minify="1"></script> <script type="pmdelayedscript" data-perfmatters-type="litespeed/javascript" data-cfasync="false" data-no-optimize="1" data-no-defer="1" data-no-minify="1">window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments)}
gtag('js',new Date());gtag('config','G-2KV0LKNB19')</script><script type="pmdelayedscript" data-src="https://www.empirecipes.com/wp-content/litespeed/localres/aHR0cHM6Ly9wYWdlYWQyLmdvb2dsZXN5bmRpY2F0aW9uLmNvbS9wYWdlYWQvanM=/adsbygoogle.js?client=ca-pub-5191995660490525" crossorigin="anonymous" data-perfmatters-type="litespeed/javascript" data-cfasync="false" data-no-optimize="1" data-no-defer="1" data-no-minify="1"></script><link rel="icon" href="https://www.empirecipes.com/wp-content/uploads/2025/03/Site-Icon-empirecipes-1.svg" sizes="32x32" /><link rel="icon" href="https://www.empirecipes.com/wp-content/uploads/2025/03/Site-Icon-empirecipes-1.svg" sizes="192x192" /><link rel="apple-touch-icon" href="https://www.empirecipes.com/wp-content/uploads/2025/03/Site-Icon-empirecipes-1.svg" /><meta name="msapplication-TileImage" content="https://www.empirecipes.com/wp-content/uploads/2025/03/Site-Icon-empirecipes-1.svg" /><style id="wp-custom-css">/*
 * WhatNinaCooks - Palette & Typography
 * Adapté depuis eatrapid.com
 * Palette : --primary #E3989D / --dark rgb(52,54,57) / Qualion Round
 */

/*--------------------------------------------------------------
# 1. Variables & Root
--------------------------------------------------------------*/
:root {
    --primary:       #E3989D;
    --primary-light: #f1c4c5;
    --bg-soft:       #fbedee;
    --form:          #FBF4ED;
    --dark:          rgb(52, 54, 57);
    --font-family:   "Qualion Round", Arial, Helvetica, sans-serif;
}

/*--------------------------------------------------------------
# 2. Typography & Base
--------------------------------------------------------------*/
body {
    font-family: var(--font-family);
    font-size: 18px;
    line-height: 1.7;
    letter-spacing: 0.3px;
    color: var(--dark);
}

p {
    margin-bottom: 1.5em;
    line-height: 1.8;
    letter-spacing: 0.3px;
}

h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-family);
    letter-spacing: 0.5px;
    line-height: 1.4;
    color: var(--dark);
}

h1 { font-size: 2.5rem; }
h2 { font-size: 2rem; }
h3 { font-size: 1.7rem; }
h4 { font-size: 1.4rem; }
h5 { font-size: 1.2rem; }
h6 { font-size: 1.1rem; }

/*--------------------------------------------------------------
# 3. Navigation Typography
--------------------------------------------------------------*/
.main-navigation a,
.main-navigation .menu-toggle,
.main-navigation .menu-bar-items {
    font-family: var(--font-family);
    font-weight: 900;
    text-transform: capitalize;
    font-size: 22px;
    letter-spacing: 0.8px;
}

/*--------------------------------------------------------------
# 4. Entry Meta
--------------------------------------------------------------*/
.entry-meta {
    font-family: var(--font-family);
    font-weight: 300;
    font-size: 15px;
    letter-spacing: 0.3px;
    line-height: 1.6;
}

.entry-meta a          { color: var(--dark); }
.entry-meta a:hover    { color: var(--primary); }
time.entry-date.published { color: var(--dark); }

/*--------------------------------------------------------------
# 5. Buttons & Interactive Elements
--------------------------------------------------------------*/
.content-area input:focus,
.content-area textarea:focus {
    border-color: var(--primary) !important;
    box-shadow:   0 0 0 1px var(--primary), 0px 1px 2px rgba(0,0,0,0.15) !important;
}

/*--------------------------------------------------------------
# 6. Separator
--------------------------------------------------------------*/
.wp-block-separator {
    border-bottom: 4px dotted var(--primary-light);
    background:    transparent;
    color:         transparent;
    opacity:       0.6;
}

/*--------------------------------------------------------------
# 7. Pagination
--------------------------------------------------------------*/
.paging-navigation .nav-links .current {
    background:  var(--primary);
    color:       #ffffff;
    font-family: var(--font-family);
    width:       44px !important;
    height:      44px !important;
    font-size:   17px;
    border-radius: 50px;
    display:     inline-flex;
    align-items: center;
    justify-content: center;
}

.paging-navigation .nav-links .page-numbers:not(.next, .current, .prev, .page-numbers.dots) {
    font-family: var(--font-family);
    border:      1px solid var(--primary);
    color:       var(--primary) !important;
    width:       44px !important;
    height:      44px !important;
    font-size:   17px;
    border-radius: 50px;
    display:     inline-flex;
    align-items: center;
    justify-content: center;
}

.paging-navigation .nav-links .page-numbers:not(.next, .current, .prev, .page-numbers.dots):hover {
    background: var(--primary);
    color:      #ffffff !important;
}

.nav-links           { display: flex; align-items: center; gap: 10px; }
.paging-navigation a { color: var(--dark); }
.page-numbers.dots   { color: var(--primary); font-size: 17px; }

/*--------------------------------------------------------------
# 8. Breadcrumb
--------------------------------------------------------------*/
.breadcrumb {
    font-family:    var(--font-family);
    font-size:      16px;
    letter-spacing: 0.3px;
    color:          var(--dark);
    opacity:        0.7;
    padding:        10px 15px;
    margin-bottom:  20px;
}

.breadcrumb a:hover { color: var(--primary); }

/*--------------------------------------------------------------
# 9. Article H2
--------------------------------------------------------------*/
.entry-content h2:not(.wp-block-rank-math-toc-block h2, .wprm-recipe h2),
.post-content  h2:not(.wp-block-rank-math-toc-block h2, .wprm-recipe h2) {
    position:         relative;
    margin-top:       45px;
    margin-bottom:    25px;
    padding:          16px 20px 16px 30px;
    font-family:      var(--font-family);
    font-size:        1.8rem;
    font-weight:      400;
    letter-spacing:   0.5px;
    line-height:      1.5;
    color:            var(--dark);
    background-color: #fff;
    border-radius:    8px;
    box-shadow:       0 2px 5px rgba(0,0,0,0.05);
}

.entry-content h2:not(.wp-block-rank-math-toc-block h2, .wprm-recipe h2)::before,
.post-content  h2:not(.wp-block-rank-math-toc-block h2, .wprm-recipe h2)::before {
    content:       "";
    position:      absolute;
    left:          0;
    top:           50%;
    transform:     translateY(-50%);
    width:         5px;
    height:        100%;
    background:    linear-gradient(to bottom, var(--primary), var(--primary-light));
    border-radius: 10px;
}

@media (max-width: 768px) {
    .entry-content h2,
    .post-content h2 {
        padding:   12px 18px 12px 22px;
        font-size: 1.5rem;
    }
}

/*--------------------------------------------------------------
# 10. Table of Contents (Rank Math)
--------------------------------------------------------------*/
.wp-block-rank-math-toc-block {
    background:    var(--form);
    border-radius: 0;
    box-shadow:    none;
    margin:        30px 0;
    overflow:      hidden;
    border:        none;
    padding:       0 !important;
}

.wp-block-rank-math-toc-block h2 {
    font-family:      var(--font-family); /* ✅ CORRIGÉ: était var(--primary) */
    font-size:        24px;
    font-weight:      400;
    letter-spacing:   3px;
    text-transform:   uppercase;
    color:            var(--dark);
    padding:          28px 28px 20px !important;
    background-color: var(--form);
    margin:           0 !important;
    display:          flex;
    justify-content:  space-between;
    align-items:      center;
    cursor:           pointer;
    border-bottom:    none;
}

.wp-block-rank-math-toc-block h2:after {
    content:     "›";
    font-family: var(--font-family);
    font-weight: 400;
    color:       var(--primary); /* ✅ CORRIGÉ: remplace #b25962 hardcodé */
    font-size:   1.8rem;
    margin-left: 10px;
    transition:  transform 0.3s ease;
    display:     inline-block;
    transform:   rotate(90deg);
}

.wp-block-rank-math-toc-block.toc-collapsed h2:after {
    transform: rotate(-90deg);
}

.wp-block-rank-math-toc-block nav {
    padding:    0 28px 24px;
    transition: max-height 0.5s ease, opacity 0.3s ease, padding 0.3s ease;
    max-height: 2000px;
    opacity:    1;
    overflow:   hidden;
    background: var(--form);
}

.wp-block-rank-math-toc-block.toc-collapsed nav {
    max-height:     0;
    opacity:        0;
    padding-top:    0;
    padding-bottom: 0;
}

.wp-block-rank-math-toc-block ul { list-style: none !important; padding: 0 !important; margin: 0 !important; }
.wp-block-rank-math-toc-block li { margin-bottom: 18px !important; padding-left: 0 !important; position: relative; }

.wp-block-rank-math-toc-block a {
    font-family:     var(--font-family) !important;
    display:         flex !important;
    align-items:     center !important;
    text-decoration: underline !important;
    color:           var(--primary) !important; /* ✅ CORRIGÉ: remplace #b25962 hardcodé */
    font-size:       1.1rem !important;
    letter-spacing:  0.3px !important;
    padding-left:    36px !important;
    position:        relative !important;
    line-height:     1.5 !important;
    transition:      color 0.2s, opacity 0.2s !important;
    opacity:         0.85;
}

.wp-block-rank-math-toc-block a:hover {
    color:   var(--dark) !important; /* ✅ CORRIGÉ: était --primary-light */
    opacity: 1;
}

.wp-block-rank-math-toc-block a:before {
    content:         "»";
    position:        absolute;
    left:            0;
    top:             50%;
    transform:       translateY(-50%);
    display:         flex;
    align-items:     center;
    justify-content: center;
    width:           26px;
    height:          26px;
    background:      var(--bg-soft);
    border-radius:   50%;
    font-size:       1rem;
    font-weight:     400;
    color:           var(--primary); /* ✅ CORRIGÉ: remplace #b25962 hardcodé */
    line-height:     1;
}

.wp-block-rank-math-toc-block a:after {
    display: none;
}

@media (max-width: 768px) {
    .wp-block-rank-math-toc-block h2  { font-size: 11px; padding: 22px 20px 16px !important; }
    .wp-block-rank-math-toc-block a   { font-size: 1rem !important; padding-left: 32px !important; }
    .wp-block-rank-math-toc-block nav { padding: 0 20px 20px; }
}

/*--------------------------------------------------------------
/*--------------------------------------------------------------
# 11. FAQ (Rank Math) — style TOC
--------------------------------------------------------------*/
#rank-math-faq {
    background:    var(--form);
    margin:        30px 0;
    padding:       0;
    overflow:      hidden;
}

/* Titre FAQ */
#rank-math-faq > div > h2,
#rank-math-faq h2,
#fa-qs {
    font-family:      var(--font-family) !important;
    font-size:        24px !important;
    font-weight:      400 !important;
    letter-spacing:   3px !important;
    text-transform:   uppercase !important;
    color:            var(--dark) !important;
    padding:          28px 28px 20px !important;
    background-color: var(--form) !important;
    margin:           0 !important;
    border:           none !important;
    box-shadow:       none !important;
}

/* Retire le ::before de l'H2 article (ligne rose gauche) sur le FAQ */
#fa-qs::before,
#rank-math-faq h2::before {
    display: none !important;
}

/* Items */
#rank-math-faq .rank-math-list-item {
    border:        none;
    border-radius: 0;
    margin-bottom: 18px !important;
    overflow:      visible;
    background:    transparent;
    padding:       0 28px;
    transition:    none;
    position:      relative;
}

/* Cache le checkbox natif */
#rank-math-faq .rank-math-list-item input {
    position: absolute;
    opacity:  0;
    z-index:  2;
    cursor:   pointer;
    width:    100%;
    height:   100%;
    left:     0;
    top:      0;
    margin:   0;
}

/* Question */
#rank-math-faq .rank-math-question {
    font-family:  var(--font-family);
    font-weight:  400;
    font-size:    1.05rem;
    color:        var(--primary) !important;
    padding:      0 0 0 36px;
    cursor:       pointer;
    position:     relative;
    background:   transparent;
    text-decoration: underline;
    line-height:  1.5;
    transition:   color 0.2s;
}

#rank-math-faq .rank-math-question:hover {
    color:      var(--dark) !important;
    background: transparent;
}

/* Bullet » */
#rank-math-faq .rank-math-question::before {
    content:         "»";
    position:        absolute;
    left:            0;
    top:             50%;
    transform:       translateY(-50%);
    display:         flex;
    align-items:     center;
    justify-content: center;
    width:           26px;
    height:          26px;
    background:      var(--bg-soft);
    border-radius:   50%;
    font-size:       1rem;
    color:           var(--primary);
    line-height:     1;
    text-decoration: none;
}

/* Supprime le + natif */
#rank-math-faq .rank-math-question::after {
    display: none !important;
}

/* Réponse — cachée par défaut */
#rank-math-faq .rank-math-answer {
    max-height:  0;
    overflow:    hidden;
    padding:     0 0 0 36px;
    transition:  max-height 0.4s ease, padding 0.3s ease, opacity 0.3s ease;
    font-size:   1rem;
    line-height: 1.7;
    color:       var(--dark);
    font-family: var(--font-family);
    opacity:     0;
}

/* Réponse ouverte */
#rank-math-faq .rank-math-list-item input:checked ~ .rank-math-answer {
    max-height: 600px;
    padding:    10px 0 10px 36px;
    opacity:    1;
}

/* Question ouverte */
#rank-math-faq .rank-math-list-item input:checked ~ .rank-math-question {
    color:      var(--dark) !important;
    background: transparent;
}

/* Bullet actif */
#rank-math-faq .rank-math-list-item input:checked ~ .rank-math-question::before {
    background: var(--primary-light);
    color:      var(--dark);
}

@media (max-width: 768px) {
    #rank-math-faq .rank-math-list-item { padding: 0 20px; }
    #rank-math-faq .rank-math-question  { font-size: 0.95rem; }
    #rank-math-faq .rank-math-answer    { font-size: 0.9rem; }
}
/*--------------------------------------------------------------
# FAQ - details/summary natif (WhatNinaCooks)
--------------------------------------------------------------*/

.faq-block {
    margin: 30px 0;
}

.faq-block details {

    border-radius: 0;
    margin-bottom: 12px;
    overflow:      hidden;
    background:    #ffffff;
    transition:    background 0.3s ease;
}

.faq-block details[open] {
    background: var(--bg-soft);
}

.faq-block details summary {
    font-family:  var(--font-family);
    font-size:    1.1rem;
    font-weight:  400;
    color:        var(--dark);
    padding:      18px 55px 18px 22px;
    cursor:       pointer;
    position:     relative;
    list-style:   none;
    line-height:  1.5;
    transition:   background 0.3s ease, color 0.3s ease;
}

/* Retire le triangle natif sur tous les navigateurs */
.faq-block details summary::-webkit-details-marker { display: none; }
.faq-block details summary::marker               { display: none; }

/* Icône + */
.faq-block details summary::after {
    content:    "+";
    position:   absolute;
    right:      20px;
    top:        50%;
    transform:  translateY(-50%);
    font-size:  1.6rem;
    color:      var(--primary);
    transition: transform 0.3s ease, content 0.1s;
    line-height: 1;
}

/* Icône − quand ouvert */
.faq-block details[open] summary::after {
    content:   "−";
    transform: translateY(-50%) rotate(180deg);
}

.faq-block details[open] summary {
    background: var(--bg-soft);
    color:      var(--primary);
}

.faq-block details summary:hover {
    background: var(--bg-soft);
}

/* Réponse */
.faq-block details > div {
    padding:     0 22px 20px 22px;
    font-family: var(--font-family);
    font-size:   1rem;
    line-height: 1.75;
    color:       var(--dark);
}

.faq-block details > div p {
    margin: 15px 0 0;
}

@media (max-width: 768px) {
    .faq-block details summary {
        font-size: 1rem;
        padding:   16px 50px 16px 18px;
    }
    .faq-block details > div {
        font-size: 0.95rem;
        padding:   0 18px 18px;
    }
}

.category .post-image img,
.category .entry-image img,
.category article img {
    aspect-ratio: 1 / 1;
    object-fit: cover;
    width: 100%;
}
.category .entry-title {
    text-align: left;
    font-size: 22px;
    line-height: 1.4;
    margin: 10px 0;
}

body.category .entry-summary,
body.category .post-excerpt,
body.category .entry-content {
    display: none !important;
}</style><style>.perfmatters-lazy-youtube{position:relative;width:100%;max-width:100%;height:0;padding-bottom:56.23%;overflow:hidden}.perfmatters-lazy-youtube img{position:absolute;top:0;right:0;bottom:0;left:0;display:block;width:100%;max-width:100%;height:auto;margin:auto;border:none;cursor:pointer;transition:.5s all;-webkit-transition:.5s all;-moz-transition:.5s all}.perfmatters-lazy-youtube img:hover{-webkit-filter:brightness(75%)}.perfmatters-lazy-youtube .play{position:absolute;top:50%;left:50%;right:auto;width:68px;height:48px;margin-left:-34px;margin-top:-24px;background:url(https://www.empirecipes.com/wp-content/plugins/perfmatters/img/youtube.svg) no-repeat;background-position:center;background-size:cover;pointer-events:none;filter:grayscale(1)}.perfmatters-lazy-youtube:hover .play{filter:grayscale(0)}.perfmatters-lazy-youtube iframe{position:absolute;top:0;left:0;width:100%;height:100%;z-index:99}.wp-has-aspect-ratio .wp-block-embed__wrapper{position:relative;}.wp-has-aspect-ratio .perfmatters-lazy-youtube{position:absolute;top:0;right:0;bottom:0;left:0;width:100%;height:100%;padding-bottom:0}</style><link rel="stylesheet" id="rank-math-toc-block-css" media="all" data-pmdelayedstyle="https://www.empirecipes.com/wp-content/plugins/seo-by-rank-math/includes/modules/schema/blocks/toc/assets/css/toc_list_style.css"><link rel="stylesheet" id="fluent-form-styles-css" media="all" data-pmdelayedstyle="https://www.empirecipes.com/wp-content/plugins/fluentform/assets/css/fluent-forms-public.css"><link rel="stylesheet" id="fluentform-public-default-css" media="all" data-pmdelayedstyle="https://www.empirecipes.com/wp-content/plugins/fluentform/assets/css/fluentform-public-default.css"></head><body class="wp-singular post-template-default single single-post postid-24846 single-format-standard wp-custom-logo wp-embed-responsive wp-theme-generatepress post-image-above-header post-image-aligned-center sticky-menu-fade right-sidebar nav-float-right separate-containers nav-search-enabled header-aligned-center dropdown-hover" itemtype="https://schema.org/Blog" itemscope>

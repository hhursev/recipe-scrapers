<label for="email" class="screen-reader-text">Email</label><input placeholder="Email *" id="email" name="email" type="email" value="" size="30" required /><p class="comment-form-cookies-consent"><input id="wp-comment-cookies-consent" name="wp-comment-cookies-consent" type="checkbox" value="yes" /> <label for="wp-comment-cookies-consent">Save my name, email, and website in this browser for the next time I comment.</label></p><p class="form-submit"><input name="submit" type="submit" id="submit" class="submit" value="Post Comment" /> <input type='hidden' name='comment_post_ID' value='24846' id='comment_post_ID' />
<input type='hidden' name='comment_parent' id='comment_parent' value='0' /></p></form></div></div></div></main></div><div class="widget-area sidebar is-right-sidebar" id="right-sidebar"><div class="inside-right-sidebar"><style>:root {
    --primary:       #955865;
    --primary-light: #D3C3C4;
    --bg-soft:       #F7F5F0;
    --dark:          #343639;
    --font-family:   "Qualion Round", Arial, Helvetica, sans-serif;
}

.about-me-widget {
    max-width: 400px;
    margin: 20px auto;
    padding: 24px;
    background-color: #fff;
    border-radius: 0;
    box-shadow: none;
    text-align: center;
    font-family: var(--font-family);
    border-top: 2px solid var(--primary-light);
}
.about-me-widget .profile-image {
    width: 100%;
    max-width: 350px;
    height: auto;
    object-fit: cover;
    margin-bottom: 15px;
    border-radius: 0;
}
.about-me-widget h1 {
    font-family: var(--font-family);
    font-size: 24px;
    font-weight: 400;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--dark);
    margin: 15px 0 20px;
}
.about-me-widget .description {
    font-family: var(--font-family);
    font-size: 16px;
    line-height: 25px;
    letter-spacing: 0.3px;
    color: var(--dark);
    opacity: 0.82;
    margin-bottom: 24px;
    padding: 0 12px;
}
.about-me-widget .read-more-btn {
    display: inline-block;
    font-family: var(--font-family);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 11px 26px;
    background: var(--primary);
    color: #ffffff;
    text-decoration: none;
    border: none;
    border-radius: 0;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
    white-space: nowrap;
}
.about-me-widget .read-more-btn:hover {
    background: var(--dark);
    color: #ffffff;
}

/* ===== SOCIAL ICONS ===== */
.about-me-social {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 14px;
    margin-top: 22px;
}
.about-me-social-label {
    font-family: 'Dancing Script', cursive;
    font-size: 20px;
    color: var(--primary);
    margin-right: 4px;
}
.about-me-social a {
    display: flex;
    align-items: center;
    color: var(--dark);
    opacity: 0.6;
    text-decoration: none;
    transition: opacity 0.2s ease, color 0.2s ease;
}
.about-me-social a:hover { opacity: 1; color: var(--primary); }
.about-me-social svg { width: 16px; height: 16px; fill: currentColor; }

/* ===== DIVIDER ===== */
.about-me-divider {
    height: 1px;
    background: var(--primary-light);
    margin: 24px 0;
}

/* ===== SEARCH ===== */
.about-me-search-title {
    font-family: var(--font-family);
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--dark);
    margin: 0 0 14px;
}
.about-me-search-form {
    position: relative;
    width: 100%;
}
.about-me-search-input {
    width: 100%;
    padding: 11px 44px 11px 14px;
    border: 1px solid var(--primary-light);
    border-radius: 0;
    font-family: var(--font-family);
    font-size: 13px;
    font-style: italic;
    color: var(--dark);
    background: #fff;
    outline: none;
    box-sizing: border-box;
    transition: border-color 0.2s ease;
}
.about-me-search-input:focus { border-color: var(--primary); }
.about-me-search-input::placeholder { color: #bbb; }
.about-me-search-btn {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
}
.about-me-search-btn svg {
    width: 16px;
    height: 16px;
    stroke: var(--primary-light);
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    transition: stroke 0.2s ease;
}
.about-me-search-btn:hover svg { stroke: var(--primary); }

/* ===== POPULAR RECIPES ===== */
.about-me-popular-title {
    font-family: var(--font-family);
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--dark);
    margin: 24px 0 16px;
}
.about-me-popular-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
}
.about-me-popular-item a {
    text-decoration: none;
    display: block;
}
.about-me-popular-item img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
}
.about-me-popular-item:hover img {
    transform: scale(1.03);
}
.about-me-popular-item-wrap {
    overflow: hidden;
}
.about-me-popular-item-title {
    font-family: var(--font-family);
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--dark);
    margin-top: 8px;
    line-height: 1.5;
    text-align: center;
    transition: color 0.2s ease;
}
.about-me-popular-item a:hover .about-me-popular-item-title {
    color: var(--primary);
}

/* ===== FOOTER LINE ===== */
.about-me-widget::after {
    content: '';
    display: block;
    margin: 24px auto 0;
    height: 1px;
    width: 60%;
    background: var(--primary-light);
}

@media (max-width: 480px) {
    .about-me-widget { margin: 10px; padding: 20px; max-width: none; }
    .about-me-widget .description { font-size: 12px; padding: 0 8px; }
    .about-me-widget .read-more-btn { font-size: 10px; padding: 10px 20px; }
}</style><div class="about-me-widget">

    font-family: 'Qualion Round';
    src: url('https://www.empirecipes.com/wp-content/themes/generatepress/fonts/qualionround-demibold-webfont.woff2') format('woff2');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
 }

:root {
  --epr-toggle-size: 26px;
  --epr-dark:    #343639;
  --epr-light:   #F7F5F0;
  --epr-bg:      #ffffff;
  --epr-border:  #D3C3C4;
  --epr-primary: #955865;
  --epr-font:    "Qualion Round", Arial, Helvetica, sans-serif;
}

* { box-sizing: border-box; }

/* ===== NAV ===== */
.epr-custom-nav {
  background: var(--epr-bg);
  border-top: 4px solid var(--epr-primary);
  width: 100%;
  position: relative;
  z-index: 1000;
  font-family: var(--epr-font);
}
.epr-nav-container {
  max-width: 1280px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  padding: 0 40px;
  gap: 10px;
  position: relative;
}

/* ===== LOGO ===== */
.epr-nav-logo { display: flex; align-items: center; flex-shrink: 0; padding: 5px 25px; }
.epr-nav-logo img { height: 82px; width: auto; max-width: 240px; display: block; }

/* ===== MENU ===== */
.epr-nav-menu {
  display: flex; list-style: none;
  margin: 0 0 0 auto; padding: 0; align-items: center;
}
.epr-nav-menu > li > a {
  display: block; padding: 18px 13px;
  font-family: var(--epr-font);
  font-size: 18px;
  font-weight: 400;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--epr-dark); text-decoration: none;
  white-space: nowrap; transition: color 0.2s;
}
.epr-nav-menu > li > a:hover { color: var(--epr-primary); }

/* ===== BROWSE RECIPES ===== */
.epr-has-browse { position: static; }

.epr-browse-link {
  display: flex !important;
  align-items: center;
  gap: 5px;
  padding: 18px 13px !important;
  font-family: var(--epr-font) !important;
  font-size: 18px !important;
  font-weight: 400 !important;
  letter-spacing: 2px !important;
  text-transform: uppercase !important;
  color: var(--epr-dark) !important;
  text-decoration: none;
  white-space: nowrap;
  transition: color 0.2s;
}
.epr-has-browse.mob-open .epr-browse-link { color: var(--epr-primary) !important; }
.epr-has-browse.mob-open .epr-arrow       { transform: rotate(180deg); }
.epr-browse-link:hover                    { color: var(--epr-primary) !important; }

.epr-arrow {
  font-size: 0.55rem;
  display: inline-block;
  transition: transform 0.25s;
}

/* ===== PANNEAU BROWSE ===== */
.epr-browse-panel {
  display: none;
  position: absolute;
  top: 100%;
  left: 50%;
  transform: translateX(-50%);
  width: 940px;
  max-width: 98vw;
  background: #fff;
  border-top: 3px solid var(--epr-primary);
  box-shadow: 0 8px 28px rgba(0,0,0,0.10);
  z-index: 9999;
  padding: 16px 20px;
}
.epr-has-browse.mob-open .epr-browse-panel { display: block; }

.epr-browse-inner {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 5px;
}

/* ===== GROUPE ===== */
.epr-group { border-bottom: 1px solid var(--epr-border); }

.epr-group-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8px 10px;
  gap: 6px;
}
.epr-group-header:hover { background: var(--epr-light); }

.epr-group-title {
  font-family: var(--epr-font);
  font-size: 11px;
  font-weight: 400;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: var(--epr-dark);
  text-decoration: none;
  transition: color 0.2s;
  flex: 1;
}
.epr-group-title:hover { color: var(--epr-primary); }

.epr-group-btn {
  background: none;
  border: 1px solid var(--epr-border);
  border-radius: 3px;
  width: 22px; height: 22px;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; flex-shrink: 0; padding: 0;
  transition: background 0.15s, border-color 0.15s;
}
.epr-group-btn:hover { background: var(--epr-primary); border-color: var(--epr-primary); }
.epr-group-btn:hover .epr-gtoggle { color: #fff; }

.epr-gtoggle {
  font-size: 1.1rem; font-weight: 700;
  color: var(--epr-primary); line-height: 1;
  display: block; transition: color 0.15s;
}

.epr-group-body {
  display: none; flex-direction: column;
  padding: 4px 0 8px 10px;
}
.epr-group.open .epr-group-body { display: flex; }

.epr-group-body a {
  display: block; padding: 5px 8px;
  font-family: var(--epr-font);
  font-size: 11px;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--epr-dark);
  text-decoration: none;
  border-radius: 3px;
  transition: background 0.15s, color 0.15s, padding-left 0.15s;
}
.epr-group-body a:hover {
  background: var(--epr-light);
  color: var(--epr-primary);
  padding-left: 14px;
}

/* ===== SEARCH DESKTOP ===== */
.epr-nav-search { position: relative; display: flex; align-items: center; }
.epr-search-toggle {
  display: flex; align-items: center;
  padding: 18px 12px; color: var(--epr-dark);
  text-decoration: none; transition: color 0.2s; cursor: pointer;
}
.epr-search-toggle:hover { color: var(--epr-primary); }
.epr-search-box {
  display: none; position: absolute; top: 100%; right: 0;
  background: #fff; border-top: 3px solid var(--epr-primary);
  box-shadow: 0 8px 24px rgba(0,0,0,0.10);
  padding: 12px; min-width: 280px; z-index: 9999;
}
.epr-search-box.open { display: block; }
.epr-search-box form, .epr-search-box-mobile form {
  display: flex; align-items: center;
  border: 2px solid var(--epr-border);
  border-radius: 0; overflow: hidden; transition: border-color 0.2s;
}
.epr-search-box form:focus-within,
.epr-search-box-mobile form:focus-within { border-color: var(--epr-primary); }
.epr-search-box input, .epr-search-box-mobile input {
  flex: 1; border: none; outline: none;
  padding: 9px 12px;
  font-family: var(--epr-font);
  font-size: 11px;
  letter-spacing: 1px;
  color: var(--epr-dark); background: #fff;
}
.epr-search-box button, .epr-search-box-mobile button {
  background: var(--epr-dark); border: none; padding: 9px 12px;
  cursor: pointer; color: #fff; display: flex; align-items: center; transition: background 0.2s;
}
.epr-search-box button:hover,
.epr-search-box-mobile button:hover { background: var(--epr-primary); }

/* ===== TOGGLE MOBILE ===== */
.epr-nav-toggle {
  display: none; background: none;
  border: none; color: var(--epr-dark);
  cursor: pointer; padding: 5px 8px;
  border-radius: 4px; line-height: 1; flex-shrink: 0;
}
.epr-nav-toggle svg { width: var(--epr-toggle-size); height: var(--epr-toggle-size); display: block; }
.epr-nav-toggle:hover { background: var(--epr-light); color: var(--epr-primary); }
.epr-nav-search-mobile { display: none; }
.epr-search-box-mobile  { display: none; }

/* ===== TABLET 1024px ===== */
@media (max-width: 1024px) {
  .epr-nav-logo img { height: 44px; max-width: 170px; }
  .epr-nav-menu > li > a,
  .epr-browse-link { padding: 18px 8px !important; font-size: 10px !important; }
  .epr-browse-panel { width: 720px; }
  .epr-browse-inner { grid-template-columns: repeat(3, 1fr); }
}

/* ===== MOBILE ≤ 768px ===== */
@media (max-width: 768px) {

  .epr-nav-container {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 10px 20px; gap: 0;
  }
  .epr-nav-toggle {
    display: flex; align-items: center;
    justify-content: flex-start; grid-column: 1;
  }
  .epr-nav-logo { grid-column: 2; padding: 5px 10px; justify-content: center; }
  .epr-nav-logo img { height: 52px; max-width: 180px; }

  .epr-nav-search-mobile {
    display: flex; grid-column: 3;
    justify-content: flex-end; align-items: center;
  }
  .epr-nav-search-mobile a {
    color: var(--epr-dark); display: flex;
    align-items: center; padding: 5px;
  }
  .epr-nav-search-mobile a:hover { color: var(--epr-primary); }
  .epr-nav-search-desktop { display: none !important; }

  .epr-nav-menu {
    display: none; flex-direction: column;
    width: 100%; background: #fff;
    border-top: 2px solid var(--epr-primary);
    padding: 5px 0; margin-left: 0; grid-column: 1 / -1;
  }
  .epr-nav-menu.open { display: flex; }
  .epr-nav-menu > li { width: 100%; border-bottom: 1px solid #f0f0f0; }
  .epr-nav-menu > li > a { padding: 13px 15px; font-size: 11px; display: block; }

  .epr-browse-link {
    width: 100%;
    padding: 13px 15px !important;
    font-size: 11px !important;
    justify-content: space-between;
  }

  .epr-browse-panel {
    position: static !important;
    transform: none !important;
    width: 100% !important;
    max-width: 100% !important;
    box-shadow: none;
    border-top: none;
    border-left: 3px solid var(--epr-primary);
    margin: 0 0 5px 15px;
    padding: 5px 0;
    background: #f9f9f9;
  }

  .epr-browse-inner { grid-template-columns: 1fr; gap: 0; }

  .epr-group { border-bottom: 1px solid #eee; }
  .epr-group-header { padding: 10px 12px; }
  .epr-group-title { font-size: 11px; }
  .epr-group-body a {
    padding: 7px 20px !important;
    font-size: 11px;
    border-bottom: 1px solid #eee;
  }

  .epr-search-box-mobile {
    display: none; padding: 10px 15px;
    background: #f9f9f9;
    border-top: 1px solid #eee;
    border-bottom: 2px solid var(--epr-primary);
  }
  .epr-search-box-mobile.open { display: block; }
}</style> <script type="pmdelayedscript" data-perfmatters-type="litespeed/javascript" data-cfasync="false" data-no-optimize="1" data-no-defer="1" data-no-minify="1">(function(){var browseItem=document.querySelector('.epr-has-browse');var browseLink=document.querySelector('.epr-browse-link');document.getElementById('eprNavToggle').addEventListener('click',function(){document.getElementById('eprNavMenu').classList.toggle('open')});browseLink.addEventListener('click',function(e){e.preventDefault();browseItem.classList.toggle('mob-open')});document.addEventListener('click',function(e){if(!browseItem.contains(e.target)){browseItem.classList.remove('mob-open')}});document.querySelectorAll('.epr-group-btn').forEach(function(btn){btn.addEventListener('click',function(e){e.stopPropagation();var group=this.closest('.epr-group');var isOpen=group.classList.contains('open');document.querySelectorAll('.epr-group.open').forEach(function(g){g.classList.remove('open');g.querySelector('.epr-gtoggle').textContent='+'});if(!isOpen){group.classList.add('open');this.querySelector('.epr-gtoggle').textContent='−'}})});document.getElementById('eprSearchToggle').addEventListener('click',function(e){e.preventDefault();var box=document.getElementById('eprSearchBox');box.classList.toggle('open');if(box.classList.contains('open')){setTimeout(function(){box.querySelector('input').focus()},100)}});document.addEventListener('click',function(e){var s=document.querySelector('.epr-nav-search-desktop');if(s&&!s.contains(e.target)){var b=document.getElementById('eprSearchBox');if(b)b.classList.remove('open');}});document.getElementById('eprSearchToggleMobile').addEventListener('click',function(e){e.preventDefault();var box=document.getElementById('eprSearchBoxMobile');box.classList.toggle('open');if(box.classList.contains('open')){setTimeout(function(){box.querySelector('input').focus()},100)}});window.addEventListener('resize',function(){if(window.innerWidth>768){document.getElementById('eprNavMenu').c
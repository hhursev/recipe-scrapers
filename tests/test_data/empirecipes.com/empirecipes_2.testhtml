    line-height: 1.7;
}

.epr-disclaimer-link,
.epr-comment-link {
    font-family: var(--font-family);
    color: var(--primary);
    opacity: 1;
    text-decoration: none;
    border-bottom: 1px solid var(--primary-light);
    transition: color 0.2s ease;
}

.epr-disclaimer-link:hover,
.epr-comment-link:hover {
    color: var(--dark);
    border-bottom-color: var(--dark);
}

/* ===== ACTION BUTTONS ===== */
.epr-recipe-buttons {
    display: flex;
    gap: clamp(8px, 2vw, 12px);
    margin-top: clamp(20px, 4vw, 28px);
    flex-wrap: nowrap;
}

.epr-action-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 11px 26px;
    background: var(--dark);
    color: #ffffff !important;
    font-family: var(--font-family);

<a class="screen-reader-text skip-link" href="#content" title="Skip to content">Skip to content</a><style>/* ===== FORCE LE FOND EMIPRECIPES ===== */
.top-bar,
.top-bar *,
.inside-top-bar,
.inside-top-bar *,
body .top-bar,
body .inside-top-bar,
.top-bar-align-left,
.top-bar-align-right,
.top-bar-align-center,
.epr-top-bar-wrapper {
  background-color: #343639 !important;
  background: #343639 !important;
}

.inside-top-bar {
  padding: 0 !important;
}

/* ===== WRAPPER ===== */
.epr-top-bar-wrapper {
  background-color: #343639 !important;
  width: 100%;
  display: block;
}

/* ===== CONTENT CONTAINER ===== */
.epr-top-bar-content {
  display: flex !important;
  justify-content: space-between !important;
  align-items: center !important;
  width: 100%;
  max-width: 1200px;
  margin: 0;
  padding: 10px 10px;
  background-color: #343639 !important;
}

/* ===== LEGAL LINKS - LEFT ===== */
.epr-top-legal {
  display: flex !important;
  gap: 15px;
  align-items: center;
  background: transparent !important;
}

.epr-top-legal a {
  color: rgba(255, 255, 255, 0.65) !important;
  text-decoration: none !important;
  font-size: 10px;
  font-weight: 400;
  letter-spacing: 2px;
  text-transform: uppercase;
  white-space: nowrap;
  transition: color 0.2s ease;
  font-family: "Qualion Round", Arial, Helvetica, sans-serif !important;
  background: transparent !important;
}

.epr-top-legal a:hover {
  color: #D3C3C4 !important;
}

/* ===== SÉPARATEUR ===== */
.epr-top-legal-sep {
  width: 1px;
  height: 10px;
  background: rgba(255, 255, 255, 0.2);
  display: inline-block;
}

/* ===== SOCIAL ICONS - RIGHT ===== */
.epr-top-social {
  display: flex !important;
  gap: 10px;
  align-items: center;
  background: transparent !important;
}

.epr-top-social a {
  display: inline-flex !important;
  align-items: center;
  justify-content: center;
  color: rgba(255, 255, 255, 0.5) !important;
  transition: color 0.2s ease, background-color 0.2s ease;
  text-decoration: none !important;
  padding: 4px;
  background: transparent !important;
  border-radius: 3px;
}

.epr-top-social a:hover {
  color: #ffffff !important;
  background-color: #955865 !important;
}

.epr-top-social svg {
  width: 14px;
  height: 14px;
  fill: currentColor;
  display: block;
}

/* ===== RESPONSIVE 1024px ===== */
@media screen and (max-width: 1024px) {
  .epr-top-bar-content { padding: 8px 15px; }
  .epr-top-legal { gap: 12px; }
  .epr-top-legal a { font-size: 9px; }
  .epr-top-social { gap: 8px; }
  .epr-top-social svg { width: 13px; height: 13px; }
}

/* ===== RESPONSIVE 768px ===== */
@media screen and (max-width: 768px) {
  .epr-top-bar-content {
    padding: 8px 12px !important;
    flex-wrap: nowrap !important;
  }
  .epr-top-legal { gap: 8px !important; flex-shrink: 1; }
  .epr-top-legal a { font-size: 9px !important; letter-spacing: 1.5px; }
  .epr-top-legal-sep { display: none; }
  .epr-top-social { gap: 6px !important; flex-shrink: 0; }
  .epr-top-social svg { width: 13px; height: 13px; }
}

/* ===== RESPONSIVE 640px ===== */
@media screen and (max-width: 640px) {
  .epr-top-bar-content { padding: 6px 10px !important; }
  .epr-top-legal { gap: 6px !important; }
  .epr-top-legal a { font-size: 9px !important; }
  .epr-top-social { gap: 5px !important; }
  .epr-top-social svg { width: 13px; height: 13px; }
}

/* ===== RESPONSIVE 480px ===== */
@media screen and (max-width: 480px) {
  .epr-top-bar-content {
    flex-direction: column !important;
    gap: 8px;
    padding: 8px 10px !important;
  }
  .epr-top-legal {
    gap: 8px !important;
    flex-wrap: wrap;
    justify-content: center;
    order: 2;
  }
  .epr-top-legal a { font-size: 9px !important; }
  .epr-top-social { gap: 10px !important; order: 1; }
  .epr-top-social svg { width: 14px; height: 14px; }
}

/* ===== RESPONSIVE 380px ===== */
@media screen and (max-width: 380px) {
  .epr-top-legal a { font-size: 9px !important; }
  .epr-top-social svg { width: 13px; height: 13px; }
}</style><div class="epr-top-bar-wrapper"><div class="epr-top-bar-content"><div class="epr-top-legal">

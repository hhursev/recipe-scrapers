    --primary:       #955865;
    --primary-light: #D3C3C4;
    --bg-soft:       #F7F5F0;
    --dark:          #343639;
    --font-family:   "Qualion Round", Arial, Helvetica, sans-serif;
}

.epr-article-header {
    background: #ffffff;
    padding: clamp(30px, 5vw, 48px) clamp(15px, 3vw, 20px);
    margin-bottom: 30px;
    border-bottom: 2px solid var(--primary-light);
    box-shadow: 0 4px 18px rgba(0, 0, 0, 0.05);
}

.epr-article-header-content {
    max-width: 1200px;
    margin: 0 auto;
}

.epr-article-header-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 30px;
    align-items: start;
}

/* ===== BREADCRUMBS ===== */
.epr-breadcrumbs {
    margin-bottom: clamp(15px, 3vw, 20px);
}

.epr-breadcrumb-nav {
    font-family: var(--font-family);
    font-size: clamp(0.75rem, 2vw, 0.85rem);
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--dark);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
    line-height: 1.6;
}

.epr-breadcrumb-nav a {
    color: var(--dark);
    opacity: 0.65;
    text-decoration: none;
    transition: color 0.2s ease, opacity 0.2s ease;
}

.epr-breadcrumb-nav a:hover {
    color: var(--primary);
    opacity: 1;
}

.epr-separator {
    color: var(--primary-light);
    margin: 0 2px;
}

.epr-current-page {
    color: var(--dark);
    opacity: 0.45;
}

/* ===== TITLE ===== */
.epr-article-title {
    font-family: var(--font-family);
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 400;
    line-height: 1.3;
    letter-spacing: 1px;

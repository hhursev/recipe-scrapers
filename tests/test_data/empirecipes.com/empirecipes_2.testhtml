}.wprm-recipe-template-ewpgls {
    margin: 20px auto;
    --glacier-background: #ffffff; /*wprm_background type=color*/
    background-color: var(--glacier-background);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen-Sans, Ubuntu, Cantarell, "Helvetica Neue", sans-serif; /*wprm_main_font_family type=font*/
    font-size: 16px; /*wprm_main_font_size type=font_size*/
    line-height: 1.5em; /*wprm_main_line_height type=font_size*/
    --glacier-text-color: #231f20; /*wprm_main_text type=color*/
    color: var(--glacier-text-color);
    border: 1px solid var(--glacier-text-color);
    max-width: 1600px; /*wprm_max_width type=size*/

    --glacier-interactivity-color: #955865; /*wprm_interactivity_color type=color*/
    --glacier-accent-color: #00a3b9; /*wprm_accent_color type=color*/

    --glacier-header-text: #231f20; /*wprm_header_text type=color*/
    --glacier-header-background: #d3c3c4; /*wprm_header_background_text type=color*/
}
.wprm-recipe-template-ewpgls a {
    color: #955865; /*wprm_link type=color*/
}
.wprm-recipe-template-ewpgls p, .wprm-recipe-template-ewpgls li {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen-Sans, Ubuntu, Cantarell, "Helvetica Neue", sans-serif; /*wprm_main_font_family type=font*/
    font-size: 1em;
    line-height: 1.5em; /*wprm_main_line_height type=font_size*/
}
.wprm-recipe-template-ewpgls li {
    margin: 0 0 0 32px;
    padding: 0;
}
.rtl .wprm-recipe-template-ewpgls li {
    margin: 0 32px 0 0;
}
.wprm-recipe-template-ewpgls ol, .wprm-recipe-template-ewpgls ul {
    margin: 0;
    padding: 0;
}
.wprm-recipe-template-ewpgls br {
    display: none;
}
.wprm-recipe-template-ewpgls .wprm-recipe-name,
.wprm-recipe-template-ewpgls .wprm-recipe-header {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen-Sans, Ubuntu, Cantarell, "Helvetica Neue", sans-serif; /*wprm_header_font_family type=font*/
    color: var(--glacier-header-text);
    line-height: 1.3em; /*wprm_header_line_height type=font_size*/
}
.wprm-recipe-template-ewpgls .wprm-recipe-header * {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen-Sans, Ubuntu, Cantarell, "Helvetica Neue", sans-serif; /*wprm_main_font_family type=font*/
}
.wprm-recipe-template-ewpgls h1,
.wprm-recipe-template-ewpgls h2,
.wprm-recipe-template-ewpgls h3,
.wprm-recipe-template-ewpgls h4,
.wprm-recipe-template-ewpgls h5,
.wprm-recipe-template-ewpgls h6 {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen-Sans, Ubuntu, Cantarell, "Helvetica Neue", sans-serif; /*wprm_header_font_family type=font*/
    color: #231f20; /*wprm_header_text type=color*/
    line-height: 1.3em; /*wprm_header_line_height type=font_size*/
    margin: 0;
    padding: 0;
}
.wprm-recipe-template-ewpgls h1 {
    font-size: 2.2em; /*wprm_h1_size type=font_size*/
}
.wprm-recipe-template-ewpgls h2 {
    font-size: 2.2em; /*wprm_h2_size type=font_size*/
}
.wprm-recipe-template-ewpgls h3 {
    font-size: 1.8em; /*wprm_h3_size type=font_size*/
}
.wprm-recipe-template-ewpgls h4 {
    font-size: 1em; /*wprm_h4_size type=font_size*/
}
.wprm-recipe-template-ewpgls h5 {
    font-size: 1em; /*wprm_h5_size type=font_size*/
}
.wprm-recipe-template-ewpgls h6 {
    font-size: 1em; /*wprm_h6_size type=font_size*/
}
.wprm-recipe-template-ewpgls.wprm-min-500 .glacier-meta {
    margin-top: 40px;

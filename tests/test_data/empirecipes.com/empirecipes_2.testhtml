}

.epr-action-btn:hover {
    background: var(--primary);
    color: #ffffff !important;
}

.single-post .entry-header .entry-title {
    display: none;
}

@media (min-width: 1200px) {
    .epr-article-header-inner { gap: 50px; }
}

@media (max-width: 480px) {

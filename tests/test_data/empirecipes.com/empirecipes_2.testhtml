    left: 0;
    bottom: 0;
    width: clamp(60px, 15vw, 120px);
    height: 2px;
    background: var(--primary-light);
}

/* ===== META ===== */
.epr-article-meta {
    font-family: var(--font-family);
    font-size: clamp(0.75rem, 2vw, 0.85rem);
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--dark);
    opacity: 0.65;
    margin-bottom: clamp(8px, 2vw, 10px);

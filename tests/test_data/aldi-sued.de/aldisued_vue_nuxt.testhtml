ed="false" data-v-9b8b1fa2 data-v-2022dab0><!----> Internationale Rezepte <!----></a><span class="base-icon color--mid-gray breadcrumbs__separator" style="" data-v-9b8b1fa2><!--[--><svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24"><path fill="currentColor" d="M9.06 5.621a1.5 1.5 0 0 1 0-2.121l1.824 1.824a.776.776 0 0 1 .022.02l6.125 6.126a.75.75 0 0 1 0 1.06l-6.125 6.125a.713.713 0 0 1-.022.021L9.06 20.5a1.5 1.5 0 0 1 0-2.121L15.44 12 9.06 5.621Z"></path></svg><!--]--></span><!--]--><!--]--><!--[--><!--[--><a href="/rezepte/internationale-rezepte/frankreich" class="text-link breadcrumbs__item" aria-disabled="false" data-v-9b8b1fa2 data-v-2022dab0><!----> Französische Rezepte  <!----></a><span class="base-icon color--mid-gray breadcrumbs__separator" style="" data-v-9b8b1fa2><!--[--><svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24"><path fill="currentColor" d="M9.06 5.621a1.5 1.5 0 0 1 0-2.121l1.824 1.824a.776.776 0 0 1 .022.02l6.125 6.126a.75.75 0 0 1 0 1.06l-6.125 6.125a.713.713 0 0 1-.022.021L9.06 20.5a1.5 1.5 0 0 1 0-2.121L15.44 12 9.06 5.621Z"></path></svg><!--]--></span><!--]--><!--]--><!--[--><!--[--><span class="breadcrumbs__item breadcrumbs__item--static breadcrumbs__currentItem" aria-current="page" data-v-9b8b1fa2>Nizza-Salat (Salat Niçoise)</span><!--]--><!--]--><!--]--></div></nav><!--]--></div></section><div><div class="cms-container"><!--[--><section class="container-layout container-layout--padded" style="" data-aem-key="title" id="title"><div class="component-layout--wide component-layout"><!--[--><!--[--><!--[--><!--[--><h1 class="base-title" data-mn="page-base-title">Nizza-Salat (Salat Niçoise)</h1><!--]--><!--]--><!--]--><!--]--></div></section><section class="container-layout container-layout--padded" style="" data-aem-key="image" id="image"><div class="component-layout"><!--[--><!--[--><!--[--><!--[--><div class="editorial-image--curved editorial-image"><!--[--><picture class="base-picture"><!--[--><source media="(min-width: 760px)" srcset="https://dm.emea.cms.aldi.cx/is/image/aldiprodeu/Rezept_Article_RZ49613620000000%3A16-9?wid=3056&amp;fit=constrain&amp;lastModified=2025-07-24T07:46:16.575Z 3056w, https://dm.emea.cms.aldi.cx/is/image/aldiprodeu/Rezept_Article_RZ49613620000000%3A16-9?wid=1528&amp;fit=constrain&amp;lastModified=2025-07-24T07:46:16.575Z 1528w" sizes="(min-width: 1528px) 1528px, 100vw"><source media="(min-width: 552px)" srcset="https://dm.emea.cms.aldi.cx/is/image/aldiprodeu/Rezept_Article_RZ49613620000000%3A16-9?wid=1528&amp;fit=constrain&amp;lastModified=2025-07-24T07:46:16.575Z 1528w" sizes="100vw"><source srcset="https://dm.emea.cms.aldi.cx/is/image/aldiprodeu/Rezept_Article_RZ49613620000000%3A4-3?wid=1104&amp;fit=constrain&amp;lastModified=2025-07-24T07:46:16.316Z 1104w" sizes="100vw"><!--]--><img class="base-image base-picture__img base-picture__img--cover" src="https://dm.emea.cms.aldi.cx/is/image/aldiprodeu/Rezept_Article_RZ49613620000000?wid=5000" alt="Serviervorschlag: Nizza-Salat (Salat Niçoise)" fetchpriority="high" width="5000" height="2810" onerror="this.setAttribute(&#39;data-error&#39;, 1)"></picture><!--]--></div><!--]--><!--]--><!--]--><!--]--></div></section><section class="container-layout container-layout--padded" style="" data-aem-key="richtext" id="richtext"><div class="component-layout--wide component-layout"><!--[--><!--[--><!--[--><!--[--><div class="base-rich-text aem-richtext"><p>Ein klassischer französischer Salat, der besonders durch seine frischen Zutaten und die Kombination von Thunfisch und Ei überzeugt. Perfekt für ein leichtes Mittag- oder Abendessen.</p>
<p>
<b>Schwierigkeit: </b>
Leicht
</p>
<p>
<b>Zubereitungszeit: </b>
20 min&nbsp;&nbsp;|&nbsp;&nbsp;
<b>Kochzeit: </b>
10 min  |  
<b>Gesamtzeit: </b>
30 min
</p></div><!--]--><!--]--><!--]--><!--]--></div></section><section class="container-layout container-layout--padded container-layout--white-background" style="background-color:#ffffff;" data-aem-key="multilayout" id="multilayout"><div class="component-layout--wide component-layout"><!--[--><!--[--><!--[--><!--[--><div class="component-grid"><!----><div class="component-grid__content--2 component-grid__content"><!--[--><div data-aem-key="richtext"><!--[--><!--[--><!--[--><!--[--><div class="base-rich-text aem-richtext"><p><b>Zutaten für 4 Portionen</b></p>
<ul><li>
4
LANDFREUDE Eier
</li><li>
1
Kopfsalat
</li><li>
200
g
grüne Bohnen
</li><li>
LE GUSTO Salz
</li><li>
4
Tomaten
</li><li>
½ Gurke
</li><li>
1
rote Zwiebel
</li><li>
1
rote Paprika
</li><li>
2
Dosen ALMARE Thunfischfilets
</li><li>
50
g
KING’S CROWN Spanische entsteinte (schwarze) Oliven
</li><li>
1
EL
CUCINA NOBILE Kapern
</li><li>
½ Topf Bio-Topfkräuter Basilikum
</li><li>
1
Knoblauchzehe
</li><li>
1
Zitrone
</li><li>
3
EL
CUCINA NOBILE Condimento Bianco
</li><li>
1
TL
DELIKATO Delikatess-Senf
</li><li>
6
EL
CANTINELLE Natives Olivenöl extra
</li><li>
DIADEM Zucker
</li><li>
LE GUSTO Pfeffer
</li></ul></div><!--]--><!--]--><!--]--><!--]--></div><div data-aem-key="richtext_1676630546"><!--[--><!--[--><!--[--><!--[--><div class="base-rich-text aem-richtext"><p><b>Zubereitung</b></p>
<ol><li>Die Eier hart kochen. Den Salat waschen und abtropfen lassen. Die Bohnen waschen und putzen. In leicht gesalzenem Wasser ca. 5–7 Minuten bissfest garen. Anschließend die Bohnen in Eiswasser abschrecken, damit sie ihre grüne Farbe behalten.</li><li>Die Tomaten waschen und achteln. Die Gurke schälen und in Scheiben schneiden. Die rote Zwiebel schälen und in feine Ringe schneiden. Die Paprikaschote waschen, entkernen und in Streifen schneiden. </li><li>Den Thunfisch aus der Dose abtropfen lassen. Die Oliven und Kapern abtropfen lassen. Das Basilikum waschen und schneiden.</li><li>Den Knoblauch schälen und fein hacken. Zitronensaft, Weißweinessig, Senf, Olivenöl, 1 Prise Zucker, Salz und Pfeffer zu einem Dressing mixen.</li><li>Den Salat in einer Schüssel verteilen. Tomaten, Gurkenscheiben, Zwiebel, Paprika, grüne Bohnen und den Thunfisch darauf anrichten. Die abgekühlten und geschälten Eier halbieren und auf den Salat legen. Die Oliven und Kapern gleichmäßig auf dem Nizza-Salat verteilen. Das Dressing dazu reichen.</li></ol>
</div><!--]--><!--]--><!--]--><!--]--></div><!--]--></div></div><!--]--><!--]--><!--]--><!--]--></div></section><section class="container-layout container-layout--padded" style="background-color:#f5f5f6;" data-aem-key="multilayout_2139238315" id="multilayout_2139238315"><div class="component-layout--wide component-layout"><!--[--><!--[--><!--[--><!--[--><div class="component-grid"><div class="base-heading base-heading--h5 component-grid__headline"><!----><h2 class="base-heading__main base-heading--h5"><!--[-->Rezept-Highlights für dich<!--]--></h2><!----></div><div class="component-grid__content--3 component-grid__content"><!--[--><div class="cms-multilayout-teaser" style="background-color:#ffffff;" data-aem-key="teaser"><picture class="base-picture cms-multilayout-teaser__image"><!--[--><source media="(min-width: 992px)" srcset="https://dm.emea.cms.aldi.cx/is/image/aldiprodeu/Rezept_Article_RZ49616130000000%3A2-1?wid=1400&amp;fit=constrain&amp;lastModified=2025-07-24T07:47:10.749Z 1400w, https://dm.emea.cms.aldi.cx/is/image/aldiprodeu/Rezept_Article_RZ49616130000000%3A2-1?wid=700&amp;fit=constrain&amp;lastModified=2025-07-24T07:47:10.749Z 700w" sizes="(min-width: 1528px) 700px, 50vw"><source media="(min-width: 760px)" srcset="https://dm.emea.cms.aldi.cx/is/image/aldiprodeu/Rezept_Article_RZ49616130000000%3A16-9?wid=992&amp;fit=constrain&amp;lastModified=2025-07-24T07:47:11.022Z 992w" sizes="50vw"><source srcset="https://dm.emea.cms.aldi.cx/is/image/aldiprodeu/Rezept_Article_RZ49616130000000%3A16-9?wid=1520&amp;fit=constrain&amp;lastModified=2025-07-24T07:47:11.022Z 1520w" sizes="100vw"><!--]--><img class="base-image base-picture__img" src="https://dm.emea.cms.aldi.cx/is/image/aldiprodeu/Rezept_Article_RZ49616130000000?wid=2000" alt width="2000" height="1000" onerror="this.setAttribute(&#39;data-error&#39;, 1)"></picture><div class="cms-multilayout-teaser__content"><div class="cms-multilayout-teaser__headline"><p class="cms-multilayout-teaser__title">Dense Bean Sala
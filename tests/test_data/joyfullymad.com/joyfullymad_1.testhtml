	<script type="application/ld+json" class="yoast-schema-graph">{"@context":"https:\/\/schema.org","@graph":[{"@type":"Article","@id":"https:\/\/joyfullymad.com\/chewy-oatmeal-cookies\/#article","isPartOf":{"@id":"https:\/\/joyfullymad.com\/chewy-oatmeal-cookies\/"},"author":{"name":"Madison Wetherill","@id":"https:\/\/joyfullymad.com\/#\/schema\/person\/5bae4d08d5bbd819e9853a87aac6d8e2"},"headline":"Chewy Oatmeal Cookies","datePublished":"2026-04-29T11:00:00+00:00","wordCount":1451,"commentCount":0,"publisher":{"@id":"https:\/\/joyfullymad.com\/#organization"},"image":{"@id":"https:\/\/joyfullymad.com\/chewy-oatmeal-cookies\/#primaryimage"},"thumbnailUrl":"https:\/\/joyfullymad.com\/wp-content\/uploads\/2026\/04\/Chewy-Oatmeal-Cookies-13.jpg","articleSection":["Christmas Recipes","Cookies &amp; Bars","Desserts","Meal Train Recipes","Party Recipes"],"inLanguage":"en-US","potentialAction":[{"@type":"CommentAction","name":"Comment","target":["https:\/\/joyfullymad.com\/chewy-oatmeal-cookies\/#respond"]}]},{"@type":["WebPage","FAQPage"],"@id":"https:\/\/joyfullymad.com\/chewy-oatmeal-cookies\/","url":"https:\/\/joyfullymad.com\/chewy-oatmeal-cookies\/","name":"Soft and Chewy Oatmeal Cookies Recipe","isPartOf":{"@id":"https:\/\/joyfullymad.com\/#website"},"primaryImageOfPage":{"@id":"https:\/\/joyfullymad.com\/chewy-oatmeal-cookies\/#primaryimage"},"image":{"@id":"https:\/\/joyfullymad.com\/chewy-oatmeal-cookies\/#primaryimage"},"thumbnailUrl":"https:\/\/joyfullymad.com\/wp-content\/uploads\/2026\/04\/Chewy-Oatmeal-Cookies-13.jpg","datePublished":"2026-04-29T11:00:00+00:00","description":"Soft, sweet and warm with just a hint of cinnamon, these chewy oatmeal cookies are the epitome of comfort. They're perfect for sharing.","breadcrumb":{"@id":"https:\/\/joyfullymad.com\/chewy-oatmeal-cookies\/#breadcrumb"},"mainEntity":[{"@id":"https:\/\/joyfullymad.com\/chewy-oatmeal-cookies\/#faq-question-1738276414452"},{"@id":"https:\/\/joyfullymad.com\/chewy-oatmeal-cookies\/#faq-question-1777427833485"},{"@id":"https:\/\/joyfullymad.com\/chewy-oatmeal-cookies\/#faq-question-1777427834563"},{"@id":"https:\/\/joyfullymad.com\/chewy-oatmeal-cookies\/#faq-question-1777427835764"}],"inLanguage":"en-US","potentialAction":[{"@type":"ReadAction","target":["https:\/\/joyfullymad.com\/chewy-oatmeal-cookies\/"]}]},{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/joyfullymad.com\/chewy-oatmeal-cookies\/#primaryimage","url":"https:\/\/joyfullymad.com\/wp-content\/uploads\/2026\/04\/Chewy-Oatmeal-Cookies-13.jpg","contentUrl":"https:\/\/joyfullymad.com\/wp-content\/uploads\/2026\/04\/Chewy-Oatmeal-Cookies-13.jpg","width":1198,"height":1800,"caption":"Five oatmeal cookies on parchment paper with scattered oats."},{"@type":"BreadcrumbList","@id":"https:\/\/joyfullymad.com\/chewy-oatmeal-cookies\/#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https:\/\/joyfullymad.com\/"},{"@type":"ListItem","position":2,"name":"Recipes","item":"https:\/\/joyfullymad.com\/recipe-index\/"},{"@type":"ListItem","position":3,"name":"Cookies &amp; Bars","item":"https:\/\/joyfullymad.com\/category\/easy-dessert-recipes\/cookies-bars\/"},{"@type":"ListItem","position":4,"name":"Chewy Oatmeal Cookies"}]},{"@type":"WebSite","@id":"https:\/\/joyfullymad.com\/#website","url":"https:\/\/joyfullymad.com\/","name":"A Joyfully Mad Kitchen","description":"Easy, wholesome recipes designed for sharing","publisher":{"@id":"https:\/\/joyfullymad.com\/#organization"},"potentialAction":[{"@type":"SearchAction","target":{"@type":"EntryPoint","urlTemplate":"https:\/\/joyfullymad.com\/?s={search_term_string}"},"query-input":{"@type":"PropertyValueSpecification","valueRequired":true,"valueName":"search_term_string"}}],"inLanguage":"en-US"},{"@type":"Organization","@id":"https:\/\/joyfullymad.com\/#organization","name":"A Joyfully Mad Kitchen","url":"https:\/\/joyfullymad.com\/","logo":{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/joyfullymad.com\/#\/schema\/logo\/image\/","url":"https:\/\/joyfullymad.com\/wp-content\/uploads\/2019\/01\/jm-logo-2019.jpg","contentUrl":"https:\/\/joyfullymad.com\/wp-content\/uploads\/2019\/01\/jm-logo-2019.jpg","width":640,"height":300,"caption":"A Joyfully Mad Kitchen"},"image":{"@id":"https:\/\/joyfullymad.com\/#\/schema\/logo\/image\/"},"sameAs":["http:\/\/facebook.com\/joyfullymad","https:\/\/x.com\/joyfullymad","http:\/\/instagram.com\/joyfullymad","http:\/\/pinterest.com\/joyfullymad"]},{"@type":"Person","@id":"https:\/\/joyfullymad.com\/#\/schema\/person\/5bae4d08d5bbd819e9853a87aac6d8e2","name":"Madison Wetherill","sameAs":["https:\/\/joyfullymad.com\/about-me"]},{"@type":"Question","@id":"https:\/\/joyfullymad.com\/chewy-oatmeal-cookies\/#faq-question-1738276414452","position":1,"url":"https:\/\/joyfullymad.com\/chewy-oatmeal-cookies\/#faq-question-1738276414452","name":"How should I store soft oatmeal cookies?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Store them in an airtight container at room temperature for 4 to 5 days for the best texture. ","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https:\/\/joyfullymad.com\/chewy-oatmeal-cookies\/#faq-question-1777427833485","position":2,"url":"https:\/\/joyfullymad.com\/chewy-oatmeal-cookies\/#faq-question-1777427833485","name":"Can I freeze them?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Yes. Freeze the scooped dough balls on a parchment-lined baking sheet until firm, then transfer them to a freezer bag or airtight container for up to 3 months. Bake from frozen and add 1 to 3 minutes to the baking time. You can also freeze fully baked cookies once cooled, with parchment between layers so they don’t stick. For cookies like these though, I prefer freezing the unbaked dough, otherwise they won’t thaw out as chewy.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https:\/\/joyfullymad.com\/chewy-oatmeal-cookies\/#faq-question-1777427834563","position":3,"url":"https:\/\/joyfullymad.com\/chewy-oatmeal-cookies\/#faq-question-1777427834563","name":"Can I use quick oats?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"I like to use old-fashioned oats, which are also known as rolled oats. If you want to try quick oats, you may need a little more but keep the total under 3 cups for the best result. Quick oats are thinner and absorb more moisture, while old-fashioned oats will give a chunkier, more rustic texture.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https:\/\/joyfullymad.com\/chewy-oatmeal-cookies\/#faq-question-1777427835764","position":4,"url":"https:\/\/joyfullymad.com\/chewy-oatmeal-cookies\/#faq-question-1777427835764","name":"Can I add raisins or chocolate chips?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Sure! Add up to half a cup of add-ins if you like.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Recipe","name":"Chewy Oatmeal Cookies","author":{"@id":"https:\/\/joyfullymad.com\/#\/schema\/person\/5bae4d08d5bbd819e9853a87aac6d8e2"},"description":"These soft and chewy oatmeal cookies are a breeze to whip up and boast cinnamon, vanilla and oat flavors in every bite. They pair well with a cup of coffee or tea, and are also ideal for cookie trays.","datePublished":"2026-04-29T07:00:00+00:00","image":["https:\/\/joyfullymad.com\/wp-content\/uploads\/2026\/04\/Chewy-Oatmeal-Cookies-13.jpg","https:\/\/joyfullymad.com\/wp-content\/uploads\/2026\/04\/Chewy-Oatmeal-Cookies-13-500x500.jpg","https:\/\/joyfullymad.com\/wp-content\/uploads\/2026\/04\/Chewy-Oatmeal-Cookies-13-500x375.jpg","https:\/\/joyfullymad.com\/wp-content\/uploads\/2026\/04\/Chewy-Oatmeal-Cookies-13-480x270.jpg"],"recipeYield":["30","30 cookies"],"prepTime":"PT20M","cookTime":"PT11M","totalTime":"PT31M","recipeIngredient":["1 cup unsalted butter (softened)","1 ½ cups brown sugar","1 teaspoon vanilla extract","1 ½ cups all-purpose flour","1 tablespoon cornstarch","2 teaspoon baking powder","½ teaspoon baking soda","1 teaspoon cinnamon","½ teaspoon salt","2 ½ cups old-fashioned oats"],"recipeInstructions":[{"@type":"HowToStep","text":"Start by preheating your oven to 350°F (177°C) and lining your baking sheet with parchment paper.","name":"Start by preheating your oven to 350°F (177°C) and lining your baking sheet with parchment paper.","url":"https:\/\/joyfullymad.com\/chewy-oatmeal-cookies\/#wprm-recipe-38458-step-0-0"},{"@type":"HowToStep","text":"Then cream together the softened 1 cup unsalted butter, 1 ½ cups brown sugar, and 1 teaspoon vanilla extract.","name":"Then cream together the softened 1 cup unsalted butter, 1 ½ cups brown sugar, and 1 teaspoon vanilla extract.","url":"https:\/\/joyfullymad.com\/chewy-oatmeal-cookies\/#wprm-recipe-38458-step-0-1"},{"@type":"HowToStep","text":"Stir in the 1 ½ cups all-purpose flour, 1 tablespoon cornstarch, 2 teaspoon baking powder, ½ teaspoon baking soda, 1 teaspoon cinnamon, and ½ teaspoon salt until a gooey dough is formed, then fold in the 2 ½ cups old-fashioned oats.","name":"Stir in the 1 ½ cups all-purpose flour, 1 tablespoon cornstarch, 2 teaspoon baking powder, ½ teaspoon baking soda, 1 teaspoon cinnamon, and ½ teaspoon salt until a gooey dough is formed, then fold in the 2 ½ cups old-fashioned oats.","url":"https:\/\/joyfullymad.com\/chewy-oatmeal-cookies\/#wprm-recipe-38458-step-0-2"},{"@type":"HowToStep","text":"Use your 2-tablespoon cookie scoop to scoop 6 cookie dough balls onto your parchment lined baking sheet.","name":"Use your 2-tablespoon cookie scoop to scoop 6 cookie dough balls onto your parchment lined baking sheet.","url":"https:\/\/joyfullymad.com\/chewy-oatmeal-cookies\/#wprm-recipe-38458-step-0-3"},{"@type":"HowToStep","text":"Bake for about 11-12 minutes, then let cool for at least 5 minutes on the baking sheet before moving to a cooling rack.","name":"Bake for about 11-12 minutes, then let cool for at least 5 minutes on the baking sheet before moving to a cooling rack.","url":"https:\/\/joyfullymad.com\/chewy-oatmeal-cookies\/#wprm-recipe-38458-step-0-4"},{"@type":"HowToStep","text":"Repeat with the rest of the cookie dough and enjoy when cooled!","name":"Repeat with the rest of the cookie dough and enjoy when cooled!","url":"https:\/\/joyfullymad.com\/chewy-oatmeal-cookies\/#wprm-recipe-38458-step-0-5"}],"recipeCategory":["Desserts"],"recipeCuisine":["American"],"keywords":"cookies, desserts, oatmeal, oatmeal cookies","nutrition":{"@type":"NutritionInformation","servingSize":"1 cookie","calories":"146 kcal","carbohydrateContent":"21 g","proteinContent":"2 g","fatContent":"7 g","saturatedFatContent":"4 g","transFatContent":"0.2 g","cholesterolContent":"16 mg","sodiumContent":"90 mg","fiberContent":"1 g","sugarContent":"11 g","unsaturatedFatContent":"2.4 g"},"@id":"https:\/\/joyfullymad.com\/chewy-oatmeal-cookies\/#recipe","isPartOf":{"@id":"https:\/\/joyfullymad.com\/chewy-oatmeal-cookies\/#article"},"mainEntityOfPage":"https:\/\/joyfullymad.com\/chewy-oatmeal-cookies\/"}]}</script>

ernativeText":null,"caption":null,"height":340,"width":1514,"__typename":"UploadFile"},"responsive_banner_image":{"documentId":"h3jmjw9cyby8gf1ou19b7iyc","url":"https://medias.blogosferathermomix.es/blog-images-production/Lurpark_banner_mobile_e12c22dfc2/Lurpark_banner_mobile_e12c22dfc2.jpg","alternativeText":null,"width":768,"height":1022,"__typename":"UploadFile"},"__typename":"Megabanner"}],"banner":{"documentId":"trsqoyoiqolqyf9kievqz4ct","link":"https://www.vorwerk.com/es/es/c/home/productos/thermomix/thermomix-black-color-negro?utm_source=Blogosfera\\u0026utm_medium=banner\\u0026utm_campaign=productosblogosfera","target":"blank","__typename":"Banner"}},"area":{"documentId":"r69h7sercczeev582tdein9b","name":"Pamplona","description":"","address":"Calle Rioja, 4 31008 Pamplona.","phone":" 948 199 066","active":true,"coordinates":"42.8093008 : -1.6594668000000183","latitude":"42.8093008","longitude":"-1.6594668000000183","maintenance":false,"media_token":"7a047d3d-5b51-11e7-ae42-0050568e6382","onetrust_id":"7ae7a0bc-be93-4a18-be8d-b37ff8033999-test","seo_token":"61acdc69-65d8-3d00-409c-8d3d1855898a","url":"thermomix-pamplona.es","visible":true,"zoom_host_id":"VZMF7m7ITyycXlbrRgGXzw","createdAt":"2025-06-26T07:27:25.914Z","updatedAt":"2025-08-07T09:42:18.251Z","publishedAt":"2025-08-07T09:42:18.207Z","province":{"documentId":"mzlejzey8gsavorcq2lppgrr","name":"Navarra","map_code":"31","zip_code":"31","__typename":"Province"},"image":{"documentId":"ssjyt5nq8mo3ot21aa76t4gr","url":"https://medias.blogosferathermomix.es/blog-images-production/85e15e29d8737e84cf7fcef39bcf622e_e5f7f27111/85e15e29d8737e84cf7fcef39bcf622e_e5f7f27111.jpg","name":"85e15e29d8737e84cf7fcef39bcf622e.jpg","alternativeText":null,"width":380,"height":345,"size":105.68,"__typename":"UploadFile"},"rrss":null,"news":[],"__typename":"Area"},"postResult":{"documentId":"k197c3on75uabl7deal4veap","slug":"pan-de-espelta-y-centeno","title":"PAN DE ESPELTA Y CENTENO","likesTotal":3,"categories":[{"slug":"masas-panes-reposteria","name":"Masas, panes y repostería","__typename":"PostCategory"}],"highlighted":false,"highlighted_media":null,"excerpt":"","publishedAt":"2018-12-12T18:36:00.000Z","active":true,"content":"\\u003cp\\u003eEste pan integral con harina de espelta y centeno, es muy fácil de elaborar y queda muy rico!\\u0026nbsp; La espelta es un cereal sumamente rico en proteínas, minerales (como el fósforo, hierro y magnesio) y vitaminas.\\u0026nbsp; El centeno es rico en minerales antioxidantes y ácido fólico. Tanto la espelta como el centeno tienen menos gluten que el trigo y destacan por su alto contenido en fibra.\\u003c/p\\u003e\\u003cp\\u003eRecomiendo utilizar harinas ecológicas.\\u003c/p\\u003e\\u003cp\\u003eNecesitas dos horas y media para la elaboración de este pan, mas el tiempo de enfriamiento.\\u003cbr\\u003e\\u003c/p\\u003e\\u003cp\\u003e\\u003cimg style=\\"\\" src=\\"http://thermomix-pamplona.es/media/Posts/attachments/5663f04d7daa8b9a18dcd362c313f874.jpg\\" class=\\"img-responsive\\" data-id=\\"82546\\" data-size=\\"attachments\\"\\u003e\\u003c/p\\u003e\\u003cp\\u003eIngredientes:\\u003c/p\\u003e\\u003cp\\u003e350 g de agua mineral\\u003cbr\\u003e500 g de harina integral de espelta\\u003cbr\\u003e100 g de harina integral de centeno ( y un poco más para espolvorear)\\u003cbr\\u003e1 sobre de levadura de panadería granulada instantánea ecológica o 20 g de levadura prensada fresca\\u003cbr\\u003e1-2 cucharaditas de sal\\u003cbr\\u003e\\u003cbr\\u003eAccesorios: film transparente, papel de horno, bandeja de horno y rejilla\\u003cbr\\u003e\\u003c/p\\u003e\\u003cp\\u003ePreparación:\\u003c/p\\u003e\\u003cp\\u003e1. Pon el agua en el vaso y calienta 2 min/37º/vel 1.\\u003cbr\\u003e\\u003cbr\\u003e2. Añade la levadura, la harina de espelta, la harina de centeno y la sal y mezcla 20 seg/vel 6.\\u003cbr\\u003e\\u003cbr\\u003e3. Retira el cubilete y amasa 3 min/ velocidad espiga.\\u003cbr\\u003e\\u003cbr\\u003e4. Retira la masa del vaso y con las manos aceitadas forma una bola. Déjala reposar en un bol grande pincelado con aceite y tapado con film transparente, en un lugar cálido hasta que doble su volumen (aprox una hora).\\u003c/p\\u003e\\u003cp\\u003e\\u003cimg style=\\"\\" src=\\"http://thermomix-pamplona.es/media/Posts/attachments/39fa17b5df655c662d98c225a733000f.jpg\\" class=\\"img-responsive\\" data-id=\\"82548\\" data-size=\\"attachments\\"\\u003e\\u003cbr\\u003e\\u003cbr\\u003e5. Amasa ligeramente la masa y dale forma de hogaza. Colócala en la bandeja de horno forrada con papel de hornear. Haz unos cortes con un cuchillo y espolvorea con harina integral de centeno. Deja reposar hasta que vuelva a doblar (aprox 30 minutos) en un lugar cálido, sin corrientes de aire.\\u003cbr\\u003e\\u003c/p\\u003e\\u003cp\\u003e\\u003cimg style=\\"\\" src=\\"http://thermomix-pamplona.es/media/Posts/attachments/0999c4a3a1a7565c8dae19659ed4bf34.jpg\\" class=\\"img-responsive\\" data-id=\\"82547\\" data-size=\\"attachments\\"\\u003e\\u003cbr\\u003e\\u003cbr\\u003e6. Pon una bol refractario con agua en la base del horno (para crear humedad) y precalienta el horno a 220ª.\\u003cbr\\u003e\\u003cbr\\u003e7. Hornea durante 10 minutos a 220º . Después baja la temperatura a 200º y hornea 20-25 minutos más. Deja enfriar sobre una rejilla. \\u003c/p\\u003e\\u003cp\\u003eReceta de Thermomix Magazine, número 101\\u003cbr\\u003e\\u003cbr\\u003e\\u003cbr\\u003e\\u003c/p\\u003e","createdAt":"2018-12-12T19:15:20.000Z","updatedAt":"2018-12-12T19:15:20.000Z","pub_date":"2018-12-12T18:36:00.000Z","featured_comment":null,"is_promo":false,"is_recipe_post":true,"date_ini_promo":null,"date_end_promo":null,"seo_token":"e2a2a34b-fe39-11e8-8ee9-0050568e40d3","old_slug":null,"preparation_time":null,"preparation_portions":null,"advisor":{"documentId":"bcuziw1kiaxu0ppo5rmfohjh","alias":"CLAUDIA TORRENT ALAMANY","first_name":"CLAUDIA","last_name":"TORRENT ALAMANY","email":"torrent.alamany.claudia@ithermomix.es","slug":"claudia-torrent","area":{"documentId":"r69h7sercczeev582tdein9b","url":"thermomix-pamplona.es","name":"Pamplona","__typename":"Area"},"__typename":"Advisor"},"utensils":[],"ingredients":[],"steps":[],"media":[],"__typename":"Post"},"advisor":{"documentId":"bcuziw1kiaxu0ppo5rmfohjh","active":true,"alias":"CLAUDIA TORRENT ALAMANY","email":"torrent.alamany.claudia@ithermomix.es","email_blogosfera":"claudia@valdorba.es","first_name":"CLAUDIA","last_name":"TORRENT ALAMANY","phone":"619541683","slug":"claudia-torrent","text":"\\u003cp\\u003ePertenezco a la Delegaci\\u0026oacute;n de Navarra y llevo diecinueve a\\u0026ntilde;os en Thermomix. Como usuaria, cada d\\u0026iacute;a me maravillo de lo que me aporta thermomix en la cocina: m\\u0026aacute;s variedad y creatividad, m\\u0026aacute;s ahorro, m\\u0026aacute;s salud, menos esfuerzo y menos tiempo en la cocina. Como profesi\\u0026oacute;n, me permite trabajar en equipo, conocer a muchas personas, organizar mi tiempo, adquirir formaci\\u0026oacute;n y experiencia y adem\\u0026aacute;s de recibir mis comisiones mensuales, \\u0026nbsp;participar en viajes y promociones.\\u003c/p\\u003e","outstanding":false,"seo_token":"4cf4cefb-a29e-11e7-917b-0050568e40d3","old_slug":"torrentalamanyclaudia","link_webshop":"https://vorwerk.com/es/es/thermomix-agente/thermomix.html/claudia.torrent-alamany","have_link_webshop":true,"imagar_advisor_id":"5794","createdAt":"2025-06-26T07:32:30.042Z","updatedAt":"2026-04-09T00:38:58.139Z","publishedAt":"2026-04-09T00:38:58.131Z","area":{"documentId":"r69h7sercczeev582tdein9b","name":"Pamplona","description":"","url":"thermomix-pamplona.es","__typename":"Area"},"image":{"documentId":"c6znywv1iqtymoj4e4r3ltp0","url":"https://medias.blogosferathermomix.es/blog-images-production/1e52d49dbbc7f538a78664a8935bfb1a_3703dea47c/1e52d49dbbc7f538a78664a8935bfb1a_3703dea47c.jpg","name":"1e52d49dbbc7f538a78664a8935bfb1a.jpg","alternativeText":null,"width":150,"height":150,"size":30.9,"__typename":"UploadFile"},"rrss":{"facebook":"https://www.facebook
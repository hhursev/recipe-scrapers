548&amp;q=65&amp;fit=fill&amp;f=jpeg&amp;g=ce 1110w,https://images.zuckerjagdwurst.com/img/4ffqjdnkyxz9gq68eg2jhbh3qd8x?w=2220&amp;h=1096&amp;q=65&amp;fit=fill&amp;f=jpeg&amp;g=ce 2220w" alt="R1046 Einfache Sauerteigbrötchen über Nacht"/></picture><noscript><picture><source type="image/webp" srcSet="https://images.zuckerjagdwurst.com/img/4ffqjdnkyxz9gq68eg2jhbh3qd8x?w=278&amp;h=137&amp;q=65&amp;fit=fill&amp;f=webp&amp;g=ce 278w,https://images.zuckerjagdwurst.com/img/4ffqjdnkyxz9gq68eg2jhbh3qd8x?w=555&amp;h=274&amp;q=65&amp;fit=fill&amp;f=webp&amp;g=ce 555w,https://images.zuckerjagdwurst.com/img/4ffqjdnkyxz9gq68eg2jhbh3qd8x?w=1110&amp;h=548&amp;q=65&amp;fit=fill&amp;f=webp&amp;g=ce 1110w,https://images.zuckerjagdwurst.com/img/4ffqjdnkyxz9gq68eg2jhbh3qd8x?w=2220&amp;h=1096&amp;q=65&amp;fit=fill&amp;f=webp&amp;g=ce 2220w" sizes="(min-width: 1110px) 1110px, 100vw"/><source type="image/jpeg" srcSet="https://images.zuckerjagdwurst.com/img/4ffqjdnkyxz9gq68eg2jhbh3qd8x?w=278&amp;h=137&amp;q=65&amp;fit=fill&amp;f=jpeg&amp;g=ce 278w,https://images.zuckerjagdwurst.com/img/4ffqjdnkyxz9gq68eg2jhbh3qd8x?w=555&amp;h=274&amp;q=65&amp;fit=fill&amp;f=jpeg&amp;g=ce 555w,https://images.zuckerjagdwurst.com/img/4ffqjdnkyxz9gq68eg2jhbh3qd8x?w=1110&amp;h=548&amp;q=65&amp;fit=fill&amp;f=jpeg&amp;g=ce 1110w,https://images.zuckerjagdwurst.com/img/4ffqjdnkyxz9gq68eg2jhbh3qd8x?w=2220&amp;h=1096&amp;q=65&amp;fit=fill&amp;f=jpeg&amp;g=ce 2220w" sizes="(min-width: 1110px) 1110px, 100vw"/><img data-gatsby-image-ssr="" data-main-image="" style="opacity:0" sizes="(min-width: 1110px) 1110px, 100vw" decoding="async" loading="lazy" src="https://images.zuckerjagdwurst.com/img/4ffqjdnkyxz9gq68eg2jhbh3qd8x?w=1110&amp;h=548&amp;q=65&amp;fit=fill&amp;f=jpeg&amp;g=ce" srcSet="https://images.zuckerjagdwurst.com/img/4ffqjdnkyxz9gq68eg2jhbh3qd8x?w=278&amp;h=137&amp;q=65&amp;fit=fill&amp;f=jpeg&amp;g=ce 278w,https://images.zuckerjagdwurst.com/img/4ffqjdnkyxz9gq68eg2jhbh3qd8x?w=555&amp;h=274&amp;q=65&amp;fit=fill&amp;f=jpeg&amp;g=ce 555w,https://images.zuckerjagdwurst.com/img/4ffqjdnkyxz9gq68eg2jhbh3qd8x?w=1110&amp;h=548&amp;q=65&amp;fit=fill&amp;f=jpeg&amp;g=ce 1110w,https://images.zuckerjagdwurst.com/img/4ffqjdnkyxz9gq68eg2jhbh3qd8x?w=2220&amp;h=1096&amp;q=65&amp;fit=fill&amp;f=jpeg&amp;g=ce 2220w" alt="R1046 Einfache Sauerteigbrötchen über Nacht"/></picture></noscript><script type="module">const t="undefined"!=typeof HTMLImageElement&&"loading"in HTMLImageElement.prototype;if(t){const t=document.querySelectorAll("img[data-main-image]");for(let e of t){e.dataset.src&&(e.setAttribute("src",e.dataset.src),e.removeAttribute("data-src")),e.dataset.srcset&&(e.setAttribute("srcset",e.dataset.srcset),e.removeAttribute("data-srcset"));const t=e.parentNode.querySelectorAll("source[data-srcset]");for(let e of t)e.setAttribute("srcset",e.dataset.srcset),e.removeAttribute("data-srcset");e.complete&&(e.style.opacity=1)}}</script></div></div></div></section><section class="card-module--card--dCwUR"><section class="index-module--container--nkg-l"><div class="card-module--printControls--BVyNr"><button type="button" class="card-module--printButton--QBuXX" aria-label="Rezept drucken"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="20" height="20" aria-hidden="true" focusable="false"><path d="M6 9V2h12v7"></path><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path><rect x="6" y="14" width="12" height="8" rx="1"></rect></svg><span class="card-module--printLabel--AI6Cb">Rezept drucken</span></button></div><h2 class="card-module--title--y0cTN">Einfache Sauerteigbrötchen über Nacht</h2><div class="card-module--infos--GVz7U"><div itemProp="recipeYield">8–10 Brötchen</div><div> ca. 14 Stunden (30 Minuten Zubereitung + 13 Stunden Gehzeit + 20 Minuten Backzeit)</div></div><div class="card-module--sections--tW0vd"><div class="card-module--section--Ilnkv"><h3 class="card-module--headline--X0z4Q">Zutaten</h3><div class="card-module--ingredients--QK-on"><div class="renderer-module--text--uXtwy"><ul><li ordered="false" node="[object Object]" itemProp="recipeIngredient">130 g aktiver Sauerteigstarter</li><li ordered="false" node="[object Object]" itemProp="recipeIngredient">330 g Wasser</li><li ordered="false" node="[object Object]" itemProp="recipeIngredient">400 g Weizenmehl (Type 550)</li><li ordered="false" node="[object Object]" itemProp="recipeIngredient">100 g Weizenvollkornmehl</li><li ordered="false" node="[object Object]" itemProp="recipeIngredient">12 g Salz</li><li ordered="false" node="[object Object]" itemProp="recipeIngredient">Samen und Saaten (z. B. Sonnenblumenkerne, Sesam, Mohn)</li></ul></div></div></div><div class="card-module--section--Ilnkv"><h3 class="card-module--headline--X0z4Q">Zubereitung</h3><div class="card-module--instructions--eTJjd" itemProp="recipeInstructions"><div class="renderer-module--text--uXtwy"><ol><li><p>Den Sauerteigstarter füttern, sodass er abends aktiv und bereit zum Backen ist. Wenn er morgens vor der Arbeit gefüttert wird, dann im Verhältnis 1:4:4, im Sommer eher 1:5:5.</p></li><li><p>Alle Zutaten vermischen und 10–15 Minuten von Hand oder am besten in der Küchenmaschine verkneten.</p></li><li><p>Den Teig etwa 3–4 Stunden bei Raumtemperatur gehen lassen, bis sich der Teig ungefähr um 50 Prozent vergrößert hat. Das kann je nach Raumtemperatur unterschiedlich schnell gehen. Achtet also auf euren Teig.</p></li><li><p>Nach der Gehzeit den Teig abgedeckt, zum Beispiel mit einer Frischhaltefolie, über Nacht (etwa 10–16 Stunden) in den Kühlschrank stellen.</p></li><li><p>Morgens eine Mischung aus Samen und Saaten auf der Arbeitsfläche verteilen. Die Teigoberfläche in der Schüssel leicht befeuchten und anschließend auf die Saatenmischung stürzen. Den Teig einmal zusammenklappen, dann in acht Teiglinge teilen.</p></li><li><p>Bei 230 °C (Ober-/Unterhitze) etwa 20 Minuten mit Wasserdampf backen: Entweder durch einen Backofen mit Dampffunktion oder indem ihr eine ofenfeste Form auf den Boden des Ofens stellt und kurz vor dem Backen mit heißem Wasser befüllt. Oder indem ihr Wasser einfach auf den Ofenboden schüttet, sofern das euer Ofen verträgt. Tipp: Nach den ersten 10 Minuten den Dampf kurz ablassen, damit die Brötchen knusprig werden.</p></li></ol><blockquote><p><strong>So könnte euer Zeitplan aussehen:</strong><br/><strong><em>Tag 1</em> – 7 Uhr:</strong> Sauerteigstarter füttern<br/><strong><em>Tag 1</em> – 18 Uhr:</strong> Teig ansetzen<br/><strong><em>Tag 1</em> – 21 Uhr:</strong> Teig in den Kühlschrank stellen<br/><strong><em>Tag 2</em> – 7 Uhr:</strong> Brötchen backen</p></blockquote></div></div></div></div></section></section><section class="index-module--container--nkg-l"><div class="index-module--photos--qdyTF"><div class="index-module--photo--BX-1-"><div data-gatsby-image-wrapper="" class="gatsby-image-wrapper gatsby-image-wrapper-constrained"><div style="max-width:1110px;display:block"><img alt="" role="presentation" aria-hidden="true" src="data:image/svg+xml;charset=utf-8,%3Csvg height=&#x27;825&#x27; width=&#x27;1110&#x27; xmlns=&#x27;http://www.w3.org/2000/svg&#x27; version=&#x27;1.1&#x27;%3E%3C/svg%3E" style="max-width:100%;display:block;position:static"/></div><img aria-hidden="true" data-placeholder-image="" style="opacity:1;transition:opacity 500ms linear" decoding="async" src="data:image/jpeg;base64," alt=""/><picture><source type="image/webp" data-srcset="https://images.zuckerjagdwurst.com/img/7dezrlu9n6rwl98jvpf85ued3hbv?w=278&amp;h=207&amp;q=65&amp;fit=fill&amp;f=webp&amp;g=ce 278w,https://images.zuckerjagdwurst.com/img/7dezrlu9n6rwl98jvpf85ued3hbv?w=555&amp;h=413&amp;q=65&amp;fit=fill&amp;f=webp&amp;g=ce 555w,https://images.zuckerjagdwurst.com/img/7dezrlu9n6rwl98jvpf85ued3hbv?w=1110&amp;h=825&amp;q=65&amp;fit=fill&amp;f=webp&amp;g=ce 1110w,https://images.zuckerjagdwurst.com/img/7dezrlu9n6rwl98jvpf85ued3hbv?
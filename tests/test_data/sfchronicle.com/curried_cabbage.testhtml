-id="Flex1" data-unit="hnp-sfchronicle.com/article_dtc" class="block mnh50px sm:mnh250px aic lg:block lg:mnh250px lg:aic"></div></div></div></div></div><div data-layout="Layout1Column" class="f fdc mxa mb16 sm:mb40"><div class="zone center f fdc g40"><div class="package"><div><section class="mw1200px mx20 lg:mx36 xl:mxa mb16"><div class="f fdc sy16"><div class="f fw aic breadcrumbSm lg:breadcrumbLg pb1 lining-nums"><a href="/food/" data-link="native" class="hover:o70 td300 ttu c-primaryAccessible">Food</a><span class="mx4">//</span><a href="/food/recipes/" data-link="native" class="hover:o70 td300 ttu c-primaryAccessible">Recipes</a></div><div class="rel"><div id="content" class="abs -top100"></div><h1 class="fw500 md:fw500 lg:fw500 block standardHeadlineSm sm:standardHeadlineMd lg:standardHeadlineLg">Bring balance to the table with a hearty veggie stew and turmeric-chile toast</h1></div><div class="f jcb sm:aic sm:fdr sm:g0 fdc ais g16"><div class="f fdc sy4"><span class="c-gray700 f aic g2 fw owa"><span class="lg:fs16"><span class="lg:largeTimestamp smallTimestamp lg:fs16">By </span><span class="bylineSm lg:bylineLg pb1"><span class="wbbw c-gray700">Christian Reynoso</span></span><span class="creditSm lg:fs16 c-gray700 ml2 mr4">, </span></span><span class="creditSm lg:fs16 ls0 block sm:inline">Contributor</span></span><span><span class="smallTimestamp lg:largeTimestamp pb1 c-gray600"><time dateTime="2026-01-09 04:00:20">Jan 9, 2026</time></span></span></div><div class="aic sx12 f"><a target="_blank" rel="noopener noreferrer" class="y32px" href="https://www.facebook.com/dialog/feed?app_id=137086563877087&amp;link=https%3A%2F%2Fwww.sfchronicle.com%2Ffood%2Frecipes%2Farticle%2Fcurried-cabbage-stew-toast-21270627.php%3Futm_campaign%3DCMS%2520Sharing%2520Tools%2520(Premium)%26utm_source%3Dfacebook.com%26utm_medium%3Dreferral&amp;name=Bring%20balance%20to%20the%20table%20with%20a%20hearty%20veggie%20stew%20and%20turmeric-chile%20toast&amp;description=This%20gently%20spi
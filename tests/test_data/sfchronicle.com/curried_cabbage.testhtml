linkedIn":null,"instagram":null,"twitter":null,"tiktok":null,"bluesky":null,"hasContact":null,"primarySiteId":null,"sponsorLogoUrl":null,"originId":null,"image":null}],"hero":null,"publishedOnline":"2026-01-09 04:00:20","lastModifiedDate":"2026-01-09 04:00:21","lastPublishedDisplayed":"2026-01-09 04:00:20","shareTools":{"facebook":"https://www.facebook.com/dialog/feed?app_id=137086563877087\u0026link=https%3A%2F%2Fwww.sfchronicle.com%2Ffood%2Frecipes%2Farticle%2Fcurried-cabbage-stew-toast-21270627.php%3Futm_campaign%3DCMS%2520Sharing%2520Tools%2520(Premium)%26utm_source%3Dfacebook.com%26utm_medium%3Dreferral\u0026name=Bring%20balance%20to%20the%20table%20with%20a%20hearty%20veggie%20stew%20and%20turmeric-chile%20toast\u0026description=This%20gently%20spiced%20cabbage%2C%20sweet%20potato%20and%20white%20bean%20stew%20hits%20the%20sweet%20spot%20between%20nourishing%20and%20indulgent%2C%20especially%20with%20turmeric-chile%20butter%20toast%20on%20the%20side.\u0026picture=https%3A%2F%2Fs.hdnux.com%2Fphotos%2F01%2F55%2F51%2F55%2F28744520%2F5%2FrawImage.jpg\u0026redirect_uri=https%3A%2F%2Fwww.sfchronicle.com%2Ffood%2Frecipes%2Farticle%2Fcurried-cabbage-stew-toast-21270627.php%3Futm_campaign%3DCMS%2520Sharing%2520Tools%2520(Premium)%26utm_source%3DUTMSOURCE%26utm_medium%3DUTMMEDIUM","twitter":"https://twitter.com/intent/tweet?url=https%3A%2F%2Fwww.sfchronicle.com%2Ffood%2Frecipes%2Farticle%2Fcurried-cabbage-stew-toast-21270627.php%3Futm_campaign%3DCMS%2520Sharing%2520Tools%2520(Premium)%26utm_source%3Dt.co%26utm_medium%3Dreferral\u0026text=Bring%20balance%20to%20the%20table%20with%20a%20hearty%20veggie%20stew%20and%20turmeric-chile%20toast\u0026via=sfchronicle","bluesky":"https://bsky.app/intent/compose?text=Bring%20balance%20to%20the%20table%20with%20a%20hearty%20veggie%20stew%20and%20turmeric-chile%20toast%20https%3A%2F%2Fwww.sfchronicle.com%2Ffood%2Frecipes%2Farticle%2Fcurried-cabbage-stew-toast-21270627.php\u0026url=https%3A%2F%2Fwww.sfchronicle.com%2Ffood%2Frecipes%2Farticle%2Fcurried-cabbage-stew-toast-21270627.php%3Futm_campaign%3DCMS%2520Sharing%2520Tools%2520(Premium)%26utm_source%3Dbsky.app%26utm_medium%3Dreferral","email":"mailto:?subject=Your%20friend%20has%20shared%20a%20San%20Francisco%20Chronicle%20link%20with%20you%3A\u0026body=Bring%20balance%20to%20the%20table%20with%20a%20hearty%20veggie%20stew%20and%20turmeric-chile%20toast%0A%0Ahttps%3A%2F%2Fwww.sfchronicle.com%2Ffood%2Frecipes%2Farticle%2Fcurried-cabbage-stew-toast-21270627.php%3Futm_campaign%3DCMS%2520Sharing%2520Tools%2520(Premium)%26utm_source%3Dshare-by-email%26utm_medium%3Demail%0A%0AThis%20gently%20spiced%20cabbage%2C%20sweet%20potato%20and%20white%20bean%20stew%20hits%20the%20sweet%20spot%20between%20nourishing%20and%20indulgent%2C%20especially%20with%20turmeric-chile%20butter%20toast%20on%20the%20side.%0A%0AThis%20message%20was%20sent%20via%20San%20Francisco%20Chronicle"},"followTopic":false,"followTopicAlertable":null,"__typename":"Article","type":"articleHeader"}],"id":"articleHeader","type":"ArticleHeader","options":{"placement":"main","layout":"1Column","setContentDiv":true,"removeTimestamp":false}}]}]},{"id":"zoneSet5","layout":"2ColumnRightPadded","options":{},"zones":[{"id":"zoneBody","options":{"articleBody":"1"},"widgets":[{"items":[{"body":[{"__typename":"ImageBlock","type":"image","params":{"layout":"photo","chapter":null,"chapterHeader":null,"id":28744520,"orientation":"landscape","byline":"Christian Reynoso ","image":{"url":"https://s.hdnux.com/photos/01/55/51/55/28744520/5/rawImage.jpg","b64":null,"width":2048,"height":1536,"caption":{"plain":"Warmly spiced stew is paired with toast that’s slathered with seasoned butter. ","html1":"\u003cp\u003eWarmly spiced stew is paired with toast that’s slathered with seasoned butter. \u003c/p\u003e","serializedReact":null},"loading":"lazy","external":null,"alt":"Warmly spiced stew is paired with toast that’s slathered with seasoned butter. "}}},{"__typename":"ZoneBlock","type":"zone","params":{"layout":null,"chapter":null,"chapterHeader":null,"eid":"item-102852","embed":{"__type":"thirdPartyFreeformEmbed","__id":"everlit","__data":{"publicationId":"pblc_kYW067sbmBR"},"__tpId":"everlit"},"guid":"zoneInlineA","widgets":null}},{"__typename":"TextBlock","type":"text","params":{"layout":"","chapter":null,"chapterHeader":null,"html1":"\u003cp\u003eThere are some predictable cycles in the food media world. In the spring, everything on the plate must be green or have an egg involved. In the summer, it’s all about easy, fresh and staying away from the oven like it’s a bad idea. (The grill, however, is allowed.) Early fall is about getting back into a routine, whatever that means. Late fall through early winter turns cozy, sweet and very much about entertaining: what to bring, what to bake what will travel well.\u003c/p\u003e","isDropcap":false,"serializedReact":{"type":"p","key":null,"ref":null,"props":{"children":"There are some predictable cycles in the food media world. In the spring, everything on the plate must be green or have an egg involved. In the summer, it’s all about easy, fresh and staying away from the oven like it’s a bad idea. (The grill, however, is allowed.) Early fall is about getting back into a routine, whatever that means. Late fall through early winter turns cozy, sweet and very much about entertaining: what to bring, what to bake what will travel well."}}}},{"__typename":"ZoneBlock","type":"zone","params":{"layout":null,"chapter":null,"chapterHeader":null,"eid":null,"embed":{},"guid":"zoneInlineA","widgets":null}},{"__typename":"TextBlock","type":"text","params":{"layout":"","chapter":null,"chapterHeader":null,"html1":"\u003cp\u003eWinter is also about coziness, but it’s layered with this idea of new beginnings. Maybe that means pulling back on alcohol, easing off overly rich foods or just wanting something that feels grounding again. I used to think predictions like this were constraining, like they boxed us in. These days, I think it’s helpful to have loose guides and themes to help us decide what feels right to put on the table when the days are short and we’re cooking a little more by instinct.\u003c/p\u003e","isDropcap":false,"serializedReact":{"type":"p","key":null,"ref":null,"props":{"children":"Winter is also about coziness, but it’s layered with this idea of new beginnings. Maybe that means pulling back on alcohol, easing off overly rich foods or just wanting something that feels grounding again. I used to think predictions like this were constraining, like they boxed us in. These days, I think it’s helpful to have loose guides and themes to help us decide what feels right to put on the table when the days are short and we’re cooking a little more by instinct."}}}},{"__typename":"ZoneBlock","type":"zone","params":{"layout":null,"chapter":null,"chapterHeader":null,"eid":"item-101985","embed":{"__type":"blueConicFreeformEmbed","__id":"Promo","__data":{"variant":"sfcSurvey:articleParagraph"},"__tpId":"Promo"},"guid":"zoneInlineA","widgets":null}},{"__typename":"ZoneBlock","type":"zone","params":{"layout":null,"chapter":null,"chapterHeader":null,"eid":"item-102365","embed":{"__type":"blueConicFreeformEmbed","__id":"Promo","__data":{"variant":"inlineSFCHighMomentumInDMA:articleParagraph"},"__tpId":"Promo"},"guid":"zoneInlineA","widgets":null}},{"__typename":"ZoneBlock","type":"zone","params":{"layout":null,"chapter":null,"chapterHeader":null,"eid":"item-102367","embed":{"__type":"blueConicFreeformEmbed","__id":"Promo","__data":{"variant":"inlineSFCLowMomentumOutofDMA:articleParagraph"},"__tpId":"Promo"},"guid":"zoneInlineA","widgets":null}},{"__typename":"TextBlock","type":"text","params":{"layout":"","chapter":null,"chapterHeader":null,"html1":"\u003cp\u003eAs for me, I keep coming back to balance. One night it’s pizza, the next it’s a big salad — sometimes it’s all on the same plate. With this week’s recipe, I’m firmly in the balance camp: a hearty vegetable stew paired with a big piece of butter-slathered toast.\u003c/p\u003e","isDropcap":false,"serializedReact":{"type":"p","key":null,"ref":null,"props":{"children":"As for me, I keep coming back to balance. One night it’s pizza, the next it’s a big salad — sometimes it’s all on the same plate. With this week’s recipe, I’m firmly in the balance camp: a hearty vegetable stew paired with a big piece of butter-slathered toast."}}}},{"__typename":"AdBlock","type":"ad","params":{"layout":null,"chapter":null,"chapterHeader":null,"code":null,"small":"A300","large":"CONCERT1","showInlineAdLabel":true,"adUnitPath":"hnp-sfchronicle.com/article_dtc"}},{"__typename":"TextBlock","type":"text","params":{"layout":"","chapter":null,"chapterHeader":null,"html1":"\u003cp\u003eThe stew is warmly spiced, which brings depth and comfort, but it’s softened by sweet potato, tender cabbage and creamy white beans. Savoy cabbage, if you can find it, is especially good here. It’s leafy, crinkly, and vibrantly hued. When it simmers, it turns tender without losing its structure. I think of it as a young vegetable with an old soul.\u003c/p\u003e","isDropcap":false,"serializedReact":{"type":"p","key":null,"ref":null,"props":{"children":"The stew is warmly spiced, which brings depth and comfort, but it’s softened by sweet potato, tender cabbage and creamy white beans. Savoy cabbage, if you can find it, is especially good here. It’s leafy, crinkly, and vibrantly hued. When it simmers, it turns tender without losing its structure. I think of it as a young vegetable with an old soul."}}}},{"__typename":"TextBlock","type":"text","params":{"layout":"","chapter":null,"chapterHeader":null,"html1":"\u003cp\u003eThen there’s the toast. I prefer a thick piece of baguette, toasted in olive oil so it’s already rich before you even get to the butter. That butter is seasoned with earthy turmeric, bright lemon zest and crushed chile flakes for heat. It’s simple, but it does a lot. I highly recommend seasoning butter more often if you don’t already; it’s one of those small things that makes meals feel more intentional.\u003c/p\u003e","isDropcap":false,"serializedReact":{"type":"p","key":null,"ref":null,"props":{"children":"Then there’s the toast. I prefer a thick piece of baguette, toasted in olive oil so it’s already rich before you even get to the butter. That butter is seasoned with earthy turmeric, bright lemon zest and crushed chile flakes for heat. It’s simple, but it does a lot. I highly recommend seasoning butter more often if you don’t already; it’s one of those small things that makes meals feel more intentional."}}}},{"__typename":"ZoneBlock","type":"zone","params":{"layout":null,"chapter":null,"chapterHeader":null,"eid":"item-104247","embed":{"__type":"thirdPartyFreeformEmbed","__id":"googlepreferredsourcesinlinemodule","__data":{"headlineText":"See more S.F. Chronicle on Google","descriptionText":"Make us a Preferred Source to get more of our news when you search.","buttonText":"Add Preferred Source","linkUrl":"https://www.google.com/preferences/source?q=sfchronicle.com","trackingName":"sfchronicle_google_preferred_source "},"__tpId":"googlepreferredsourcesinlinemodule"},"guid":"zoneInlineA","widgets":null}},{"__typename":"TextBlock","type":"text","params":{"layout":"","chapter":null,"chapterHeader":null,"html1":"\u003cp\u003eIn the end, this soup might be a predictable recipe for the beginning of a new year. Honestly, it’s exactly what I want right now. And hopefully, you do too.\u003c/p\u003e","isDropcap":false,"serializedReact":{"type":"p","key":null,"ref":null,"props":{"children":"In the end, this soup might be a predictable recipe for the beginning of a new year. Honestly, it’s exactly what I want right now. And hopefully, you do too."}}}},{"__typename":"ImageBlock","type":"image","params":{"layout":"photo","chapter":null,"chapterHeader":null,"id":28744521,"orientation":"portrait","byline":"Christian Reynoso ","image":{"url":"https://s.hdnux.com/photos/01/55/51/55/28744521/5/rawImage.jpg","b64":null,"width":1536,"height":2048,"caption":{"plain":"Spiced cabbage stew and a thick piece of buttery baguette: an ideal winter meal.","html1":"\u003cp\u003eSpiced cabbage stew and a thick piece of buttery baguette: an ideal winter meal.\u003c/p\u003e","serializedReact":null},"loading":"lazy","external":null,"alt":"Spiced cabbage stew and a thick piece of buttery baguette: an ideal winter meal."}}},{"__typename":"TextBlock","type":"text","params":{"layout":"","chapter":null,"chapterHeader":null,"html1":"\u003ch2 class=\"cci_subhead\" title=\"CCI Subhead\"\u003eCurried Cabbage Stew with Turmeric-Chile Butter Toasts\u003c/h2\u003e","isDropcap":false,"serializedReact":{"type":"h2","key":null,"ref":null,"props":{"className":"cci_subhead","title":"CCI Subhead","children":"Curried Cabbage Stew with Turmeric-Chile Butter Toasts"}}}},{"__typename":"TextBlock","type":"text","params":{"layout":"","chapter":null,"chapterHeader":null,"html1":"\u003cp\u003e\u003cem\u003eServes 4\u003c/em\u003e\u003c/p\u003e","isDropcap":false,"serializedReact":{"type":"p","key":null,"ref":null,"props":{"children":{"type":"em","key":null,"ref":null,"props":{"children":"Serves 4"}}}}}},{"__typename":"AdBlock","type":"ad","params":{"layout":null,"chapter":null,"chapterHeader":null,"code":null,"small":"CONCERT1","large":"CONCERT2","showInlineAdLabel":true,"adUnitPath":"hnp-sfchronicle.com/article_dtc"}},{"__typename":"TextBlock","type":"text","params":{"layout":"","chapter":null,"chapterHeader":null,"html1":"\u003cp\u003eThis winter meal pairs tender vegetables in a savory, gently spiced gingery broth with very rich toast. It feels soothing and revitalizing, but still indulgent enough to feel satisfying.\u003c/p\u003e","isDropcap":false,"serializedReact":{"type":"p","key":null,"ref":null,"props":{"children":"This winter meal pairs tender vegetables in a savory, gently spiced gingery broth with very rich toast. It feels soothing and revitalizing, but still indulgent enough to feel satisfying."}}}},{"__typename":"TextBlock","type":"text","params":{"layout":"","chapter":null,"chapterHeader":null,"html1":"\u003cp\u003eIf you can’t find Savoy cabbage (named for the Savoy region of France), green cabbage or Napa cabbage will work just fine. I suggest a curry powder that includes turmeric and garam masala, but if you have the individual spices and feel like mixing your own, I recommend it. The flavors will be brighter and more distinct.\u003c/p\u003e","isDropcap":false,"serializedReact":{"type":"p","key":null,"ref":null,"props":{"children":"If you can’t find Savoy cabbage (named for the Savoy region of France), green cabbage or Napa cabbage will work just fine. I suggest a curry powder that includes turmeric and garam masala, but if you have the individual spices and feel like mixing your own, I recommend it. The flavors will be brighter and more distinct."}}}},{"__typename":"TextBlock","type":"text","params":{"layout":"","chapter":null,"chapterHeader":null,"html1":"\u003cp\u003e3 tablespoons extra-virgin olive oil\u003c/p\u003e","isDropcap":false,"serializedReact":{"type":"p","key":null,"ref":null,"props":{"children":"3 tablespoons extra-virgin olive oil"}}}},{"__typename":"TextBlock","type":"text","params":{"layout":"","chapter":null,"chapterHeader":null,"html1":"\u003cp\u003e2 cups diced sweet potato (from about 1 medium sweet potato)\u003c/p\u003e","isDropcap":false,"serializedReact":{"type":"p","key":null,"ref":null,"props":{"children":"2 cups diced sweet potato (from about 1 medium sweet potato)"}}}},{"__typename":"TextBlock","type":"text","params":{"layout":"","chapter":null,"chapterHeader":null,"html1":"\u003cp\u003e1 medium yellow onion, diced small\u003c/p\u003e","isDropcap":false,"serializedReact":{"type":"p","key":null,"ref":null,"props":{"children":"1 medium yellow onion, diced small"}}}},{"__typename":"AdBlock","type":"ad","params":{"layout":null,"chapter":null,"chapterHeader":null,"code":null,"small":"B300","large":null,"showInlineAdLabel":true,"adUnitPath":"hnp-sfchronicle.com/article_dtc"}},{"__typename":"TextBlock","type":"text","params":{"layout":"","chapter":null,"chapterHeader":null,"html1":"\u003cp\u003e4 large garlic cloves, thinly sliced \u003c/p\u003e","isDropcap":false,"serializedReact":{"type":"p","key":null,"ref":null,"props":{"children":"4 large garlic cloves, thinly sliced "}}}},{"__typename":"TextBlock","type":"text","params":{"layout":"","chapter":null,"chapterHeader":null,"html1":"\u003cp\u003e1-inch piece ginger, finely chopped \u003c/p\u003e","isDropcap":false,"serializedReact":{"type":"p","key":null,"ref":null,"props":{"children":"1-inch piece ginger, finely chopped "}}}},{"__typename":"TextBlock","type":"text","params":{"layout":"","chapter":null,"chapterHeader":null,"html1":"\u003cp\u003eSalt and pepper\u003c/p\u003e","isDropcap":false,"serializedReact":{"type":"p","key":null,"ref":null,"props":{"children":"Salt and pepper"}}}},{"__typename":"TextBlock","type":"text","params":{"layout":"","chapter":null,"chapterHeader":null,"html1":"\u003cp\u003e1 tablespoon curry powder\u003c/p\u003e","isDropcap":false,"serializedReact":{"type":"p","key":null,"ref":null,"props":{"children":"1 tablespoon curry powder"}}}},{"__typename":"TextBlock","type":"text","params":{"layout":"","chapter":null,"chapterHeader":null,"html1":"\u003cp\u003e1 small head (about 10 ounces) of Savoy or green cabbage, cored and roughly chopped\u003c/p\u003e","isDropcap":false,"serializedReact":{"type":"p","key":null,"ref":null,"props":{"children":"1 small head (about 10 ounces) of Savoy or green cabbage, cored and roughly chopped"}}}},{"__typename":"AdBlock","type":"ad","params":{"layout":null,"chapter":null,"chapterHeader":null,"code":null,"small":"CONCERT2","large":null,"showInlineAdLabel":true,"adUnitPath":"hnp-sfchronicle.com/article_dtc"}},{"__typename":"TextBlock","type":"text","params":{"layout":"","chapter":null,"chapterHeader":null,"html1":"\u003cp\u003e6 cups chicken or vegetable stock \u003c/p\u003e","isDropcap":false,"serializedReact":{"type":"p","key":null,"ref":null,"props":{"children":"6 cups chicken or vegetable stock "}}}},{"__typename":"TextBlock","type":"text","params":{"layout":"","chapter":null,"chapterHeader":null,"html1":"\u003cp\u003e1 (14-ounce) can white beans, drained and rinsed\u003c/p\u003e","isDropcap":false,"serializedReact":{"type":"p","key":null,"ref":null,"props":{"children":"1 (14-ounce) can white beans, drained and rinsed"}}}},{"__typename":"TextBlock","type":"text","params":{"layout":"","chapter":null,"chapterHeader":null,"html1":"\u003cp\u003e6 tablespoons unsalted butter, room temperature\u003c/p\u003e","isDropcap":false,"serializedReact":{"type":"p","key":null,"ref":null,"props":{"children":"6 tablespoons unsalted butter, room temperature"}}}},{"__typename":"TextBlock","type":"text","params":{"layout":"","chapter":null,"chapterHeader":null,"html1":"\u003cp\u003e¼ teaspoon turmeric\u003c/p\u003e","isDropcap":false,"serializedReact":{"type":"p","key":null,"ref":null,"props":{"children":"¼ teaspoon turmeric"}}}},{"__typename":"TextBlock","type":"text","params":{"layout":"","chapter":null,"chapterHeader":null,"html1":"\u003cp\u003e¼ teaspoon crushed red chile flakes \u003c/p\u003e","isDropcap":false,"serializedReact":{"type":"p","key":null,"ref":null,"props":{"children":"¼ teaspoon crushed red chile flakes "}}}},{"__typename":"AdBlock","type":"ad","params":{"layout":null,"chapter":null,"chapterHeader":null,"code":null,"small":"S300","large":null,"showInlineAdLabel":true,"adUnitPath":"hnp-sfchronicle.com/article_dtc"}},{"__typename":"TextBlock","type":"text","params":{"layout":"","chapter":null,"chapterHeader":null,"html1":"\u003cp\u003e1 lemon\u003c/p\u003e","isDropcap":false,"serializedReact":{"type":"p","key":null,"ref":null,"props":{"children":"1 lemon"}}}},{"__typename":"TextBlock","type":"text","params":{"layout":"","chapter":null,"chapterHeader":null,"html1":"\u003cp\u003e1 baguette, split in half lengthwise and toasted with olive oil \u003c/p\u003e","isDropcap":false,"serializedReact":{"type":"p","key":null,"ref":null,"props":{"children":"1 baguette, split in half lengthwise and toasted with olive oil "}}}},{"__typename":"TextBlock","type":"text","params":{"layout":"","chapter":null,"chapterHeader":null,"html1":"\u003cp\u003e\u003cstrong\u003eCook the\u003c/strong\u003e \u003cstrong\u003eCurried Cabbage Stew: \u003c/strong\u003eHeat the olive oil in a large size pot or Dutch oven over medium heat. Once the oil is warm, add the sweet potato, onion, garlic and ginger. Season with salt and pepper and stir. Cover with a lid and cook, lifting the lid to stir occasionally until the potato is fork tender and the onion is beginning to caramelize on the edges, about 8 to 12 minutes. \u003c/p\u003e","isDropcap":false,"serializedReact":{"type":"p","key":null,"ref":null,"props":{"children":[{"type":"strong","key":"0","ref":null,"props":{"children":"Cook the"}}," ",{"type":"strong","key":"2","ref":null,"props":{"children":"Curried Cabbage Stew: "}},"Heat the olive oil in a large size pot or Dutch oven over medium heat. Once the oil is warm, add the sweet potato, onion, garlic and ginger. Season with salt and pepper and stir. Cover with a lid and cook, lifting the lid to stir occasionally until the potato is fork tender and the onion is beginning to caramelize on the edges, about 8 to 12 minutes. "]}}}},{"__typename":"ZoneBlock","type":"zone","params":{"layout":null,"chapter":null,"chapterHeader":null,"eid":null,"embed":null,"guid":"zoneInlineB","widgets":[]}},{"__typename":"TextBlock","type":"text","params":{"layout":"","chapter":null,"chapterHeader":null,"html1":"\u003cp\u003eStir the curry powder into the vegetables and follow with the cabbage. Season the cabbage with salt, then stir and cook it until it wilts to half its volume, about 3 minutes. Pour in the stock and bring to a simmer. Simmer until the cabbage has completely wilted and some white parts turn a bit yellow, about 7 minutes. Add the white beans and simmer for 1 more minute. Turn the heat off and season with salt to taste.  \u003c/p\u003e","isDropcap":false,"serializedReact":{"type":"p","key":null,"ref":null,"props":{"children":"Stir the curry powder into the vegetables and follow with the cabbage. Season the cabbage with salt, then stir and cook it until it wilts to half its volume, about 3 minutes. Pour in the stock and bring to a simmer. Simmer until the cabbage has completely wilted and some white parts turn a bit yellow, about 7 minutes. Add the white beans and simmer for 1 more minute. Turn the heat off and season with salt to taste.  "}}}},{"__typename":"AdBlock","type":"ad","params":{"layout":null,"chapter":null,"chapterHeader":null,"code":null,"small":null,"large":null,"showInlineAdLabel":true,"adUnitPath":"hnp-sfchronicle.com/article_dtc"}},{"__typename":"TextBlock","type":"text","params":{"layout":"","chapter":null,"chapterHeader":null,"html1":"\u003cp\u003e\u003cstrong\u003eMake the Turmeric-Chile Butter:\u003c/strong\u003e Meanwhile, add the butter, turmeric and chile to a small bowl and mix together with a fork. Finely grate in about half the lemon zest and season with salt. \u003c/p\u003e","isDropcap":false,"serializedReact":{"type":"p","key":null,"ref":null,"props":{"children":[{"type":"strong","key":"0","ref":null,"props":{"children":"Make the Turmeric-Chile Butter:"}}," Meanwhile, add the butter, turmeric and chile to a small bowl and mix together with a fork. Finely grate in about half the lemon zest and season with salt. "]}}}},{"__typename":"TextBlock","type":"text","params":{"layout":"","chapter":null,"chapterHeader":null,"html1":"\u003cp\u003e\u003cstrong\u003ePrepare the Toast:\u003c/strong\u003e To serve, ladle the stew into bowls. Break the baguette into smaller pieces — I prefer large pieces, about ¼ of the total baguette — and toast. Spread the butter on the toast and place in the bowl with the stew. \u003c/p\u003e","isDropcap":false,"serializedReact":{"type":"p","key":null,"ref":null,"props":{"children":[{"type":"strong","key":"0","ref":null,"props":{"children":"Prepare the Toast:"}}," To serve, ladle the stew into bowls. Break the baguette into smaller pieces — I prefer large pieces, about ¼ of the total baguette — and toast. Spread the butter on the toast and place in the bowl with the stew. "]}}}},{"__typename":"ZoneBlock","type":"zone","params":{"layout":null,"chapter":null,"chapterHeader":null,"eid":"item-101919","embed":{"__type":"blueConicFreeformEmbed","__id":"NewsletterSignup","__data":{"variant":"drinkingWithEsther:articleBottom"},"__tpId":"NewsletterSignup"},"guid":"zoneInlineA","widgets":null}}],"__typename":"Article","type":"articleBody"}],"id":"articleBody","type":"ArticleBody","options":{"hasChapters":false}},{"items":[{"authors":[{"name":"Christian Reynoso","firstName":"Christian","lastName":"Reynoso","title":null,"biography":null,"url":null,"slug":null,"email":null,"displayEmail":null,"facebook":null,"linkedIn":null,"instagram":null,"twitter":null,"tiktok":null,"bluesky":null,"hasContact":null,"primarySiteId":null,"sponsorLogoUrl":null,"originId":null,"image":null}],"publishedOnline":"2026-01-09 04:00:20","lastPublishedDisplayed":"2026-01-09 04:00:20","tagBubbles":[],"__typename":"Article","type":"articleFooter"}],"id":"articleFooter","type":"ArticleFooter","options":{"placement":"main","removeTimestamp":false}}]},{"id":"pzoneC","options":{},"widgets":[{"id":"0","type":"Ad","options":{"hideOnMobile":true,"sticky":true,"large":"A300","adUnitPath":"hnp-sfchronicle.com/article_dtc","hasChapters":false},"items":[]},{"eid":"collection-123603-dynamic_featured_story","collections":[],"items":[{"__typename":"Link","type":"link","id":"260127","eid":"link-260127","url":"https://www.sfchronicle.com/projects/2026/top-100-best-restaurants-san-francisco-bay-area/","title":"Top 100 Restaurants in the Bay Area","abstract":"Our restaurant critics rank the best places to eat, from 100 to the new No. 1. This year’s list reflects changes in the dining landscape — and San Francisco’s resurgence on the scene.","plainTextAbstract":"Our restaurant critics rank the best places to eat, from 100 to the new No. 1. This year’s list reflects changes in the dining landscape — and San Francisco’s resurgence on the scene.","excerpt":"Our restaurant critics rank the best places to eat, from 100 to the new No. 1. This year’s list reflects changes in the dining landscape — and San Francisco’s resurgence on the scene.","eyebrow":{"linkText":"Best Restaurants","url":"/best-restaurants/"},"badge":null,"displayedDate":"2026-04-06 08:00:00","authorName":"San Francisco Chronicle Staff","authors":[],"bylineObjects":[{"id":null,"name":"San Francisco Chronicle Staff","title":null,"url":null,"credit":null,"image":null}],"image":{"url":"https://s.hdnux.com/photos/01/65/35/75/30793563/3/rawImage.jpg","b64":null,"width":2048,"height":1365,"caption":{"plain":"Top 100 2026","html1":null,"serializedReact":null},"loading":"lazy","external":null,"alt":"Top 100 2026","title":"top-100-2026-t50-social-sandys"},"sponsored":null,"collectionConfig":{"showLabels":false,"persistentTimestamp":false,"showEyebrows":true,"showPhoto":null,"showByline":false,"showTimestamp":false,"useImg":true,"blurb":null,"useBlurb":false,"hideBlurbOnMobile":false,"forceHideEyebrows":false},"videoloop":null,"playerId":null,"slideshowImages":null,"bizRelItem":null}],"id":"zoneC0","type":"FeaturedStory","options":{"content":null,"siteStyle":"premium","subClass":null,"title":{},"commerceType":"","wcmCollectionTitle":"Top 100 feature collection","placement":"sidebar"},"totalItems":null,"blueconicPurpose":"","blueconicFormat":"","blueconicVariant":"","blueconicLimit":0,"blueconicJSON":"","dataProvider":""},{"eid":"collection-122511-mostPopular","collections":[],"items":[{"__typename":"ArticleStub","type":"article","url":"/opinion/editorials/article/katie-porter-governor-california-22208808.php","title":"Endorsement: Two governor candidates stand out. Here’s our pick","excerpt":"OPINION: Wit
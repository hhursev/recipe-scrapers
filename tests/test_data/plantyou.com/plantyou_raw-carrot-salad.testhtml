/plantyou.com/wp-content/uploads/2020/12/py_primary-logo_rgb-colour.png","width":2560,"height":1204,"caption":"PlantYou"},"image":{"@id":"https://plantyou.com/#/schema/logo/image/"},"sameAs":["https://www.facebook.com/plantyoublog","https://x.com/carleighbodrug","https://www.instagram.com/plantyou","https://www.pinterest.com/plantyou"]},{"@type":"Person","@id":"https://plantyou.com/#/schema/person/fed23918b3134c6e6b333560170fec3c","name":"carleigh","image":{"@type":"ImageObject","inLanguage":"en-US","@id":"https://plantyou.com/#/schema/person/image/","url":"https://secure.gravatar.com/avatar/1788611eb4fbf30878d8c137be481d4d?s=96&d=blank&r=g","contentUrl":"https://secure.gravatar.com/avatar/1788611eb4fbf30878d8c137be481d4d?s=96&d=blank&r=g","caption":"carleigh"},"sameAs":["https://plantyou.com/about/"]},{"@type":"Question","@id":"https://plantyou.com/raw-carrot-salad/#faq-question-1761988177760","position":1,"url":"https://plantyou.com/raw-carrot-salad/#faq-question-1761988177760","name":"How long does it keep?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Refrigerate in an airtight container or jar in the fridge for up to 2 days. Shake or toss before serving.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https://plantyou.com/raw-carrot-salad/#faq-question-1761988217992","position":2,"url":"https://plantyou.com/raw-carrot-salad/#faq-question-1761988217992","name":"Can I use pre-shredded carrots?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Absolutely, just make sure they’re fresh for the best texture.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https://plantyou.com/raw-carrot-salad/#faq-question-1761988231717","position":3,"url":"https://plantyou.com/raw-carrot-salad/#faq-question-1761988231717","name":"Can I use frozen or cooked carrots?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"You wouldn't get the signature crunch with cooked carrots, but you can still enjoy the dressing on those.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https://plantyou.com/raw-carrot-salad/#faq-question-1761988422700","position":4,"url":"https://plantyou.com/raw-carrot-salad/#faq-question-1761988422700","name":"Can I adjust the spice level?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Of course! Reduce or omit the chili flakes for a milder version, or add more for extra heat.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Recipe","name":"Raw Carrot Salad","author":{"@id":"https://plantyou.com/#/schema/person/fed23918b3134c6e6b333560170fec3c"},"description":"Vibrant, deqlicious, and ready instantly! This salad is the perfect light lunch or side dish.","datePublished":"2025-11-03T15:08:50+00:00","image":["https://plantyou.com/wp-content/uploads/2025/11/DSC01638-scaled.jpg","https://plantyou.com/wp-content/uploads/2025/11/DSC01638-500x500.jpg","https://plantyou.com/wp-content/uploads/2025/11/DSC01638-500x375.jpg","https://plantyou.com/wp-content/uploads/2025/11/DSC01638-480x270.jpg"],"recipeYield":["2"],"prepTime":"PT10M","totalTime":"PT10M","recipeIngredient":["2  carrots (julienned or peeled into ribbons)","½  red onion (thinly sliced)","1 handful cilantro (finely chopped)","½ tbsp maple syrup","1 tsp chili flakes","1 tsp rice vinegar","1 tsp sesame oil (or avocado oil)","1 tbsp sesame seeds","¼ cup pistachios (crushed)"],"recipeInstructions":[{"@type":"HowToStep","text":"Add the carrots, red onion and cilantro to a jar, followed by the maple syrup, vinegar, chili flakes, sesame oil, sesame seeds and pistachios. ","name":"Add the carrots, red onion and cilantro to a jar, followed by the maple syrup, vinegar, chili flakes, sesame oil, sesame seeds and pistachios. ","url":"https://plantyou.com/raw-carrot-salad/#wprm-recipe-24640-step-0-0"},{"@type":"HowToStep","text":"Add a lid to the jar, and shake until completely mixed. Pour into a dish and enjoy. Alternatively stir all ingredients in a big bowl and enjoy. ","name":"Add a lid to the jar, and shake until completely mixed. Pour into a dish and enjoy. Alternatively stir all ingredients in a big bowl and enjoy. ","url":"https://plantyou.com/raw-carrot-salad/#wprm-recipe-24640-step-0-1"}],"aggregateRating":{"@type":"AggregateRating","ratingValue":"5","ratingCount":"1"},"recipeCategory":["Salad"],"recipeCuisine":["Asian"],"keywords":"10 minute recipe, autumn harvest, autumn salad, creamy vegan salad, delicious recipes, naturally plant based, naturally vegan, plant based salad, quick recipes, quickies, vegan side dish","nutrition":{"@type":"NutritionInformation","calories":"180.3 kcal","carbohydrateContent":"17.5 g","proteinContent":"4.9 g","fatContent":"11.3 g","saturatedFatContent":"1.5 g","sodiumContent":"61.6 mg","fiberContent":"4.6 g","sugarContent":"8.3 g","unsaturatedFatContent":"9.3 g","servingSize":"1 serving"},"@id":"https://plantyou.com/raw-carrot-salad/#recipe","isPartOf":{"@id":"https://plantyou.com/raw-carrot-salad/#article"},"mainEntityOfPage":"https://plantyou.com/raw-carrot-salad/"}]}</script>

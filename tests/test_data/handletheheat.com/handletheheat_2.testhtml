itemtype="https://schema.org/ListItem"><a href="#toc-tessas-tips" itemprop="url"><span itemprop="name">Tessa’s Tips</span></a><meta itemprop="position" content="5"></li><li class="meyne-toc-item" style="display: none;" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem"><a href="#toc-storage-make-ahead" itemprop="url"><span itemprop="name">Storage &amp; Make ahead</span></a><meta itemprop="position" content="6"></li><li class="meyne-toc-item" style="display: none;" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem"><a href="#toc-no-bake-chocolate-peanut-butter-cheesecake" itemprop="url"><span itemprop="name">No Bake Chocolate Peanut Butter Cheesecake</span></a><meta itemprop="position" content="7"></li><li class="meyne-toc-item" style="display: none;" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem"><a href="#toc-email-this-recipe" itemprop="url"><span itemprop="name">Email This Recipe</span></a><meta itemprop="position" content="8"></li><li class="meyne-toc-item" style="display: none;" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem"><a href="#toc-frequently-asked-questions" itemprop="url"><span itemprop="name">Frequently Asked Questions</span></a><meta itemprop="position" content="9"></li></ol></nav><script type="text/javascript">(function(){var btnAll = document.getElementById("toc-btn-all-2577878646");var btnLess = document.getElementById("toc-btn-less-3863305978");if(!btnAll || !btnLess) return;var toc = btnAll.closest(".meyne-toc");if(!toc) return;var items = toc.querySelectorAll(".meyne-toc-item");function setExpanded(expanded){for(var i=0;i<items.length;i++){if(i>=3){ items[i].style.display = expanded ? "list-item" : "none"; }}if(expanded){btnAll.classList.add("is-active"); btnLess.classList.remove("is-active");btnAll.setAttribute("aria-pressed","true"); btnLess.setAttribute("aria-pressed","false");} else {btnAll.classList.remove("is-active"); btnLess.class
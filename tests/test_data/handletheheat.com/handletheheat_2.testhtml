			/* POST HEADER MOBILE FIX FOR EMAIL BUTTON */
@media (max-width: 767px) {
	.custom-post-header .yoast-breadcrumbs {
		margin-bottom: 10px;
	}
	.custom-post-header .custom-meta .wp-block-group__inner-container {
		margin-bottom: 0;
	}
	.custom-post-header .wprm-recipe-summary {
		font-size: 17px;
		line-height: 1.3;
	}
	.header-cta-mobile {
		max-height: 50px;
	}
	.custom-post-header .wprm-recipe-rating {
		margin-left: -8px;
	}
}


/* MEGA MENU */
.kadence-menu-mega-enabled > .sub-menu {
	padding: 0 !important;	
}

.kadence-menu-mega-enabled > .sub-menu a {
	color: var(--global-palette3);
}

.kadence-menu-mega-enabled > .sub-menu a:hover,
.kadence-menu-mega-enabled > .sub-menu .current-menu-item > a,
.kadence-menu-mega-enabled > .sub-menu .entry-title a:hover {
	color: var(--global-palette1) !important;
	background: transparent !important;
}

.header-navigation .header-menu-container ul ul.sub-menu, .header-navigation .header-menu-container ul ul.submenu {
	box-shadow: none !important;
}

#menu-item-241 .kadence-post-image img {
	border-radius: 50% !Important;
}

@media (min-width: 767px) {
	.mega-menu .menu {
		columns: 2;
	}
}

.mega-menu .menu a {
	color: var(--global-palette3) !important;
	padding: 5px 0 !important;
	font-size: 15px !important;
	letter-spacing: .9px !important;
}

.mega-menu .menu a:hover {
	background: transparent !important;
	color: var(--global-palette1) !important;
}

.bold a {
	font-weight: bold !important;
}


@media (max-width: 767px) {
	.kadence-menu-mega-enabled .dropdown-nav-special-toggle,
	.kadence-menu-mega-enabled > .sub-menu {
		/display: none !important;
	}
	.sub-menu.show-drawer .alignfull {
		width: auto !important;
		margin: 0 -28px !important;
	}
	.mobile-navigation .mega-menu ul li > a {
		background: transparent !important;
	}
	.mega-menu .menu a {
		font-size: 14px !important;
	}
}


/* ==========================================================================
   GENERAL
   ========================================================================== */

.site-main-header-wrap {
	max-height: 126px;
}

@media (max-width: 767px) {
	.site-main-header-wrap {
		max-height: 80px;
	}
}

h2.kt-adv-heading236_dae28b-0d em {
	font-size: 34px;
}

.single-post .entry-content > h2:not(.wp-block-kadence-advancedheading),
.single-post .entry-content > h3,
.single-post .entry-content > h4 {
	line-height: 1;
	margin: 30px 0 24px;
}

.kadence-pro-fixed-wrap.child-is-fixed:has(.generator-modal) {
	position: absolute;
}

.bordered-box {
	overflow: visible;
}

.bordered-box h2 {
	background: #fff;
	top: -24px;
}

div:not(.faq-block) h2 {
	margin-bottom: 0 !important;
}

.wp-block-group:has(.schema-faq) {
	padding: 0 !important;
}

.schema-faq-question strong {
	font-weight: 400 !important;
}

.site-header-wrap .squiggly a {
	padding-bottom: 2px;
}

.latest-recipe-link img {
	width: 80px;
}

.gcontainer{
	z-index: 99999999999999999999999;
}

.gslide-image img,
.glightbox-container {
	z-index: 99999999999999999;
}

.minicourse-modal .kt-modal-container {
	padding: 0 !important;
	width: auto;
}


.about-page-about-image {
	margin-bottom: 30px
}

.about-page-about-image figure {
	max-width: 1150px;
	position: relative;
	bottom: -30px !important;
}

.newsletter-container input {
	color: #fff !important;
	font-family: var(--sans-serif) !important;
}

.kadence-pro-fixed-item.item-is-fixed:has(.floating-newsletter) {
	right: 14px !important;
}

.floating-newsletter a {
	color: var(--global-palette3);
	text-decoration: none;
	font-size: 15px;
}

.floating-newsletter a:hover {
  color: var(--global-palette1);
}

.floating-newsletter a::after {
	content: '';
	width: 100px;
	height: 2px;
	background: url(https://handletheheat.com/wp-content/plugins/handle-the-heat-plugin/images/underline.svg);
}

.kadence-pro-fixed-wrap:has(.floating-newsletter) {
  z-index: 9999;
}

@media (min-width: 767px) {
	.site-footer-section .modal-trigger.mobile-only {
		display: none !important;
	}
}

@media (max-width: 768px) {
	.site-footer-section .modal-trigger.desktop-only {
		display: none !important;
	}
}

slick-heartbeat {
  z-index: 9999;
}

/* Desktop Search for Sticky Header */
.site-main-header-wrap.kadence-sticky-header .site-header-item.site-header-focus-item .search-toggle-open-container {
	display: none;
}

.site-main-header-wrap.kadence-sticky-header.item-is-fixed.item-is-stuck .site-header-item.site-header-focus-item .search-toggle-open-container {
	display: block;
}

/* ==========================================================================
   MOBILE TOP HEADER
   ========================================================================== */

@media (max-width: 767px) {
	.site-top-header-inner-wrap.site-header-row-has-sides {
		display: block;
	}

	.site-top-header-inner-wrap.site-header-row-has-sides .site-header-top-section-left {
		width: 100%;
		max-width: none;
		flex: 0 0 100%;
		display: block;
		margin: 0;
		padding: 0;
	}

	.site-top-header-inner-wrap.site-header-row-has-sides .site-header-top-section-right,
	.site-top-header-inner-wrap.site-header-row-has-sides .site-header-top-section-center {
		display: none;
	}

	.site-top-header-inner-wrap.site-header-row-has-sides .site-header-item,
	.site-top-header-inner-wrap.site-header-row-has-sides .mobile-html2,
	.site-top-header-inner-wrap.site-header-row-has-sides .header-html-inner {
		width: 100%;
		max-width: none;
		margin: 0;
	}

	.site-top-header-inner-wrap.site-header-row-has-sides .header-html-inner {
		display: flex;
		align-items: center;
		justify-content: center;
		flex-wrap: nowrap;
		gap: 12px;
		padding: 0;
		box-sizing: border-box;
	}

	.site-top-header-inner-wrap.site-header-row-has-sides .header-html-inner > * {
		display: flex;
		align-items: center;
		justify-content: center;
		flex: 0 0 auto;
	}

	.site-top-header-inner-wrap.site-header-row-has-sides .header-html-inner * {
		white-space: nowrap;
	}

	.site-top-header-inner-wrap.site-header-row-has-sides .header-html-inner p {
		margin: 0;
		line-height: 1;
	}

	.site-top-header-inner-wrap.site-header-row-has-sides .header-html-inner a {
		display: flex;
		align-items: center;
		gap: 8px;
		line-height: 1;
		color: #fff;
		text-decoration: none !important;
	}

	.site-top-header-inner-wrap.site-header-row-has-sides .header-html-inner img {
		display: block;
		margin: 0;
	}

	.site-top-header-inner-wrap.site-header-row-has-sides .header-html-inner p:first-of-type img {
		margin-bottom: -3px;
	}

	.site-top-header-inner-wrap.site-header-row-has-sides .header-html-inner p:last-of-type img {
		margin-top: -12px;
	}

	.site-top-header-inner-wrap.site-header-row-has-sides .generator-modal,
	.site-top-header-inner-wrap.site-header-row-has-sides .kt-blocks-modal-link {
		display: flex;
		align-items: center;
		justify-content: center;
		margin: 0 -12px 0 0;
	}

	.site-top-header-inner-wrap.site-header-row-has-sides .mobile-html2 p {
		font-size: 12px;
		font-family: var(--sans-serif);
	}

	.site-top-header-inner-wrap.site-header-row-has-sides .kb-theme-content-width {
		max-width: none !important;
		width: 100%;
		padding-left: 8px;
		padding-right: 8px;
	}
}

/* ==========================================================================
   HOME PAGE
   ========================================================================== */
.hero-featured .wp-block-image figcaption a {
  pointer-events: auto;
}

/* ==========================================================================
   ABOUT PAGE
   ========================================================================== */

.page-id-235 .content-area {
	margin-bottom: 4rem;
}

@media screen and (max-width: 766px) {
	.about-page-about-image {
		margin-top: -160px;
	}
}

.page-id-235 .negative-margin-bottom {
  margin-bottom: -70px;
}

/* ==========================================================================
   BLOG POST
   ========================================================================== */
.hth-recipe-meta__time:empty::before {
  display: none;
}

@media screen and (max-width: 766px) {
	.sprinkle-of-science .wp-block-kadence-column:nth-child(2) {
		 grid-row: 1;
	}
	
 .sprinkle-of-science .meyne-acc-content .kt-row-column-wrap:not(
    :has(.wp-block-kadence-column:nth-child(2) img)
  ) {
    padding-top: 0;
  }
}

/* ==========================================================================
   OLD RECIPE RUNDOWN
   ========================================================================== */

.tessas-recipe-rundown {
	border: 1px solid var(--global-palette3) !important;
	margin-top: 70px !important;
	position: relative;
}

.tessas-recipe-rundown h2 {
	top: -55px;
	display: inline-block;
	position: relative;
	background: #fff;
	display: inline;
	line-height: 1.2;
	padding-inline: var(--hth-highlight-pad);
	margin-inline: calc(var(--hth-highlight-pad) * -1);
	background-image: linear-gradient(
		rgba(var(--title-highlight-rgb), 0.3),
		rgba(var(--title-highlight-rgb), 0.3)
	);
	background-repeat: no-repeat;
	background-size: 100% var(--hth-highlight-height);
	background-position: 0 calc(100% - var(--hth-highlight-lift));
	-webkit-box-decoration-break: clone;
	box-decoration-break: clone;
}

.tessas-recipe-rundown p {
	margin-bottom: 14px;
	max-width: 550px;
	font-size: 18px;
}

.tessas-recipe-rundown p:first-of-type {
	margin-top: -50px;
}

.tessas-recipe-rundown p strong {
	font-family: var(--sans-serif);
	color: var(--global-palette1);
}

.tessas-recipe-rundown::after {
	content: '';
	width: 220px;
	height: 297px;
	background-image: url(/wp-content/plugins/handle-the-heat-plugin/images/tessa-cut-out.png);
	background-size: contain;
	position: absolute;
	right: 0;
	bottom: 0;
}

@media (max-width: 767px) {
	.tessas-recipe-rundown::after {
		width: 120px;
		height: 148px;
		background-size: contain;
		background-repeat: no-repeat;
		right: -60px;
		bottom: -1px;
	}
}


/* ==========================================================================
   FEATURED COMMENT BLOCK
   ========================================================================== */

:not(.hth-featured-comments-double) .wp-block-small-plugins-featured-comment-block {
	background: var(--global-palette9);
	margin-bottom: 30px;
	border-radius: 15px;
	margin-top: 80px;
	padding: 60px 20px 10px !important;
	position: relative;
}

:not(.hth-featured-comments-double) .wp-block-small-plugins-featured-comment-block p.has-huge-font-size {
	background-image: url(/wp-content/plugins/handle-the-heat-plugin/images/pink-underline.svg);
	background-repeat: no-repeat;
	background-position: center center;
	display: none;
}

:not(.hth-featured-comments-double) .wp-block-small-plugins-featured-comment-block .wp-block-comment-content {
	text-align: left;
	font-style: italic;
}

:not(.hth-featured-comments-double) .wp-block-small-plugins-featured-comment-block .wprm-comment-rating {
	display: block;
	position: absolute;
	left: 50%;
	top: -50px;
	transform: translatex(-50%);
	background: var(--global-palette1) !important;
	padding: 4px 9px 0;
	width: 150px;
	border-radius: 10px;
}

:not(.hth-featured-comments-double) .wp-block-small-plugins-featured-comment-block .wprm-comment-rating .wprm-rating-stars {
	margin-left: 5px !important;
}

:not(.hth-featured-comments-double) .wp-block-small-plugins-featured-comment-block .wprm-comment-rating .wprm-rating-star-full svg path {
	fill: #fff;
	stroke: #fff;
}

:not(.hth-featured-comments-double) .wp-block-small-plugins-featured-comment-block .wprm-comment-rating .wprm-rating-stars::after {
	content: 'Featured Reader Review';
	text-transform: uppercase;
	display: block;
	font-family: var(--sans-serif);
	font-size: 10px;
	text-align: center;
	font-style: normal;
	color: #fff;
	margin: 4px 0 -14px;
}

 .wp-block-small-plugins-featured-comment-block .wp-block-comment-author-name {
	text-transform: uppercase !important;
	font-family: var(--sans-serif);
	font-weight: 700 !important;
	font-size: 12px;
	display: block;
	text-align: left !important;
}

:not(.hth-featured-comments-double) .wp-block-small-plugins-featured-comment-block .has-text-align-center.wp-block-comment-author-name {
	text-align: left !important;
	font-weight: 700 !important;
	margin-top: -20px;
	font-size: 12px !important;
}

.wp-block-small-plugins-featured-comment-block .wp-block-comment-content {
	font-family: var(--)
}

.wp-block-small-plugins-featured-comment-block p:has(+.wp-block-comment-author-name) {
	display: none;
}

@media (min-width: 767px) {
	:not(.hth-featured-comments-double) .wp-block-small-plugins-featured-comment-block {
		margin: 30px 0;
		margin-right: 80px;
		padding-top: 30px !important;
		padding-right: 90px !important;
	}

	:not(.hth-featured-comments-double) .wp-block-small-plugins-featured-comment-block .wprm-comment-rating {
		left: auto;
		right: -84px !important;
		top: 50% !important;
		transform: translatey(-50%) !important;
		background: var(--global-palette1) !important;
	}
}

.double-featured-comment h2 {
	background-image: url('/wp-content/plugins/handle-the-heat-plugin/images/pink-underline.svg');
	background-repeat: no-repeat;
	background-position: center center;
}

.double-featured-comment h2 span {
	display: inline-block;
	content:'';
	background-image: url(/wp-content/plugins/handle-the-heat-plugin/images/heart.svg);
	background-repeat: no-repeat;
	background-position: center center;
	width: 48px;
	height: 42px;
	margin-bottom: -10px;
}


/* ==========================================================================
   SWIRL OF SCIENCE LINKS
   ========================================================================== */

.entry-content a.swirl-of-science-link,
.archive a.swirl-of-science-link {
	text-decoration: none;
	background-image: url('/wp-content/plugins/handle-the-heat-plugin/images/curved-line.svg');
	background-repeat: repeat-x;
	background-position: 0 calc(100% - -1px);
	background-size: auto 6px;
	padding-bottom: 0.15em;
	-webkit-box-decoration-break: clone;
	box-decoration-break: clone;
}

a.swirl-of-science-link:has(img),
a.swirl-of-science-link:has(h1),
a.swirl-of-science-link:has(h2),
a.swirl-of-science-link:has(h3),
a.swirl-of-science-link:has(.wp-block-kadence-advancedheading),
.entry-title a.swirl-of-science-link {
	background-image: none !important;
	padding-bottom: 0 !important;
}


/* ==========================================================================
   COMMENTS
   ========================================================================== */

#wpdcom {
	margin: 0;
}

#wpd-post-rating {
	display: none;
}

.wpd-form-foot .comment-form-wprm-rating {
    position: absolute;
    top: -44px;
}

@media (max-width: 766px) {
	.wpdiscuz-textarea-foot {
		position: relative;
		min-height: 50px;
	}
	
	.wpd-form-foot .comment-form-wprm-rating {
    top: 6px;
	}
}

.wpd-form-wrap {
	background: var(--global-palette3);
	padding: 30px;
	border-radius: 15px;
	color: #fff;
}

.wpd-form-wrap::before {
	content: "Leave a Comment!";
	display: block;
	font-size: 28px;
	letter-spacing: 1.2px;
	line-height: 1;
}

#wpdcom .wpd-form-head {
	margin-top: 0;
	border: none;
}

.wpd-textarea-wrap {
	min-height: 150px;
}

.wpd-textarea-wrap textarea {
	min-height: 130px !important;
	line-height: 1.2;
	margin-bottom: 5px;
}

.wpd-textarea-wrap textarea::placeholder {
	line-height: 1.3 !important;
}

.wpd-editor-buttons-right .wmu-add {
	display: inline-flex;
	align-items: center;
	gap: 6px;
	padding: 8px 14px;
	border-radius: 6px;
	background: var(--global-palette1);
	color: #3e403f;
	cursor: pointer;
	font-size: 14px;
	margin: 10px -3px 0 0 !important;
}

.wpd-editor-buttons-right .wmu-add:hover {
	background: var(--global-palette2);
	color: var(--global-palette3) !important;
}

.wpd-editor-buttons-right .wmu-add::after {
	content: "UPLOAD AN IMAGE";
	color: #fff;
	font-family: var(--sans-serif);
}

.wpd-editor-buttons-right .wmu-add i {
	display: none;
}

.wpd-form-foot {
	margin-left: 0 !important;
	position: relative;
}

.wpd-form-foot .comment-form-wprm-rating {
	position: absolute;
}

.wpd-form-foot .comment-form-wprm-rating label {
	font-family: var(--sans-serif);
	font-weight: regular;
	font-size: 16px;
	text-transform: uppercase;
}

.wpdiscuz-comment-pagination .page-numbers {
	border: none !important;
}

.wpdiscuz-comment-pagination .page-numbers.current {
	background: #fff !important;
}

@media (max-width: 766px) {
	#wpdcom.wpd-layout-3 .wpd-comment .wpd-comment-left .wpd-avatar {
		top: 0px;
		right: -70px;
	}

	.wpd-comment-footer {
		margin-bottom: 30px !important;
	}

	#wpdcom.wpd-layout-3 .depth-2.wpd-comment .wpd-comment-left .wpd-avatar {
		right: -53px;
	}
}

@media (min-width: 767px) {
	#wpdcom.wpd-layout-3 .wpd-comment .wpd-comment-left .wpd-avatar {
		right: -75px;
	}
}


/* ==========================================================================
   RECIPE CARD EMAIL / FOOTER
   ========================================================================== */

.wprm-recipe-template-hth---meyne .recipe-card-email {
	border: 2px solid var(--global-palette1);
	padding: 20px !important;
	margin-top: 20px;
	text-align: center;
}

.wprm-recipe-template-hth---meyne .recipe-card-email::after {
  content: '';
  width: 35px;
  height: 35px;
  background: var(--global-palette1);
  border-radius: 50%;
  background-image: url('/wp-content/plugins/handle-the-heat-plugin/images/red-email.svg');  
  position: absolute;
	top: -18px;
  left: 50%;
	transform: translate(-50%,0);
}

.wprm-recipe-template-hth---meyne .recipe-card-email h2::after {
	display: none;
}

.wprm-recipe-template-hth---meyne .recipe-card-email .gform_wrapper {
	display: flex;
	row-gap: 10px;
	align-items: center;
	flex-wrap: wrap;
}

.wprm-recipe-template-hth---meyne .recipe-card-email .gform_title {
	margin-bottom: 10px !important;
	position: relative;
}

.wprm-recipe-template-hth---meyne .recipe-card-email .gform_wrapper form {
	display: grid;
	grid-template-columns: 1fr;
}

@media (min-width: 768px) {
	.wprm-recipe-template-hth---meyne .recipe-card-email .gform_wrapper form {
		grid-template-columns: 4fr 1fr;
	}
}

.wprm-recipe-template-hth---meyne .recipe-card-email form {
	position: relative;
}

.wprm-recipe-template-hth---meyne .recipe-card-email .gfield_checkbox label {
	position: absolute;
	font-size: 11px !important;
	font-family: var(--sans-serif);
	letter-spacing: .3px;
}

@media (max-width: 768px) {
	.wprm-recipe-template-hth---meyne .recipe-card-email .gfield_checkbox label {
		bottom: -50px;
	}
	.wprm-recipe-template-hth---meyne .recipe-card-email {
		padding: 20px 20px 64px !important;
	}
	.wprm-recipe-template-hth---meyne .recipe-card-email .gform-footer {
		margin: 0 !important;
	}
	.wprm-recipe-template-hth---meyne .recipe-card-email p {
		line-height: 1.1 !important;
	}
	.wprm-recipe-template-hth---meyne .recipe-card-email .ginput_container_email {
		margin-bottom: -14px !important;
	}
	.wprm-recipe-template-hth---meyne .recipe-card-email .ginput_container_email input::placeholder {
		font-size: 12px !important;
	}
	.wprm-recipe-template-hth---meyne .recipe-card-email form {
		flex: 1;
 		min-width: 0;
	}
}

.wprm-recipe-template-hth---meyne .recipe-card-email .gfield_checkbox .gfield-choice-input {
	display: none !important;
}

.wprm-recipe-template-hth---meyne .recipe-card-email .gform-field-label {
	margin-left: 0 !important;
}

.wprm-recipe-template-hth---meyne .recipe-card-email .gform-theme--foundation .gform_fields {
	row-gap: 10px;
}

.wprm-recipe-template-hth---meyne .recipe-card-email .ginput_container_email input {
	border: 1px solid var(--global-palette3) !important;
	box-shadow: none !important;
	border-radius: 0 !important;
	font-family: var(--sans-serif) !important;
	text-transform: uppercase;
	letter-spacing: .6px !important;
	padding: 6px 10px !important;
}

.wprm-recipe-template-hth---meyne .recipe-card-email .gform-footer {
	margin-top: 0 !important;
	min-width: 52px;
	margin-left: 10px;
	max-height: 30px;
}

.wprm-recipe-template-hth---meyne .recipe-card-email .gform-footer input {
	background: var(--global-palette1) !important;
	font-family: var(--sans-serif) !important;
	text-transform: uppercase !important;
	letter-spacing: 1px !important;
	border-radius: 10px !important;
	padding: 10px 16px; !important;
	min-width: 70px !important;
	font-weight: bold !important;
}

@media (min-width: 768px) {
    .wprm-recipe-template-hth---meyne .recipe-card-email .gform_wrapper form {
        flex: 0 0 36% !important;
    }
}

.wprm-recipe-template-hth---meyne .recipe-card-footer {
	padding: 20px !important;
	line-height: 1.3;
	align-items: center;
}

.wprm-recipe-template-hth---meyne .recipe-card-footer-cta {
	border-right: none !important;
	border-bottom: 1px solid var(--global-palette1);
	margin-bottom: -20px;
}

.wprm-recipe-template-hth---meyne .recipe-card-footer h3 {
	margin-top: 6px !important;
}

@media (max-width: 767px) {
	.recipe-card-footer-share {
		text-align: center;
	}

	.wprm-call-to-action {
		gap: 4px !important;
		padding-top: 0 !important;
	}

	.wprm-call-to-action-icon {
		margin: -6px 0 0 !important;
	}
}

@media (min-width: 768px) {
	.wprm-recipe-template-hth---meyne .recipe-card-email .gform_wrapper .gform_heading {
		flex: 0 0 60%;
	}

	.wprm-recipe-template-hth---meyne .recipe-card-email .gform_wrapper form {
		flex: 0 0 40%;
	}

	.wprm-recipe-template-hth---meyne .recipe-card-footer {
		flex-wrap: nowrap !important;
	}

	.wprm-recipe-template-hth---meyne .recipe-card-footer-cta {
		border-right: 1px solid var(--global-palette1) !important;
		border-bottom: none;
		margin-bottom: 0;
	}

	.wprm-recipe-template-hth---meyne .desktop-flex {
		gap: 6px;
	}
}


/* ==========================================================================
   TOC
   ========================================================================== */

.meyne-toc {
	background: #fff !important;
	padding: 0;
	border-top: 1px solid var(--global-palette3);
	padding-top: 10px;
	margin: 40px 0;
}

.meyne-toc h2 {
	margin: 10px 0 !important;
}

.meyne-toc-toggle-group {
	gap: 0;
}



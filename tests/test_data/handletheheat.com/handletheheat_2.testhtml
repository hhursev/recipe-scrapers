<script id="meyne-kadence-alt-filter-labels-js-after">
(function() {
	function applyMeyneAltLabels(scope) {
		var root = scope || document;
		var labels = window.meyneKadenceAltLabels || {};

		root.querySelectorAll('.kb-radio-check-item[data-value]').forEach(function(item) {
			var termId = item.getAttribute('data-value');
			var label = item.querySelector('label');

			if (!termId || !label || !labels[termId]) {
				return;
			}

			label.textContent = labels[termId];
		});
	}

	document.addEventListener('DOMContentLoaded', function() {
		applyMeyneAltLabels(document);
	});

	document.addEventListener('kb-query-loaded', function(event) {
		applyMeyneAltLabels(document);
	});
})();
//# sourceURL=meyne-kadence-alt-filter-labels-js-after
</script>

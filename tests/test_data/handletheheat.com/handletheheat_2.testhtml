	.mobile-2 .scrollable .kt-inside-inner-col {
		width: 100% !important;
		max-width: none !important;
		min-width: 0 !important;
		flex: 1 1 auto !important;
		flex-basis: auto !important;
	}

	.mobile-2 .scrollable .kb-query-item > .wp-block-kadence-column,
	.mobile-2 .scrollable .kb-query-item > .wp-block-kadence-column > .kt-inside-inner-col {

/* Colored background behind posts with tags */
.category .wp-block-post h3, .archive .wp-block-post h3 {
	padding: 6px 16px 10px !important;
}

.category .wp-block-post.tag-easy .wp-block-group__inner-container,
.category .wp-block-post.tag-1-bowl .wp-block-group__inner-container,
.archive .tag-easy,
.archive .tag-1-bowl {
	background: #F5FBF7;
}

.category .wp-block-post.tag-30-minute .wp-block-group__inner-container,
.category .wp-block-post.tag-1-hour .wp-block-group__inner-container,
.category .wp-block-post.tag-make-ahead .wp-block-group__inner-container,
.archive .tag-30-minute,
.archive .tag-1-hour,
.archive .tag-make-ahead {
	background: #FCF6E5;
}

.category .wp-block-post.tag-popular .wp-block-group__inner-container,
.category .wp-block-post.tag-crowd-pleaser .wp-block-group__inner-container,
.category .wp-block-post.tag-tessas-favorite .wp-block-group__inner-container,
.category .wp-block-post.tag-reader-favorite .wp-block-group__inner-container,
.archive .tag-popular,
.archive .tag-crowd-pleaser,
.archive .tag-tessas-favorite,
.archive .tag-reader-favorite {
	background: #FDF4F0;
}

.archive.tag .entry-content-wrap {
	padding: 0 20px !important;
}

.category-baking-science .archive-more-posts {
	margin-bottom: 30px !important;
}

.category-baking-science .archive-more-posts .wp-block-kadence-advancedbtn {
	display: none;
}

a.primary-tag {
  bottom: 73px;
}

.archive a.primary-tag {
  /bottom: 94px;
}

.archive .wp-block-query li p {
  position: relative;
}

.archive .wp-block-query li p a.primary-tag {
  bottom: 4px;
  position: absolute;
}

.archive .two-column-section  a.primary-tag {
  bottom: 53px;
}

@media screen and (min-width: 767px) {
	.archive a.primary-tag {
   /bottom: 73px;
 }
	
	.archive .two-column-section a.primary-tag {
    bottom: 4px;
  }	
}

a.primary-tag:not(:is(.tag-easy, .tag-1-bowl, .tag-30-minute, .tag-1-hour, .tag-make-ahead, .tag-crowd-pleaser, .tag-popular, .tag-reader-favorite, .tag-tessas-favorite)) {
	display: none;
}

.tag h1.wp-block-term-name {
  display: none;
}

/* Built-out Category v2 */
.archive div h1.has-highlight-underline + p {
  margin-top: 10px;
	text-align: center;
}

.archive main > div:first-of-type {

            .entry-content a.swirl-of-science-link {
                text-decoration: none;
                background-image: url('/wp-content/plugins/handle-the-heat-plugin/images/curved-line.svg');
                background-repeat: repeat-x;
                background-position: 0 calc(100% - 1px);
                background-size: auto 6px;
                padding-bottom: 0.15em;
                -webkit-box-decoration-break: clone;
                box-decoration-break: clone;
            }
    
            .entry-content a.swirl-of-science-link:has(img),
            .entry-content a.swirl-of-science-link:has(h1),
            .entry-content a.swirl-of-science-link:has(h2),

/* ==========================================================================
   KADENCE QUERY FILTER / RECIPE INDEX FILTER
   ========================================================================== */

.filter-accordion-fix .kadence-query-filter {
	height: auto !important;
	min-height: 0 !important;
	align-self: flex-start !important;
	flex: 0 0 auto !important;
}

.filter-accordion-fix .kadence-filter-wrap {
	margin: 10px;
	padding: 0;
	height: auto !important;
	min-height: 0 !important;
}

.filter-accordion-fix .kb-query-label {
	display: flex;
	align-items: center;
	justify-content: space-between;
	width: 100%;
	margin: 0;
	padding: 14px 18px;
	cursor: pointer;
	font-weight: 400;
	font-family: var(--sans-serif);
	text-transform: uppercase;
	font-size: 17px;
	line-height: 1.2;
	position: relative;
	list-style: none;
}

.filter-accordion-fix .kb-query-label::after {
	content: "";
	width: 10px;
	height: 10px;
	border-right: 2px solid currentColor;
	border-bottom: 2px solid currentColor;
	transform: rotate(45deg);
	transition: transform 0.25s ease;
	flex: 0 0 auto;
	margin-left: 16px;
}

.filter-accordion-fix .kadence-filter-wrap.is-open .kb-query-label::after {
	transform: rotate(-135deg);
}

.filter-accordion-fix .checkbox-options {
	display: block !important;
	height: 0;
	overflow: hidden;
	padding: 0 18px;
	transition: height 0.3s ease, padding-top 0.3s ease, padding-bottom 0.3s ease;
}

.filter-accordion-fix .kadence-filter-wrap.is-open .checkbox-options {
	padding-top: 4px;
	padding-bottom: 16px;
}

.filter-accordion-fix .kb-radio-check-item {
	display: flex !important;
	align-items: flex-start;
	width: 100%;
	margin: 0 0 10px !important;
}

.filter-accordion-fix .kb-radio-check-item:last-child {
	margin-bottom: 0 !important;
}

.filter-accordion-fix .kb-radio-check-item label {
	display: block;
	width: 100%;
}

.filter-accordion-fix .checkbox-options,
.filter-accordion-fix .filter-refresh-container {
	display: block !important;
}

.filter-accordion-fix .checkbox-options > .kb-radio-check-item,
.filter-accordion-fix .filter-refresh-container > .kb-radio-check-item {
	display: flex !important;
	width: 100% !important;
	clear: both;
}

/* Critical height fixes for Kadence layout */

.kb-row-layout-id236_9c9334-15 > .kt-row-column-wrap {
	align-items: flex-start !important;
}

.kb-row-layout-id236_9c9334-15 > .kt-row-column-wrap > .wp-block-kadence-column {
	align-self: flex-start !important;
	height: auto !important;
	min-height: 0 !important;
}

.kb-row-layout-id236_9c9334-15 > .kt-row-column-wrap > .wp-block-kadence-column > .kt-inside-inner-col {
	height: auto !important;
	min-height: 0 !important;
	align-self: flex-start !important;
}

.filter-accordion-fix.wp-block-kadence-query,
.filter-accordion-fix {
	height: auto !important;
	min-height: 0 !important;
	align-self: flex-start !important;
}

.filter-accordion-fix > .wp-block-kadence-column,
.filter-accordion-fix > .wp-block-kadence-column > .kt-inside-inner-col {
	height: auto !important;
	min-height: 0 !important;
	align-self: flex-start !important;
}

.filter-accordion-fix .kadence-column236_42f6ac-5c,
.filter-accordion-fix .kadence-column236_42f6ac-5c > .kt-inside-inner-col {
	height: auto !important;
	min-height: 0 !important;
	align-self: flex-start !important;
	flex: 0 0 auto !important;
}

.filter-accordion-fix .wp-block-kadence-query-filter-checkbox,
.filter-accordion-fix .wp-block-kadence-query-filter-reset {
	height: auto !important;
	min-height: 0 !important;
	align-self: flex-start !important;
}

.filter-accordion-fix .kadence-query-filter,
.filter-accordion-fix .kadence-filter-wrap,
.filter-accordion-fix .checkbox-options,
.filter-accordion-fix .filter-refresh-container {
	max-height: none;
	min-height: 0 !important;
	width: 100%;
}

.filter-accordion-fix,
.filter-accordion-fix * {
	box-sizing: border-box;
}

/* Design */
.kb-radio-check-item label {
	text-transform: none !important;
}

.kb-query-basic-style .kadence-filter-wrap input[type=checkbox], .kb-query-basic-style .kadence-filter-wrap input[type=radio] {
	border: 1px solid var(--global-palette3);
	border-radius: 0;
}

.kb-query-basic-style .kadence-filter-wrap input[type="checkbox"]:checked + label, .kb-query-basic-style .kadence-filter-wrap input[type="radio"]:checked + label {
	font-weight: 700;
}

@media (max-width: 767px){

  /* Make the whole row stack cleanly */
  .kb-row-layout-id236_9c9334-15 > .kt-row-column-wrap {
    flex-direction: column;
  }

  /* Force both columns to full width */
  .kb-row-layout-id236_9c9334-15 .wp-block-kadence-column {
    width: 100% !important;
    max-width: 100% !important;
    flex: 0 0 100% !important;
  }

  /* Make sure inner wrappers don’t constrain width */
  .kb-row-layout-id236_9c9334-15 .kt-inside-inner-col {
    width: 100%;
    max-width: 100%;
  }

  /* Specifically ensure filter block spans full width */
  .filter-accordion-fix {
    width: 100% !important;
    max-width: 100% !important;
  }

}


<script id="wp-util-js-after">
(function(){
  function initOne(wrap){
    if(!wrap) return;

    var jsonAttr = wrap.getAttribute('data-mbg-json') || '';
    var d = {};
    try{
      d = JSON.parse(jsonAttr || '{}');
    }catch(e){
      console.error('[MBG] Invalid JSON data', e);
      return;
    }

    var c = wrap.querySelector('canvas.bake-wheel');
    if(!c) return;

    var x = c.getContext('2d');
    var b = wrap.querySelector('.spin-button');
    var t = wrap.querySelectorAll('.category-btn');
    var r = wrap.querySelector('.results');

    if(!x || !b || !r || !t || !t.length) return;

    var s = [];
    var spinning = false;
    var rot = 0;

    var headings = [
      "Time to turn up the heat! Your recipe match:",
      "Consider this your official excuse to bake...",
      "Great choice (or should we say… great spin?)! Your recipe match:",
      "Whisking you luck! You're making:"
    ];

    function pickHeading(){
      return headings[Math.floor(Math.random() * headings.length)];
    }

    function drawMessage(msg){
      x.clearRect(0,0,400,400);
      x.fillStyle = '#FDF4F0';
      x.beginPath();
      x.arc(200,200,175,0,2*Math.PI);
      x.fill();
      x.strokeStyle = '#1f1f1f';
      x.lineWidth = 2;
      x.stroke();

      x.fillStyle = '#1f1f1f';
      x.font = 'normal 18px sans-serif';
      x.textAlign = 'center';
      x.textBaseline = 'middle';
      x.fillText(String(msg).toUpperCase(), 200, 200);
    }

    function draw(segs){
      if(!Array.isArray(segs) || segs.length < 2){
        drawMessage(segs && segs.length === 1 ? 'Add at least 2 segments' : 'No segments set');
        return;
      }

      var cx=200, cy=200, rad=175, ang=(2*Math.PI)/segs.length;
      x.clearRect(0,0,400,400);

      segs.forEach(function(seg,i){
        var st = rot + i*ang;
        var end = st + ang;

        x.beginPath();
        x.moveTo(cx,cy);
        x.arc(cx,cy,rad,st,end);
        x.closePath();
        x.fillStyle = i%2===0 ? '#F8DDD3' : '#FDF4F0';
        x.fill();
        x.strokeStyle = '#1f1f1f';
        x.lineWidth = 2;
        x.stroke();

        var label = (seg && seg.name != null) ? String(seg.name) : '';
        x.save();
        x.translate(cx,cy);
        x.rotate(st + ang/2);
        x.textAlign='center';
        x.fillStyle='#1f1f1f';
        x.font='bold 13px sans-serif';
        var words = label.split(' ').filter(Boolean);
        var lh=16, tr=rad*0.6, th=words.length*lh, sy=-(th/2)+(lh/2);
        (words.length ? words : ['']).forEach(function(w,j){
          x.fillText(w,tr,sy+(j*lh));
        });
        x.restore();
      });

      x.beginPath();
      x.arc(cx,cy,20,0,2*Math.PI);
      x.fillStyle='#1f1f1f';
      x.fill();
    }

    function showResult(){
      if (!Array.isArray(s) || s.length < 1) return;

      var ang = (2 * Math.PI) / s.length;
      var norm = ((rot % (2 * Math.PI)) + (2 * Math.PI)) % (2 * Math.PI);
      var pointerAngle = (3 * Math.PI) / 2;
      var delta = (pointerAngle - norm + (2 * Math.PI)) % (2 * Math.PI);

      var idx = Math.floor(delta / ang) % s.length;
      var seg = s[idx];
      if (!seg) return;

      var headingEl = wrap.querySelector('.result-heading');
      if (headingEl) headingEl.textContent = pickHeading();

      var resultContainer = wrap.querySelector('.recipe-result');
      var buttonWrap = wrap.querySelector('.recipe-button-wrap');

      if (!resultContainer || !buttonWrap) return;

      resultContainer.innerHTML = '';
      buttonWrap.innerHTML = '';

      if (seg.recipes && seg.recipes.length > 0) {
        var rec = seg.recipes[0];

        var a = document.createElement('a');
        a.href = rec.url;
        a.textContent = rec.title;
        resultContainer.appendChild(a);

        var btn = document.createElement('a');
        btn.href = rec.url;
        btn.className = 'recipe-button';
        btn.textContent = "Let's Bake It!";
        buttonWrap.appendChild(btn);
      } else {
        resultContainer.textContent = 'No recipe linked yet.';
      }

      r.classList.add('show');
    }

    function spin(){
      if(spinning) return;
      if(!Array.isArray(s) || s.length < 2) return;

      spinning = true;
      b.disabled = true;
      r.classList.remove('show');

      var spins = 5 + Math.random()*3;
      var extra = Math.random()*360;
      var total = (spins*360 + extra) * (Math.PI/180);
      var dur = 4000;
      var start = Date.now();
      var startRot = rot;

      function anim(){
        var el = Date.now()-start;
        var prog = Math.min(el/dur,1);
        var ease = 1 - Math.pow(1-prog,3);
        rot = startRot + total*ease;
        draw(s);

        if(prog < 1) requestAnimationFrame(anim);
        else{
          spinning = false;
          b.disabled = false;
          showResult();
        }
      }
      anim();
    }

    t.forEach(function(btn){
      btn.addEventListener('click', function(){
        var cat = this.getAttribute('data-category');

        t.forEach(function(bt){ bt.classList.remove('active'); });
        this.classList.add('active');

        if(cat && d && d[cat] && Array.isArray(d[cat])) {
          s = d[cat];
          rot = 0;
          draw(s);

          if (s.length >= 2) {
            b.disabled = false;
            b.textContent = 'Spin the Wheel!';
          } else {
            b.disabled = true;
            b.textContent = 'Add more segments';
          }

          r.classList.remove('show');
        } else {
          s = [];
          rot = 0;
          drawMessage('No segments for this category');
          b.disabled = true;
          b.textContent = 'No segments for this category';
          r.classList.remove('show');
        }
      });
    });

    b.addEventListener('click', spin);
    drawMessage('Select a category');
  }

  function initAll(){
    document.querySelectorAll('.bake-generator[data-mbg-json]').forEach(initOne);
  }

  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', initAll);
  } else {
    initAll();
  }
})();
//# sourceURL=wp-util-js-after
</script>

/* ==========================================================================
   SCROLLABLE / MOBILE SCROLL
   ========================================================================== */

@media (max-width: 768px) {
	.mobile-scroll .kt-tab-title-inactive {
		border: 1px solid #eee;
		border-radius: 10px;
	}
	.scrollable {
		overflow-x: auto;
		white-space: nowrap;
	}

	.scrollable .kb-query-grid-wrap,
	.scrollable .kt-row-column-wrap {
		grid-template-columns: none !important;
		grid-auto-flow: column !important;
		grid-auto-columns: clamp(130px, 28vw, 320px);
		gap: 20px;
	}

	.mobile-2 .scrollable .kb-query-grid-wrap,
	.mobile-2 .scrollable .kt-row-column-wrap {
		grid-auto-columns: clamp(260px, 70vw, 320px) !important;
	}

	.scrollable .kb-query-item,
	.scrollable .kt-inside-inner-col > * {
		box-sizing: border-box;
	}

	.mobile-2 .scrollable .kb-query-item {
		width: 100%;
		min-width: 100%;
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
	}

	.mobile-2 .scrollable .kb-query-grid-wrap,
	.mobile-2 .scrollable .kt-row-column-wrap {

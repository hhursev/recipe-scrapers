<div class="jump-highlight-overlay" aria-hidden="true"></div>

<script>
window.addEventListener('load', function () {
	const targetId = 'email-recipe';
	const body = document.body;
	const overlay = document.querySelector('.jump-highlight-overlay');

	function updateJumpHighlight() {
		if (window.location.hash === '#email-recipe') {
			body.classList.add('jump-highlight-active');
		} else {
			body.classList.remove('jump-highlight-active');
		}
	}

	updateJumpHighlight();
	window.addEventListener('hashchange', updateJumpHighlight);

	if (overlay) {
		overlay.addEventListener('click', function () {
			history.replaceState(null, '', window.location.pathname + window.location.search);
			body.classList.remove('jump-highlight-active');
		});
	}
});
</script>




"https:\/\/handletheheat.com\/#\/schema\/person\/e59a18ff3f9a94134fbab0488119fd90"},"potentialAction":[{"@type":"SearchAction","target":{"@type":"EntryPoint","urlTemplate":"https:\/\/handletheheat.com\/?s={search_term_string}"},"query-input":{"@type":"PropertyValueSpecification","valueRequired":true,"valueName":"search_term_string"}}],"inLanguage":"en-US"},{"@type":["Person","Organization"],"@id":"https:\/\/handletheheat.com\/#\/schema\/person\/e59a18ff3f9a94134fbab0488119fd90","name":"Tessa Arias","image":{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/handletheheat.com\/wp-content\/uploads\/2024\/10\/Tessa-Handle-the-Heat-Cookie-Handbook-Fall-2020-9-web-size.jpg","url":"https:\/\/handletheheat.com\/wp-content\/uploads\/2024\/10\/Tessa-Handle-the-Heat-Cookie-Handbook-Fall-2020-9-web-size.jpg","contentUrl":"https:\/\/handletheheat.com\/wp-content\/uploads\/2024\/10\/Tessa-Handle-the-Heat-Cookie-Handbook-Fall-2020-9-web-size.jpg","width":1000,"height":1250,"caption":"Tessa Arias"},"logo":{"@id":"https:\/\/handletheheat.com\/wp-content\/uploads\/2024\/10\/Tessa-Handle-the-Heat-Cookie-Handbook-Fall-2020-9-web-size.jpg"},"description":"I share trusted baking recipes your friends will LOVE alongside insights into the science of sweets. I'm a professionally trained chef, cookbook author, and cookie queen. I love to write about all things sweet, carb-y, and homemade. I live in Phoenix, Arizona (hence the blog name!)","sameAs":["https:\/\/handletheheat.com\/about-me\/","https:\/\/www.facebook.com\/HandletheHeat","https:\/\/www.instagram.com\/handletheheat","https:\/\/www.pinterest.com\/handleheat\/","https:\/\/x.com\/handleheat","https:\/\/www.youtube.com\/tessaariastv"],"knowsAbout":["Food Blogging","Recipe Development","Cookies","Baking","Recipe Testing"],"jobTitle":"Recipe Blogger","worksFor":"Handle the Heat","url":"https:\/\/handletheheat.com\/author\/tessaaarias1\/"},{"@type":"Question","@id":"https:\/\/handletheheat.com\/no-bake-chocolate-peanut-butter-cheesecake\/#faq-question-1770771555363","position":1,"url":"https:\/\/handletheheat.com\/no-bake-chocolate-peanut-butter-cheesecake\/#faq-question-1770771555363","name":"What is a no bake peanut butter cheesecake?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"A no bake peanut butter cheesecake is a cheesecake made without eggs that sets in the refrigerator instead of the oven. The texture is extra creamy and mousse-like and must be kept col to hold its shape.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https:\/\/handletheheat.com\/no-bake-chocolate-peanut-butter-cheesecake\/#faq-question-1770771588732","position":2,"url":"https:\/\/handletheheat.com\/no-bake-chocolate-peanut-butter-cheesecake\/#faq-question-1770771588732","name":"Why didn't my no bake cheesecake set?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"A no bake cheesecake usually fails to set if the ingredients contain too much liquid because a spreadable, generic, or low-fat cream cheese product was used, or if the cheesecake wasn't chilled thoroughly. For best results, chill overnight in the back of the fridge.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https:\/\/handletheheat.com\/no-bake-chocolate-peanut-butter-cheesecake\/#faq-question-1770771599652","position":3,"url":"https:\/\/handletheheat.com\/no-bake-chocolate-peanut-butter-cheesecake\/#faq-question-1770771599652","name":"Can I freeze no bake cheesecake?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Yes! No bake cheesecake freezes very well. Wrap slices tightly in plastic wrap and store in an airtight container for up to 1 month. Thaw overnight in the refrigerator.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Recipe","name":"No Bake Chocolate Peanut Butter Cheesecake","author":{"@type":"Person","name":"Tessa Arias"},"description":"This No Bake Peanut Butter Cheesecake has a buttery graham cracker crust, ultra creamy filling, and rich chocolate ganache. Easy, smooth, and perfect for summer.","datePublished":"2026-05-07T03:00:00+00:00","image":["https:\/\/handletheheat.com\/wp-content\/uploads\/2026\/05\/no-bake-peanut-butter-cheesecake-SQUARE.jpg","https:\/\/handletheheat.com\/wp-content\/uploads\/2026\/05\/no-bake-peanut-butter-cheesecake-SQUARE-500x500.jpg","https:\/\/handletheheat.com\/wp-content\/uploads\/2026\/05\/no-bake-peanut-butter-cheesecake-SQUARE-500x375.jpg","https:\/\/handletheheat.com\/wp-content\/uploads\/2026\/05\/no-bake-peanut-butter-cheesecake-SQUARE-480x270.jpg"],"recipeYield":["8","8 to 10 servings"],"prepTime":"PT30M","recipeIngredient":["16  whole (227 grams) graham crackers","7 tablespoons (100 grams) unsalted butter,  (melted)","24 ounces (680 grams) cream cheese,  (completed softened to room temperature)","1 1\/2 cups (188 grams) powdered sugar","1 cup (270 grams) creamy peanut butter*","1 teaspoon vanilla extract","1\/2 cup (120 ml) heavy cream,  (at room temperature)","1\/2 cup (120 ml) heavy cream","4 ounces (113 grams) semisweet chocolate"],"recipeInstructions":[{"@type":"HowToSection","name":"Make the crust:","itemListElement":[{"@type":"HowToStep","text":"Place the graham crackers in the bowl of a food processor and pulse until finely ground. Add in the melted butter and pulse until moistened.","name":"Place the graham crackers in the bowl of a food processor and pulse until finely ground. Add in the melted butter and pulse until moistened.","url":"https:\/\/handletheheat.com\/no-bake-chocolate-peanut-butter-cheesecake\/#wprm-recipe-30491-step-0-0"},{"@type":"HowToStep","text":"Thoroughly grease the bottoms and sides of 9-inch springform pan.","name":"Thoroughly grease the bottoms and sides of 9-inch springform pan.","url":"https:\/\/handletheheat.com\/no-bake-chocolate-peanut-butter-cheesecake\/#wprm-recipe-30491-step-0-1"},{"@type":"HowToStep","text":"Pour crust into the prepared pan. Using the bottom of a measuring cup or flat glass, press the crust firmly into the bottom and 1-inch up the sides of the pan. Refrigerate.","name":"Pour crust into the prepared pan. Using the bottom of a measuring cup or flat glass, press the crust firmly into the bottom and 1-inch up the sides of the pan. Refrigerate.","url":"https:\/\/handletheheat.com\/no-bake-chocolate-peanut-butter-cheesecake\/#wprm-recipe-30491-step-0-2"}]},{"@type":"HowToSection","name":"Make the filling:","itemListElement":[{"@type":"HowToStep","text":"In the bowl of an electric mixer fitted with the paddle attachment, beat the cream cheese for one minute or until smooth and creamy, scraping down the sides and bottom of the bowl.","name":"In the bowl of an electric mixer fitted with the paddle attachment, beat the cream cheese for one minute or until smooth and creamy, scraping down the sides and bottom of the bowl.","url":"https:\/\/handletheheat.com\/no-bake-chocolate-peanut-butter-cheesecake\/#wprm-recipe-30491-step-1-0"},{"@type":"HowToStep","text":"Add in the sugar and continue beating until smooth. Add in the peanut butter, vanilla, and heavy cream, beating between each addition and scraping down the sides of the bowl as necessary.","name":"Add in the sugar and continue beating until smooth. Add in the peanut butter, vanilla, and heavy cream, beating between each addition and scraping down the sides of the bowl as necessary.","url":"https:\/\/handletheheat.com\/no-bake-chocolate-peanut-butter-cheesecake\/#wprm-recipe-30491-step-1-1"},{"@type":"HowToStep","text":"Beat the mixture on medium-high speed for about 2 minutes, or until completely smooth and creamy.","name":"Beat the mixture on medium-high speed for about 2 minutes, or until completely smooth and creamy.","url":"https:\/\/handletheheat.com\/no-bake-chocolate-peanut-butter-cheesecake\/#wprm-recipe-30491-step-1-2"},{"@type":"HowToStep","text":"Pour the cheesecake mixture into the springform pan. Refrigerate for at least 6 hours or overnight.","name":"Pour the cheesecake mixture into the springform pan. Refrigerate for at least 6 hours or overnight.","url":"https:\/\/handletheheat.com\/no-bake-chocolate-peanut-butter-cheesecake\/#wprm-recipe-30491-step-1-3"}]},{"@type":"HowToSection","name":"Make the ganache:","itemListElement":[{"@type":"HowToStep","text":"In a small saucepan, bring the heavy cream to a simmer then remove from heat and add chopped chocolate. You can also heat the cream in the microwave. Let stand 1 minute then stir until the chocolate has melted. Stir until smooth.","name":"In a small saucepan, bring the heavy cream to a simmer then remove from heat and add chopped chocolate. You can also heat the cream in the microwave. Let stand 1 minute then stir until the chocolate has melted. Stir until smooth.","url":"https:\/\/handletheheat.com\/no-bake-chocolate-peanut-butter-cheesecake\/#wprm-recipe-30491-step-2-0"},{"@type":"HowToStep","text":"Allow to cool for 5 minutes before pouring over the cheesecake.","name":"Allow to cool for 5 minutes before pouring over the cheesecake.","url":"https:\/\/handletheheat.com\/no-bake-chocolate-peanut-butter-cheesecake\/#wprm-recipe-30491-step-2-1"},{"@type":"HowToStep","text":"Return the cheesecake to the fridge to chill for another hour before serving. If the cheesecake is too loose to slice and serve, freeze for 30 minutes to 1 hour to firm up. Keep refrigerated or frozen.","name":"Return the cheesecake to the fridge to chill for another hour before serving. If the cheesecake is too loose to slice and serve, freeze for 30 minutes to 1 hour to firm up. Keep refrigerated or frozen.","url":"https:\/\/handletheheat.com\/no-bake-chocolate-peanut-butter-cheesecake\/#wprm-recipe-30491-step-2-2"}]}],"aggregateRating":{"@type":"AggregateRating","ratingValue":"5","ratingCount":"25","reviewCount":"7"},"review":[{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"If still helpful to know, basically use half of all ingredients. The area of a 9-inch round pan is 64 square inches; half that size is 32 inches.  The area of a 6-inch round pan is 28 square inches. Assuming both the 9-inch and 6-inch pans are 3 inches high, a half recipe should fit in the 6-inch springform pan.  If it looks like the smaller pan might be too full, I would fill it only to a height that still allows room for the ganache.","author":{"@type":"Person","name":"Becky L Rudella"},"datePublished":"2026-05-11"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"This was so delicious! The cream cheese here is not full fat, so I used mascarpone instead but did not beat it too much, afraid it would turn to butter. I dissolved the sugar in the cream instead. I used a natural peanut butter with chunks which I previously mixed well and it didn’t separate. For the base I used specula's\/spekulatios cookies I have left from Xmas still which matched beautifully. I have passed on your recipe to many friends, and would definitely do it again!","author":{"@type":"Person","name":"Alma"},"datePublished":"2025-06-15"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Best cream cheese frosting ever! Thx","author":{"@type":"Person","name":"Bobby"},"datePublished":"2024-01-16"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Awesome recipe! It was a hit!!!","author":{"@type":"Person","name":"Joy"},"datePublished":"2023-11-11"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"I typically don't like cheesecake or anything with cream cheese, but this was amazing!! The PB layer was soooo good! Thanks a bunch!","author":{"@type":"Person","name":"Annie V"},"datePublished":"2023-06-27"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Great recipe, it DOES taste like a giant peanut butter cup and my coworker asked me to make this for his birthday for the second year in a row. I added some mini Reese's cups as garnish :)","author":{"@type":"Person","name":"Robyn"},"datePublished":"2023-06-18"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Easy to follow recipe . Absolutely amazing","author":{"@type":"Person","name":"Mike G."},"datePublished":"2023-06-02"}],"recipeCategory":["Dessert"],"recipeCuisine":["American"],"keywords":"cheesecake, chocolate ganache, no bake, no bake cheesecake, peanut butter","@id":"https:\/\/handletheheat.com\/no-bake-chocolate-peanut-butter-cheesecake\/#recipe","isPartOf":{"@id":"https:\/\/handletheheat.com\/no-bake-chocolate-peanut-butter-cheesecake\/#article"},"mainEntityOfPage":"https:\/\/handletheheat.com\/no-bake-chocolate-peanut-butter-cheesecake\/"}]}</script>
	<!-- / Yoast SEO Premium plugin. -->



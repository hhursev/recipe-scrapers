<link rel='stylesheet' id='meyne-global-lightbox-css' href='https://handletheheat.com/wp-content/plugins/handle-the-heat-plugin/css/meyne-lightbox.css?ver=1.0' media='all' />
<style id='meyne-global-lightbox-inline-css'>
:root{--meyne-lightbox-icon:url("https://handletheheat.com/wp-content/plugins/handle-the-heat-plugin/images/expand.svg");}
/*# sourceURL=meyne-global-lightbox-inline-css */
</style>
<style id='meyne-bake-generator-inline-css'>
.bake-generator{margin:0 auto;padding-bottom:125px;}
.bake-generator h2{padding:16px;text-align:center;color:#fff;background:#1f1f1f;margin:0 -20px 20px -20px;}
.bake-generator p {text-align: center; margin: -8px 0 12px; font-size: 13px; font-family: var(--sans-serif);}
.bake-generator .category-selection{margin-bottom:30px;}
.bake-generator .category-selection h3{margin-bottom:15px; margin-top: 20px;color:#1f1f1f;font-size:1.1em;font-weight:500;text-align:center;}
.bake-generator .category-buttons{display:flex;flex-wrap:wrap;justify-content:center;gap:10px;}
.bake-generator .category-btn{padding:3px 12px 2px;font-size:12px;background:#fff;color:#1f1f1f;border:1px solid #1f1f1f;border-radius:10px;cursor:pointer;}
.bake-generator .category-btn:hover{border-color:#fdf4f0;background:#fdf4f0;}
.bake-generator .category-btn.active{background:#fdf4f0;color:#1f1f1f;border-color:#fdf4f0;}
.bake-generator .wheel-container{display:flex;flex-direction:column;align-items:center;margin-bottom:30px;}
.bake-generator .wheel-wrapper{position:relative;width:400px;height:400px;margin-bottom:20px;}
.bake-generator .wheel-pointer{position:absolute;top:-15px;left:50%;transform:translateX(-50%);width:30px;height:25px;background:#1f1f1f;clip-path:polygon(50% 100%, 0% 0%, 100% 0%);border-radius:4px;z-index:10;}
.bake-generator canvas{display:block;border:1px solid #1f1f1f;border-radius:50%;}
.bake-generator .spin-button{display:block;padding:10px 20px;font-size:16px;background:#1f1f1f;color:#fff;border:none;border-radius:10px;cursor:pointer;}
.bake-generator .spin-button:hover{background:#F8DDD3;color:#1f1f1f;}
.bake-generator .spin-button:disabled{display: none;}
.bake-generator .results{display:none;padding:25px;margin:30px 40px 0;background:#FDF4F0;border-top:none;border-radius:10px;box-shadow:4px 4px 18px 0 rgba(0,0,0,.13);text-align:center;}
.bake-generator .results.show{display:block;}
.bake-generator .result-heading{color:#1f1f1f;font-family:helvetica,sans-serif;margin:0 0 10px;font-size:14px;text-transform:uppercase;}
.bake-generator .recipe-result a{color:var(--global-palette-highlight);text-decoration:underline;}
.bake-generator .recipe-button-wrap{margin-top:18px;}
.bake-generator .recipe-button{display:inline-flex;justify-content:center;align-items:center;padding:10px 20px;font-size:16px;font-family:helvetica,sans-serif;text-transform:uppercase;background:var(--global-palette1);color:#fff;text-decoration:none;border-radius:10px;}
.bake-generator .recipe-button:hover{background:#F8DDD3;color:#1f1f1f;}

.generator-modal {
	background:url(/wp-content/plugins/meyne-bake-generator/images/recipe-selector-wheel.gif) no-repeat !important;
    background-size: contain !important;
    width: 44px !important;
    height: 50px !important;
    margin-right: 8px !important;
    margin-top: 15px !important;
}

.generator-modal:hover {
	background: url(/wp-content/plugins/meyne-bake-generator/images/recipe-selector-wheel-hover.png) no-repeat !important;
}

.generator-modal button.kb-btn-global-custom.kt-modal-label-show {
	font-size: 0; 
  border: none;	
	border-radius: 50%;
	width: auto;
	height: 36px;
  padding: 20px 10px 0 20px;
}

@media screen and (max-width: 766px) {
	.generator-modal {
		background:url(/wp-content/plugins/meyne-bake-generator/images/WHEEL_RED.gif) no-repeat !important;
		background-size: contain !important;
		width: 32px !important;
		height: 40px !important;
		margin-right: 0 !important;
		margin-top: 6px !important;
	}

	.generator-modal:hover {
		background: url(/wp-content/plugins/meyne-bake-generator/images/recipe-selector-wheel-hover.png) no-repeat !important;
		background-size: contain !important;
	}

	.generator-modal button.kb-btn-global-custom.kt-modal-label-show {
		font-size: 0; 
		border: none;	
		border-radius: 50%;
		width: auto;
		height: 36px;
		padding: 20px 10px 0 20px;
	}
}

.generator-modal .scrollable {
	flex-wrap: nowrap !important;
    justify-content: flex-start !important;
}

@media screen and (max-width: 766px) {
	.bake-generator h2 {
		font-size: 22px;
		margin: 0 !important;
		padding: 6px;
	}
	.bake-generator h2 em {
		font-siz: 34px !important;
	}
}

.kt-modal-container .bake-generator .category-buttons.scrollable {
    overflow-x: auto;
}

@media (max-width:600px){
	.kt-modal-container .bake-generator{padding 0;overflow-x:hidden;}
	.kt-modal-container .bake-generator .wheel-wrapper{width:260px;height:260px;}
	.kt-modal-container .bake-generator .bake-wheel{width:260px;height:260px;}
	.kt-modal-container .bake-generator .wheel-pointer{top:-12px;width:24px;height:20px;}
	.kt-modal-container .bake-generator .category-selection h3{margin-top:16px; padding-left: 15px;}
	.kt-modal-container .bake-generator .results{margin-left:0;margin-right:0; padding: 15px;}
	.kt-modal-container .bake-generator .result-heading{white-space:normal;overflow-wrap:anywhere;}
	.kt-modal-container .bake-generator .category-buttons.scrollable{flex-wrap:nowrap !important;justify-content:flex-start;overflow-x:auto;-webkit-overflow-scrolling:touch;padding-bottom:6px;}

	.generator-modal .kt-modal-container {
		padding: 0;
	}

  .bake-generator .wheel-wrapper{
    width:260px;
    height:260px;
  }

  .bake-generator canvas.bake-wheel{
    width:260px;
    height:260px;
  }

  .bake-generator .wheel-pointer{
    top:-12px;
    width:24px;
    height:20px;
  }

  .bake-generator .category-buttons.scrollable{
    flex-wrap:nowrap;
    justify-content:flex-start;
    overflow-x:auto;
    -webkit-overflow-scrolling:touch;
    padding-bottom:6px;
	margin-left: 10px;
  }

  .bake-generator .results{
    margin-left:10px !important;
    margin-right:10px !important;
	margin-bottom: 50px !important;
  }

  .bake-generator .result-heading{
    white-space:normal;
    text-wrap: wrap !important;
	margin-bottom: 12px;
  }

  .bake-generator .recipe-button{
    justify-content:center;
  }
	
	.bake-generator .recipe-result {
		margin-bottom: 14px !important;
	}
	
	.bake-generator .recipe-result a {
		justify-content: center !important;
		color: var(--global-palette1) !important;
		font-size: 16px;
		font-family: 'georgia';
	}

}
/*# sourceURL=meyne-bake-generator-inline-css */
</style>

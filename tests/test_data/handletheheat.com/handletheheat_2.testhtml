	<style type="text/css">.wprm-recipe-template-hth-snippet {
    font-family: var(--sans-serif);
    font-size: 1em; /*wprm_font_size type=font_size*/
    text-align: left; /*wprm_text_align type=align*/
    margin-top: 0px; /*wprm_margin_top type=size*/
    margin-bottom: 15px; /*wprm_margin_bottom type=size*/
}

.wprm-recipe-template-hth-snippet a {
	text-transform: uppercase;
	font-size: 14px;
}.wprm-recipe-template-hth---meyne {
    margin: 20px auto !important;
    padding: 30px !important;
    border-radius: 15px !important;
    background-color: #fdf4f0; /*wprm_background type=color*/
    font-family: "Times New Roman", Times, serif; /*wprm_main_font_family type=font*/
    font-size: 16px; /*wprm_main_font_size type=font_size*/
    line-height: 1.4em !important; /*wprm_main_line_height type=font_size*/
    color: #1f1f1f; /*wprm_main_text type=color*/
    max-width: 850px; /*wprm_max_width type=size*/
}

.wprm-recipe-template-hth---meyne .recipe-card-header-text {
  flex-grow: 1;
}

.wprm-recipe-template-hth---meyne .recipe-card-header-text .wprm-recipe-rating {
  margin-top: 4px !important;
}

@media (max-width: 767px) {
  .wprm-recipe-template-hth---meyne {
    margin: 20px 0 !important;
    padding: 20px 15px !important;
  }
  .wprm-recipe-template-hth---meyne .wprm-recipe-times-container {
    flex-wrap: nowrap;
  }
}

.wprm-recipe-link {
   font-family: helvetica, sans-serif; 
  font-size: 15px !important;
}

.wprm-recipe-template-hth---meyne p, .wprm-recipe-template-hth---meyne li {
    font-family: "Times New Roman", Times, serif; /*wprm_main_font_family type=font*/
    font-size: 1em !important;
    line-height: 1.4em !important; /*wprm_main_line_height type=font_size*/
}
.wprm-recipe-template-hth---meyne li {
    margin: 0 0 0 32px !important;
    padding: 0 !important;
}
.wprm-recipe-template-hth---meyne .wprm-recipe-instructions-container li {
    margin-bottom: 12px !important;
}
.rtl .wprm-recipe-template-hth---meyne li {
    margin: 0 32px 0 0 !important;
}
.wprm-recipe-template-hth---meyne ol, .wprm-recipe-template-hth---meyne ul {
    margin: 0 !important;
    padding: 0 !important;
}
.wprm-recipe-template-hth---meyne br {
    display: none;
}
.wprm-recipe-template-hth---meyne .wprm-recipe-name,
.wprm-recipe-template-hth---meyne .wprm-recipe-header {
    font-family: Georgia, serif; /*wprm_header_font_family type=font*/
    color: #1f1f1f; /*wprm_header_text type=color*/
    line-height: 1.3em; /*wprm_header_line_height type=font_size*/
}
.wprm-recipe-template-hth---meyne .wprm-recipe-header * {
    font-family: "Times New Roman", Times, serif; /*wprm_main_font_family type=font*/
  margin: 24px 0 15px !important;
}
.wprm-recipe-template-hth---meyne h1,
.wprm-recipe-template-hth---meyne h2,
.wprm-recipe-template-hth---meyne h3,
.wprm-recipe-template-hth---meyne h4,
.wprm-recipe-template-hth---meyne h5,
.wprm-recipe-template-hth---meyne h6 {
  font-weight: normal;
    margin: 0 !important;
    padding: 0 !important;
}
.wprm-recipe-template-hth---meyne .wprm-recipe-name {
  margin-bottom: 10px !important;
}
.wprm-recipe-template-hth---meyne h2 {
    font-size: 28px; /*wprm_h2_size type=font_size*/
}
.wprm-recipe-template-hth---meyne h3 {
    font-size: 30px; /*wprm_h3_size type=font_size*/
    margin: 1em 0 15px !important;
}
.wprm-recipe-template-hth---meyne h4 {
    font-size: 13px; /*wprm_h4_size type=font_size*/
}
.wprm-recipe-template-hth---meyne h5 {
    font-size: 13px; /*wprm_h5_size type=font_size*/
}
.wprm-recipe-template-hth---meyne h6 {
    font-size: 13px; /*wprm_h6_size type=font_size*/
}.wprm-recipe-template-hth---meyne {
	border-style: solid; /*wprm_border_style type=border*/
	border-width: 0px; /*wprm_border_width type=size*/
	border-color: #aaaaaa; /*wprm_border type=color*/
	border-radius: 0px; /*wprm_border_radius type=size*/
	padding: 10px;
}
.wprm-recipe-template-hth---meyne .wprm-recipe-group-name {
  margin: 20px 0 12px !important;
  text-transform: uppercase;
  font-family: var(--sans-serif);
}
.wprm-recipe-template-hth---meyne .wprm-recipe-author-container{
  font-family: var(--sans-serif);
  font-size: 12px;
}

.wprm-recipe-template-hth---meyne .wprm-recipe-time-container,
.wprm-recipe-template-hth---meyne .wprm-recipe-details-unit{
  line-height: 1.4;
  font-size: 13px !important;
}


.wprm-recipe-template-hth---meyne .recipe-card-header {
	display: flex;
    /flex-wrap: wrap;
	gap: 38px;
}

.wprm-recipe-template-hth---meyne .wprm-recipe-author-with-image {
  flex-wrap: nowrap;
}

@media (max-width: 767px) {
  .wprm-recipe-template-hth---meyne .recipe-card-header {
     gap: 13px;
  }
  .wprm-recipe-template-hth---meyne .wprm-recipe-times-container {
    display: flex;
    flex-wrap: nowrap; 
  }
  .wprm-recipe-template-hth---meyne .wprm-recipe-details-container-table.wprm-recipe-table-borders-inside-only .wprm-recipe-block-container-table {
    border-top: none !important;
    border-right: 1px solid var(--global-palette1) !important;
    border-bottom: none !important;
    border-left: none !important;
  }
}

.wprm-recipe-template-hth---meyne .label {
	color: var(--global-palette13);
	margin-bottom: 6px;
  font-size: 12px !important;
}

.wprm-recipe-template-hth---meyne .recipe-card-email {
  background: #fff;
  border-radius: 15px;
  padding: 35px;
  display: flex;
  gap: 35px;
  flex-wrap: wrap;
}

@media (max-width: 767px) {
  .wprm-recipe-template-hth---meyne .recipe-card-email {
    gap: 15px;
    padding: 10px 20px;
  }
}

.wprm-recipe-template-hth---meyne .recipe-card-email h3 {
  position: relative;
  font-size: 22px; 
  line-height: 1.6;
  margin: 0 0 7px 0 !important;
  padding-left: 45px !important;
}

.wprm-recipe-template-hth---meyne .recipe-card-email h2::after {
  content: '';
  width: 35px;
  height: 35px;
  background: var(--global-palette1);
  border-radius: 50%;
  background-image: url('/wp-content/plugins/handle-the-heat-plugin/images/red-email.svg');  
  position: absolute;
  left: 0;
}

.wprm-recipe-template-hth---meyne .wprm-toggle-switch .wprm-toggle-switch-slider {
    background-color: transparent;
    border: 1px solid;
}

.wprm-recipe-template-hth---meyne .wprm-toggle-switch .wprm-toggle-switch-slider:before {
  background-color: #d9383d !important;
}

.wprm-recipe-template-hth---meyne .wprm-toggle-switch-label,
.wprm-recipe-template-hth---meyne .wprm-prevent-sleep-description {
  font-family: helvetica, sans-serif !important;
  font-size: 14px;
}

.wprm-recipe-template-hth---meyne .wprm-recipe-video {
  margin-top: 30px;
}

.wprm-recipe-template-hth---meyne .recipe-card-footer {
  margin-top: 20px;
  background: #fff;
  border-radius: 15px;
  padding: 30px;
  display: flex;
  gap: 30px;
  flex-wrap: wrap;
}

.wprm-recipe-template-hth---meyne .recipe-card-footer-cta {
  flex-grow: 1;
  border-right: 1px solid var(--global-palette1);
  padding-right: 10px;
}

.wprm-recipe-template-hth---meyne .recipe-card-footer-share {
  flex-grow: 1;
  width: 75%;
}

.wprm-recipe-template-hth---meyne .wprm-call-to-action-header,
.wprm-recipe-template-hth---meyne .recipe-card-footer h3 {
  font-size: 22px !important;
  font-weight: normal !important;
}

@media (min-width: 767px) {
  .desktop-flex {
    display: flex;
  }
}

.wprm-recipe-template-hth---meyne .wprm-recipe-servings-container,
.wprm-recipe-template-hth--meyne .wprm-recipe-servings-adjustable-disabled {
    font-family: var(--sans-serif) !important;
  font-size: 12px !important;
}

.wprm-recipe-template-hth---meyne .wprm-recipe-servings-label {
  font-family: var(--sans-serif) !important;
  font-size: 12px !important;
  font-weight: bold;
}

.wprm-recipe-template-hth---meyne .wprm-recipe-servings-adjustable-tooltip {
  font-size: 12px !important;

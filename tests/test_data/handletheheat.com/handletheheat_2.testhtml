        <style type="text/css">
        .meyne-toc {
            background: #f9f9f9;
            border: 1px solid #ffffff;
            border-radius: 4px;
            padding: 20px;
            margin: 20px 0;
            color: #1f1f1f;
        }

        .meyne-toc-header{
            display:flex;
            align-items:flex-start;
            justify-content:space-between;
            gap:12px;
            margin: 0 0 10px 0;
        }

        .meyne-toc-title {
            margin: 0;
        }

        .meyne-toc-list {
            list-style: none;
            margin: 0;
            padding: 0;
        }

        .meyne-toc-list li {
            margin: 5px 0;
            position: relative;
            line-height: 1.6;
        }

        .meyne-toc-list a {
            color: #1f1f1f;
            text-decoration: none;
        }

        .meyne-toc-list a:hover {
            color: #1f1f1f;
            text-decoration: underline;
        }

        .meyne-toc-toggle-group{
            display:flex;
            gap:8px;
            align-items:center;
            flex-shrink: 0;
        }

        .meyne-toc-toggle-btn{
            border:1px solid #000;
            background:transparent;
            color:#000;
            padding:6px 10px;
            font-size:13px;
            line-height:1;
            border-radius:4px;
            cursor:pointer;
        }

        .meyne-toc-toggle-btn.is-active{
            background:#000;
            color:#fff;
        }

        .meyne-toc-toggle-btn:hover{
            opacity: 0.9;
        }

        html {
            scroll-behavior: smooth;
        }
        </style>
        


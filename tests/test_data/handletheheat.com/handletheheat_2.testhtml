<meta name="pinterest-rich-pin" content="false" /><style data-no-optimize="1" data-cfasync="false">
	.adthrive-ad {
		margin-top: 10px;
		margin-bottom: 10px;
		text-align: center;
		overflow-x: visible;
		clear: both;
		line-height: 0;
	}
	/* fix sticky sidebar ads for fixed header */
body:not(.wp-theme-kadence) .adthrive-sidebar.adthrive-stuck {
margin-top: 90px;
z-index: 9!important;
}
body:not(.wp-theme-kadence) .adthrive-sticky-sidebar > div {
top: 90px!important;
}

/* sticky content ads */
body:not(.wp-theme-kadence) .adthrive-device-desktop .adthrive-sticky-container > div,
body:not(.wp-theme-kadence) .adthrive-device-tablet .adthrive-sticky-container > div {
top: 90px!important;
}

/* float recipe ads */
@media (min-width: 768px) {
body.adthrive-device-desktop .adthrive-recipe,
body.adthrive-device-tablet .adthrive-recipe {
	float: right;
	clear: right;
	margin-left: 10px;
}
}

/*recipe print page */
body.wprm-print .adthrive-sidebar, 
body:has(.mv-create-print-view) .adthrive-sidebar {
    right: 10px;
    min-width: 250px;
    max-width: 320px
}
body:has(.mv-create-print-view) .adthrive-sidebar {
    position:fixed;
    top: 275px;
}
body.wprm-print .adthrive-sidebar:not(.adthrive-stuck),
body:has(.mv-create-print-view) .adthrive-sidebar:not(.adthrive-stuck) {
    position: absolute;
    top: 275px;
}
body.wprm-print .wprm-recipe,
body:has(.mv-create-print-view) .mv-create-print-view {
    max-width:800px;
}
@media screen and (max-width: 1299px) {
    body.wprm-print.adthrive-device-desktop .wprm-recipe,
    body:has(.mv-create-print-view) .mv-create-print-view {
        margin-left: 25px;
        max-width: 650px;
    }
}

body:not(.wp-theme-kadence) .adthrive-collapse-mobile-background,
body:not(.wp-theme-kadence) .adthrive-player-position.adthrive-collapse-mobile.adthrive-collapse-top-center.adthrive-player-without-wrapper-text,
body:not(.wp-theme-kadence) .raptive-player-container.adthrive-collapse-mobile.adthrive-collapse-top-center.adthrive-player-without-wrapper-text{
top:56px!important;
}

/* Add a min height for video player in WPRM recipe card */
body.adthrive-device-desktop .wprm-recipe-video,
body.adthrive-device-tablet .wprm-recipe-video {
    min-height: 300px!important;
}
body.adthrive-device-phone .wprm-recipe-video {
    min-height:190px!important;
}

/* fix sticky sidebar ads for fixed header */
body.wp-theme-kadence .adthrive-sidebar.adthrive-stuck {
margin-top: 135px;
z-index: 1 !important;
}
body.wp-theme-kadence .adthrive-sticky-sidebar > div {
top: 135px!important;
z-index: 1 !important;
}

/* sticky content ads */
body.wp-theme-kadence.adthrive-device-desktop .adthrive-sticky-container > div {
top: 125.67px!important;
}

body.wp-theme-kadence.adthrive-device-tablet .adthrive-sticky-container > div {
top: 86.38px!important;
}

body.wp-theme-kadence.adthrive-device-phone .adthrive-sticky-container > div {
top: 181px!important;
}

.adthrive-stuck.adthrive-sticky-outstream {
    z-index: 1139 !important;
}

/* move desktop SO to the left */
.adthrive-sticky-outstream.adthrive-sticky-outstream-desktop {
right: unset!important;
left: 5px!important;
}

@media (min-width: 768px) {
.raptive-player-position .adthrive-video-close {
float: none!important;
left: unset!important;
right: -20px!important;
}
}
</style>

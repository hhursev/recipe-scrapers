ent":{"gramsPerMilliliter":0.49,"gramsPerUnit":2.3,"title":"smoked paprika","urlSegment":"smoked-paprika","aisle":{"name":"Spices & Dried Herbs"}},"groupName":"Picadillo","preLinkTextMetric":"1 tsp ","linkTextMetric":"smoked paprika","unstructuredTextMetric":"1 tsp smoked paprika","preLinkTextImperial":"1 tsp ","linkTextImperial":"smoked paprika","unstructuredTextImperial":"1 tsp smoked paprika","link":"\\/collections\\/paprika-recipes"},{"ingredient":{"gramsPerMilliliter":1.06,"gramsPerUnit":10,"title":"tomato purée","urlSegment":"tomato-puree","aisle":{"name":"Store Cupboard"}},"groupName":"Picadillo","preLinkTextMetric":"2 tbsp of ","linkTextMetric":"tomato purée","unstructuredTextMetric":"2 tbsp of tomato purée","preLinkTextImperial":"2 tbsp of ","linkTextImperial":"tomato purée","unstructuredTextImperial":"2 tbsp of tomato purée","link":"\\/collections\\/tomato-recipes"},{"ingredient":{"gramsPerMilliliter":0.64,"gramsPerUnit":26,"title":"raisins","urlSegment":"raisins","aisle":{"name":"Store Cupboard"}},"groupName":"Picadillo","preLinkTextMetric":"100g of ","linkTextMetric":"raisins","unstructuredTextMetric":"100g of raisins","preLinkTextImperial":"3 1\\/2 oz of ","linkTextImperial":"raisins","unstructuredTextImperial":"3 1\\/2 oz of raisins","link":"\\/collections\\/raisin-recipes"},{"ingredient":{"gramsPerMilliliter":1,"gramsPerUnit":100,"title":"chicken stock","urlSegment":"chicken-stock","aisle":{"name":"Store Cupboard"}},"groupName":"Picadillo","preLinkTextMetric":"300ml of ","linkTextMetric":"chicken stock","unstructuredTextMetric":"300ml of chicken stock","preLinkTextImperial":"2\\/3 pint of ","linkTextImperial":"chicken stock","unstructuredTextImperial":"2\\/3 pint of chicken stock"},{"ingredient":{"gramsPerMilliliter":0,"gramsPerUnit":0,"title":"tomatillo salsa","urlSegment":"tomatillo-salsa","aisle":{"name":"Cooking Sauces"}},"groupName":"Picadillo","preLinkTextMetric":"300g of ","linkTextMetric":"tomatillo salsa","unstructuredTextMetric":"300g of tomatillo salsa","preLinkTextImperial":"10 2\\/3 oz of ","linkTextImperial":"tomatillo salsa","unstructuredTextImperial":"10 2\\/3 oz of tomatillo salsa"},{"ingredient":{"gramsPerMilliliter":1.44,"gramsPerUnit":21,"title":"honey","urlSegment":"honey","aisle":{"name":"Store Cupboard"}},"groupName":"Picadillo","preLinkTextMetric":"1 tsp ","linkTextMetric":"honey","unstructuredTextMetric":"1 tsp honey","preLinkTextImperial":"1 tsp ","linkTextImperial":"honey","unstructuredTextImperial":"1 tsp honey","link":"\\/collections\\/honey-recipes"},{"ingredient":{"gramsPerMilliliter":1,"gramsPerUnit":30,"title":"lime juice","urlSegment":"lime-juice","aisle":{"name":"Fruit & Vegetables"}},"groupName":"Picadillo","preLinkTextMetric":"","postLinkTextMetric":", to taste","linkTextMetric":"lime juice","unstructuredTextMetric":"lime juice, to taste","preLinkTextImperial":"","postLinkTextImperial":", to taste","linkTextImperial":"lime juice","unstructuredTextImperial":"lime juice, to taste","link":"\\/collections\\/lime-recipes"},{"ingredient":{"gramsPerMilliliter":0.17,"gramsPerUnit":6.67,"title":"coriander","urlSegment":"coriander","aisle":{"name":"Salad & Fresh Herbs"}},"groupName":"Picadillo","preLinkTextMetric":"1 handful of ","postLinkTextMetric":", chopped","linkTextMetric":"coriander","unstructuredTextMetric":"1 handful of coriander, chopped","preLinkTextImperial":"1 handful of ","postLinkTextImperial":", chopped","linkTextImperial":"coriander","unstructuredTextImperial":"1 handful of coriander, chopped","link":"\\/collections\\/coriander-recipes"},{"ingredient":{"gramsPerMilliliter":1.02,"gramsPerUnit":0,"title":"salt","urlSegment":"salt","aisle":{"name":"Store Cupboard"}},"groupName":"Picadillo","preLinkTextMetric":"","postLinkTextMetric":", to taste","linkTextMetric":"salt","unstructuredTextMetric":"salt, to taste","preLinkTextImperial":"","postLinkTextImperial":", to taste","linkTextImperial":"salt","unstructuredTextImperial":"salt, to taste","link":"\\/collections\\/salt-recipes"},{"ingredient":{"gramsPerMilliliter":1,"gramsPerUnit":20,"title":"olive oil","urlSegment":"olive-oil","aisle":{"name":"Oils & Vinegars"}},"groupName":"Picadillo","preLinkTextMetric":"","linkTextMetric":"olive oil","unstructuredTextMetric":"olive oil","preLinkTextImperial":"","linkTextImperial":"olive oil","unstructuredTextImperial":"olive oil"}],"steps":[{"nodeId":71876,"text":"To begin, heat a splash of olive oil in a large pan and add the mince. Cook until nicely browned – you may need to do this in batches to avoid overcrowding the mince","stepVideo":{"videoPlayerId":"videoplayer-9d2932a2-3187-460d-83f2-365ceffcfd62","autoplay":true,"controls":false,"isRecipeV2HeadMedia":false,"isHeadMedia":false,"toggleElementsOnPlayAndEnded":false,"isPortraitVideo":false,"muted":false},"image":{"randomStringId":"rx353da0df285e40ec92d0ac5dc4a3915c","useDoubleCrops":true,"hasFocalPoint":false},"ingredients":[]},{"nodeId":71876,"text":"Decant the mince into a bowl and sweat the onions, garlic, carrot and potato in the same pan you used to brown the mince. Add the bay leaf and spices","stepVideo":{"videoPlayerId":"videoplayer-a9aba30d-e2dc-4e23-977c-2e0783433981","autoplay":true,"controls":false,"isRecipeV2HeadMedia":false,"isHeadMedia":false,"toggleElementsOnPlayAndEnded":false,"isPortraitVideo":false,"muted":false},"image":{"randomStringId":"rx9d42faadb241410199c2bb6384824959","useDoubleCrops":true,"hasFocalPoint":false},"ingredients":[]},{"nodeId":71876,"text":"Once the onions are translucent, return the mince to the pan and add the tomato purée, raisins, chicken stock and tomatillo salsa. Turn down the heat and simmer for 30 minutes","stepVideo":{"videoPlayerId":"videoplayer-8adf363b-8c72-4f29-9e69-9652b0441022","autoplay":true,"controls":false,"isRecipeV2HeadMedia":false,"isHeadMedia":false,"toggleElementsOnPlayAndEnded":false,"isPortraitVideo":false,"muted":false},"image":{"randomStringId":"rx991781a6d63048ee949005d60aca3818","useDoubleCrops":true,"hasFocalPoint":false},"ingredients":[]},{"nodeId":71876,"text":"Season with the honey, lime juice and salt. Stir through the coriander and serve with rice or as a taco filling\r\n","stepVideo":{"videoPlayerId":"videoplayer-21b26c39-944e-4bf3-88c0-bc762f11847a","autoplay":true,"controls":false,"isRecipeV2HeadMedia":false,"isHeadMedia":false,"toggleElementsOnPlayAndEnded":false,"isPortraitVideo":false,"muted":false},"image":{"randomStringId":"rxa1325cdcee0d4779a41908f6c14450ef","useDoubleCrops":true,"hasFocalPoint":false},"ingredients":[]}],"activeAbstract":"\u003cp>This simple picadillo recipe has the perfect balance of sweetness and spice. A pleasing tanginess comes from the addition of vibrant tomatillo salsa for a great depth of flavour. Serve in tacos or with rice for a hearty \u003ca href=\"\\/collections\\/mexican-recipes\">Mexican\u003c\\/a>-inspired \u003ca href=\"\\/collections\\/midweek-meal-recipes\">midweek meal\u003c\\/a>.\u003c\\/p>","yieldTextOverride":" 4","tagCourse":{"title":"Main","link":"\\/collections\\/main-course-recipes"},"tagDifficulty":{"title":"easy","link":"\\/collections\\/easy-recipes"},"minutesToCook":"40 minutes","totalTime":40,"isO8601_TimeToCook":"PT40M","aisles":[{"title":"Fresh Meat","unstructuredTextImperial":["500g of beef mince"]},{"title":"Fruit & Vegetables","unstructuredTextImperial":["1 onion, diced","2 garlic cloves, sliced","1 carrot, finely diced","1 potato, finely diced","lime juice, to taste"]},{"title":"Salad & Fresh Herbs","unstructuredTextImperial":["1 bay leaf","1 handful of coriander, chopped"]},{"title":"Spices & Dried Herbs","unstructuredTextImperial":["1 tsp ground cumin","1 tsp ground coriander","1 tsp smoked paprika"]},{"title":"Store Cupboard","unstructuredTextImperial":["2 tbsp of tomato purée","100g of raisins","300ml of chicken stock","1 tsp honey","salt, to taste"]},{"title":"Cooking Sauces","unstructuredTextImperial":["300g of tomatillo salsa"]},{"title":"Oils & Vinegars","unstructuredTextImperial":["olive oil"]}],"equipments":[],"relatedRecipes":[{"chefName":"Robert Thompson","id":53610,"nodeId":53610,"contentItemId":"b2af43b4-aa3a-48b6-8c49-b1a759467ca3","alias":"recipePage","title":"Charred mackerel with tomato ceviche","byLine":"by Robert Thompson","teaserHtml":"                                \u003cp>A simple summer recipe, Robert Thompson pairs beef tomatoes with lime and coriander to make a zingy ceviche, served with charred, barbecued mackerel fillets. A stunning mackerel recipe perfect if you're looking for new barbecue ideas.                                                                                                                                            \u003c\\/p>\n\n\n\n\n\n\n\n","teaser":"A simple summer recipe, Robert Thompson pairs beef tomatoes with lime and coriander to make a zingy ceviche, served with charred, barbecued mackerel fillets. A stunning mackerel recipe perfect if you're looking for new barbecue ideas.","course":"Starter","difficulty":"easy","recipeType":"Chef","cookingTime":20,"url":"https:\\/\\/www.greatbritishchefs.com\\/recipes\\/grilled-mackerel-recipe-tomato-ceviche","link":"https:\\/\\/www.greatbritishchefs.com\\/recipes\\/grilled-mackerel-recipe-tomato-ceviche","image":{"randomStringId":"rxf1f8f1937f83409d839cf37fa6a34aaf","url":"https:\\/\\/media-cdn2.greatbritishchefs.com\\/media\\/mldnje2x\\/img59512.jpg","alt":"Grilled mackerel with tomato ceviche","useDoubleCrops":true,"hasFocalPoint":false},"otherImages":[],"partitionName":"Great British Chefs","publishedDate":"2016-05-03T00:00:00Z","competitionEntered":false,"hasVideo":false,"isTheKitchen":false,"membershipTier":20,"isVisible":true,"isRenderedOnClient":false,"updateDate":"2016-05-03T00:00:00Z","datePublished":"3 May 2016","score":1,"mobileTitle":"Charred mackerel with tomato ceviche"},{"chefName":"Vivek Singh","id":53081,"nodeId":53081,"contentItemId":"9ec22a1f-09c1-48d3-bf91-56e5dbdd43c6","alias":"recipePage","title":"South Indian-style stir fry of leftover turkey with curried yogh
,"contentItemId":"b18bb237-3aa7-49ec-9fdb-393de5a62a68","alias":"collectionPage","title":"Easy","byLine":"Recipe Collection","teaserHtml":"","teaser":"","cookingTime":0,"url":"https:\\/\\/www.greatbritishchefs.com\\/collections\\/easy-recipes","link":"https:\\/\\/www.greatbritishchefs.com\\/collections\\/easy-recipes","image":{"randomStringId":"rxf18d1cf95d89441a86b871409d72d0e7","url":"https:\\/\\/media-cdn2.greatbritishchefs.com\\/media\\/pntnjad0\\/img87708.jpg","alt":"image","useDoubleCrops":true,"hasFocalPoint":false},"otherImages":[],"partitionName":"Great British Chefs","publishedDate":"2015-04-23T00:00:00Z","competitionEntered":false,"hasVideo":false,"isTheKitchen":false,"membershipTier":10,"isVisible":true,"isRenderedOnClient":false,"updateDate":"2015-04-23T00:00:00Z","datePublished":"23 April 2015","score":0.66,"mobileTitle":"Easy"}],"contentBlockItems":[],"titleImageList":[{"randomStringId":"rx9b016da0545940359988cd6fec25c442","url":"https:\\/\\/media-cdn2.greatbritishchefs.com\\/media\\/mwtkdmv3\\/img73858.jpg","alt":"Picadillo","useDoubleCrops":true,"hasFocalPoint":false}],"isTheKitchen":true,"starRatingSettings":1,"averageStarRating":5,"starRatingCount":1,"priorityKeywords":[],"isSingleMpuAdUsed":false,"newsletterSetting":{"newsletterId":"GreatBritishChefsNewsletterId","resolvedNewsletterId":690,"description":"New recipes, chef content, seasonal features and exclusive offers, every Monday and Friday.","label":"Great British Chefs Newsletter","frequency":"Every Monday & Friday","newsletterType":"Default","visibleInManager":true,"disclaimer":"\u003cp>By entering your email address above, you are agreeing to receive marketing emails from Food Publishing Ltd. You’ll receive the latest recipes, food features, special offers, related promotions and lots more. You can find out how we store and process your data in our \u003ca rel=\"noopener\" href=\"\\/policies\" target=\"_blank\" class=\"disclaimer--link\">privacy policy\u003c\\/a> and you can unsubscribe at any time by visiting our \u003ca rel=\"noopener\" href=\"\\/newsletter-management-centre\" target=\"_blank\" class=\"disclaimer--link\">Newsletter Management Centre\u003c\\/a>.\u003c\\/p>","subline":"\u003cp>Join an ever-growing community of food lovers now by subscribing to our newsletter and get all the latest recipes, features and much more to your inbox\u003c\\/p>","headlineSubmit":"Thanks for subscribing","sublineSubmit":"\u003cp>By subscribing you agree to receive our twice-weekly newsletter and occasional offers from selected partners. Unsubscribe or update your preferences anytime.\u003c\\/p>","unableToSubscribeMessage":""},"linkedData":{"@context":"https:\\/\\/schema.org\\/","name":"Picadillo","description":"This simple picadillo recipe has the perfect balance of sweetness and spice. A pleasing tanginess comes from the addition of vibrant tomatillo salsa for a great depth of flavour.","recipeCategory":"Main","totalTime":"PT40M","recipeIngredient":["500g of beef mince","1 onion, diced","2 garlic cloves, sliced","1 carrot, finely diced","1 potato, finely diced","1 bay leaf","1 tsp ground cumin","1 tsp ground coriander","1 tsp smoked paprika","2 tbsp of tomato purée","100g of raisins","300ml of chicken stock","300g of tomatillo salsa","1 tsp honey","lime juice, to taste","1 handful of coriander, chopped","salt, to taste","olive oil"],"recipeInstructions":[{"@type":"HowToStep","text":"To begin, heat a splash of olive oil in a large pan and add the mince. Cook until nicely browned – you may need to do this in batches to avoid overcrowding the mince"},{"@type":"HowToStep","text":"Decant the mince into a bowl and sweat the onions, garlic, carrot and potato in the same pan you used to brown the mince. Add the bay leaf and spices"},{"@type":"HowToStep","text":"Once the onions are translucent, return the mince to the pan and add the tomato purée, raisins, chicken stock and tomatillo salsa. Turn down the heat and simmer for 30 minutes"},{"@type":"HowToStep","text":"Season with the honey, lime juice and salt. Stir through the coriander and serve with rice or as a taco filling\r\n"}],"keywords":"easy","aggregateRating":{"@type":"AggregateRating","ratingValue":"5","ratingCount":"1"},"headline":"Picadillo Recipe","publisher":{"@type":"Organization","name":"Great British Chefs","url":"https:\\/\\/www.greatbritishchefs.com\\/","logo":{"@type":"ImageObject","url":"https:\\/\\/media-cdn2.greatbritishchefs.com\\/media\\/kxtop14a\\/gbc_logo1.svg","width":262,"height":62},"brand":{"@type":"Brand","name":"Great British Chefs"},"sameAs":["https:\\/\\/www.facebook.com\\/greatbritishchefs","https:\\/\\/www.instagram.com\\/gbchefs\\/","https:\\/\\/twitter.com\\/gbchefs","https:\\/\\/www.tiktok.com\\/@gbchefs","https:\\/\\/www.pinterest.co.uk\\/gbchefs\\/","https:\\/\\/www.youtube.com\\/@GreatBritishChefs","https:\\/\\/www.linkedin.com\\/company\\/great-british-chefs\\/"]},"isAccessibleForFree":true,"@type":["Article","Recipe"],"image":["https:\\/\\/media-cdn2.greatbritishchefs.com\\/media\\/mwtkdmv3\\/img73858.whqc_1426x713q80.jpg"],"author":{"@type":"Person","name":"GBC Kitchen ","url":"\\/contributors\\/the-kitchen-with-great-british-chefs"},"datePublished":"2018-01-30T00:00:00Z","dateModified":"2025-04-16T12:11:15.38Z"},"tagsSubset":["minced beef","mexican","cumin","paprika","tomatillo","raisins","coriander"],"teaser":"\u003cp>This simple picadillo recipe has the perfect balance of sweetness and spice. A pleasing tanginess comes from the addition of vibrant tomatillo salsa for a great depth of flavour.\u003c\\/p>","published":"30 January 2018","dateCreated":"0001-01-01T00:00:00","excludeFromAmp":false,"membershipTierWhenPublished":0,"membershipTierAfterSixMonths":0,"membershipTier":20,"byline":"by GBC Kitchen","author":{"fullName":"GBC Kitchen ","image":{"randomStringId":"rxa1cb5ac9b18a450d9b74c878212242b1","url":"https:\\/\\/media-cdn2.greatbritishchefs.com\\/media\\/tjnhf1sg\\/thekitchenlogo_1300x1000.jpg","alt":"Kitchen logo 1300","useDo
","aisle":{"name":"Store Cupboard"}},"groupName":"Cake","preLinkTextMetric":"3 ","linkTextMetric":"Freshlay Farms Golden Yolker® eggs","unstructuredTextMetric":"3 Freshlay Farms Golden Yolker® eggs","preLinkTextImperial":"3 ","linkTextImperial":"Freshlay Farms Golden Yolker® eggs","unstructuredTextImperial":"3 Freshlay Farms Golden Yolker® eggs","link":"https:\\/\\/freshlayeggs.co.uk","activeBrandingId":"2c1ac827-0d56-410a-b13b-15a9cc5008bc"},{"ingredient":{"gramsPerMilliliter":0,"gramsPerUnit":0,"title":"self-raising flour","urlSegment":"self-raising-flour","aisle":{"name":"Store Cupboard"}},"groupName":"Cake","preLinkTextMetric":"225g of ","linkTextMetric":"self-raising flour","unstructuredTextMetric":"225g of self-raising flour","preLinkTextImperial":"8 oz of ","linkTextImperial":"self-raising flour","unstructuredTextImperial":"8 oz of self-raising flour"},{"ingredient":{"gramsPerMilliliter":0.36,"gramsPerUnit":100,"title":"ground almond","urlSegment":"ground-almonds","aisle":{"name":"Store Cupboard"}},"groupName":"Cake","preLinkTextMetric":"50g of ","linkTextMetric":"ground almonds","unstructuredTextMetric":"50g of ground almonds","preLinkTextImperial":"1 3\\/4 oz of ","linkTextImperial":"ground almonds","unstructuredTextImperial":"1 3\\/4 oz of ground almonds","link":"\\/collections\\/almond-recipes"},{"ingredient":{"gramsPerMilliliter":0.76,"gramsPerUnit":7.5,"title":"baking powder","urlSegment":"baking-powder","aisle":{"name":"Bakery"}},"groupName":"Cake","preLinkTextMetric":"1 tsp ","linkTextMetric":"baking powder","unstructuredTextMetric":"1 tsp baking powder","preLinkTextImperial":"1 tsp ","linkTextImperial":"baking powder","unstructuredTextImperial":"1 tsp baking powder"},{"ingredient":{"gramsPerMilliliter":1.03,"gramsPerUnit":100,"title":"whole milk","urlSegment":"whole-milk","aisle":{"name":"Dairy"}},"groupName":"Cake","preLinkTextMetric":"50ml of ","linkTextMetric":"whole milk","unstructuredTextMetric":"50ml of whole milk","preLinkTextImperial":"1 2\\/3 fl oz of ","linkTextImperial":"whole milk","unstructuredTextImperial":"1 2\\/3 fl oz of whole milk"},{"ingredient":{"gramsPerMilliliter":0,"gramsPerUnit":51,"title":"rhubarb","urlSegment":"rhubarb","aisle":{"name":"Fruit & Vegetables"}},"groupName":"Cake","preLinkTextMetric":"200g of ","postLinkTextMetric":", finely chopped","linkTextMetric":"rhubarb","unstructuredTextMetric":"200g of rhubarb, finely chopped","preLinkTextImperial":"7 1\\/16 oz of ","postLinkTextImperial":", finely chopped","linkTextImperial":"rhubarb","unstructuredTextImperial":"7 1\\/16 oz of rhubarb, finely chopped","link":"\\/collections\\/rhubarb-recipes"},{"ingredient":{"gramsPerMilliliter":0.97,"gramsPerUnit":0,"title":"unsalted butter","urlSegment":"unsalted-butter","aisle":{"name":"Dairy"}},"groupName":"Icing","preLinkTextMetric":"10g of ","linkTextMetric":"unsalted butter","unstructuredTextMetric":"10g of unsalted butter","preLinkTextImperial":"1\\/3 oz of ","linkTextImperial":"unsalted butter","unstructuredTextImperial":"1\\/3 oz of unsalted butter","link":"\\/collections\\/butter-recipes"},{"ingredient":{"gramsPerMilliliter":0,"gramsPerUnit":51,"title":"rhubarb","urlSegment":"rhubarb","aisle":{"name":"Fruit & Vegetables"}},"groupName":"Icing","preLinkTextMetric":"40g of ","postLinkTextMetric":", finely sliced","linkTextMetric":"rhubarb","unstructuredTextMetric":"40g of rhubarb, finely sliced","preLinkTextImperial":"1 1\\/2 oz of ","postLinkTextImperial":", finely sliced","linkTextImperial":"rhubarb","unstructuredTextImperial":"1 1\\/2 oz of rhubarb, finely sliced","link":"\\/collections\\/rhubarb-recipes"},{"ingredient":{"gramsPerMilliliter":0.55,"gramsPerUnit":1.5,"title":"icing sugar","urlSegment":"icing-sugar","aisle":{"name":"Store Cupboard"}},"groupName":"Icing","preLinkTextMetric":"130g of ","linkTextMetric":"icing sugar","unstructuredTextMetric":"130g of icing sugar","preLinkTextImperial":"4 2\\/3 oz of ","linkTextImperial":"icing sugar","unstructuredTextImperial":"4 2\\/3 oz of icing sugar"},{"ingredient":{"gramsPerMilliliter":1.1,"gramsPerUnit":0,"title":"double cream","urlSegment":"double-cream","aisle":{"name":"Dairy"}},"groupName":"Icing","preLinkTextMetric":"2 tbsp of ","linkTextMetric":"double cream","unstructuredTextMetric":"2 tbsp of double cream","preLinkTextImperial":"2 tbsp of ","linkTextImperial":"double cream","unstructuredTextImperial":"2 tbsp of double cream"},{"ingredient":{"gramsPerMilliliter":1.1,"gramsPerUnit":0,"title":"double cream","urlSegment":"double-cream","aisle":{"name":"Dairy"}},"groupName":"Cream","preLinkTextMetric":"200ml of ","linkTextMetric":"double cream","unstructuredTextMetric":"200ml of double cream","preLinkTextImperial":"6 3\\/4 fl oz of ","linkTextImperial":"double cream","unstructuredTextImperial":"6 3\\/4 fl oz of double cream"},{"ingredient":{"gramsPerMilliliter":0.81,"gramsPerUnit":100,"title":"caster sugar","urlSegment":"caster-sugar","aisle":{"name":"Store Cupboard"}},"groupName":"Cream","preLinkTextMetric":"100g of ","linkTextMetric":"caster sugar","unstructuredTextMetric":"100g of caster sugar","preLinkTextImperial":"3 1\\/2 oz of ","linkTextImperial":"caster sugar","unstructuredTextImperial":"3 1\\/2 oz of caster sugar"},{"ingredient":{"gramsPerMilliliter":0,"gramsPerUnit":0,"title":"vanilla bean paste","urlSegment":"vanilla-bean-paste","aisle":{"name":"Speciality Ingredients"}},"groupName":"Cream","preLinkTextMetric":"1 tsp ","linkTextMetric":"vanilla bean paste","unstructuredTextMetric":"1 tsp vanilla bean paste","preLinkTextImperial":"1 tsp ","linkTextImperial":"vanilla bean paste","unstructuredTextImperial":"1 tsp vanilla bean paste","link":"\\/collections\\/vanilla-recipes"}],"steps":[{"nodeId":80850,"text":"\u003cp>Pickle the rhubarb a day before. Pack the ribbons into a container. Put the rest of the ingredients in a small saucepan with a pinch of salt and bring to a simmer. Leave to cool to room temperature\u003c\\/p>","stepVideo":{"videoPlayerId":"videoplayer-13d76f3d-a6b9-42c5-b71a-ccb67e7c30b0","autoplay":true,"controls":false,"isRecipeV2HeadMedia":false,"isHeadMedia":false,"toggleElementsOnPlayAndEnded":false,"isPortraitVideo":false,"muted":false},"image":{"randomStringId":"rxf3bbce6845b3499a8a66a7e5b1e5b1ec","useDoubleCrops":true,"hasFocalPoint":false},"ingredients":[{"ingredient":{"gramsPerMilliliter":0.76,"gramsPerUnit":100,"title":"stick of rhubarb","urlSegment":"sticks-of-rhubarb","aisle":{"name":"Fruit & Vegetables"}},"preLinkTextMetric":"2 ","postLinkTextMetric":", finely sliced into ribbons","linkTextMetric":"sticks of rhubarb","unstructuredTextMetric":"2 sticks of rhubarb, finely sliced into ribbons","preLinkTextImperial":"2 ","postLinkTextImperial":", finely sliced into ribbons","linkTextImperial":"sticks of rhubarb","unstructuredTextImperial":"2 sticks of rhubarb, finely sliced into ribbons","link":"\\/collections\\/rhubarb-recipes"},{"ingredient":{"gramsPerMilliliter":0,"gramsPerUnit":0,"title":"apple cider vinegar","urlSegment":"apple-cider-vinegar","aisle":{"name":"Oils & Vinegars"}},"preLinkTextMetric":"200ml of ","linkTextMetric":"apple cider vinegar","unstructuredTextMetric":"200ml of apple cider vinegar","preLinkTextImperial":"6 3\\/4 fl oz of ","linkTextImperial":"apple cider vinegar","unstructuredTextImperial":"6 3\\/4 fl oz of apple cider vinegar"},{"ingredient":{"gramsPerMilliliter":1,"gramsPerUnit":100,"title":"water","urlSegment":"water","aisle":{"name":"Beverages"}},"preLinkTextMetric":"150ml of ","linkTextMetric":"water","unstructuredTextMetric":"150ml of water","preLinkTextImperial":"5 1\\/16 fl oz of ","linkTextImperial":"water","unstructuredTextImperial":"5 1\\/16 fl oz of water"},{"ingredient":{"gramsPerMilliliter":0.81,"gramsPerUnit":100,"title":"caster sugar","urlSegment":"caster-sugar","aisle":{"name":"Store Cupboard"}},"preLinkTextMetric":"150g of ","linkTextMetric":"caster sugar","unstructuredTextMetric":"150g of caster sugar","preLinkTextImperial":"5 1\\/3 oz of ","linkTextImperial":"caster sugar","unstructuredTextImperial":"5 1\\/3 oz of caster sugar"},{"ingredient":{"gramsPerMilliliter":0,"gramsPerUnit":0,"title":"strip of orange peel","urlSegment":"strip-of-orange-peel","aisle":{"name":"Fruit & Vegetables"}},"preLinkTextMetric":"1 ","linkTextMetric":"strip of orange peel","unstructuredTextMetric":"1 strip of orange peel","preLinkTextImperial":"1 ","linkTextImperial":"strip of orange peel","unstructuredTextImperial":"1 strip of orange peel","link":"\\/collections\\/orange-recipes"}]},{"nodeId":80850,"text":"\u003cp>Pour the pickle liquor over the ribbons, then leave to pickle overnight in the fridge\u003c\\/p>","stepVideo":{"videoPlayerId":"videoplayer-fb5f0ee7-05c0-4ee3-8ec8-40b788f5ff35","autoplay":true,"controls":false,"isRecipeV2HeadMedia":false,"isHeadMedia":false,"toggleElementsOnPlayAndEnded":false,"isPortraitVideo":false,"muted":false},"image":{"randomStringId":"rx47efbce9d0714c0f920032cdb9a86787","useDoubleCrops":true,"hasFocalPoint":false},"ingredients":[]},{"nodeId":80850,"text":"\u003cp>The next day, make the cake. Preheat the oven to 180°C\u003c\\/p>","stepVideo":{"videoPlayerId":"videoplayer-9aa2e47b-6f42-4645-ae60-6493830a8e10","autoplay":true,"controls":false,"isRecipeV2HeadMedia":false,"isHeadMedia":false,"toggleElementsOnPlayAndEnded":false,"isPortraitVideo":false,"muted":false},"image":{"randomStringId":"rxcdf2747976804218b64c0df994a3c757","useDoubleCrops":true,"hasFocalPoint":false},"ingredients":[]},{"nodeId":80850,"text":"\u003cp>Beat the sugar and butter together in a large mixing bowl until light and fluffy, then add the eggs one at a time, whisking between each addition. Fold in the flour, ground almonds, baking powder, milk and a pinch of salt, then fold in the rhubarb\u003c\\/p>","stepVideo":{"videoPlayerId":"videoplayer-518de1d5-e429-4a8e-b7c8-c46b3f61af66","autoplay":true,"controls":false,"isRecipeV2HeadMedia":false,"isHeadMedia":false,"toggleElementsOnPlayAndEnded":false,"isPortraitVideo":false,"muted":false},"image":{"randomStringId":"rx6fff37073cdc47879aaaef3309142f5c","useDoubleCrops":true,"hasFocalPoint":false},"ingredients":[{"ingredient":{"gramsPerMilliliter":0.81,"gramsPerUnit":100,"title":"caster sugar","urlSegment":"caster-sugar","aisle":{"name":"Store Cupboard"}},"preLinkTextMetric":"175g of ","linkTextMetric":"caster sugar","unstructuredTextMetric":"175g of caster sugar","preLinkTextImperial":"6 1\\/4 oz of ","linkTextImperial":"caster sugar","unstructuredTextImperial":"6 1\\/4 oz of caster sugar"},{"ingredient":{"gramsPerMilliliter":0.97,"gramsPerUnit":0,"title":"unsalted butter","urlSegment":"unsalted-butter","aisle":{"name":"Dairy"}},"preLinkTextMetric":"175g of ","linkTextMetric":"unsalted butter","unstructuredTextMetric":"175g of unsalted butter","preLinkTextImperial":"6 1\\/4 oz of ","linkTextImperial":"unsalted butter","unstructuredTextImperial":"6 1\\/4 oz of unsalted butter","link":"\\/collections\\/butter-recipes"},{"ingredient":{"gramsPerMilliliter":0,"gramsPerUnit":56,"title":"large egg","urlSegment":"large-egg","aisle":{"name":"Store Cupboard"}},"preLinkTextMetric":"3 ","linkTextMetric":"Freshlay Farms Golden Yolker® eggs","unstructuredTextMetric":"3 Freshlay Farms Golden Yolker® eggs","preLinkTextImperial":"3 ","linkTextImperial":"Freshlay Farms Golden Yolker® eggs","unstructuredTextImperial":"3 Freshlay Farms Golden Yolker® eggs","link":"https:\\/\\/freshlayeggs.co.uk","activeBrandingId":"2c1ac827-0d56-410a-b13b-15a9cc5008bc"},{"ingredient":{"gramsPerMilliliter":0,"gramsPerUnit":0,"title":"self-raising flour","urlSegment":"self-raising-flour","aisle":{"name":"Store Cupboard"}},"preLinkTextMetric":"225g of ","linkTextMetric":"self-raising flour","unstructuredTextMetric":"225g of self-raising flour","preLinkTextImperial":"8 oz of ","linkTextImperial":"self-raising flour","unstructuredTextImperial":"8 oz of self-raising flour"},{"ingredient":{"gramsPerMilliliter":0.36,"gramsPerUnit":100,"title":"ground almond","urlSegment":"ground-almonds","aisle":{"name":"Store Cupboard"}},"preLinkTextMetric":"50g of ","linkTextMetric":"ground almonds","unstructuredTextMetric":"50g of ground almonds","preLinkTextImperial":"1 3\\/4 oz of ","linkTextImperial":"ground almonds","unstructuredTextImperial":"1 3\\/4 oz of ground almonds","link":"\\/collections\\/almond-recipes"},{"ingredient":{"gramsPerMilliliter":0.76,"gramsPerUnit":7.5,"title":"baking powder","urlSegment":"baking-powder","aisle":{"name":"Bakery"}},"preLinkTextMetric":"1 tsp ","linkTextMetric":"baking powder","unstructuredTextMetric":"1 tsp baking powder","preLinkTextImperial":"1 tsp ","linkTextImperial":"baking powder","unstructuredTextImperial":"1 tsp baking powder"},{"ingredient":{"gramsPerMilliliter":1.03,"gramsPerUnit":100,"title":"whole milk","urlSegment":"whole-milk","aisle":{"name":"Dairy"}},"preLinkTextMetric":"50ml of ","linkTextMetric":"whole milk","unstructuredTextMetric":"50ml of whole milk","preLinkTextImperial":"1 2\\/3 fl oz of ","linkTextImperial":"whole milk","unstructuredTextImperial":"1 2\\/3 fl oz of whole milk"},{"ingredient":{"gramsPerMilliliter":0,"gramsPerUnit":51,"title":"rhubarb","urlSegment":"rhubarb","aisle":{"name":"Fruit & Vegetables"}},"preLinkTextMetric":"200g of ","postLinkTextMetric":", finely chopped","linkTextMetric":"rhubarb","unstructuredTextMetric":"200g of rhubarb, finely chopped","preLinkTextImperial":"7 1\\/16 oz of ","postLinkTextImperial":", finely chopped","linkTextImperial":"rhubarb","unstructuredTextImperial":"7 1\\/16 oz of rhubarb, finely chopped","link":"\\/collections\\/rhubarb-recipes"}]},{"nodeId":80850,"text":"\u003cp>Line the loaf tin with baking paper, then pour the batter into it. Bake for 1 hour, or until a skewer inserted in the centre comes out clean\u003c\\/p>","stepVideo":{"videoPlayerId":"videoplayer-3ca25b9b-fe63-46a5-9e2a-0c90b4602655","autoplay":true,"controls":false,"isRecipeV2HeadMedia":false,"isHeadMedia":false,"toggleElementsOnPlayAndEnded":false,"isPortraitVideo":false,"muted":false},"image":{"randomStringId":"rx383a0ddff2a8403684c1dd463e83a43f","useDoubleCrops":true,"hasFocalPoint":false},"ingredients":[]},{"nodeId":80850,"text":"\u003cp>Meanwhile, prepare the icing. Melt the butter in a small saucepan, then add the rhubarb and cook for 5 minutes until soft. Remove from the heat, add the sugar and cream, then use a stick blender to blitz until smooth. Add a pinch of salt then set aside to cool\u003c\\/p>","stepVideo":{"videoPlayerId":"videoplayer-c8a7c9fb-da2a-44d3-a4c6-c066ffbe1c09","autoplay":true,"controls":false,"isRecipeV2HeadMedia":false,"isHeadMedia":false,"toggleElementsOnPlayAndEnded":false,"isPortraitVideo":false,"muted":false},"image":{"randomStringId":"rxdcdb395fa62a4a388a92d7e1c774b378","useDoubleCrops":true,"hasFocalPoint":false},"ingredients":[{"ingredient":{"gramsPerMilliliter":0.97,"gramsPerUnit":0,"title":"unsalted butter","urlSegment":"unsalted-butter","aisle":{"name":"Dairy"}},"preLinkTextMetric":"10g of ","linkTextMetric":"unsalted butter","unstructuredTextMetric":"10g of unsalted butter","preLinkTextImperial":"1\\/3 oz of ","linkTextImperial":"unsalted butter","unstructuredTextImperial":"1\\/3 oz of unsalted butter","link":"\\/collections\\/butter-recipes"},{"ingredient":{"gramsPerMilliliter":0,"gramsPerUnit":51,"title":"rhubarb","urlSegment":"rhubarb","aisle":{"name":"Fruit & Vegetables"}},"preLinkTextMetric":"40g of ","postLinkTextMetric":", finely sliced","linkTextMetric":"rhubarb","unstructuredTextMetric":"40g of rhubarb, finely sliced","preLinkTextImperial":"1 1\\/2 oz of ","postLinkTextImperial":", finely sliced","linkTextImperial":"rhubarb","unstructuredTextImperial":"1 1\\/2 oz of rhubarb, finely sliced","link":"\\/collections\\/rhubarb-recipes"},{"ingredient":{"gramsPerMilliliter":0.55,"gramsPerUnit":1.5,"title":"icing sugar","urlSegment":"icing-sugar","aisle":{"name":"Store Cupboard"}},"preLinkTextMetric":"130g of ","linkTextMetric":"icing sugar","unstructuredTextMetric":"130g of icing sugar","preLinkTextImperial":"4 2\\/3 oz of ","linkTextImperial":"icing sugar","unstructuredTextImperial":"4 2\\/3 oz of icing sugar"},{"ingredient":{"gramsPerMilliliter":1.1,"gramsPerUnit":0,"title":"double cream","urlSegment":"double-cream","aisle":{"name":"Dairy"}},"preLinkTextMetric":"2 tbsp of ","linkTextMetric":"double cream","unstructuredTextMetric":"2 tbsp of double cream","preLinkTextImperial":"2 tbsp of ","linkTextImperial":"double cream","unstructuredTextImperial":"2 tbsp of double cream"}]},{"nodeId":80850,"text":"\u003cp>To make the cream, whisk the cream in a stand mixer or using an electric whisk, adding the sugar in gradually. Once all the sugar is added and the cream forms stiff peaks, fold in the vanilla and set aside\u003c\\/p>","stepVideo":{"videoPlayerId":"videoplayer-130ac026-d0e4-4139-a065-f099cac3b99f","autoplay":true,"controls":false,"isRecipeV2HeadMedia":false,"isHeadMedia":false,"toggleElementsOnPlayAndEnded":false,"isPortraitVideo":false,"muted":false},"image":{"randomStringId":"rx4722a7c18646452499d474c6cd382c94","useDoubleCrops":true,"hasFocalPoint":false},"ingredients":[{"ingredient":{"gramsPerMilliliter":1.1,"gramsPerUnit":0,"title":"double cream","urlSegment":"double-cream","aisle":{"name":"Dairy"}},"preLinkTextMetric":"200ml of ","linkTextMetric":"double cream","unstructuredTextMetric":"200ml of double cream","preLinkTextImperial":"6 3\\/4 fl oz of ","linkTextImperial":"double cream","unstructuredTextImperial":"6 3\\/4 fl oz of double cream"},{"ingredient":{"gramsPerMilliliter":0.81,"gramsPerUnit":100,"title":"caster sugar","urlSegment":"caster-sugar","aisle":{"name":"Store Cupboard"}},"preLinkTextMetric":"100g of ","linkTextMetric":"caster sugar","unstructuredTextMetric":"100g of caster sugar","preLinkTextImperial":"3 1\\/2 oz of ","linkTextImperial":"caster sugar","unstructuredTextImperial":"3 1\\/2 oz of caster sugar"},{"ingredient":{"gramsPerMilliliter":0,"gramsPerUnit":0,"title":"vanilla bean paste","urlSegment":"vanilla-bean-paste","aisle":{"name":"Speciality Ingredients"}},"preLinkTextMetric":"1 tsp ","linkTextMetric":"vanilla bean paste","unstructuredTextMetric":"1 tsp vanilla bean paste","preLinkTextImperial":"1 tsp ","linkTextImperial":"vanilla bean paste","unstructuredTextImperial":"1 tsp vanilla bean paste","link":"\\/collections\\/vanilla-recipes"}]},{"nodeId":80850,"text":"\u003cp>Once the cake has finished baking, leave it to cool in the tin for 15 minutes, before removing it and leaving it on a wire rack to cool completely\u003c\\/p>","stepVideo":{"videoPlayerId":"videoplayer-78e26891-9acc-45e7-8ccd-69f526f91838","autoplay":true,"controls":false,"isRecipeV2HeadMedia":false,"isHeadMedia":false,"toggleElementsOnPlayAndEnded":false,"isPortraitVideo":false,"muted":false},"image":{"randomStringId":"rxe14a03e49db84196ba930784da2a7d66","useDoubleCrops":true,"hasFocalPoint":false},"ingredients":[]},{"nodeId":80850,"text":"\u003cp>Drizzle the rhubarb glaze all over the cake and leave for a little longer to set. Serve slices of the cake with a generous dollop of whipped cream and some pickled rhubarb ribbons to finish\u003c\\/p>","stepVideo":{"videoPlayerId":"videoplayer-4c35373d-79d6-4733-957f-d95350ba25e6","autoplay":true,"controls":false,"isRecipeV2HeadMedia":false,"isHeadMedia":false,"toggleElementsOnPlayAndEnded":false,"isPortraitVideo":false,"muted":false},"image":{"randomStringId":"rx6a8efa00d80e4a2aa817366c7206764a","useDoubleCrops":true,"hasFocalPoint":false},"ingredients":[]}],"activeAbstract":"\u003cp>A simple sponge gets elevated with little nuggets of baked \u003ca target=\"\" data-router-slot=\"disabled\" href=\"\\/collections\\/rhubarb-recipes\" title=\"Rhubarb\">rhubarb\u003c\\/a> and rich ground \u003ca target=\"\" data-router-slot=\"disabled\" href=\"https:\\/\\/www.greatitalianchefs.com\\/collections\\/almond-recipes\" title=\"Almond\">almonds\u003c\\/a> to provide a very tasty base for lashings of bright pink rhubarb icing. Finished with a spoon of vanilla whipped cream and pickled rhubarb ribbons to add a sharp finish, it’s one of our favourite ways to showcase these very special stalks.\u003c\\/p>","yieldTextOverride":"6-8","tagCourse":{"title":"Cake","link":"\\/collections\\/cake-recipes"},"tagDifficulty":{"title":"easy","link":"\\/collections\\/easy-recipes"},"minutesToCook":"1 hour 30 minutes","totalTime":90,"isO8601_TimeToCook":"PT1H30M","isO8601_PrepTime":"","aisles":[{"title":"Fruit & Vegetables","unstructuredTextImperial":["2 sticks of rhubarb, finely sliced into ribbons","1 strip of orange peel","200g of rhubarb, finely chopped","40g of rhubarb, finely sliced"]},{"title":"Oils & Vinegars","unstructuredTextImperial":["200ml of apple cider vinegar"]},{"title":"Beverages","unstructuredTextImperial":["150ml of water"]},{"title":"Store Cupboard","unstructuredTextImperial":["150g of caster sugar","175g of caster sugar","3 Freshlay Farms Golden Yolker® eggs","225g of self-raising flour","50g of ground almonds","130g of icing sugar","100g of caster sugar"]},{"title":"Dairy","unstructuredTextImperial":["175g of unsalted butter","50ml of whole milk","10g of unsalted butter","2 tbsp of double cream","200ml of double cream"]},{"title":"Bakery","unstructuredTextImperial":["1 tsp baking powder"]},{"title":"Speciality Ingredients","unstructuredTextImperial":["1 tsp vanilla bean paste"]}],"equipments":[{"title":"900g loaf tin","qUnits":1}],"relatedRecipes":[{"chefName":"James Mackenzie","id":60998,"nodeId":60998,"contentItemId":"0e1c28a6-88e6-4335-b12d-39a3adb6ca6c","alias":"recipePage","title":"Forced Yorkshire rhubarb trifle with rum soaked parkin crumbs","byLine":"by James Mackenzie","teaserHtml":"","teaser":"","course":"Dessert","difficulty":"easy","recipeType":"Chef","cookingTime":150,"url":"https:\\/\\/www.greatbritishchefs.com\\/recipes\\/rhubarb-parkin-trifle-recipe","link":"https:\\/\\/www.greatbritishchefs.com\\/recipes\\/rhubarb-parkin-trifle-recipe","image":{"randomStringId":"rx40beea6099c74a44addbc718eca560b0","url":"https:\\/\\/media-cdn2.greatbritishchefs.com\\/media\\/dfnoimmi\\
l\",\"de\":\"Waffel\",\"en\":\"waffle\"},\"plural\":\"wafeltjes\",\"translatedPlural\":{\"es\":\"obleas\",\"fr\":\"gaufrettes\",\"it\":\"wafer\",\"nl\":\"wafeltjes\",\"de\":\"Waffeln\",\"en\":\"wafers\"},\"inSeason\":[],\"deleted\":false,\"category\":\"WxG0J3uJyX1LQDcaEFBe\",\"_category\":{\"creationDate\":null,\"lastValidation\":1693311638603,\"lastUpdate\":1693311638603,\"id\":\"WxG0J3uJyX1LQDcaEFBe\",\"deleted\":false,\"name\":\"Koekjes, zoet en snoep\",\"translatedName\":{\"es\":\"Galletas, dulces y golosinas\",\"fr\":\"Biscuits, sucreries et bonbons\",\"it\":\"Biscotti, dolci e caramelle\",\"nl\":\"Koekjes, zoet en snoep\",\"de\":\"Kekse, Süßigkeiten und Bonbons\",\"en\":\"Cookies, sweet and candies\"}},\"productGroup\":\"OtI7GdY0y4JnmbbrFjBM\"}},{\"ingredientId\":\"ofAJ7hIkWTEnonSdCqdt\",\"name\":\"rode bessen\",\"quantity\":0.5,\"quantityUnit\":\"bakje\",\"_quantityUnit\":null,\"pSrc\":null,\"src\":\"1/2 bakje rode bessen\",\"description\":null,\"_ingredient\":{\"creationDate\":1693510702665,\"lastValidation\":1693510702665,\"lastUpdate\":1693510702665,\"id\":\"ofAJ7hIkWTEnonSdCqdt\",\"single\":\"rode bes\",\"translatedSingle\":{\"es\":\"montó bes\",\"fr\":\"baies rouges\",\"it\":\"cavalcato bes\",\"nl\":\"rode bes\",\"de\":\"ritt bes\",\"en\":\"red berries\"},\"plural\":\"rode bessen\",\"translatedPlural\":{\"es\":\"grosella\",\"fr\":\"baies rouges\",\"it\":\"ribes rosso\",\"nl\":\"rode bessen\",\"de\":\"Rote Johannisbeere\",\"en\":\"red berries\"},\"inSeason\":[],\"deleted\":false,\"category\":\"4vIWxaVBM0Lf3b42hjlm\",\"_category\":{\"creationDate\":null,\"lastValidation\":1693311467391,\"lastUpdate\":1693311467391,\"id\":\"4vIWxaVBM0Lf3b42hjlm\",\"deleted\":false,\"name\":\"Fruit\",\"translatedName\":{\"es\":\"Fruta\",\"fr\":\"Fruit\",\"it\":\"Frutta\",\"nl\":\"Fruit\",\"de\":\"Frucht\",\"en\":\"Fruit\"}},\"productGroup\":\"fdvkiM1OY277mzNv2Fkn\"}},{\"ingredientId\":\"ThI1FAiDySPHSUeNR0Ps\",\"name\":\"braambessen\",\"quantity\":0.5,\"quantityUnit\":\"bakje\",\"_quantityUnit\":null,\"pSrc\":null,\"src\":\"1/2 bakje braambessen\",\"description\":null,\"_ingredient\":{\"creationDate\":1693643442921,\"lastValidation\":1693643442921,\"lastUpdate\":1693643442921,\"id\":\"ThI1FAiDySPHSUeNR0Ps\",\"single\":\"braambes\",\"translatedSingle\":{\"es\":\"Mora\",\"fr\":\"mûre\",\"it\":\"mora\",\"nl\":\"Braambes\",\"de\":\"Brombeere\",\"en\":\"blackberry\"},\"plural\":\"braambessen\",\"translatedPlural\":{\"es\":\"moras\",\"fr\":\"mûres\",\"it\":\"more\",\"nl\":\"Braambessen\",\"de\":\"Brombeeren\",\"en\":\"blackberries\"},\"inSeason\":[],\"deleted\":false,\"category\":\"4vIWxaVBM0Lf3b42hjlm\",\"_category\":{\"creationDate\":null,\"lastValidation\":1693311467391,\"lastUpdate\":1693311467391,\"id\":\"4vIWxaVBM0Lf3b42hjlm\",\"deleted\":false,\"name\":\"Fruit\",\"translatedName\":{\"es\":\"Fruta\",\"fr\":\"Fruit\",\"it\":\"Frutta\",\"nl\":\"Fruit\",\"de\":\"Frucht\",\"en\":\"Fruit\"}},\"productGroup\":\"\"}}],\"parts\":[\"Voor de cremeux\",\"Voor de coulis\",\"Voor de bodem\",\"Om af te werken\"],\"tips\":{\"0\":null,\"1\":null,\"2\":null,\"3\":null,\"4\":null,\"5\":null,\"6\":null,\"7\":null,\"8\":null,\"9\":null,\"10\":null},\"instructions\":{\"0\":\"Laat de gelatine weken in koud water.\",\"1\":\"Doe het citroensap, de dooiers, het ei en de bloemsuiker in een steelpan. Klop ze op een zacht vuur luchtig tot de eieren binden.\",\"2\":\"Knijp de geweekte gelatine uit en los ze op in de warme sabayon. Snij de boter in blokjes en roer ze erdoor.\",\"3\":\"Giet het beslag in vormpjes. Laat de cremeux opstijven in de diepvries.\",\"4\":\"Breng het diepvriesfruit met de suiker, de citroenschil en een scheutje Cointreau aan de kook. Laat 5 minuten doorkoken. Haal de citroenschil eruit, zet de mixer erin en zeef alles.\",\"5\":\"Laat de coulis afkoelen.\",\"6\":\"Smelt de witte chocolade au bain-marie. Meng er de gepofte rijst onder.\",\"7\":\"Giet de chocolade uit tussen twee bakmatjes. Rol het gelijkmatig uit tot een dikte van ongeveer 1 cm.\",\"8\":\"Laat de chocolade opstijven in de koelkast.\",\"9\":\"Steek een cirkel gepofte rijst uit, even groot als het vormpje van de cremeux. Haal een bolletje cremeux uit de vorm en laat het ontdooien op de bodem van gepofte rijst.\",\"10\":\"Verkruimel er wat van de wafeltjes over. Werk af met rode bessen, braambessen en coulis.\"},\"instructionsMeta\":{\"0\":{\"part\":1,\"ingredients\":[{\"ingredientId\":\"1GIPOwcWEUmr2eF9w7FU\",\"name\":\"gelatine\",\"quantity\":1,\"quantityUnit\":\"blaadje\",\"_quantityUnit\":null,\"_ingredient\":{\"creationDate\":1693603663713,\"lastValidation\":1693603663713,\"lastUpdate\":1693603663713,\"id\":\"1GIPOwcWEUmr2eF9w7FU\",\"single\":\"gelatine\",\"translatedSingle\":{\"es\":\"gelatina\",\"fr\":\"gélatine\",\"it\":\"gelatina\",\"nl\":\"gelatine\",\"de\":\"Gelatine\",\"en\":\"gelatine\"},\"plural\":\"gelatine\",\"translatedPlural\":{\"es\":\"gelatina\",\"fr\":\"gélatine\",\"it\":\"gelatina\",\"nl\":\"gelatine\",\"de\":\"Gelatine\",\"en\":\"gelatine\"},\"inSeason\":[],\"deleted\":false,\"category\":{\"creationDate\":null,\"lastValidation\":1693311740660,\"lastUpdate\":1693311740660,\"id\":\"YUxzVYw1e7QLSfQRbQTz\",\"deleted\":false,\"name\":\"Kruidenierswaren\",\"translatedName\":{\"es\":\"Comestibles\",\"fr\":\"Épiceries\",\"it\":\"Drogheria\",\"nl\":\"Kruidenierswaren\",\"de\":\"Lebensmittel\",\"en\":\"Groceries\"}},\"_category\":{\"creationDate\":null,\"lastValidation\":1693311740660,\"lastUpdate\":1693311740660,\"id\":\"YUxzVYw1e7QLSfQRbQTz\",\"deleted\":false,\"name\":\"Kruidenierswaren\",\"translatedName\":{\"es\":\"Comestibles\",\"fr\":\"Épiceries\",\"it\":\"Drogheria\",\"nl\":\"Kruidenierswaren\",\"de\":\"Lebensmittel\",\"en\":\"Groceries\"}}}}],\"timers\":[],\"step\":1,\"utensilIds\":[],\"_utensils\":[]},\"1\":{\"part\":1,\"ingredients\":[{\"ingredientId\":\"X0j6SHExFguNWkw77j08\",\"name\":\"citroensap\",\"quantity\":85,\"quantityUnit\":\"ml\",\"_quantityUnit\":\"ml\",\"_ingredient\":{\"creationDate\":1693608534419,\"las
uctions\":{\"askAI\":\"Vraag het aan sous-chef\",\"empty\":\"Dit recept heeft nog geen instructies. Help ons door dit te melden!\",\"emptyAction\":\"Melden\",\"emptyIsAuthor\":\"Jouw recept heeft nog geen instructies. Voeg ze toe in de app!\",\"ingredients\":\"Ingrediënten\",\"scrollDown\":\"Scroll omlaag\",\"scrollUp\":\"Scroll omhoog\",\"showAll\":\"Toon alle instructies\",\"showIngredients\":\"Bekijk ingrediënten\",\"start\":\"Begin met koken\",\"tip\":\"TIP\",\"title\":\"Instructies\",\"watch\":\"Bekijken\"},\"media\":\"Media\",\"playVideo\":\"Video afspelen\",\"reactions\":{\"all\":\"Reacties voor\",\"title\":\"Reacties\"},\"relatedHowTos\":{\"title\":\"Wist je dit al?\"},\"relatedRecipes\":\"Misschien lust je dit ook wel?\",\"report\":\"Zie je een fout in dit recept?\",\"reportSubmissionFailed\":\"Melding indienen mislukt. Probeer het opnieuw.\",\"reportSubmitted\":\"Bedankt voor je feedback!\",\"reviews\":{\"cta\":{\"appDialog\":{\"description\":\"Download onze app en voeg eenvoudig een beoordeling toe. Deel je mening en help andere gebruikers bij het kiezen van hun volgende recept.\",\"title\":\"Laat je beoordeling achter in de app\"},\"description\":\"Geef je mening en help anderen om de perfecte keuze te maken!\",\"dislike\":\"Vind ik niet leuk\",\"like\":\"Vind ik leuk\",\"reviewDialog\":{\"cancel\":\"Annuleer\",\"dislikeDescription\":\"Hoe kunnen we dit recept verbeteren?\",\"likeDescription\":\"Help anderen dit recept ook te proberen door recept tips en foto's te delen.\",\"likeTitle\":\"Leuk dat je dit recept klaarmaakte.\",\"share\":\"Deel je ervaring\"},\"submitted\":\"Bedankt voor je beoordeling!\",\"title\":\"Wat vond je van dit recept?\"},\"review\":\"beoordeling\"},\"settings\":{\"description\":\"Speel video's automatisch af wanneer je kookmodus opent.\",\"name\":\"Autoplay video's\",\"title\":\"Instellingen\"},\"utensils\":{\"title\":\"Benodigdheden\"}},\"recipeCard\":{\"date\":{\"today\":\"Vandaag\",\"yesterday\":\"Gisteren\"},\"draft\":\"Concept\",\"more\":\"Meer\"},\"recipeLists\":{\"newest\":{\"subtitle\":\"Zag je onlangs een recept op tv dat je wil uitproberen? In dit overzicht vind je de meest recente gerechten van Jeroen Meus.\",\"title\":\"Recente gerechten\"},\"recentlyViewed\":{\"title\":\"Onlangs bekeken\"},\"trending\":{\"subtitle\":\"Ontdek de meest populaire gerechten van dit moment! Deze trending recepten zijn perfect om nu uit te proberen en zullen zeker indruk maken in je keuken.\",\"title\":\"Trending recepten\"}},\"recipeNote\":{\"actions\":{\"create\":\"Notitie toevoegen\",\"edit\":\"Notitie bewerken\"},\"add\":{\"button\":\"Voeg toe\",\"placeholder\":\"Wat wil je onthouden over dit recept?\",\"title\":\"Notities voor mezelf\"},\"edit\":{\"button\":\"Opslaan\",\"placeholder\":\"Wat wil je onthouden over dit recept?\",\"title\":\"Notities voor mezelf\"}},\"recipes\":{\"links_for\":\"Gerelateerde links voor {{title}}\",\"search\":{\"cta\":{\"description\":\"Probeer het opnieuw met een andere filter.\",\"title\":\"Geen recepten gevonden\"}},\"title\":\"Recepten\"},\"report\":{\"aiDescription\":\"Klopt er iets niet? Laat het ons weten!\",\"aiTitle\":\"Wat ging er mis?\",\"description\":\"Ziet u iets geks? Laat het ons weten!\",\"placeholder\":\"Beschrijving van het probleem\",\"title\":\"Meld een probleem\",\"typeLabel\":{\"DIET\":\"Foute dieetinformatie\",\"INCORRECT\":\"Onjuiste informatie\",\"INGREDIENTS\":\"Onjuiste ingrediëntenlijst\",\"INSTRUCTIONS\":\"Fouten in de instructies\",\"MISSING_INFO\":\"Informatie ontbreekt\",\"MISUNDERSTOOD\":\"Verkeerde interpretatie door het systeem.\",\"OFFENSIVE\":\"Beledigende inhoud\",\"OTHER\":\"Overig probleem\",\"SPAM\":\"Spam of ongepaste reclame\",\"TAGS\":\"Verkeerde tags\",\"TIMING\":\"Onjuiste tijdsindicatie\",\"UNCLEAR\":\"Antwoord is onduidelijk\",\"URL\":\"Verkeerde of gebroken URL\"}},\"retail\":{\"alternatives\":{\"backToCart\":\"Terug naar winkelmandje\",\"chooseButton\":\"Vervang\",\"currentBadge\":\"Huidig\",\"currentButton\":\"Huidige\",\"emptyState\":\"Geen alternatieven beschikbaar voor dit product\",\"errorMessage\":\"Er ging iets mis bij het laden van alternatieven.\",\"priceDiffMinus\":\"-€{{amount}}\",\"priceDiffPlus\":\"+€{{amount}}\",\"requiredFor\":\"Voor {{value}}\",\"retry\":\"Opnieuw proberen\",\"retryTotal\":\"Opnieuw berekenen\",\"swapAriaLabel\":\"Bekijk alternatieven\",\"swappedBadge\":\"Verwisseld\",\"title\":\"Alternatieven\",\"totalOutdated\":\"Totaal mogelijk niet actueel\"},\"cart\":{\"addIngredientsToCart_one\":\"Voeg {{count}} ingrediënt toe\",\"addIngredientsToCart_other\":\"Voeg {{count}} ingrediënten toe\",\"addProductAriaLabel\":\"Product toevoegen\",\"addProductLabel\":\"Voeg toe\",\"adjustServings\":\"Porties aanpassen\",\"cartEmpty\":\"Winkelmandje is leeg\",\"checkingOut\":\"{{retailer}} openen...\",\"clearCart\":\"Leegmaken\",\"clearCartConfirmation\":\"Weet je zeker dat je het winkelmandje wilt leegmaken?\",\"decreaseQuantityAriaLabel\":\"Verlaag aantal\",\"decreaseServingsAriaLabel\":\"Verlaag porties\",\"editQuantityAriaLabel\":\"Pas aantal aan\",\"errorMessage\":\"Er ging iets mis bij het laden van je winkelmandje. Probeer het opnieuw.\",\"estimatedTotal\":\"Geschatte totaal\",\"estimatedTotalDisclaimer\":\"Eindprijs kan afwijken op ah.be\",\"fabItemCount_one\":\"{{count}} product\",\"fabItemCount_other\":\"{{count}} producten\",\"forRecipeCount_one\":\"voor {{count}} recept\",\"forRecipeCount_other\":\"voor {{count}} recepten\",\"goBack\":\"Terug\",\"goToRetailer\":\"Naar {{retailer}}\",\"increaseQuantityAriaLabel\":\"Verhoog aantal\",\"increaseServingsAriaLabel\":\"Verhoog porties\",\"ingredientCount_one\":\"{{count}} ingrediënt\",\"ingredientCount_other\":\"{{count}} ingrediënten\",\"itemCountShort_one\":\"{{count}} product\",\"itemCountShort_other\":\"{{count}} producten\",\"itemCount_one\":\"({{count}} product)\",\"itemCount_other\":\"({{count}} producten)\",\"listConjunction\":\"en\",\"maxQuantityLabel\":\"Maximale aantal bereikt\",\"notFoundLabel\":\"Niet gevonden\",\"notPurchasableLabel\":\"Geen aankoop nodig\",\"packCount\":\"x{{count}}\",\"pantryChip\":\"VOORRAADKAST\",\"pantryTitle\":\"Ingrediënten die je waarschijnlijk al hebt\",\"perUnit\":\"per stuk\",\"priceDisclaimerText\":\"Prijzen kunnen afwijken afhankelijk van jouw regio.\",\"productRemovedLabel\":\"Product verwijderd\",\"productsTitle\":\"Producten\",\"recipeAttribution\":\"voor {{names}}\",\"recipeInCartShort_one\":\"{{count}} recept\",\"recipeInCartShort_other\":\"{{count}} recepten\",\"recipeInCart_one\":\"{{count}} recept in winkelmandje\",\"recipeInCart_other\":\"{{count}} recepten in winkelmandje\",\"recipesInCart\":\"Recepten in je winkelmandje\",\"recipesSelected_one\":\"{{count}} recept geselecteerd\",\"recipesSelected_other\":\"{{count}} recepten geselecteerd\",\"removeProductAriaLabel\":\"Verwijder product\",\"removeRecipe\":\"Recept verwijderen\",\"removingRecipe\":\"Recept verwijderen...\",\"retry\":\"Opnieuw proberen\",\"scrollToNotFound\":\"Toon\",\"searchAlternative\":\"Zoek alternatief\",\"servings_one\":\"{{count}} portie\",\"servings_other\":\"{{count}} porties\",\"successMessage\":\"Je producten zijn toegevoegd aan je {{retailer}} winkelmandje. Rond je aankoop daar af.\",\"successTitle\":\"Winkelmandje verzonden naar {{retailer}}!\",\"title\":\"Winkelmandje\",\"unmatchedCount_one\":\"{{count}} ingrediënt niet gevonden\",\"unmatchedCount_other\":\"{{count}} ingrediënten niet gevonden\",\"unmatchedHelp\":\"Sommige ingrediënten zijn niet beschikbaar bij {{retailer}}.\",\"unmatchedTitle\":\"Niet gevonden bij {{retailer}}\",\"usedInRecipes\":\"Gebruikt in\"},\"search\":{\"errorMessage\":\"Zoeken mislukt. Probeer opnieuw.\",\"loadMore\":\"Meer laden\",\"noResults\":\"Geen producten gevonden voor '{{query}}'. Probeer een andere zoekterm.\",\"placeholder\":\"Zoek producten...\",\"retry\":\"Opnieuw proberen\"},\"shopButton\":\"Winkel\",\"viewCartButton\":\"Bekijk winkelmandje\"},\"reviewCard\":{\"likes_one\":\"{{count}} like\",\"likes_oth
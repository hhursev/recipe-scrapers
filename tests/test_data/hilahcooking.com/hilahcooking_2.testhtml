	<script type="application/ld+json" class="yoast-schema-graph">{"@context":"https:\/\/schema.org","@graph":[{"@type":"Article","@id":"https:\/\/hilahcooking.com\/strawberry-cupcakes\/#article","isPartOf":{"@id":"https:\/\/hilahcooking.com\/strawberry-cupcakes\/"},"author":{"name":"Hilah","@id":"https:\/\/hilahcooking.com\/#\/schema\/person\/a5581d973088a4e3706e0538ce47130e"},"headline":"Strawberry Cupcakes with Strawberry Frosting","datePublished":"2017-04-05T13:00:38+00:00","wordCount":186,"commentCount":0,"image":{"@id":"https:\/\/hilahcooking.com\/strawberry-cupcakes\/#primaryimage"},"thumbnailUrl":"https:\/\/hilahcooking.com\/wp-content\/uploads\/2017\/04\/fresh-strawberry-cupcakes.jpg","articleSection":["Baking","Dessert Recipes","Episodes","Featured"],"inLanguage":"en-US","potentialAction":[{"@type":"CommentAction","name":"Comment","target":["https:\/\/hilahcooking.com\/strawberry-cupcakes\/#respond"]}]},{"@type":"WebPage","@id":"https:\/\/hilahcooking.com\/strawberry-cupcakes\/","url":"https:\/\/hilahcooking.com\/strawberry-cupcakes\/","name":"Strawberry Cupcakes","isPartOf":{"@id":"https:\/\/hilahcooking.com\/#website"},"primaryImageOfPage":{"@id":"https:\/\/hilahcooking.com\/strawberry-cupcakes\/#primaryimage"},"image":{"@id":"https:\/\/hilahcooking.com\/strawberry-cupcakes\/#primaryimage"},"thumbnailUrl":"https:\/\/hilahcooking.com\/wp-content\/uploads\/2017\/04\/fresh-strawberry-cupcakes.jpg","datePublished":"2017-04-05T13:00:38+00:00","author":{"@id":"https:\/\/hilahcooking.com\/#\/schema\/person\/a5581d973088a4e3706e0538ce47130e"},"description":"Strawberry Cupcakes recipe made with fresh strawberries, sour cream, lemon zest with a fresh strawberry buttercream frosting","inLanguage":"en-US","potentialAction":[{"@type":"ReadAction","target":["https:\/\/hilahcooking.com\/strawberry-cupcakes\/"]}]},{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/hilahcooking.com\/strawberry-cupcakes\/#primaryimage","url":"https:\/\/hilahcooking.com\/wp-content\/uploads\/2017\/04\/fresh-strawberry-cupcakes.jpg","contentUrl":"https:\/\/hilahcooking.com\/wp-content\/uploads\/2017\/04\/fresh-strawberry-cupcakes.jpg","width":750,"height":500,"caption":"strawberry cupcakes"},{"@type":"WebSite","@id":"https:\/\/hilahcooking.com\/#website","url":"https:\/\/hilahcooking.com\/","name":"Hilah Cooking","description":"Delicious recipes your whole family will love","potentialAction":[{"@type":"SearchAction","target":{"@type":"EntryPoint","urlTemplate":"https:\/\/hilahcooking.com\/?s={search_term_string}"},"query-input":{"@type":"PropertyValueSpecification","valueRequired":true,"valueName":"search_term_string"}}],"inLanguage":"en-US"},{"@type":"Person","@id":"https:\/\/hilahcooking.com\/#\/schema\/person\/a5581d973088a4e3706e0538ce47130e","name":"Hilah","image":{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/secure.gravatar.com\/avatar\/eb34204802f6b60d9b4645100fdf64272e641726b1f855836e7b1909a80ade5e?s=96&d=mm&r=r","url":"https:\/\/secure.gravatar.com\/avatar\/eb34204802f6b60d9b4645100fdf64272e641726b1f855836e7b1909a80ade5e?s=96&d=mm&r=r","contentUrl":"https:\/\/secure.gravatar.com\/avatar\/eb34204802f6b60d9b4645100fdf64272e641726b1f855836e7b1909a80ade5e?s=96&d=mm&r=r","caption":"Hilah"},"sameAs":["http:\/\/hilahcooking.com","http:\/\/facebook.com\/hilahcooking","https:\/\/x.com\/hilahcooking"],"url":"https:\/\/hilahcooking.com\/author\/hilah-cooking\/"},{"@context":"https:\/\/schema.org\/","@type":"Recipe","name":"Strawberry Cupcakes with Strawberry Frosting","description":"","author":{"@type":"Person","name":"Hilah Johnson"},"image":{"@type":"ImageObject","url":"https:\/\/hilahcooking.com\/wp-content\/uploads\/2017\/04\/fresh-strawberry-cupcakes.jpg","height":500,"width":750},"url":"https:\/\/hilahcooking.com\/strawberry-cupcakes\/","recipeIngredient":["1 pound fresh strawberries (or frozen, thawed)","1 cup sour cream or Greek yogurt","2 cups all-purpose flour","1 teaspoon baking soda","1\/4 teaspoon salt","1\/2 cup butter (1\/4 pound), at room temperature","1 cup sugar","2 egg whites","1 teaspoon vanilla extract","1\/2 teaspoon lemon zest","Optional: 2-3 drops red food coloring","1\/2 cup (1\/4 pound) butter, at room temperature","3 cups powdered sugar, sifted","Strawberry puree, from above","pinch salt"],"recipeInstructions":[{"@type":"HowToStep","text":"Hull fresh strawberries. Thaw frozen strawberries.","url":"https:\/\/hilahcooking.com\/strawberry-cupcakes\/#instruction-step-1"},{"@type":"HowToStep","text":"Puree berries in a food processor or blender. Add up to 2 tablespoons water if you need to get your blender moving. Strain puree into a small pot to remove seeds. Simmer puree over medium heat, uncovered, 15-20 minutes until reduced by a third and thickened. Stir occasionally, scraping the bottom and sides, to keep from sticking. You should have a little over 1\/2 cup once cooked. Remove 3 tablespoons puree and set aside for icing.","url":"https:\/\/hilahcooking.com\/strawberry-cupcakes\/#instruction-step-2"},{"@type":"HowToStep","text":"Combine this 1\/2 cup puree with sour cream and set aside.","url":"https:\/\/hilahcooking.com\/strawberry-cupcakes\/#instruction-step-3"},{"@type":"HowToStep","text":"Line 12 standard cupcake tins with paper liners. Set oven to 350ºF (176ºC)","url":"https:\/\/hilahcooking.com\/strawberry-cupcakes\/#instruction-step-4"},{"@type":"HowToStep","text":"Sift together the flour, baking soda and salt and set aside.","url":"https:\/\/hilahcooking.com\/strawberry-cupcakes\/#instruction-step-5"},{"@type":"HowToStep","text":"Cream butter and sugar together on medium-high speed for 2 minutes or until light and fluffy.","url":"https:\/\/hilahcooking.com\/strawberry-cupcakes\/#instruction-step-6"},{"@type":"HowToStep","text":"Beat in egg whites one at a time until fully combined.","url":"https:\/\/hilahcooking.com\/strawberry-cupcakes\/#instruction-step-7"},{"@type":"HowToStep","text":"Add vanilla and zest (and optional coloring).","url":"https:\/\/hilahcooking.com\/strawberry-cupcakes\/#instruction-step-8"},{"@type":"HowToStep","text":"Add half the flour mix and combine on low speed until almost fully incorporated.","url":"https:\/\/hilahcooking.com\/strawberry-cupcakes\/#instruction-step-9"},{"@type":"HowToStep","text":"Add half the sour cream+strawberries and mix.","url":"https:\/\/hilahcooking.com\/strawberry-cupcakes\/#instruction-step-10"},{"@type":"HowToStep","text":"Add remaining flour and mix.","url":"https:\/\/hilahcooking.com\/strawberry-cupcakes\/#instruction-step-11"},{"@type":"HowToStep","text":"Add remaining sour cream and mix on low until smooth.","url":"https:\/\/hilahcooking.com\/strawberry-cupcakes\/#instruction-step-12"},{"@type":"HowToStep","text":"Scoop into cupcake tins, filling 3\/4 full. Bake 20 minutes.","url":"https:\/\/hilahcooking.com\/strawberry-cupcakes\/#instruction-step-13"},{"@type":"HowToStep","text":"Cool in pan 5 minutes, then remove cupcakes to cool on racks completely.","url":"https:\/\/hilahcooking.com\/strawberry-cupcakes\/#instruction-step-14"},{"@type":"HowToStep","text":"For the strawberry frosting:","url":"https:\/\/hilahcooking.com\/strawberry-cupcakes\/#instruction-step-15"},{"@type":"HowToStep","text":"Beat the butter with 2 cups powdered sugar on low speed until incorporated, then increase speed to high and mix another minute until fluffy.","url":"https:\/\/hilahcooking.com\/strawberry-cupcakes\/#instruction-step-16"},{"@type":"HowToStep","text":"Add remaining sugar this way.","url":"https:\/\/hilahcooking.com\/strawberry-cupcakes\/#instruction-step-17"},{"@type":"HowToStep","text":"At the end, mix in 2-3 tablespoons fresh strawberry puree from step 1, and a pinch of salt.","url":"https:\/\/hilahcooking.com\/strawberry-cupcakes\/#instruction-step-18"},{"@type":"HowToStep","text":"Ice cooled cupcakes and garnish with fresh strawberry slices or a bit of leftover puree","url":"https:\/\/hilahcooking.com\/strawberry-cupcakes\/#instruction-step-19"}],"recipeYield":"12","nutrition":{"servingSize":"1","calories":"448 calories","fatContent":"19","carbohydrateContent":"66","proteinContent":"3.8","@type":"nutritionInformation"},"datePublished":"2017-04-05","@id":"https:\/\/hilahcooking.com\/strawberry-cupcakes\/#recipe","isPartOf":{"@id":"https:\/\/hilahcooking.com\/strawberry-cupcakes\/#article"},"mainEntityOfPage":"https:\/\/hilahcooking.com\/strawberry-cupcakes\/"}]}</script>

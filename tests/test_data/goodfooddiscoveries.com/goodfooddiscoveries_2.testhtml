			<script type="application/ld+json">{"@context":"https:\/\/schema.org","@type":"Recipe","name":"Crispy Garlic Parmesan Potatoes","image":["https:\/\/goodfooddiscoveries.com\/wp-content\/uploads\/2026\/05\/crispy-garlic-parmesan-potatoes-7.jpg","https:\/\/goodfooddiscoveries.com\/wp-content\/uploads\/2026\/05\/crispy-garlic-parmesan-potatoes-7-500x500.jpg","https:\/\/goodfooddiscoveries.com\/wp-content\/uploads\/2026\/05\/crispy-garlic-parmesan-potatoes-7-500x375.jpg","https:\/\/goodfooddiscoveries.com\/wp-content\/uploads\/2026\/05\/crispy-garlic-parmesan-potatoes-7-480x270.jpg"],"description":"If you're looking for the perfect BBQ side dish, these crispy garlic parmesan potatoes are it. Golden baby potatoes, coated in a garlicky parmesan crust and roasted until deeply crispy. They're ready in 40 minutes and honestly impossible to stop eating.","keywords":"bbq side, crispy, garlic, parmesan, potatoes, crispy potatoes, crispy garlic parmesan potatoes","author":{"@type":"Person","name":"Magda Gonczaruk"},"datePublished":"2026-05-13T13:18:57+00:00","prepTime":"PT10M","cookTime":"PT35M","totalTime":"PT45M","recipeCategory":["Sides","Appetizers"],"recipeCuisine":["Fusion"],"recipeYield":["4","4 servings"],"nutrition":{"@type":"NutritionInformation","calories":"320 cal","carbohydrateContent":"35 g","fatContent":"16 g","fiberContent":"4 g","proteinContent":"11 g","servingSize":"4 servings"},"recipeIngredient":["1.5 lbs (700 g) baby potatoes, halved","3 tbsp olive oil","3 cloves garlic, minced","2 tsp Italian seasonings","Salt u0026 black pepper","100 g (1 cup) finely grated parmesan","Fresh parsley","Greek yogurt herb dip"],"recipeInstructions":[{"@type":"HowToStep","name":"Place potatoes in a pot of salted water. Bring to a boil and then cook for 8 minutes, until just fork-tender.","text":"Place potatoes in a pot of salted water. Bring to a boil and then cook for 8 minutes, until just fork-tender.","url":"https:\/\/goodfooddiscoveries.com\/crispy-garlic-parmesan-potatoes\/#wpzoom-rcb-direction-step-0","image":""},{"@type":"HowToStep","name":"Drain well and let them steam dry for a few minutes.","text":"Drain well and let them steam dry for a few minutes.","url":"https:\/\/goodfooddiscoveries.com\/crispy-garlic-parmesan-potatoes\/#wpzoom-rcb-direction-step-270","image":""},{"@type":"HowToStep","name":"Transfer potatoes to a bowl. Add olive oil, garlic, Italian seasonings, pinch of salt, and pepper. Toss to coat evenly.","text":"Transfer potatoes to a bowl. Add olive oil, garlic, Italian seasonings, pinch of salt, and pepper. Toss to coat evenly.","url":"https:\/\/goodfooddiscoveries.com\/crispy-garlic-parmesan-potatoes\/#wpzoom-rcb-direction-step-124","image":""},{"@type":"HowToStep","name":"Spread grated parmesan on a plate. Roll each potato piece in the parmesan, pressing lightly so it sticks on all sides.","text":"Spread grated parmesan on a plate. Roll each potato piece in the parmesan, pressing lightly so it sticks on all sides.","url":"https:\/\/goodfooddiscoveries.com\/crispy-garlic-parmesan-potatoes\/#wpzoom-rcb-direction-step-170619117932340","image":""},{"@type":"HowToStep","name":"Place potatoes cut-side down on a baking sheet.","text":"Place potatoes cut-side down on a baking sheet.","url":"https:\/\/goodfooddiscoveries.com\/crispy-garlic-parmesan-potatoes\/#wpzoom-rcb-direction-step-1761225875542508","image":""},{"@type":"HowToStep","name":"Roast at 220\u00b0C (425\u00b0F) for 25\u201330 minutes, until golden and crispy.","text":"Roast at 220\u00b0C (425\u00b0F) for 25\u201330 minutes, until golden and crispy.","url":"https:\/\/goodfooddiscoveries.com\/crispy-garlic-parmesan-potatoes\/#wpzoom-rcb-direction-step-1776331442570532","image":""},{"@type":"HowToStep","name":"Transfer to a serving plate, sprinkle with fresh parsley. Serve with a homemade fresh herb dip on the side.","text":"Transfer to a serving plate, sprinkle with fresh parsley. Serve with a homemade fresh herb dip on the side.","url":"https:\/\/goodfooddiscoveries.com\/crispy-garlic-parmesan-potatoes\/#wpzoom-rcb-direction-step-1777466697370484","image":""}],"aggregateRating":{"@type":"AggregateRating","ratingValue":"5.0","ratingCount":1}}</script>

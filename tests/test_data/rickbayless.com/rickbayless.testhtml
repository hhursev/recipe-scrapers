						<h1>
							Mango Guacamole						</h1><!-- .page-header -->
												
					</div>

					<div class="sidebar-right-layout">

						<div class="main-post-content">

							
								<div class="recipe-content">

																			<div class="recipe-hero-image">
											<img class="lazy" id="recipe-image" src="data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20viewBox='0%200%20925%20520'%3E%3C/svg%3E" data-src="https://www.rickbayless.com/wp-content/uploads/2013/12/Screen-Shot-2014-04-01-at-12.12.04-PM-925x520.png" alt="Mango Guacamole">
										</div>
									
									<div class="recipe-serving-share">

										<div class="recipe-servings">
																							<span>Servings:</span> 2&nbsp;1/2 cups 											
										</div>

										<div class="recipe-share">
											<ul>
												<li>

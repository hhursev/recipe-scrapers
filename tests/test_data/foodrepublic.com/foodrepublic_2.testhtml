N","postalCode":"46038","addressCountry":"US"},"contactPoint":{"@type":"ContactPoint","telephone":"(908) 514-8038","contactType":"customer support","email":"staff@foodrepublic.com"},"publishingPrinciples":"https:\/\/www.foodrepublic.com\/policies\/","@id":"https:\/\/www.foodrepublic.com\/","name":"Food Republic","url":"https:\/\/www.foodrepublic.com\/","logo":{"@type":"ImageObject","url":"https:\/\/www.foodrepublic.com\/img\/food-republic-share-image-1280x720-v3.jpg","caption":"Food Republic Logo"},"description":"Food industry news, cooking tips, reviews, rankings, recipes, and interviews from the experts at Food Republic - since 2010.","sameAs":["https:\/\/www.instagram.com\/foodrepublic","https:\/\/subscribe.foodrepublic.com\/newsletter","https:\/\/flipboard.com\/@FoodRepublic","https:\/\/bsky.app\/profile\/foodrepublic.bsky.social"]},"description":"Our classic Italian soup recipe features acini de pepe pasta, a rich, veggie-infused broth, and plenty of beefy meatballs for the perfect savory bite."}</script>
<script type="application/ld+json">{"@context":"https:\/\/schema.org","@type":"Recipe","image":"https:\/\/www.foodrepublic.com\/img\/gallery\/our-best-italian-wedding-soup-recipe\/intro-1775745727.jpg","name":"Our Best Italian Wedding Soup Recipe","author":[{"@type":"Person","name":"Michelle McGlinn","description":"Michelle is a professional food stylist, photographer, and recipe developer who specializes in home-cooked, rustic, and easy meals. She has experience in commercial food styling with national brands and photographs for local businesses and restauranteurs.","url":"https:\/\/www.foodrepublic.com\/author\/michellemcglinn\/","knowsAbout":["Slow-Roasted Meats","30-Minute Meals","Craft Cocktails"],"alumniOf":[{"@type":"Organization","name":"Kent State University"},{"@type":"Organization","name":"Paris American Academy"}],"sameAs":["https:\/\/www.linkedin.com\/in\/michellemcglinn"]},{"@type":"Person","name":"Food Republic Staff","url":"https:\/\/www.foodrepublic.com\/author\/foodrepublicstaff\/"}],"datePublished":"2026-04-18T11:32:00+00:00","description":"Our classic Italian soup recipe features acini de pepe pasta, a rich, veggie-infused broth, and plenty of beefy meatballs for the perfect savory bite.","recipeIngredient":["\u00bc cup milk","\u00bd cup breadcrumbs","1 pound ground beef","1 egg","\u00bc cup grated Parmesan cheese","1 tablespoon minced garlic","\u00bd teaspoon salt","\u00bd teaspoon pepper","2 tablespoons olive oil","1 cup diced yellow onion","\u00bd cup peeled and diced carrot","\u00bd cup diced celery","4 cloves minced garlic","1 tablespoon Italian seasoning blend","1 (3-inch) Parmesan rind","\u00bd teaspoon salt","\u00bd teaspoon pepper","6 cups chicken broth","1 cup acini de pepe pasta","4 cups baby spinach"],"recipeInstructions":[{"@type":"HowToStep","text":"Begin the meatballs: Combine the milk and breadcrumbs in a bowl. Let the milk soak into the breadcrumbs until the crumbs are paste-like, about 5 minutes."},{"@type":"HowToStep","text":"Add all meatball ingredients but the oil to the bowl. Use your hands to mix until just combined, being careful not to overmix."},{"@type":"HowToStep","text":"Roll the mixture into \u00be-inch meatballs, placing them on a parchment-lined baking sheet as you go."},{"@type":"HowToStep","text":"Heat the 2 tablespoons olive oil in a large pot over medium heat."},{"@type":"HowToStep","text":"Add the meatballs and sear on each side until browned, about 5 minutes total, working in batches as needed. (Note: The meatballs will not be cooked all the way through.)"},{"@type":"HowToStep","text":"Remove the meatballs from the pot and add the onion, carrot, and celery. Cook until softened, about 5 minutes. Add the garlic and stir."},{"@type":"HowToStep","text":"Add the Italian seasoning, Parmesan rind, salt, pepper, and chicken broth to the pot. Return the meatballs to the pot."},{"@type":"HowToStep","text":"Bring the soup to a boil, then add the acini de pepe and stir. Boil until meatballs are cooked through and pasta is al dente, about 10 minutes."},{"@type":"HowToStep","text":"Remove the Parmesan rind and add the spinach. Stir until spinach is wilted and bright green, about 1 minute."},{"@type":"HowToStep","text":"Ladle the soup into bowls and serve with extra grated Parmesan."}],"video":{"@type":"VideoObject","name":"Our Best Italian Wedding Soup Recipe","description":"Our classic Italian soup recipe features acini de pepe pasta, a rich, veggie-infused broth, and plenty of beefy meatballs for the perfect savory bite.","thumbnailUrl":["https:\/\/www.foodrepublic.com\/img\/gallery\/our-best-italian-wedding-soup-recipe\/intro-1775745727.jpg"],"contentUrl":"https:\/\/www.youtube.com\/watch?v=ylFqPsrm2l0","uploadDate":"2026-04-10T00:00:00+00:00"},"keywords":"classic, weeknight, easy, comforting, acini de pepe pasta, meatballs","recipeCuisine":"Italian, European, American","recipeCategory":"dinner, lunch, soup","recipeYield":[4,"4 Servings"],"aggregateRating":{"@type":"AggregateRating","ratingValue":"4.5","ratingCount":"2"},"prepTime":"PT20M","cookTime":"PT30M","totalTime":"PT50M","nutrition":{"@type":"NutritionInformation","calories":"755 calories","carbohydrateContent":"52 g carbohydrates","cholesterolContent":"144 mg cholesterol","fatContent":"41 g fat","fiberContent":"4 g fiber","proteinContent":"43 g protein","saturatedFatContent":"14 g saturated fat","servingSize":"648 g","sodiumContent":"1504 mg ","sugarContent":"11 g ","transFatContent":"1 g "}}</script>
                </head>

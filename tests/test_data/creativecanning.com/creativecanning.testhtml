alueName":"search_term_string"}}],"inLanguage":"en-US"},{"@type":["Person","Organization"],"@id":"https:\/\/creativecanning.com\/#\/schema\/person\/2b54fece3f5e993e43626bd156607739","name":"Ashley Adamant","image":{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/creativecanning.com\/wp-content\/uploads\/2024\/09\/Headshot-May-2021-3-768x1024.jpg","url":"https:\/\/creativecanning.com\/wp-content\/uploads\/2024\/09\/Headshot-May-2021-3-768x1024.jpg","contentUrl":"https:\/\/creativecanning.com\/wp-content\/uploads\/2024\/09\/Headshot-May-2021-3-768x1024.jpg","width":768,"height":1024,"caption":"Ashley Adamant"},"logo":{"@id":"https:\/\/creativecanning.com\/wp-content\/uploads\/2024\/09\/Headshot-May-2021-3-768x1024.jpg"},"description":"I'm an off-grid homesteader in rural Vermont and the author of Creative Canning, a blog that helps people create their own safe home canning recipes.","sameAs":["https:\/\/creativecanning.com\/about\/","https:\/\/www.facebook.com\/CreativeCanning\/","https:\/\/www.instagram.com\/creativecanning\/","https:\/\/www.pinterest.com\/CreativeCanning\/","https:\/\/www.youtube.com\/@AshleyAdamant"]},{"@type":"Recipe","name":"Zucchini Relish Recipe for Canning","author":{"@type":"Person","name":"Ashley Adamant"},"description":"Zucchini relish is a flavorful topping for summer grilling, and the perfect way to use up extra zucchini from the garden.","datePublished":"2021-08-16T17:13:58+00:00","image":["https:\/\/creativecanning.com\/wp-content\/uploads\/2021\/02\/Zucchini-Relish-61.jpg","https:\/\/creativecanning.com\/wp-content\/uploads\/2021\/02\/Zucchini-Relish-61-500x500.jpg","https:\/\/creativecanning.com\/wp-content\/uploads\/2021\/02\/Zucchini-Relish-61-500x375.jpg","https:\/\/creativecanning.com\/wp-content\/uploads\/2021\/02\/Zucchini-Relish-61-480x270.jpg"],"recipeYield":["32","32 servings, Makes 4 Half Pint (8 oz) Jars"],"prepTime":"PT130M","cookTime":"PT10M","totalTime":"PT150M","recipeIngredient":["2 cups zucchini (diced (about 3 medium))","1 cup onion (diced (about 1 medium))","1 cup red bell pepper (diced (about 2 small or 1 large))","2 Tbsp salt (pickling and canning salt, or kosher salt)","1 3\/4 cup sugar","2 tsp celery seed (whole)","1 tsp mustard seed (whole)","1 cup cider vinegar (5% acidity)","Pickle Crisp Granules (optional, helps veggies stay firm after canning)"],"recipeInstructions":[{"@type":"HowToStep","text":"Wash vegetables.","name":"Wash vegetables.","url":"https:\/\/creativecanning.com\/zucchini-relish\/#wprm-recipe-22305-step-0-0"},{"@type":"HowToStep","text":"Remove stem and blossom ends from zucchini and dice into 1\/4 to 1\/2 inch pieces.  Measure 2 cups.","name":"Remove stem and blossom ends from zucchini and dice into 1\/4 to 1\/2 inch pieces.  Measure 2 cups.","url":"https:\/\/creativecanning.com\/zucchini-relish\/#wprm-recipe-22305-step-0-1"},{"@type":"HowToStep","text":"Peel and dice onion.  Measure 1 cup.","name":"Peel and dice onion.  Measure 1 cup.","url":"https:\/\/creativecanning.com\/zucchini-relish\/#wprm-recipe-22305-step-0-2"},{"@type":"HowToStep","text":"Stem and seed peppers, then dice.  Measure 1 cup.","name":"Stem and seed peppers, then dice.  Measure 1 cup.","url":"https:\/\/creativecanning.com\/zucchini-relish\/#wprm-recipe-22305-step-0-3"},{"@type":"HowToStep","text":"Important, don&#x27;t skip this step! Combine diced vegetables in a large bowl and sprinkle salt over the top.  Stir gently to distribute the salt, then add water until vegetables are completely submerged.  Allow the vegetables to soak in the saltwater for 2 hours, then drain completely.","name":"Important, don&#x27;t skip this step! Combine diced vegetables in a large bowl and sprinkle salt over the top.  Stir gently to distribute the salt, then add water until vegetables are completely submerged.  Allow the vegetables to soak in the saltwater for 2 hours, then drain completely.","url":"https:\/\/creativecanning.com\/zucchini-relish\/#wprm-recipe-22305-step-0-4"},{"@type":"HowToStep","text":"Prepare a water bath canner (optional, only if canning).","name":"Prepare a water bath canner (optional, only if canning).","url":"https:\/\/creativecanning.com\/zucchini-relish\/#wprm-recipe-22305-step-0-5"},{"@type":"HowToStep","text":"In a separate saucepan or stockpot, bring vinegar, sugar, and spices to a gentle simmer (180 degrees F).  Do not add salt, the salt is only used to soak veggies before draining.","name":"In a separate saucepan or stockpot, bring vinegar, sugar, and spices to a gentle simmer (180 degrees F).  Do not add salt, the salt is only used to soak veggies before draining.","url":"https:\/\/creativecanning.com\/zucchini-relish\/#wprm-recipe-22305-step-0-6"},{"@type":"HowToStep","text":"Add drained vegetables to the simmering vinegar\/spices and gently simmer for 10 minutes.","name":"Add drained vegetables to the simmering vinegar\/spices and gently simmer for 10 minutes.","url":"https:\/\/creativecanning.com\/zucchini-relish\/#wprm-recipe-22305-step-0-7"},{"@type":"HowToStep","text":"Pack hot relish into prepared half-pint or pint jars, leaving 1\/2 inch headspace.","name":"Pack hot relish into prepared half-pint or pint jars, leaving 1\/2 inch headspace.","url":"https:\/\/creativecanning.com\/zucchini-relish\/#wprm-recipe-22305-step-0-8"},{"@type":"HowToStep","text":"If not canning, just seal jars and allow them to cool on the counter before storing in the refrigerator.","name":"If not canning, just seal jars and allow them to cool on the counter before storing in the refrigerator.","url":"https:\/\/creativecanning.com\/zucchini-relish\/#wprm-recipe-22305-step-0-9"},{"@type":"HowToStep","text":"If canning, de-bubble jars, wipe rims, and adjust headspace to ensure 1\/2 inch.  Seal with 2 part canning lids.","name":"If canning, de-bubble jars, wipe rims, and adjust headspace to ensure 1\/2 inch.  Seal with 2 part canning lids.","url":"https:\/\/creativecanning.com\/zucchini-relish\/#wprm-recipe-22305-step-0-10"},{"@type":"HowToStep","text":"Process in a water bath canner for 10 minutes, then turn off the heat.  Allow the jars to sit in the canner for another 5 minutes to cool slightly, then remove the jars to cool on a towel on the counter.","name":"Process in a water bath canner for 10 minutes, then turn off the heat.  Allow the jars to sit in the canner for another 5 minutes to cool slightly, then remove the jars to cool on a towel on the counter.","url":"https:\/\/creativecanning.com\/zucchini-relish\/#wprm-recipe-22305-step-0-11"},{"@type":"HowToStep","text":"Leave the jars undisturbed for 24 hours, then check seals.  Store any unsealed jars in the refrigerator for immediate use.  Properly canned and sealed jars should maintain peak quality on the pantry shelf for 12-18 months.","name":"Leave the jars undisturbed for 24 hours, then check seals.  Store any unsealed jars in the refrigerator for immediate use.  Properly canned and sealed jars should maintain peak quality on the pantry shelf for 12-18 months.","url":"https:\/\/creativecanning.com\/zucchini-relish\/#wprm-recipe-22305-step-0-12"}],"aggregateRating":{"@type":"AggregateRating","ratingValue":"4.47","ratingCount":"13","reviewCount":"2"},"review":[{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"This is absolutely delicious \r\nSo good i had to make a second batch \r\n100 stars","author":{"@type":"Person","name":"Amy"},"datePublished":"2025-09-07"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"This is so delicious…best relish I have even had!  Will be making this again very soon.  My entire family loves it and I cannot keep in it.","author":{"@type":"Person","name":"Lisa"},"datePublished":"2025-07-26"}],"recipeCategory":["Relish"],"recipeCuisine":["American"],"keywords":"zucchini canning recipes","nutrition":{"@type":"NutritionInformation","calories":"49 kcal","carbohydrateContent":"12 g","proteinContent":"0.2 g","fatContent":"0.1 g","saturatedFatContent":"0.02 g","sodiumContent":"438 mg","fiberContent":"0.3 g","sugarContent":"12 g","unsaturatedFatContent":"0.07 g","servingSize":"1 serving"},"@id":"https:\/\/creativecanning.com\/zucchini-relish\/#recipe","isPartOf":{"@id":"https:\/\/creativecanning.com\/zucchini-relish\/#article"},"mainEntityOfPage":"https:\/\/creativecanning.com\/zucchini-relish\/"}]}</script>

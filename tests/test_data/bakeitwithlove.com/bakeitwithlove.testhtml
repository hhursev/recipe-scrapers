	<script type="application/ld+json" class="yoast-schema-graph">{"@context":"https://schema.org","@graph":[{"@type":"Article","@id":"https://bakeitwithlove.com/italian-sausage-bake/#article","isPartOf":{"@id":"https://bakeitwithlove.com/italian-sausage-bake/"},"author":{"name":"Angela Latimer","@id":"https://bakeitwithlove.com/#/schema/person/b914edf5bae470ade3af8828a6bd0327"},"headline":"Italian Sausage Bake","datePublished":"2020-11-10T14:00:02+00:00","dateModified":"2023-07-18T02:34:47+00:00","wordCount":1562,"commentCount":13,"publisher":{"@id":"https://bakeitwithlove.com/#organization"},"image":{"@id":"https://bakeitwithlove.com/italian-sausage-bake/#primaryimage"},"thumbnailUrl":"https://bakeitwithlove.com/wp-content/uploads/2020/11/Italian-Sausage-Bake-sq.jpg","articleSection":["Casseroles","Main Dish","Pasta","Recipes"],"inLanguage":"en-US","potentialAction":[{"@type":"CommentAction","name":"Comment","target":["https://bakeitwithlove.com/italian-sausage-bake/#respond"]}]},{"@type":["WebPage","FAQPage"],"@id":"https://bakeitwithlove.com/italian-sausage-bake/","url":"https://bakeitwithlove.com/italian-sausage-bake/","name":"Easy Italian Sausage Bake: Simple 5-Ingredient Dinner","isPartOf":{"@id":"https://bakeitwithlove.com/#website"},"primaryImageOfPage":{"@id":"https://bakeitwithlove.com/italian-sausage-bake/#primaryimage"},"image":{"@id":"https://bakeitwithlove.com/italian-sausage-bake/#primaryimage"},"thumbnailUrl":"https://bakeitwithlove.com/wp-content/uploads/2020/11/Italian-Sausage-Bake-sq.jpg","datePublished":"2020-11-10T14:00:02+00:00","dateModified":"2023-07-18T02:34:47+00:00","description":"This Italian sausage bake is an easy family casserole dinner made with pasta, spaghetti sauce, Italian sausage links, cheese, and basil!","breadcrumb":{"@id":"https://bakeitwithlove.com/italian-sausage-bake/#breadcrumb"},"mainEntity":[{"@id":"https://bakeitwithlove.com/italian-sausage-bake/#faq-question-1689613920258"},{"@id":"https://bakeitwithlove.com/italian-sausage-bake/#faq-question-1689613922819"},{"@id":"https://bakeitwithlove.com/italian-sausage-bake/#faq-question-1689613923394"}],"inLanguage":"en-US","potentialAction":[{"@type":"ReadAction","target":["https://bakeitwithlove.com/italian-sausage-bake/"]}]},{"@type":"ImageObject","inLanguage":"en-US","@id":"https://bakeitwithlove.com/italian-sausage-bake/#primaryimage","url":"https://bakeitwithlove.com/wp-content/uploads/2020/11/Italian-Sausage-Bake-sq.jpg","contentUrl":"https://bakeitwithlove.com/wp-content/uploads/2020/11/Italian-Sausage-Bake-sq.jpg","width":1200,"height":1200,"caption":"Large square angled side view of the Italian Sausage Bake served on white plate."},{"@type":"BreadcrumbList","@id":"https://bakeitwithlove.com/italian-sausage-bake/#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://bakeitwithlove.com/"},{"@type":"ListItem","position":2,"name":"Recipes","item":"https://bakeitwithlove.com/recipe-index/"},{"@type":"ListItem","position":3,"name":"Casseroles","item":"https://bakeitwithlove.com/category/recipes/main-dish/casseroles/"},{"@type":"ListItem","position":4,"name":"Italian Sausage Bake"}]},{"@type":"WebSite","@id":"https://bakeitwithlove.com/#website","url":"https://bakeitwithlove.com/","name":"Bake It With Love","description":"Classic Recipes, Comfort Food and Amazing Desserts!","publisher":{"@id":"https://bakeitwithlove.com/#organization"},"potentialAction":[{"@type":"SearchAction","target":{"@type":"EntryPoint","urlTemplate":"https://bakeitwithlove.com/?s={search_term_string}"},"query-input":{"@type":"PropertyValueSpecification","valueRequired":true,"valueName":"search_term_string"}}],"inLanguage":"en-US"},{"@type":"Organization","@id":"https://bakeitwithlove.com/#organization","name":"Bake It With Love","url":"https://bakeitwithlove.com/","logo":{"@type":"ImageObject","inLanguage":"en-US","@id":"https://bakeitwithlove.com/#/schema/logo/image/","url":"https://bakeitwithlove.com/wp-content/uploads/2021/09/bakeitwithlovesquare.png","contentUrl":"https://bakeitwithlove.com/wp-content/uploads/2021/09/bakeitwithlovesquare.png","width":300,"height":300,"caption":"Bake It With Love"},"image":{"@id":"https://bakeitwithlove.com/#/schema/logo/image/"},"sameAs":["https://www.facebook.com/bakeitwithloveblog","https://x.com/bakeitwithlove","https://www.instagram.com/bake_it_with_love/","https://www.pinterest.com/BakeWithLove","https://www.youtube.com/channel/UCltHiAyi3_GscyzP_yxYDLg"]},{"@type":"Person","@id":"https://bakeitwithlove.com/#/schema/person/b914edf5bae470ade3af8828a6bd0327","name":"Angela Latimer","description":"Angela is an at home chef that developed a passion for all things cooking and baking at a young age in her Grandma's kitchen. After many years in the food service industry, she now enjoys sharing all of her family favorite recipes and creating tasty dinner and amazing dessert recipes here at Bake It With Love!","sameAs":["https://bakeitwithlove.com/about/","BakeItWithLoveBlog/","bake_it_with_love/","BakeWithLove/","https://x.com/bakeitwithlove","UCltHiAyi3_GscyzP_yxYDLg"],"knowsAbout":["Food Blogging. Recipe Development","Food Photography","Baking","Desserts","Dessert Baking","Dinner Recipes","Leftover Recipes"],"knowsLanguage":["English"],"jobTitle":"Food Blogger, Founder","worksFor":"Bake It With Love","url":"https://bakeitwithlove.com/author/admin/"},{"@type":"Question","@id":"https://bakeitwithlove.com/italian-sausage-bake/#faq-question-1689613920258","position":1,"url":"https://bakeitwithlove.com/italian-sausage-bake/#faq-question-1689613920258","name":"What Else Can I Add To My Italian Sausage Bake Casserole?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"You can add whatever you happen to have on hand! I like to toss in any extra veggies I may have, such as bell peppers, mushrooms, onions, or spinach. You can even layer in different kinds of cheeses!","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https://bakeitwithlove.com/italian-sausage-bake/#faq-question-1689613922819","position":2,"url":"https://bakeitwithlove.com/italian-sausage-bake/#faq-question-1689613922819","name":"Can I Freeze My Italian Sausage Bake?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Sure! It makes a great freezer meal for later. Go ahead and assemble your casserole and then wrap it tightly in both plastic wrap and then foil. Then you can freeze it for up to 3 months. ","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https://bakeitwithlove.com/italian-sausage-bake/#faq-question-1689613923394","position":3,"url":"https://bakeitwithlove.com/italian-sausage-bake/#faq-question-1689613923394","name":"What Kind Of Sauce Should I Use For An Italian Sausage Casserole?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Whatever kind you like! To keep it simple, you can use your favorite variety of store-bought sauce. Or, you can use a tasty homemade version! You can also mix it up by making it spicy or even using cheesy Alfredo sauce. ","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Recipe","name":"Italian Sausage Bake","author":{"@id":"https://bakeitwithlove.com/#/schema/person/b914edf5bae470ade3af8828a6bd0327"},"description":"This Italian sausage bake is an easy family casserole dinner made with pasta, spaghetti sauce, Italian sausage links, cheese, and basil! With only 5 ingredients, it&#39;s a super meal to put together quickly and still serve up hearty comfort food that everyone will enjoy! It will definitely be added to your weekly dinner rotation!","datePublished":"2020-11-10T08:00:02+00:00","image":["https://bakeitwithlove.com/wp-content/uploads/2020/11/Italian-Sausage-Bake-h.jpg","https://bakeitwithlove.com/wp-content/uploads/2020/11/Italian-Sausage-Bake-h-500x500.jpg","https://bakeitwithlove.com/wp-content/uploads/2020/11/Italian-Sausage-Bake-h-500x375.jpg","https://bakeitwithlove.com/wp-content/uploads/2020/11/Italian-Sausage-Bake-h-480x270.jpg"],"recipeYield":["6","6 servings"],"prepTime":"PT5M","cookTime":"PT40M","totalTime":"PT45M","recipeIngredient":["1 lb Italian sausage ((Italian sausage links - sweet, mild, or spicy))","24 oz spaghetti sauce ((your favorite brand))","16 oz rotini pasta ((or penne pasta))","1 cup mozzarella cheese ((grated))","1/4 cup Parmesan cheese ((optional - shredded or grated))","1 Tbsp basil ((optional - fresh, chopped))"],"recipeInstructions":[{"@type":"HowToStep","text":"Preheat your oven to 375°F (190°C) and lightly grease your 2.5-quart casserole or baking dish, or a 9 x 13 baking pan with extra virgin olive oil.","name":"preheat","url":"https://bakeitwithlove.com/italian-sausage-bake/#wprm-recipe-25165-step-0-0"},{"@type":"HowToStep","text":"Cook your rotini, penne, rigatoni, or ziti pasta per the package instructions, minus about two minutes for an al dente texture. Drain and rinse in cool water to stop the cooking process.","name":"boil","url":"https://bakeitwithlove.com/italian-sausage-bake/#wprm-recipe-25165-step-0-1"},{"@type":"HowToStep","text":"Transfer the cooked pasta to your prepared baking dish.","name":"pasta","url":"https://bakeitwithlove.com/italian-sausage-bake/#wprm-recipe-25165-step-0-2","image":"https://bakeitwithlove.com/wp-content/uploads/2020/11/the-first-layer-in-the-italian-sausage-bake-is-rotini-or-penne-pasta.jpg"},{"@type":"HowToStep","text":"Pour marinara or spaghetti sauce over the cooked pasta layer.","name":"sauce","url":"https://bakeitwithlove.com/italian-sausage-bake/#wprm-recipe-25165-step-0-3","image":"https://bakeitwithlove.com/wp-content/uploads/2020/11/the-second-layer-in-Italian-sausage-bake-is-spaghetti-sauce.jpg"},{"@type":"HowToStep","text":"Cut your Italian sausage links into chunks and press them into the top of the sauce layer.","name":"sausage","url":"https://bakeitwithlove.com/italian-sausage-bake/#wprm-recipe-25165-step-0-4","image":"https://bakeitwithlove.com/wp-content/uploads/2020/11/the-third-layer-in-italian-sausage-and-pasta-bake-is-chunked-pieces-of-italian-sausage-links.jpg"},{"@type":"HowToStep","text":"Grate mozzarella and Parmesan cheeses then spread over the top of the sausage layer.","name":"cheese","url":"https://bakeitwithlove.com/italian-sausage-bake/#wprm-recipe-25165-step-0-5","image":"https://bakeitwithlove.com/wp-content/uploads/2020/11/the-fourth-layer-of-italian-sausage-bake-is-mozzarella-and-parmesan-cheese.jpg"},{"@type":"HowToStep","text":"Top with fresh-cut basil and bake at 375°F (190°C) for 35-40 minutes. When done, the casserole should be bubbling around the edges, and the sausage pieces should have an internal temperature of 160°F (71°C).","name":"bake","url":"https://bakeitwithlove.com/italian-sausage-bake/#wprm-recipe-25165-step-0-6","image":"https://bakeitwithlove.com/wp-content/uploads/2020/11/the-fifth-and-final-layer-on-the-pasta-bake-is-freshly-chopped-basil.jpg"},{"@type":"HowToStep","text":"Remove from the oven and serve immediately. Garnish with more cheese, basil, or chopped parsley if desired.","name":"serve","url":"https://bakeitwithlove.com/italian-sausage-bake/#wprm-recipe-25165-step-0-7"}],"aggregateRating":{"@type":"AggregateRating","ratingValue":"4.98","ratingCount":"39","reviewCount":"6"},"review":[{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"I removed the sausage from the casing and sauteed it with some diced onion and garlic.   Turned out great!","author":{"@type":"Person","name":"Joanne"},"datePublished":"2025-12-18"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Absolutely delicious. I would like to add some veggies next time I’m thinking some broccoli florettes. Would I thaw them out or keep them frozen, and at what point would they go into the  mixture?  I feel like if they’re included at the beginning, they would cook too much.","author":{"@type":"Person","name":"Stacey"},"datePublished":"2025-10-14"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Turned out great.  Quick and easy.  Delish!","author":{"@type":"Person","name":"Joanne"},"datePublished":"2025-04-16"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"4"},"reviewBody":"This was a very good base recipe.  I added one of the suggested additions, mushrooms.  I assembled things a bit differently, though; I put all the ingredients (including the mozzarella and part of the parmesan, but except the sausage) into a bowl and stirred it up.  For spaghetti sauce, I used Rao's Tomato Basil.  Like one of the other commenters, I also needed more sauce; fortunately, I had part of a jar on hand. My advice is that if you're adding anything to it, use the 32-ounce jar.  After tasting the mixture, I also added two teaspoons of Italian seasoning, a teaspoon of garlic powder and a teaspoon of onion powder.  I sprinkled the fresh basil on top before adding the sausage.\r\n\r\nI think the next time I make this (and I will), I'll pre-cook the sausage and cut down on the baking time, or pre-cook the sausage, cover the casserole with aluminum foil before baking, and use the regular time.  Some pieces of sausage got blackened at the ends, and there were some crunchy bits of overbaked pasta in the casserole.  The cut-up sausage was a great and different take on meatballs, and the casserole itself came out very well overall.  Thanks very much!","author":{"@type":"Person","name":"Aline Terrell"},"datePublished":"2023-10-19"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"For me it was definitely enough.  I think it may depend on the size of your casserole dish.","author":{"@type":"Person","name":"Dave"},"datePublished":"2023-07-17"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Loved this and will definitely make again.","author":{"@type":"Person","name":"Robin Hillyard"},"datePublished":"2021-10-21"}],"recipeCategory":["Casseroles","Dinner Recipes","Main Course"],"recipeCuisine":["American","Italian"],"keywords":"Baked Italian Sausage, easy dinners, Italian Sausage Bake","nutrition":{"@type":"NutritionInformation","calories":"642 kcal","carbohydrateContent":"64 g","proteinContent":"28 g","fatContent":"30 g","saturatedFatContent":"12 g","cholesterolContent":"75 mg","sodiumContent":"1335 mg","fiberContent":"4 g","sugarContent":"7 g","servingSize":"1 serving"},"@id":"https://bakeitwithlove.com/italian-sausage-bake/#recipe","isPartOf":{"@id":"https://bakeitwithlove.com/italian-sausage-bake/#article"},"mainEntityOfPage":"https://bakeitwithlove.com/italian-sausage-bake/"}]}</script>
	<!-- / Yoast SEO Premium plugin. -->



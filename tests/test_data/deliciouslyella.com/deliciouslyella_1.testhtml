issa stuffed sweet potatoes are a great midweek dinner. Roasted in the oven, the soft sweet potato is then mixed together with chickpeas, harissa paste, lime juice and tahini to create a delicious stuffed potato.","en-US-POSIX":"These harissa stuffed sweet potatoes are a great midweek dinner. Roasted in the oven, the soft sweet  potato is then mixed together with garbanzo beans, harissa paste, lime juice and tahini to create a delicious stuffed potato."},"heroImage":{"en-US":{"metadata":{"tags":[]},"sys":{"space":{"sys":{"type":"Link","linkType":"Space","id":"8ffyq0lxv9d2"}},"id":"h87kgGHgxz8zuWzJnps4b","type":"Asset","createdAt":"2020-12-23T14:23:03.982Z","updatedAt":"2020-12-23T14:23:03.982Z","environment":{"sys":{"id":"master","type":"Link","linkType":"Environment"}},"revision":1},"fields":{"title":{"en-US":"© Safia Shakarchi - Deliciously Ella - Harissa Stuffed Sweet Potato -4"},"file":{"en-US":{"url":"//images.ctfassets.net/8ffyq0lxv9d2/h87kgGHgxz8zuWzJnps4b/69039622c741695738134bbd03efeea6/___Safia_Shakarchi_-_Deliciously_Ella_-_Harissa_Stuffed_Sweet_Potato_-4.jpg","details":{"size":5457290,"image":{"width":3948,"height":5560}},"fileName":"___Safia_Shakarchi_-_Deliciously_Ella_-_Harissa_Stuffed_Sweet_Potato_-4.jpg","contentType":"image/jpeg"}}},"id":"h87kgGHgxz8zuWzJnps4b"}},"images":{"en-US":[{"sys":{"type":"Link","linkType":"Asset","id":"3Akk356WYKXgQ0xaLVF1Bi"}}]},"servesMaximum":{"en-US":4},"totalMinutes":{"en-US":60},"ingredientSections":{"en-US":[{"sys":{"type":"Link","linkType":"Entry","id":"6MkzIMA5sUsvEl1vNaiCvf"}}]},"method":{"en-US":[{"sys":{"type":"Link","linkType":"Entry","id":"7JN9JA2OK1kBIv3SADbQvF"}},{"sys":{"type":"Link","linkType":"Entry","id":"4VdIuXn05iRLH6nKxQqgJm"}},{"sys":{"type":"Link","linkType":"Entry","id":"4Fcc5KhV2O3awvqOKYcW7G"}},{"sys":{"type":"Link","linkType":"Entry","id":"1WM1l8ZcAFahmT6MUiTYbq"}},{"sys":{"type":"Link","linkType":"Entry","id":"5YHgzqcAsP7nTlRRO8q27h"}}]},"relatedRecipes":{"en-US":[{"sys":{"type":"Link","linkTy
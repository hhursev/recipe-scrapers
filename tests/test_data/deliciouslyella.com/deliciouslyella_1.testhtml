sAvailable":true,"new":false,"id":"5eU2ZmQBZYKOWuq2UyOC4c","contentfulType":"unit","visibility":"Public","presenter":{},"terms":{"en-US":"teaspoons","de":""},"languages":["en-US"],"pillars":[],"isSleep":false,"isWater":false,"categories":[]},"imperial":{"metadata":{"tags":[]},"sys":{"space":{"sys":{"type":"Link","linkType":"Space","id":"8ffyq0lxv9d2"}},"id":"5eU2ZmQBZYKOWuq2UyOC4c","type":"Entry","createdAt":"2018-11-28T21:14:33.999Z","updatedAt":"2019-01-10T12:57:37.293Z","environment":{"sys":{"id":"master","type":"Link","linkType":"Environment"}},"revision":3,"contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"unit"}}},"fields":{"singularName":{"en-US":" teaspoon"},"pluralName":{"en-US":" teaspoons"}},"contentType":"unit","isAvailable":true,"new":false,"id":"5eU2ZmQBZYKOWuq2UyOC4c","contentfulType":"unit","visibility":"Public","presenter":{},"terms":{"en-US":"teaspoons","de":""},"languages":["en-US"],"pillars":[],"isSleep":false,"isWater":false,"categories":[]},"friendly":{"metadata":{"tags":[]},"sys":{"space":{"sys":{"type":"Link","linkType":"Space","id":"8ffyq0lxv9d2"}},"id":"7z1zozxKiUCqKOhC8Zy0Sd","type":"Entry","createdAt":"2022-07-26T16:44:59.670Z","updatedAt":"2022-10-03T20:36:43.895Z","environment":{"sys":{"id":"master","type":"Link","linkType":"Environment"}},"revision":3,"contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"unit"}}},"fields":{"singularName":{"en-US":" pinch of"},"pluralName":{"en-US":" pinches of"}},"contentType":"unit","isAvailable":true,"new":false,"id":"7z1zozxKiUCqKOhC8Zy0Sd","contentfulType":"unit","visibility":"Public","presenter":{},"terms":{"en-US":"pinches of","de":""},"languages":["en-US"],"pillars":[],"isSleep":false,"isWater":false,"categories":[]}}}]}],"method":[{"id":"35jPHkpwhGrOl3Sa9owS9E","heading":{"de":"1.","en-US":"step 1"},"description":{"de":"Heize den Backofen auf 190 °C Umluft vor. Lege die Süßkartoffelstücke und die abgetropften Kichererbsen auf ein Backblech und vermische sie mit einem Schuss Olivenöl, Kreuzkümmel, Paprika und einer Prise Salz. Backe sie 30-35 Minuten, bis die Süßkartoffeln weich werden.","en-US":"Preheat oven to 190°C fan / 375°F. Place the sweet potato chunks and drained chickpeas on a baking tray and drizzle with olive oil, cumin, paprika and a pinch of salt. Mix well and roast for 30–35 minutes until the sweet potatoes begin to soften.","en-US-POSIX":"Preheat oven to 190°C fan / 375°F. Place the sweet potato chunks and drained garbanzos onto a baking tray and drizzle with olive oil, cumin, paprika and a pinch of salt. Mix well and roast for 30–35 minutes until the sweet potatoes begin to soften."}},{"id":"2WEathf4LXVGroNn0zy8k7","heading":{"de":"2.","en-US":"step 2"},"description":{"de":"Bereite währenddessen das Dressing zu. Püriere dazu alle Zutaten in einem leistungsstarken Mixer.","en-US":"While they cook, make the dressing. Place all of the dressing ingredients into a powerful blender and blitz until smooth."}},{"id":"7dsjUIHvTkZ0DI1HWdKyLd","heading":{"de":"3.","en-US":"step 3"},"description":{"de":"Fülle den Grünkohl in eine große Rührschüssel. Gib einen Schuss Olivenöl und etwas Salz darüber und massiere den Grünkohl ein paar Minuten mit den Händen. Reibe dabei die Blätter, bis sie schön weich werden. Gieße dann das Dressing darüber und reibe es vorsichtig mit den Händen in die Blätter.","en-US":"Place the kale into a large mixing bowl; add a drizzle of olive oil and a sprinkling of salt. Massage the kale with your hands for a few minutes, really rubbing the leaves until the kale is nice and soft. When ready, pour over the dressing and gently rub it into the kale, again using your hands."}},{"id":"2tiGauynPcleFNKMgzIXRd","heading":{"de":"4.","en-US":"step 4"},"description":{"de":"Nimm die fertigen Süßkartoffeln und Kichererbsen aus dem Ofen und lasse sie ein paar Minuten abkühlen. Mische sie unter den Grünkohl und fülle den Salat in eine Servierschüssel. Bestreue mit frischer Petersilie, etwas frischem Pfeffer und einer Prise Chiliflocken.","en-US":"Once the sweet potatoes and chickpeas are cooked, remove from the oven. Allow to cool for a few minutes and then toss through the kale. Transfer to a serving bowl and finish with fresh parsley, a crack of black pepper and a pinch of chilli flakes.","en-US-POSIX":"Once the sweet potatoes and garbanzos are cooked, remove from the oven. Allow to cool for a few minutes and then toss through the kale. Transfer to a serving bowl and finish with fresh parsley, a crack of black pepper and a pinch of chili flakes."}}],"tip":"Massaging kale may sound a little strange but it makes a world of difference; softening the leaves to soak up maximum dressing.","categories":["2nNyXpAp40mosMAoI6iaiK"],"recipeCategories":[{"id":"2nNyXpAp40mosMAoI6iaiK","name":"Mains"}],"subcategories":[{"id":"1lP0PIf0m3xvIQb3OoRT1K"},{"id":"6YnDYQy5W8YqerUtYMsIrB","name":"Quick \u0026 Easy"},{"id":"7iPp0sF3EPA26IttZ67dWA","name":"Midweek"},{"id":"2kHvwrSegTzq7GGN3DXVf1"},{"id":"7Isz1ljJRHG1BySoPQ9uWr"},{"id":"2F5Q1KjrhWnCsUeiIByHRN","name":"Ella's Picks"}],"nutrients":["Source of fibre","Source of calcium","Source of antioxidants"],"relatedRecipes":{"0":{"metadata":{"tags":[]},"sys":{"space":{"sys":{"type":"Link","linkType":"Space","id":"8ffyq0lxv9d2"}},"id":"1UvfIlg1nPAMwFXC8BEFZ2","type":"Entry","createdAt":"2020-10-12T10:16:17.561Z","updatedAt":"2023-09-05T15:24:23.276Z","environment":{"sys":{"id":"master","type":"Link","linkType":"Environment"}},"revision":11,"contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"recipe"}}},"fields":{"title":{"de":"Mit Kichererbsen gefüllte Süßkartoffeln","en-US":"Chickpea-stuffed Sweet Potatoes","en-US-POSIX":"Garbanzo Bean-stuffed Sweet Potatoes"},"slug":{"en-US":"chickpea-stuffed-sweet-potatoes"},"metaDescription":{"en-US":"These chickpea-stuffed sweet potatoes are a great midweek dinner as they're simple and delicious. The creamy tahini chickpeas are mixed with chives and lemon juice and taste amazing piled high on top of a hot sweet potato."},"availableFrom":{"en-US":"2020-11-05T00:00"},"featuredFrom":{"en-US":"2020-11-12T00:00"},"featuredTo":{"en-US":"2020-11-13T00:00"},"featuredOrder":{"en-US":1},"categories":{"en-US":[{"sys":{"type":"Link","linkType":"Entry","id":"2nNyXpAp40mosMAoI6iaiK"}}]},"description":{"de":"Diese mit Kichererbsen gefüllten Süßkartoffeln sind ein tolles Abendessen unter der Woche, denn sie sind ganz einfach und köstlich. Die cremigen Kichererbsen mit Tahini, Schnittlauch und Zitronensaft schmecken großartig auf den heißen Süßkartoffeln. Wir genießen sie am liebsten mit einem einfachen grünen Salat. ","en-US":"These chickpea-stuffed sweet potatoes are a great midweek dinner as they're simple and delicious. The creamy tahini chickpeas are mixed with chives and lemon juice and taste amazing piled high on top of a hot sweet potato. We like to serve this with a simple green salad on the side.","en-US-POSIX":"These garbanzo-stuffed sweet potatoes are a great midweek dinner as they’re simple and delicious. The creamy tahini garbanzo beans are mixed with chives and lemon juice and taste amazing piled high on top of a hot sweet potato. We like to serve this with a simple green salad on the side."},"heroImage":{"en-US":{"metadata":{"tags":[]},"sys":{"space":{"sys":{"type":"Link","linkType":"Space","id":"8ffyq0lxv9d2"}},"id":"3shg8WgCVYo2o9tzjArW9Z","type":"Asset","createdAt":"2020-10-12T09:32:46.724Z","updatedAt":"2020-10-12T09:32:46.724Z","environment":{"sys":{"id":"master","type":"Link","linkType":"Environment"}},"revision":1},"fields":{"title":{"en-US":"© Safia Shakarchi - Deliciously Ella - Stuffed Sweet Po -8"},"file":{"en-US":{"url":"//images.ctfassets.net/8ffyq0lxv9d2/3shg8WgCVYo2o9tzjArW9Z/6690274fccd6a1ff994230bbf885cb7d/Safia_Shakarchi_-_Deliciously_Ella_-_Stuffed_Sweet_Po_-8","details":{"size":4424390,"image":{"width":4000,"height":5265}},"fileName":"Safia Shakarchi - Deliciously Ella - Stuffed Sweet Po -8","contentType":"image/jpeg"}}},"id":"3shg8WgCV
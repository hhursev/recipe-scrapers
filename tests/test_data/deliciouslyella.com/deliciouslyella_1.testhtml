ype":"Environment"}},"publishedVersion":88,"revision":22,"contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"recipe"}}},"fields":{"title":{"de":"Cremiger Brokkoli-Nudelauflauf","en-US":"Creamy Broccoli Pasta Bake"},"slug":{"de":"cremiger-brokkoli-nudelauflauf","en-US":"creamy-broccoli-pasta-bake"},"metaDescription":{"en-US":"Moreish and creamy, with a golden crispy topping, our Broccoli Pasta Bake is packed with veggies and full of flavour. This is bound to be a new family favourite."},"availableFrom":{"en-US":"2024-01-22T00:00"},"featuredFrom":{"en-US":"2026-01-14T00:00"},"featuredTo":{"en-US":"2026-01-15T00:00"},"featuredOrder":{"en-US":1},"popularFrom":{"en-US":"2025-11-03T00:00"},"popularOrder":{"en-US":16},"categories":{"en-US":[{"sys":{"type":"Link","linkType":"Entry","id":"2nNyXpAp40mosMAoI6iaiK"}},{"sys":{"type":"Link","linkType":"Entry","id":"GIFhxoAcB9A7sBWJDAFoi"}}]},"description":{"de":"Wer nach mehr Geschmack und cremigen Texturen sucht, liegt mit diesem Brokkoli-Nudelauflauf goldrichtig. Es erwartet dich verschiedenes Gemüse, ein knuspriges Topping und leckere Aromen. Brokkoli, Erbsen, Lauch und Riesenbohnen werden in einer köstlichen und reichhaltigen Soße aus Cashews, körnigen Senf und Hefeflocken gebacken. Dieses Rezept könnte sich schon bald zu einem neuen Familienfavorit entwickeln.","en-US":"Moreish and creamy, with a golden crispy topping, our Broccoli Pasta Bake is packed with veggies and full of flavour. Load up on goodness with broccoli, peas, leeks and butter beans, in a deliciously rich sauce using cashews, wholegrain mustard and nutritional yeast. This is bound to be a new family favourite.","en-US-POSIX":"Moreish and creamy, with a golden crispy topping, our Broccoli Pasta Bake is packed with veggies and full of flavor. Load up on goodness with broccoli, peas, leeks and lima beans, in a deliciously rich sauce using cashews, wholegrain mustard and nutritional yeast. This is bound to be a new family favorite."},"heroImage":{"
ed":false,"allergyIDs":["6ZMKWrKQhUpBOHASExzcQK"],"allergies":["Nut"]},"12":{"metadata":{"tags":[],"concepts":[]},"sys":{"space":{"sys":{"type":"Link","linkType":"Space","id":"8ffyq0lxv9d2"}},"id":"qlO0uB7hqoge20sE46Omw","type":"Entry","createdAt":"2018-12-19T17:51:13.816Z","updatedAt":"2025-01-10T13:44:41.260Z","environment":{"sys":{"id":"master","type":"Link","linkType":"Environment"}},"publishedVersion":143,"revision":22,"contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"recipe"}}},"fields":{"title":{"de":"Salat aus Lila Sprossen-Brokkoli \u0026 Süßkartoffeln mit Miso","en-US":"Miso Broccoli \u0026 Sweet Potato Salad","en-US-POSIX":"Miso Broccolini Salad \u0026 Sweet Potatoes"},"slug":{"en-US":"miso-broccoli-and-sweet-potato-salad"},"metaDescription":{"en-US":"Purple sprouting broccoli is a delicious ingredient to cook with when it’s in season. We love roasting it until it’s crispy and slightly charred on top, which works so well with sweet potato in this salad."},"availableFrom":{"en-US":"2018-12-02T00:00"},"featuredFrom":{"en-US":"2019-05-10T00:00"},"featuredTo":{"en-US":"2019-05-11T00:00"},"categories":{"en-US":[{"sys":{"type":"Link","linkType":"Entry","id":"2nNyXpAp40mosMAoI6iaiK"}}]},"description":{"de":"Mit Lila Sprossen-Brokkoli lassen sich tolle Gerichte kochen, wenn er Saison hat. Ich backe ihn gerne, bis er knusprig und leicht braun ist. In diesem Rezept marinieren wir ihn mit Misopaste, Zitronensaft, Sesam und Tamarisoße. Die Marinade sorgt für einen tollen Geschmack und passt auch gut zu den Süßkartoffeln.","en-US":"Purple sprouting broccoli is a delicious ingredient to cook with when it’s in season. We love roasting it until it’s crispy and slightly charred on top. Here we coat it in a miso, lemon, sesame and tamari marinade which creates a really rich flavour, which is great with the sweet potatoes too. ","en-US-POSIX":"Purple winter sprouting broccolini is such a lovely ingredient to cook with when it’s in season. I love roasting it until it’s crispy and slightly charred on top. Here we coat it in a miso, lemon, sesame and tamari marinade which creates a really rich flavor, which is great with the sweet potatoes too. "},"heroImage":{"en-US":{"metadata":{"tags":[]},"sys":{"space":{"sys":{"type":"Link","linkType":"Space","id":"8ffyq0lxv9d2"}},"id":"dwN5s9JYicGkWYcEMkG2Q","type":"Asset","createdAt":"2018-12-19T17:38:31.657Z","updatedAt":"2018-12-19T17:38:31.657Z","environment":{"sys":{"id":"master","type":"Link","linkType":"Environment"}},"revision":1},"fields":{"title":{"en-US":"Miso purple sprouting broccoli  "},"file":{"en-US":{"url":"//downloads.ctfassets.net/8ffyq0lxv9d2/dwN5s9JYicGkWYcEMkG2Q/af4d70ca2913994d9475d4e312bd3c0b/18-02-07-PurpleBroccoliSalad-1.jpg","details":{"size":23731202,"image":{"width":3448,"height":5172}},"fileName":"18-02-07-PurpleBroccoliSalad-1.jpg","contentType":"image/jpeg"}}},"id":"dwN5s9JYicGkWYcEMkG2Q"}},"images":{"en-US":[{"sys":{"type":"Link","linkType":"Asset","id":"6grH4e94u4qmgMYsQuAueI"}},{"sys":{"type":"Link","linkType":"Asset","id":"1tflDiue1awQ8KeSiOKgoe"}}]},"servesMinimum":{"en-US":4},"servesMaximum":{"en-US":4},"prepTimeText":{"en-US":"45"},"totalMinutes":{"en-US":45},"ingredientSections":{"en-US":[{"sys":{"type":"Link","linkType":"Entry","id":"33SQeHtTkkskCyaAMAYmOo"}}]},"method":{"en-US":[{"sys":{"type":"Link","linkType":"Entry","id":"3RPKUnfcA0YukaOuksEkKO"}},{"sys":{"type":"Link","linkType":"Entry","id":"1t1BKHVmKkKKOW0qQGAmki"}},{"sys":{"type":"Link","linkType":"Entry","id":"1y4wTfZIiokC84IkGgQcm4"}},{"sys":{"type":"Link","linkType":"Entry","id":"8E3yIrIj72ImSSwyk4siW"}},{"sys":{"type":"Link","linkType":"Entry","id":"pZIUxu72OkYUyG8oE6EYc"}},{"sys":{"type":"Link","linkType":"Entry","id":"55vNPkAziuHLMBNGJS1hTi"}},{"sys":{"type":"Link","linkType":"Entry","id":"46SDijcEXDZ1i75UQwPBn1"}}]},"tip":{"de":"Ich mag den Salat besonders mit einer Handvoll knuspriger, gerösteter Mandeln"},"subcategories":{"en-US":[{"sys":{"type":"Link","linkType":"Entry","id"
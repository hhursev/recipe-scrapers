t potato skins stuffed with mashed sweet potato, black beans, cherry tomatoes, chipotle, miso and coriander, topped with a dollop of tahini coconut yoghurt and homemade guacamole. ","en-US-POSIX":"Crispy sweet potato skins stuffed with mashed sweet potato, black beans, cherry tomatoes, chipotle, miso and cilantro, topped with a dollop of tahini coconut yogurt and homemade guacamole."},"heroImage":{"en-US":{"metadata":{"tags":[]},"sys":{"space":{"sys":{"type":"Link","linkType":"Space","id":"8ffyq0lxv9d2"}},"id":"1TbSfjyxhRvYZ2XF9ejNrF","type":"Asset","createdAt":"2019-01-18T11:03:49.105Z","updatedAt":"2019-01-18T11:03:49.105Z","environment":{"sys":{"id":"master","type":"Link","linkType":"Environment"}},"revision":1},"fields":{"title":{"en-US":"Loaded Sweet Potato Skins"},"file":{"en-US":{"url":"//images.ctfassets.net/8ffyq0lxv9d2/1TbSfjyxhRvYZ2XF9ejNrF/de7fbd1e7f8ccc12a472c250f371e326/LoadedMexicanStyleSweetPotatoSkins.jpg","details":{"size":5200751,"image":{"width":3456,"height":3456}},"fileName":"LoadedMexicanStyleSweetPotatoSkins.jpg","contentType":"image/jpeg"}}},"id":"1TbSfjyxhRvYZ2XF9ejNrF"}},"servesMinimum":{"en-US":2},"servesMaximum":{"en-US":2},"prepTimeText":{"de":"5 Minuten","en-US":"5 minutes"},"cookTimeText":{"de":"70 Minuten","en-US":"70 minutes"},"totalMinutes":{"en-US":80},"ingredientSections":{"en-US":[{"sys":{"type":"Link","linkType":"Entry","id":"7aslhhA9A5Csqh9MBk5cuo"}},{"sys":{"type":"Link","linkType":"Entry","id":"4l10UM0Xz5zAGtgXwjy5mn"}},{"sys":{"type":"Link","linkType":"Entry","id":"4n4Ptn2RSrh9BzSGOOLdvn"}}]},"method":{"en-US":[{"sys":{"type":"Link","linkType":"Entry","id":"3o2y6T8Qiskwn0TQkMhwsR"}},{"sys":{"type":"Link","linkType":"Entry","id":"1PPq2gSmUlp8RUIPAVcTP7"}},{"sys":{"type":"Link","linkType":"Entry","id":"1Qwda2EpSdS6VbF2NJ4Igz"}},{"sys":{"type":"Link","linkType":"Entry","id":"5AxI71sooQzFhVhc3pTyLB"}},{"sys":{"type":"Link","linkType":"Entry","id":"6WaKENYHhgCqAEIo4WslB4"}},{"sys":{"type":"Link","linkType":"Entry","id":"76SeNUWv
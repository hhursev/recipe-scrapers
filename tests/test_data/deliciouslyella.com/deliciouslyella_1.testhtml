ies":[]},"imperial":{"metadata":{"tags":[]},"sys":{"space":{"sys":{"type":"Link","linkType":"Space","id":"8ffyq0lxv9d2"}},"id":"5tAzQsxsfmMOY2uooGgEoc","type":"Entry","createdAt":"2018-11-28T16:55:52.342Z","updatedAt":"2018-12-06T11:15:33.182Z","environment":{"sys":{"id":"master","type":"Link","linkType":"Environment"}},"revision":4,"contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"unit"}}},"fields":{"singularName":{"en-US":" tablespoon"},"pluralName":{"en-US":" tablespoons"}},"contentType":"unit","isAvailable":true,"new":false,"id":"5tAzQsxsfmMOY2uooGgEoc","contentfulType":"unit","visibility":"Public","presenter":{},"terms":{"en-US":"tablespoons","de":""},"languages":["en-US"],"pillars":[],"isSleep":false,"isWater":false,"categories":[]}},"comment":{"en-US":"(or your favourite nut butter)","de":"(oder dein Lieblingsnussmus)","en-US-POSIX":"(or your favorite nut butter)"}}]}},"contentType":"ingredientSection","isAvailable":true,"new":false,"id":"564ZPsySZ3TWtup4rKEdhz","contentfulType":"ingredientSection","visibility":"Public","presenter":{},"terms":{"en-US":"","de":""},"languages":["de","en-US"],"pillars":[],"isSleep":false,"isWater":false,"categories":[],"relatedTerms":{"en-US":"      chia seeds  almond butter  blueberries  shelled hemp seeds  soya milk  porridge oats ","de":"      chiasamen  mandelmus  blaubeeren  geschalte hanfsamen  sojamilch  zarte haferflocken "},"isPlantBased":true,"allergyIDs":["20t5UqLrQx1IV8uT4uwd2T","1iGRpljRkbtERkTHItifoW","6ZMKWrKQhUpBOHASExzcQK"],"allergies":["Gluten","Soya","Nut"]}}},"method":{"en-US":{"0":{"metadata":{"tags":[]},"sys":{"space":{"sys":{"type":"Link","linkType":"Space","id":"8ffyq0lxv9d2"}},"id":"7swiVzgaE4tbvVyLGAwLqF","type":"Entry","createdAt":"2022-12-12T20:35:10.833Z","updatedAt":"2022-12-27T03:16:57.083Z","environment":{"sys":{"id":"master","type":"Link","linkType":"Environment"}},"revision":3,"contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"method"}}},"fields":{"heading":{"de":"1.","en-US":"step 1"},"description":{"de":"Gib die zarten Haferflocken, die Sojamilch, die geschälten Hanfsamen und die Chiasamen in einen kleinen Topf und stelle ihn bei mittlerer Hitze auf den Herd. Koche die Haferflocken für 4–5 Minuten und rühre mehrmals um, bis die Milch von den Haferflocken aufgesogen ist und das Porridge cremig und heiß ist. Rühre die Blaubeeren unter und koche das Ganze für 1 Weitere Minute, bis die Beeren eine dunklere Farbe bekommen haben und sie etwas von ihrem Saft abgeben. ","en-US":"Place the porridge oats, soya milk, shelled hemp seeds and chia seeds into a small saucepan over medium heat. Cook, stirring frequently, for 4–5 minutes until the milk has absorbed and the porridge is creamy and piping hot. Stir through the blueberries and cook for 1 further minute, until the berries turn a darker blue and begin to release their juices. "}},"contentType":"method","isAvailable":true,"new":false,"id":"7swiVzgaE4tbvVyLGAwLqF","contentfulType":"method","visibility":"Public","presenter":{},"terms":{"en-US":"","de":""},"languages":["de","en-US"],"pillars":[],"isSleep":false,"isWater":false,"categories":[]},"1":{"metadata":{"tags":[]},"sys":{"space":{"sys":{"type":"Link","linkType":"Space","id":"8ffyq0lxv9d2"}},"id":"6KZlSEwzwE5YTMwTj8a9Zl","type":"Entry","createdAt":"2022-12-12T20:35:50.052Z","updatedAt":"2022-12-27T03:13:06.396Z","environment":{"sys":{"id":"master","type":"Link","linkType":"Environment"}},"revision":2,"contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"method"}}},"fields":{"heading":{"de":"2.","en-US":"step 2"},"description":{"de":"Serviere das Porridge in einer Schüssel, verteile etwas Mandelmuss darüber und genieße es sofort.","en-US":"Serve in a bowl, topped with a drizzle of almond butter and enjoy immediately. "}},"contentType":"method","isAvailable":true,"new":false,"id":"6KZlSEwzwE5YTMwTj8a9Zl","contentfulType":"method","visibility":"Public","presenter":{},"terms":{"en-US":"","de":""},"languages":["de","en-US"],"pillars":[],"isSleep":false,"isWater":false,"categories":[]}}},"tip":{"de":"Du kannst tiefgekühlte Beeren verwenden, wenn du möchtest. Die Beeren solltest du dann einfach etwas auftauen lassen, bevor du sie ins Porridge rührst. Wenn du frische Blaubeeren übrig hast, kannst du sie im Tiefkühler einfrieren.","en-US":"Use frozen berries if you prefer; leave the berries to defrost before stirring through the porridge. Leftover fresh berries can be frozen for future use. "},"relatedRecipes":{"en-US":{"0":{"metadata":{"tags":[],"concepts":[]},"sys":{"space":{"sys":{"type":"Link","linkType":"Space","id":"8ffyq0lxv9d2"}},"id":"1TJmRRzJPu8Yu8uMPUyMjS","type":"Entry","createdAt":"2022-12-19T16:57:56.143Z","updatedAt":"2025-12-11T16:28:53.939Z","environment":{"sys":{"id":"master","type":"Link","linkType":"Environment"}},"publishedVersion":68,"revision":16,"contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"recipe"}}},"fields":{"title":{"de":"Power-Porridge mit Banane","en-US":"Banana Power Porridge"},"slug":{"en-US":"banana-power-porridge"},"metaDescription":{"en-US":"Start your day right with a warming bowl of banana power porridge — with hemp and chia seeds, it’s supercharged with fibre, protein and healthy fats. We love it topped with banana and crunchy cacao nibs, which help to promote good digestion. "},"availableFrom":{"en-US":"2022-08-10T00:00"},"featuredFrom":{"en-US":"2025-12-16T00:00"},"featuredTo":{"en-US":"2025-12-17T00:00"},"featuredOrder":{"en-US":1},"popularFrom":{"en-US":"2025-01-13T00:00"},"popularTo":{"en-US":"2025-01-20T00:00"},"popularOrder":{"en-US":13},"categories":{"en-US":[{"sys":{"type":"Link","linkType":"Entry","id":"2IpnFlvZu0qAy4wK0eye00"}},{"sys":{"type":"Link","linkType":"Entry","id":"GIFhxoAcB9A7sBWJDAFoi"}}]},"description":{"de":"Starte deinen Tag richtig und zwar mit einer wärmenden Schüssel voller Porridge. Das leckere Frühstück ist mit Hanfsamen und Chiasamen ausgestattet und versorgt dich bereits am Morgen mit Ballaststoffen, Proteinen und gesunden Fetten. Wir lieben Bananen, die eine köstliche Natursüße besitzen, und knusprige Kakaonibs, die gut für die Verdauung sind, als Toppings.","en-US":"Start your day right with a warming bowl of creamy porridge — with hemp and chia seeds, it’s supercharged with fibre, protein and healthy fats. We love it topped with naturally sweet banana and crunchy cacao nibs, which help to promote good digestion. ","en-US-POSIX":"Start your day right with a warming bowl of creamy porridge — with hemp and chia seeds, it’s supercharged with fiber, protein and healthy fats. We love it topped with naturally sweet banana and crunchy cacao nibs, which help to promote good digestion. "},"heroImage":{"en-US":{"sys":{"type":"Link","linkType":"Asset","id":"3i9aXg3n5gYlCVfEzmDSS2"}}},"servesMaximum":{"en-US":1},"cookTimeText":{"de":"Minuten"},"totalMinutes":{"en-US":10},"ingredientSections":{"en-US":[{"sys":{"type":"Link","linkType":"Entry","id":"fS4cIpx9wCPVUJvqXjLCj"}}]},"method":{"en-US":[{"sys":{"type":"Link","linkType":"Entry","id":"58NKoilA9kkyDDRDjRWqeJ"}},{"sys":{"type":"Link","linkType":"Entry","id":"1D44G2n4PMssO6ekhTk1BJ"}}]},"relatedRecipes":{"en-US":[{"sys":{"type":"Link","linkType":"Entry","id":"NgbltGDTFZRtn107ezha6"}},{"sys":{"type":"Link","linkType":"Entry","id":"eJEw39pmCgZfP4kCYIbxP"}},{"sys":{"type":"Link","linkType":"Entry","id":"4YsrWr6DLqBFDjS7QNXJ3N"}},{"sys":{"type":"Link","linkType":"Entry","id":"45iKSST6fMXC07JAwrcLkm"}},{"sys":{"type":"Link","linkType":"Entry","id":"1lm42RksPSuz2mlvfAqSA5"}},{"sys":{"type":"Link","linkType":"Entry","id":"2zBC4cXWJOeQ6q8OYaQqWi"}},{"sys":{"type":"Link","linkType":"Entry","id":"2IpOp8rAsCO7t41KNUbeCD"}},{"sys":{"type":"Link","linkType":"Entry","id":"2tznUeRYXAG9CqxHrvN2AV"}},{"sys":{"type":"Link","linkType":"Entry","id":"6S8vJnsS3lH1WxAAqILE7v"}},{"sys":{"type":"Link","linkType":"Entry","id":"2L5TnwfbIZyOuZkX2TFuMs"}},{"sys":{"type":"Link","linkType":"Entry","id":"Wkf85Wgyts14g3MTxJTLf"}},{"sys":{"type":
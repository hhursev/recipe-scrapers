ingredientSection","visibility":"Public","presenter":{},"terms":{"en-US":"","de":""},"languages":["de","en-US"],"pillars":[],"isSleep":false,"isWater":false,"categories":[],"relatedTerms":{"en-US":"   lemon lemons  red chilli flakes  basil ","de":"   zitrone zitronen  rote chiliflocken  basilikum "},"isPlantBased":true,"allergyIDs":[],"allergies":[]}}},"method":{"en-US":{"0":{"metadata":{"tags":[]},"sys":{"space":{"sys":{"type":"Link","linkType":"Space","id":"8ffyq0lxv9d2"}},"id":"ixNLLVAXzC0x9G0TD738G","type":"Entry","createdAt":"2022-07-28T00:45:47.244Z","updatedAt":"2023-08-09T16:10:06.258Z","environment":{"sys":{"id":"master","type":"Link","linkType":"Environment"}},"revision":7,"contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"method"}}},"fields":{"heading":{"de":"1.","en-US":"step 1"},"description":{"de":"Heize den Ofen auf 200°C Umluft vor. Verteile das geschnittene Gemüse für das Ratatouille und den Knoblauch in einer Auflaufform mit den Maßen 30 cm x 22 cm x 5 cm. Beträufle es mit Olivenöl, streue Salz und Pfeffer darüber und vermische alles gut miteinander.","en-US":"Preheat oven to 200°C fan / 430°F. Place all of the chopped ratatouille vegetables and garlic in a baking tray measuring 30 x 22 x 5cm / 12 x 8 x 2″. Drizzle over the olive oil, sprinkle with salt and pepper; toss to combine. "}},"contentType":"method","isAvailable":true,"new":false,"id":"ixNLLVAXzC0x9G0TD738G","contentfulType":"method","visibility":"Public","presenter":{},"terms":{"en-US":"","de":""},"languages":["de","en-US"],"pillars":[],"isSleep":false,"isWater":false,"categories":[]},"1":{"metadata":{"tags":[]},"sys":{"space":{"sys":{"type":"Link","linkType":"Space","id":"8ffyq0lxv9d2"}},"id":"6MNqZ9KEoNk7eweJ62tfgu","type":"Entry","createdAt":"2022-07-28T00:46:35.317Z","updatedAt":"2023-08-09T16:13:35.439Z","environment":{"sys":{"id":"master","type":"Link","linkType":"Environment"}},"revision":5,"contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"method"}}},"fields":{"heading":{"de":"2.","en-US":"step 2"},"description":{"de":"Gib die Auflaufform in den vorgeheizten Ofen und backe das Ratatouille für 25 Minuten, bis das Gemüse zart ist. ","en-US":"Place in the preheated oven and bake for 25 minutes until the vegetables are tender."}},"contentType":"method","isAvailable":true,"new":false,"id":"6MNqZ9KEoNk7eweJ62tfgu","contentfulType":"method","visibility":"Public","presenter":{},"terms":{"en-US":"","de":""},"languages":["de","en-US"],"pillars":[],"isSleep":false,"isWater":false,"categories":[]},"2":{"metadata":{"tags":[],"concepts":[]},"sys":{"space":{"sys":{"type":"Link","linkType":"Space","id":"8ffyq0lxv9d2"}},"id":"76VBNiD4NL4n4D63uAZEH7","type":"Entry","createdAt":"2022-07-28T00:47:36.422Z","updatedAt":"2024-08-19T14:14:36.174Z","environment":{"sys":{"id":"development","type":"Link","linkType":"Environment"}},"publishedVersion":18,"revision":7,"contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"method"}}},"fields":{"heading":{"de":"3.","en-US":"step 3"},"description":{"de":"Nimm die Auflaufform aus dem Ofen und gib die gehackten Tomaten dazu. Fülle die leere Tomatendose mit Wasser und gieße es in die Form. Rühre die Orzo-Nudeln, das Miso, Tahini und 1 Teelöffel feines Salz ein. Achte darauf, dass das Miso und das Tahini gleichmäßig verteilt sind. Gib die Auflaufform zurück in den Ofen und backe für weitere 20 Minuten.","en-US":"Remove from the oven and add the chopped tomatoes. Fill the empty chopped tomatoes tin with water and pour this into the dish. Stir in the spinach, orzo, miso, tahini and 1 teaspoon of fine salt, making sure that the miso and tahini are evenly distributed. Return everything to the oven for a further 20 minutes. ","en-US-POSIX":"Remove from the oven and add the chopped tomatoes. Fill the empty chopped tomatoes can with water and add this to the dish. Stir in the orzo, miso, tahini and 1 teaspoon of fine salt, making sure that the miso and tahini are evenly distributed. Return everything to the oven for a further 20 minutes. "}},"contentType":"method","isAvailable":true,"new":false,"id":"76VBNiD4NL4n4D63uAZEH7","contentfulType":"method","visibility":"Public","presenter":{},"terms":{"en-US":"","de":""},"languages":["de","en-US","en-US-POSIX"],"pillars":[],"isSleep":false,"isWater":false,"categories":[]},"3":{"metadata":{"tags":[],"concepts":[]},"sys":{"space":{"sys":{"type":"Link","linkType":"Space","id":"8ffyq0lxv9d2"}},"id":"6IZUCEHW6mhd9kSldvXueJ","type":"Entry","createdAt":"2022-07-28T00:48:26.437Z","updatedAt":"2024-10-17T10:54:22.055Z","environment":{"sys":{"id":"development","type":"Link","linkType":"Environment"}},"publishedVersion":27,"revision":5,"contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"method"}}},"fields":{"heading":{"de":"4.","en-US":"step 4"},"description":{"de":"Nimm das Gericht aus dem Ofen und rühre den frischen Spinat unter. Gib vor dem Servieren den frischen Zitronensaft darüber und verteile den frischen Basilikum und die roten Chiliflocken (falls verwendet) darauf.","en-US":"Remove from the oven and stir through the lemon juice. To serve, scatter over the basil and chilli flakes (if using), and drizzle with a little extra virgin olive oil. ","en-US-POSIX":"Remove from the oven and stir through the fresh spinach. Pour over the fresh lemon juice and top with the fresh basil and red chili flakes (if using), before serving."}},"contentType":"method","isAvailable":true,"new":false,"id":"6IZUCEHW6mhd9kSldvXueJ","contentfulType":"method","visibility":"Public","presenter":{},"terms":{"en-US":"","de":""},"languages":["de","en-US","en-US-POSIX"],"pillars":[],"isSleep":false,"isWater":false,"categories":[]}}},"relatedRecipes":{"en-US":{"0":{"metadata":{"tags":[{"sys":{"type":"Link","linkType":"Tag","id":"italian"}},{"sys":{"type":"Link","linkType":"Tag","id":"pastas"}}],"concepts":[]},"sys":{"space":{"sys":{"type":"Link","linkType":"Space","id":"8ffyq0lxv9d2"}},"id":"73ju6qzxe1mbA6GJUBQhOe","type":"Entry","
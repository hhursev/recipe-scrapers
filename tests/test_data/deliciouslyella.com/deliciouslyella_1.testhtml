inkType":"Entry","id":"3VXDtp1pbCfruKuhBpVmBP"}}]}},"contentType":"recipeCategory","isAvailable":true,"new":false,"id":"2nNyXpAp40mosMAoI6iaiK","contentfulType":"recipeCategory","visibility":"Public","presenter":{},"terms":{"en-US":"mains","de":"hauptgerichte"},"languages":["de","en-US"],"pillars":[],"isSleep":false,"isWater":false,"categories":[]}}},"description":{"de":"Unsere ultimative Wohlfühl-Tomatensuppe – cremig, aromatisch und herrlich unkompliziert. Sie liefert gleich zwei deiner „Fünf am Tag“ und ist eine tolle Ballaststoffquelle. Perfekt zum Vorkochen (hallo, schnelle Mittagessen!). Wir lieben sie mit knusprigen Knoblauch-Petersilien-Toaststicks – ehrlich, warum nicht?","en-US":"This is our ultimate cosy, creamy tomato soup – and it couldn’t be simpler to make. It’s two of your five a day and a great source of fibre, making it perfect for batch cooking (hello, easy lunches). We love it with garlicky parsley toast soldiers because, honestly, why wouldn’t you? "},"heroImage":{"en-US":{"metadata":{"tags":[],"concepts":[]},"sys":{"space":{"sys":{"type":"Link","linkType":"Space","id":"8ffyq0lxv9d2"}},"id":"6iUirHI8GYMubfX2pbki0c","type":"Asset","createdAt":"2026-01-08T10:13:50.374Z","updatedAt":"2026-01-08T10:13:50.374Z","environment":{"sys":{"id":"master","type":"Link","linkType":"Environment"}},"publishedVersion":4,"revision":1},"fields":{"title":{"en-US":"Roasted Tomato \u0026 Miso Soup"},"description":{"en-US":""},"file":{"en-US":{"url":"//images.ctfassets.net/8ffyq0lxv9d2/6iUirHI8GYMubfX2pbki0c/06f943d7c04395da108c45a07c484ccb/091225_DeliciouslyElla_8.jpg","details":{"size":3006864,"image":{"width":1333,"height":2000}},"fileName":"091225_DeliciouslyElla_8.jpg","contentType":"image/jpeg"}}},"id":"6iUirHI8GYMubfX2pbki0c"}},"images":{"en-US":{"0":{"metadata":{"tags":[],"concepts":[]},"sys":{"space":{"sys":{"type":"Link","linkType":"Space","id":"8ffyq0lxv9d2"}},"id":"3ijjBl7sExqfMOMInNWqmX","type":"Asset","createdAt":"2026-01-08T10:17:54.466Z","updatedAt":"20
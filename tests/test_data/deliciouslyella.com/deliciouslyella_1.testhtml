wd2T","1iGRpljRkbtERkTHItifoW","6ZMKWrKQhUpBOHASExzcQK"],"allergies":["Gluten","Soya","Nut"]},"2":{"metadata":{"tags":[],"concepts":[]},"sys":{"space":{"sys":{"type":"Link","linkType":"Space","id":"8ffyq0lxv9d2"}},"id":"4YsrWr6DLqBFDjS7QNXJ3N","type":"Entry","createdAt":"2019-01-25T17:25:36.390Z","updatedAt":"2025-01-17T17:26:36.360Z","environment":{"sys":{"id":"master","type":"Link","linkType":"Environment"}},"publishedVersion":106,"revision":17,"contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"recipe"}}},"fields":{"title":{"de":"Ingwer-Pecan-Porridge","en-US":"Ginger \u0026 Pecan Porridge","en-US-POSIX":"Ginger \u0026 Pecan Oatmeal"},"slug":{"en-US":"ginger-and-pecan-porridge"},"metaDescription":{"en-US":"This ginger \u0026 pecan porridge is the perfect breakfast for cold, wintery mornings. It's so warming and tastes amazing served with a dollop of creamy coconut yogurt and a handful of crunchy pecans."},"availableFrom":{"en-US":"2018-12-06T00:00"},"featuredFrom":{"en-US":"2021-12-20T00:00"},"featuredTo":{"en-US":"2021-12-21T00:00"},"categories":{"en-US":[{"sys":{"type":"Link","linkType":"Entry","id":"2IpnFlvZu0qAy4wK0eye00"}}]},"description":{"de":"Dieses Porridge ist das perfekte Frühstück für einen kalten Wintermorgen. Es ist sehr wärmend und schmeckt mit einem Klecks cremigem Kokosjoghurt und einer Handvoll knackiger Pecans unglaublich lecker. Wenn ihr noch mehr Zutaten wollt, versucht es mit gedünsteten Apfel- oder Birnenscheiben.","en-US":"This ginger \u0026 pecan porridge is the perfect breakfast for cold, wintery mornings. It's so warming and tastes amazing served with a dollop of creamy coconut yogurt and a handful of crunchy pecans. If you want to add on to this, it’s delicious with some sautéed apple or pear slices. \n","en-US-POSIX":"This oatmeal is the perfect breakfast for cold, wintery mornings. It’s so warming and tastes amazing served with a dollop of creamy coconut yogurt and a handful of crunchy pecans. If you want to add onto this, it’s delicious with some sautéed apple or pear slices. "},"heroImage":{"en-US":{"sys":{"type":"Link","linkType":"Asset","id":"3j1NTm9ZSOHfgNkSPtCGFG"}}},"images":{"en-US":[{"sys":{"type":"Link","linkType":"Asset","id":"4wjFv5Gn7YcgfroLWUhhqt"}}]},"servesMinimum":{"en-US":1},"servesMaximum":{"en-US":1},"prepTimeText":{"de":"10 Minuten","en-US":"10 minutes"},"totalMinutes":{"en-US":15},"ingredientSections":{"en-US":[{"sys":{"type":"Link","linkType":"Entry","id":"4mmK37a8FbzqDHF9LAicb4"}}]},"method":{"en-US":[{"sys":{"type":"Link","linkType":"Entry","id":"5Yf2ObNbeYuYium6FC8OFX"}},{"sys":{"type":"Link","linkType":"Entry","id":"1wXO430JEOcAIvr855dWnP"}}]},"relatedRecipes":{"en-US":[{"sys":{"type":"Link","linkType":"Entry","id":"4tPIRsDvxvsGNzgODTHLJt"}},{"sys":{"type":"Link","linkType":"Entry","id":"5UpAFaXDa0igGuE2oS0kYC"}},{"sys":{"type":"Link","linkType":"Entry","id":"111tseeDx6wWuuymosIsy6"}}]},"subcategories":{"en-US":[{"sys":{"type":"Link","linkType":"Entry","id":"6I0AEjs6xMaRtf4s7n3vxU"}},{"sys":{"type":"Link","linkType":"Entry","id":"2kHvwrSegTzq7GGN3DXVf1"}},{"sys":{"type":"Link","linkType":"Entry","id":"iCPkkkl4HRhUCwvJvD7Eg"}},{"sys":{"type":"Link","linkType":"Entry","id":"2I2ItwDXUGl9AW1hy0fVVu"}},{"sys":{"type":"Link","linkType":"Entry","id":"6bfjhWWwJuymYWTg00eX17"}}]},"nutrients":{"en-US":["Source of fibre"]}},"contentType":"recipe","isAvailable":true,"new":false,"id":"4YsrWr6DLqBFDjS7QNXJ3N","contentfulType":"recipe","visibility":"Public","featured":false,"featuredOrder":null,"presenter":{},"terms":{"en-US":"ginger pecan porridge","de":"ingwer pecan porridge"},"languages":["de","en-US","en-US-POSIX"],"pillars":[],"isSleep":false,"isWater":false,"categories":["2IpnFlvZu0qAy4wK0eye00"],"recipeCategories":[{"id":"2IpnFlvZu0qAy4wK0eye00","name":"Breakfast"}],"relatedTerms":{"en-US":"       almond milk  pecans  ginger  coconut yoghurt  maple syrup  porridge oats ","de":""},"isPlantBased":true,"allergyIDs":["20t5UqLrQx1IV8uT4uwd2T","6ZMKWrKQhUpBOHASExzcQK"],"allergies":["Gluten","Nut"]},"3":{"metadata":{"tags":[],"concepts":[]},"sys":{"space":{"sys":{"type":"Link","linkType":"Space","id":"8ffyq0lxv9d2"}},"id":"45iKSST6fMXC07JAwrcLkm","type":"Entry","createdAt":"2019-01-24T10:59:38.355Z","updatedAt":"2025-07-21T14:06:27.661Z","environment":{"sys":{"id":"master","type":"Link","linkType":"Environment"}},"publishedVersion":88,"revision":15,"contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"recipe"}}},"fields":{"title":{"de":"Birne-Walnuss-Porridge mit Zimt","en-US":"Baked Pear, Cinnamon \u0026 Walnut Porridge","en-US-POSIX":"Baked Pear, Cinnamon \u0026 Walnut Oatmeal"},"slug":{"en-US":"baked-pear-cinnamon-and-walnut-porridge"},"metaDescription":{"en-US":"This creamy pear, cinnamon \u0026 walnut porridge is the perfect winter breakfast. I love baking the pear in thin slices with a little maple and cinnamon, and then throwing in the walnuts at the end so that they go nice and crunchy. "},"availableFrom":{"en-US":"2018-12-13T00:00"},"featuredOrder":{"en-US":1},"categories":{"en-US":[{"sys":{"type":"Link","linkType":"Entry","id":"2IpnFlvZu0qAy4wK0eye00"}}]},"description":{"de":"Dieses cremige Porridge mit Birne, Zimt und Walnüssen ist das perfekte Frühstück für den Winter. Ich schneide die Birne in dünne Scheiben und backe sie mit Ahornsirup und Zimt. Gegen Ende werfe ich die Walnüsse dazu, damit sie schön knusprig werden. Das ganze kommt dann auf eine Schale mit cremigem Mandelmilch-Porridge – und dann haue ich rein!","en-US":"This creamy pear, cinnamon \u0026 walnut porridge is the perfect winter breakfast. I love baking the pear in thin slices with a little maple and cinnamon, and then throwing in the walnuts at the end so that they go nice and crunchy. ","en-US-POSIX":"This creamy pear, cinnamon and walnut oatmeal is the perfect winter breakfast. I love baking the pear in thin slices with a little maple and cinnamon, and then throwing in the walnuts at the end so that they go nice and crunchy. I then add
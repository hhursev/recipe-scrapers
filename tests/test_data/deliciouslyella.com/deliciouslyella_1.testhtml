NSTAGRAM_USER_ID":"6164372607000338","PUBLIC_STORE_DOMAIN":"deliciously-ella-shop.myshopify.com","PUBLIC_STOREFRONT_API_TOKEN":"e0fea837710bbe19838dcda4b3b871b3","REACT_APP_GOOGLE_MAPS_API_KEY":"AIzaSyB28FYNUzIhuAqjUpTV-shL38kZ8Es9wL0","REACT_APP_EVENTBRITE_ORGANIZER_ID":"531173388147","PRIVATE_EVENTBRITE_API_KEY":"QPTHWWKOYX7GUHJABKMG","REACT_APP_KLAVIYO_API_KEY":"pk_41bc6e48e06fb86b2287685f9bf6ad9cf8"},"contentfulEnv":{"spaceId":"8ffyq0lxv9d2","accessToken":"394641c1e5cdda4c9f3fcf9ac22b028ff3795e0ed306129aa391fe304c782fa2","environment":"master"},"params":{"itemId":"creamy-kale-and-sweet-potato-salad"}},"routes/($locale).recipes.$itemId":{"meta":{"title":"Creamy Kale \u0026 Sweet Potato Salad","description":"For this creamy kale \u0026 sweet potato salad, chickpeas and sweet potatoes are roasted with paprika and cumin, then tossed through kale with a creamy cashew dressing and finished with a sprinkling of parsley, chilli flakes and black pepper.","media":[{"url":"https://images.ctfassets.net/8ffyq0lxv9d2/3N5caHD03AfEq8k7Me0DYF/27a5316c0466144f918e5e0fc534c93c/kale_salad.jpg","type":"image","width":5333,"height":7996}],"jsonLd":{"@context":"https://schema.org","@id":"https://deliciouslyella.com/recipes/creamy-kale-and-sweet-potato-salad","@type":"Recipe","author":{"@type":"Organization","name":"Deliciously Ella"},"recipeCategory":"Mains","url":"https://deliciouslyella.com/recipes/creamy-kale-and-sweet-potato-salad","name":"Creamy Kale \u0026 Sweet Potato Salad","image":"//images.ctfassets.net/8ffyq0lxv9d2/3N5caHD03AfEq8k7Me0DYF/27a5316c0466144f918e5e0fc534c93c/kale_salad.jpg","recipeIngredient":["2 sweet potatoes","8.5 oz canned chickpeas","1 teaspoon ground cumin","1 teaspoon paprika","7 oz kale","handful of parsley","pinch of dried red chilli flakes","drizzle of olive oil","pinch of sea salt \u0026 black pepper"],"cookTime":"PT35M","prepTime":"PTundefinedM","totalTime":"PT35M","recipeInstructions":[{"@type":"HowToStep","text":"Preheat oven to 190°C fan / 375°F. Place the sweet potato chunks and drained chickpeas on a baking tray and drizzle with olive oil, cumin, paprika and a pinch of salt. Mix well and roast for 30–35 minutes until the sweet potatoes begin to soften."},{"@type":"HowToStep","text":"While they cook, make the dressing. Place all of the dressing ingredients into a powerful blender and blitz until smooth."},{"@type":"HowToStep","text":"Place the kale into a large mixing bowl; add a drizzle of olive oil and a sprinkling of salt. Massage the kale with your hands for a few minutes, really rubbing the leaves until the kale is nice and soft. When ready, pour over the dressing and gently rub it into the kale, again using your hands."},{"@type":"HowToStep","text":"Once the sweet potatoes and chickpeas are cooked, remove from the oven. Allow to cool for a few minutes and then toss through the kale. Transfer to a serving bowl and finish with fresh parsley, a crack of black pepper and a pinch of chilli flakes."}],"recipeYield":4,"description":"Sweet potatoes and chickpeas are roasted with paprika and cumin, then tossed through kale with a creamy cashew dressing and finished with a sprinkling of parsley, chilli flakes and black pepper — simple, creamy and delicious.","datePublished":"7 January 2020"}},"recipe":{"id":"mlzmyUJqG55zCBgzLLj48","isKidsContent":false,"isWater":false,"description":"Sweet potatoes and chickpeas are roasted with paprika and cumin, then tossed through kale with a creamy cashew dressing and finished with a sprinkling of parsley, chilli flakes and black pepper — simple, creamy and delicious.","title":"Creamy Kale \u0026 Sweet Potato Salad","slug":"creamy-kale-and-sweet-potato-salad","availableFrom":"7 January 2020","serves":4,"totalMinutes":35,"freezable":false,"ingredientSections":[{"title":"for the salad","newIngredients":[{"ingredient":{"id":"2D3CzGjswE06oKMQ4gCGYi","name":"sweet potato","pluralName":"sweet potatoes","category":{"id":"2g9jVdSisEKSu2GYCWCkM4","name":"Fresh Fruit \u0026 Vegetables
":"","de":""},"languages":["de","en-US"],"pillars":[],"isSleep":false,"isWater":false,"categories":[],"relatedTerms":{"en-US":"","de":""},"isPlantBased":true,"allergyIDs":[],"allergies":[]}}},"method":{"en-US":{"0":{"metadata":{"tags":[],"concepts":[]},"sys":{"space":{"sys":{"type":"Link","linkType":"Space","id":"8ffyq0lxv9d2"}},"id":"76lT5GzeXNNltYNurTSyzT","type":"Entry","createdAt":"2025-12-11T09:43:11.488Z","updatedAt":"2026-01-07T14:34:04.311Z","environment":{"sys":{"id":"master","type":"Link","linkType":"Environment"}},"publishedVersion":4,"revision":2,"contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"method"}}},"fields":{"heading":{"de":"1","en-US":"1"},"description":{"de":"Backofen auf 180 °C Umluft vorheizen. Tomaten, Paprika, rote Zwiebeln und Karotten in eine große, tiefe Ofenform geben. Mit Olivenöl beträufeln und salzen.","en-US":"Preheat the oven to 180°C fan / 390°F. Add the tomatoes, peppers, red onions and carrots to a large, deep roasting tin. Drizzle with olive oil and season with salt. "}},"contentType":"method","isAvailable":true,"new":true,"id":"76lT5GzeXNNltYNurTSyzT","contentfulType":"method","visibility":"Public","presenter":{},"terms":{"en-US":"","de":""},"languages":["de","en-US"],"pillars":[],"isSleep":false,"isWater":false,"categories":[]},"1":{"metadata":{"tags":[],"concepts":[]},"sys":{"space":{"sys":{"type":"Link","linkType":"Space","id":"8ffyq0lxv9d2"}},"id":"6biM7JLeusnVknntLHfLSR","type":"Entry","createdAt":"2025-12-11T09:43:26.234Z","updatedAt":"2026-01-07T14:34:15.482Z","environment":{"sys":{"id":"master","type":"Link","linkType":"Environment"}},"publishedVersion":5,"revision":2,"contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"method"}}},"fields":{"heading":{"de":"2","en-US":"2"},"description":{"de":"Den oberen Teil der Knoblauchknolle abschneiden, in Folie oder Backpapier wickeln und in die Ecke der Form legen. Alles 55–60 Minuten rösten, dabei nach der Hälfte einmal wenden, bis das Gemüse weich ist und die Tomaten zusammenfallen.","en-US":"Slice the very top off the garlic bulb. Wrap it in foil or baking parchment and tuck it in the corner of the tin. Roast for 55–60 minutes, stirring halfway, until the veg are completely tender and the tomatoes have collapsed."}},"contentType":"method","isAvailable":true,"new":true,"id":"6biM7JLeusnVknntLHfLSR","contentfulType":"method","visibility":"Public","presenter":{},"terms":{"en-US":"","de":""},"languages":["de","en-US"],"pillars":[],"isSleep":false,"isWater":false,"categories":[]},"2":{"metadata":{"tags":[],"concepts":[]},"sys":{"space":{"sys":{"type":"Link","linkType":"Space","id":"8ffyq0lxv9d2"}},"id":"6GszWf5zEUohQI3s82W9RZ","type":"Entry","createdAt":"2025-12-11T09:43:40.676Z","updatedAt":"2026-01-07T14:34:26.554Z","environment":{"sys":{"id":"master","type":"Link","linkType":"Environment"}},"publishedVersion":5,"revision":2,"contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"method"}}},"fields":{"heading":{"de":"3","en-US":"3"},"description":{"de":"In der Zwischenzeit das Petersilienöl zubereiten: Petersilie, Knoblauch, Olivenöl und eine großzügige Prise Salz in einem Mini-Zerkleinerer pürieren – oder alles fein hacken und in einer kleinen Schüssel mischen.","en-US":"Meanwhile, make the parsley oil. Add the parsley, garlic, olive oil and a generous pinch of sea salt to a mini-chopper and blend until smooth – or finely chop everything by hand and mix in a small bowl. "}},"contentType":"method","isAvailable":true,"new":true,"id":"6GszWf5zEUohQI3s82W9RZ","contentfulType":"method","visibility":"Public","presenter":{},"terms":{"en-US":"","de":""},"languages":["de","en-US"],"pillars":[],"isSleep":false,"isWater":false,"categories":[]},"3":{"metadata":{"tags":[],"concepts":[]},"sys":{"space":{"sys":{"type":"Link","linkType":"Space","id":"8ffyq0lxv9d2"}},"id":"7IwgQT8COQUKNizEn4pzzM","type":"Entry","createdAt":"2025-12-11T09:44:06.999Z","updatedAt":"2026-01-07T14:34:39.565Z","environment":{"sys":{"id":"master","type":"Link","linkType":"Environment"}},"publishedVersion":4,"revision":2,"contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"method"}}},"fields":{"heading":{"de":"4","en-US":"4"},"description":{"de":"Das geröstete Gemüse kurz abkühlen lassen, dann in einen Hochleistungsmixer geben. Weiße Riesenbohnen, Gemüsebrühe, Misopaste und Basilikum hinzufügen und glatt pürieren. Alternativ alles in einen großen Topf geben und mit dem Stabmixer pürieren.","en-US":"Leave the veg to cool for a few minutes, then transfer to a high-speed blender. Add the butter beans, vegetable stock, miso and basil, then blitz until smooth. You can also tip everything into a large saucepan and use a stick blender. "}},"contentType":"method","isAvailable":true,"new":true,"id":"7IwgQT8COQUKNizEn4pzzM","contentfulType":"method","visibility":"Public","presenter":{},"terms":{"en-US":"","de":""},"languages":["de","en-US"],"pillars":[],"isSleep":false,"isWater":false,"categories":[]},"4":{"metadata":{"tags":[],"concepts":[]},"sys":{"space":{"sys":{"type":"Link","linkType":"Space","id":"8ffyq0lxv9d2"}},"id":"4ezAqoE8mE8X8WigphgVL7","type":"Entry","createdAt":"2025-12-11T09:44:34.643Z","updatedAt":"2026-01-07T14:34:53.430Z","environment":{"sys":{"id":"master","type":"Link","linkType":"Environment"}},"publishedVersion":5,"revision":2,"contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"method"}}},"fields":{"heading":{"de":"5","en-US":"5"},"description":{"de":"Suppe in einem großen Topf bei mittlerer Hitze erhitzen, bis sie richtig heiß ist. Abschmecken und nach Bedarf nachwürzen.","en-US":"Warm in a large saucepan over medium heat until piping hot. Taste and adjust the seasoning as needed."}},"contentType":"method","isAvailable":true,"new":true,"id":"4ezAqoE8mE8X8WigphgVL7","contentfulType":"method","visibility":"Public","presenter":{},"terms":{"en-US":"","de":""},"languages":["de","en-US"],"pillars":[],"isSleep":false,"isWater":false,"categories":[]},"5":{"metadata":{"tags":[],"concepts":[]},"sys":{"space":{"sys":{"type":"Link","linkType":"Space","id":"8ffyq0lxv9d2"}},"id":"4ofddSSwRRIUOWEEGTGJcO","type":"Entry","createdAt":"2025-12-11T09:44:45.749Z","updatedAt":"2026-01-07T14:35:03.735Z","environment":{"sys":{"id":"master","type":"Link","linkType":"Environment"}},"publishedVersion":5,"revision":2,"contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"method"}}},"fields":{"heading":{"de":"6","en-US":"6"},"description":{"de":"Während die Suppe warm wird, Brot toasten, mit dem Knoblauch-Petersilien-Öl bestreichen und in Streifen schneiden. Sofort servieren – mit einem Schuss Olivenöl, reichlich schwarzem Pfeffer und den Toaststicks.","en-US":"Whilst the soup is warming, toast the bread, spread over the garlicky parsley mixture, then cut into soldiers. Serve straightaway with a drizzle of extra virgin olive oil, plenty of black pepper and the toast soldiers."}},"contentType":"method","isAvailable":true,"new":true,"id":"4ofddSSwRRIUOWEEGTGJcO","contentfulType":"method","visibility":"Public","presenter":{},"terms":{"en-US":"","de":""},"languages":["de","en-US"],"pillars":[],"isSleep":false,"isWater":false,"categories":[]}}},"tip":{"de":"Die Suppe lässt sich hervorragend einfrieren. Komplett abkühlen lassen, dann portionsweise einfrieren – perfekt für unkomplizierte Mahlzeiten.","en-US":"This soup freezes brilliantly. Leave to cool completely, then freeze in portions for easy lunches. "},"relatedRecipes":{"en-US":{"0":{"metadata":{"tags":[],"concepts":[]},"sys":{"space":{"sys":{"type":"Link","linkType":"Space","id":"8ffyq0lxv9d2"}},"id":"6BhS9LpJLkrq2cXV0jWYme","type":"Entry","createdAt":"2023-09-15T14:44:45.003Z","updatedAt":"2026-01-07T17:20:32.074Z","environment":{"sys":{"id":"master","type":"Link","linkType":"Environment"}},"publishedVersion":50,"revision":8,"contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"recipe"}}},"fields":{"title":{"de":"Einfache Tomatensuppe mit geröstetem Knoblauch","en-US":"Easy Roasted Garlic \u0026 Tomato Soup"},"slug":{"de":"einfache-tomatensuppe-mit-geroestetem-knoblauch","en-US":"easy-roasted-garlic-and-tomato-soup"},"metaDescription":{"en-US":"This easy tomato soup is as good as it gets — incredibly flavoursome and so simple to make. You’ll be making it on repeat in no time! It's perfect for batch cooking, meaning instant lunches all week."},"availableFrom":{"en-US":"2023-09-18T00:00"},"featuredFrom":{"en-US":"2026-01-13T00:00"},"featuredTo":{"en-US":"2026-01-14T00:00"},"featuredOrder":{"en-US":1},"popularFrom":{"en-US":"2023-10-09T00:00"},"popularTo":{"en-US":"2023-10-23T00:00"},"popularOrder":{"en-US":16},"categories":{"en-US":[{"sys":{"type":"Link","linkType":"Entry","id":"2nNyXpAp40mosMAoI6iaiK"}},{"sys":{"type":"Link","linkType":"Entry","id":"GIFhxoAcB9A7sBWJDAFoi"}},{"sys":{"type":"Link","linkType":"Entry","id":"78ViO8imwz3dNO4mG1NtH"}}]},"description":{"de":"Diese einfache Suppe könnte nicht besser sein – sie ist so geschmacksintensiv und wunderbar unkompliziert. Du wirst sie bestimmt immer wieder machen und kaum Zeitaufwand haben! Sie eignet sich auch perfekt zum Vorkochen, was bedeutet, dass du während der Woche stets ein schnelles Mittagessen hast.","en-US":"This easy soup is as good as it gets — incredibly flavoursome and so simple to make. You’ll be making it on repeat in no time! It's perfect for batch cooking, meaning instant lunches all week.","en-US-POSIX":"This easy soup is as good as it gets — incredibly flavorsome and so simple to make. You’ll be making it on repeat in no time! It's perfect for batch cooking, meaning instant lunches all week."},"heroImage":{"en-US":{"sys":{"type":"Link","linkType":"Asset","id":"1JinjWz8cxMm0b3FLwLXVK"}}},"images":{"en-US":[{"sys":{"type":"Link","linkType":"Asset","id":"52ycJKp0cqNPghcZRKDxQ9"}}]},"servesMaximum":{"en-US":2},"totalMinutes":{"en-US":40},"ingredientSections":{"en-US":[{"sys":{"type":"Link","linkType":"Entry","id":"6lhvWkeNRNSJiFOtVRaSqH"}},{"sys":{"type":"Link","li
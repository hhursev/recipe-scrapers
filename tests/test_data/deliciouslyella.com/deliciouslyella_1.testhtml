id":"iCPkkkl4HRhUCwvJvD7Eg"}}]},"nutrients":{"en-US":["Simple ingredients"]}},"contentType":"recipe","isAvailable":true,"new":false,"id":"2zBC4cXWJOeQ6q8OYaQqWi","contentfulType":"recipe","visibility":"Public","presenter":{},"terms":{"en-US":"classic porridge","de":"klassisches porridge"},"languages":["de","en-US","en-US-POSIX"],"pillars":[],"isSleep":false,"isWater":false,"categories":["2IpnFlvZu0qAy4wK0eye00","5wiUeY7M5K2qVYQ4QQAZvo"],"recipeCategories":[{"id":"2IpnFlvZu0qAy4wK0eye00","name":"Breakfast"},{"id":"5wiUeY7M5K2qVYQ4QQAZvo","name":"under 25 mins"}],"relatedTerms":{"en-US":"    oats  oat milk      banana bananas  maple syrup  almond peanut butter  pumpkin seeds ","de":""},"isPlantBased":false,"allergyIDs":["20t5UqLrQx1IV8uT4uwd2T","6ZMKWrKQhUpBOHASExzcQK","4lMMsj0KNtvWteH7hNGXYo"],"allergies":["Gluten","Nut","Peanuts"]},"6":{"metadata":{"tags":[]},"sys":{"space":{"sys":{"type":"Link","linkType":"Space","id":"8ffyq0lxv9d2"}},"id":"2IpOp8rAsCO7t41KNUbeCD","type":"Entry","createdAt":"2019-01-28T12:09:02.527Z","updatedAt":"2023-08-30T14:43:44.728Z","environment":{"sys":{"id":"master","type":"Link","linkType":"Environment"}},"revision":21,"contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"recipe"}}},"fields":{"title":{"de":"Porridge mit Gewürzen","en-US":"Spiced Porridge","en-US-POSIX":"Spiced Oatmeal"},"slug":{"en-US":"spiced-porridge"},"metaDescription":{"en-US":"When the weather is cold this spiced porridge is my go-to. The mix of cinnamon, ginger and turmeric with coconut sugar, raisins and sunflower seeds is really delicious and then I add banana slices and maple to finish it off.  "},"availableFrom":{"en-US":"2018-12-13T00:00"},"featuredFrom":{"en-US":"2022-10-18T00:00"},"featuredTo":{"en-US":"2022-10-19T00:00"},"featuredOrder":{"en-US":1},"popularFrom":{"en-US":"2022-11-14T00:00"},"popularTo":{"en-US":"2022-11-28T00:00"},"categories":{"en-US":[{"sys":{"type":"Link","linkType":"Entry","id":"2IpnFlvZu0qAy4wK0eye00"}}]},"description":{"de":"Wenn es draußen kalt ist, mache ich mir dieses Porridge. Die wunderbaren Gewürze haben eine wärmende Wirkung. Jeder Bissen schmeckt nach Zimt, Ingwer und Kurkuma, dazu kommen Kokosblütenzucker, Rosinen und Sonnenblumenkerne. Ich gebe noch Bananenscheiben und Ahornsirup darauf.","en-US":"When the weather is cold this spiced porridge is my go-to. It’s so warming and has such lovely spices in each bite. The mix of cinnamon, ginger and turmeric with coconut sugar, raisins and sunflower seeds is really delicious and then I add banana slices and maple to finish it off.  \n"},"heroImage":{"en-US":{"sys":{"type":"Link","linkType":"Asset","id":"79F3x19bqrL8QxRcoartAt"}}},"heroVideo":{"en-US":"https://vimeo.com/316062645/ab2dcf2485"},"images":{"en-US":[{"sys":{"type":"Link","linkType":"Asset","id":"4bq7qNV0PpDchd8PfPM67n"}}]},"servesMinimum":{"en-US":1},"servesMaximum":{"en-US":2},"prepTimeText":{"de":"5-10 Minuten","en-US":"5-10 minutes"},"cookTimeText":{"de":"5 Minuten","en-US":"5 minutes"},"totalMinutes":{"en-US":10},"ingredientSections":{"en-US":[{"sys":{"type":"Link","linkType":"Entry","id":"EDl3OB0WFkh4FDQjGd2OX"}},{"sys":{"type":"Link","linkType":"Entry","id":"2eS0fZUckDqZz9Xv29P2ws"}}]},"method":{"en-US":[{"sys":{"type":"Link","linkType":"Entry","id":"1D8njYFsyJkf41dFgBvTEu"}},{"sys":{"type":"Link","linkType":"Entry","id":"2cWhnQ96rfYoGgNtxu7wyh"}},{"sys":{"type":"Link","linkType":"Entry","id":"1UD38ksbk0twFoqesN96zz"}},{"sys":{"type":"Link","linkType":"Entry","id":"3WFMJLMBFnMJ0HJdnEsLsc"}}]},"relatedRecipes":{"en-US":[{"sys":{"type":"Link","linkType":"Entry","id":"2r2lNnpxI0CSMu2OI6CUWw"}},{"sys":{"type":"Link","linkType":"Entry","id":"1GmZtVHGd2iOqqauwOCMeo"}},{"sys":{"type":"Link","linkType":"Entry","id":"glUMlGNQoEkI0EUSoI6I4"}}]},"subcategories":{"en-US":[{"sys":{"type":"Link","linkType":"Entry","id":"6I0AEjs6xMaRtf4s7n3vxU"}},{"sys":{"type":"Link","linkType":"Entry","id":"2I2ItwDXUGl9AW1hy0fVVu"}},{"sys":{"type":"Link","linkType":"Entry","id":"6bfjhWWwJuymYWT
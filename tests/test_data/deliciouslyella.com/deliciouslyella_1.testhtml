data":{"tags":[],"concepts":[]},"sys":{"space":{"sys":{"type":"Link","linkType":"Space","id":"8ffyq0lxv9d2"}},"id":"1dewQIPShFMosSNC9gcPBQ","type":"Entry","createdAt":"2024-10-04T09:17:10.808Z","updatedAt":"2026-01-21T16:13:19.819Z","environment":{"sys":{"id":"master","type":"Link","linkType":"Environment"}},"publishedVersion":64,"revision":10,"contentType":{"sys":{"type":"Link","linkType":"ContentType","id":"recipe"}}},"fields":{"title":{"de":"20 Minuten Lauch-Erbsen-Schwarzkohl-Suppe","en-US":"20-Minute Leek, Pea \u0026 Cavolo Nero Soup ","en-US-POSIX":"20-Minute Leek, Pea \u0026 Black Kale Soup "},"slug":{"de":"20-minuten-lauch-erbsen-schwarzkohl-suppe","en-US":"20-minute-leek-pea-and-cavolo-nero-soup","en-US-POSIX":"20-minute-leek-pea-and-black-kale-soup"},"metaTitle":{"de":"20 Minuten Lauch-Erbsen-Schwarzkohl-Suppe","en-US":"20-Minute Leek, Pea \u0026 Cavolo Nero Soup "},"metaDescription":{"en-US":"We’ve been cooking this creamy green soup on repeat now that Cavolo Nero is in season. It’s filled with a nourishing mixture of green veg, blended with protein-packed butter beans and topped with crunchy lentils. "},"availableFrom":{"en-US":"2024-10-06T00:00"},"featuredFrom":{"en-US":"2026-01-27T00:00"},"featuredTo":{"en-US":"2026-01-28T00:00"},"featuredOrder":{"en-US":1},"popularFrom":{"en-US":"2024-11-18T00:00"},"popularTo":{"en-US":"2024-11-25T00:00"},"popularOrder":{"en-US":16},"categories":{"en-US":[{"sys":{"type":"Link","linkType":"Entry","id":"2nNyXpAp40mosMAoI6iaiK"}}]},"description":{"de":"Seit der Schwarzkohl wieder Saison hat, kochen wir diese Suppe ständig! Sie steckt voller grüner Power, ist durch weiße Bohnen wunderbar cremig und bekommt mit knusprigen Linsen ein tolles Topping. Perfekt für ein schnelles Mittagessen oder ein wohltuendes Abendessen, wenn es mal unkompliziert sein soll.","en-US":"We’ve been cooking this creamy green soup on repeat now that Cavolo Nero is in season. It’s filled with a nourishing mixture of green veg, blended with protein-packed butter beans and topped with crunchy lentils. It’s the perfect quick lunch or comforting supper for when you’re lacking in time and energy, but still want to eat something nourishing.","en-US-POSIX":"We’ve been cooking this cosy, super green soup on repeat now that black kale is back in season. The nourishing mix of green veggies, paired with protein-packed butter beans, creates a creamy texture, while the crispy lentil topping adds a satisfying crunch. It’s the perfect quick lunch or comforting supper for when you’re lacking in time and energy, but still want to eat something nourishing."},"heroImage":{"en-US":{"sys":{"type":"Link","linkType":"Asset","id":"3pN4zDz9eg0fLXgXafz4Gh"}}},"images":{"en-US":[{"sys":{"type":"Link","linkType":"Asset","id":"WGts1gzlzgCxzZ0lpxERW"}}]},"servesMaximum":{"en-US":4},"totalMinutes":{"en-US":20},"ingredientSections":{"en-US":[{"sys":{"type":"Link","linkType":"Entry","id":"1WRxaJUw7RGmF6LhvGmLc6"}},{"sys":{"type":"Link","linkType":"Entry","id":"46cflE6ExWcG9sTv99AWVw"}}]},"method":{"en-US":[{"sys":{"type":"Link","linkType":"Entry","id":"6HImxOJ1AFDEYRWOtg8Q8U"}},{"sys":{"type":"Link","linkType":"Entry","id":"6q4eJLhrno9uNVKBUZSGPx"}},{"sys":{"type":"Link","linkType":"Entry","id":"2XpbfsQnpCiRdxUqTvZdo"}},{"sys":{"type":"Link","linkType":"Entry","id":"rI7uz6G0OG18OCtrdXi2X"}},{"sys":{"type":"Link","linkType":"Entry","id":"6nqKSFPREV3fgmlJ0tHrWw"}}]},"tip":{"de":"Falls du keinen Schwarzkohl findest, lässt er sich problemlos durch Grünkohl ersetzen.","en-US":"If you can’t find cavolo nero, you can easily swap it for kale. ","en-US-POSIX":"If you can’t find black kale, you can easily swap it for curly kale. "},"relatedRecipes":{"en-US":[{"sys":{"type":"Link","linkType":"Entry","id":"jtfJAeHIESiKEU4ouCoIo"}},{"sys":{"type":"Link","linkType":"Entry","id":"1okBOfYcvSsVc1hgvJ7bBp"}},{"sys":{"type":"Link","linkType":"Entry","id":"tr7aG4VOJHujonbQGAAb6"}},{"sys":{"type":"Link","linkType":"Entry","id":"3DlCYDcKSbSqfap2c6snIQ"}}]},"subcat
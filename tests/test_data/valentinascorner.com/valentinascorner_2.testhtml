entinascorner.com\/","name":"Valentina&#039;s Corner","description":"Hundreds of classic recipes the whole family will love with detailed instructions.","publisher":{"@id":"https:\/\/valentinascorner.com\/#organization"},"potentialAction":[{"@type":"SearchAction","target":{"@type":"EntryPoint","urlTemplate":"https:\/\/valentinascorner.com\/?s={search_term_string}"},"query-input":{"@type":"PropertyValueSpecification","valueRequired":true,"valueName":"search_term_string"}}],"inLanguage":"en-US"},{"@type":"Organization","@id":"https:\/\/valentinascorner.com\/#organization","name":"Valentina's Corner","url":"https:\/\/valentinascorner.com\/","logo":{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/valentinascorner.com\/#\/schema\/logo\/image\/","url":"https:\/\/valentinascorner.com\/wp-content\/uploads\/2024\/10\/logo-black.svg","contentUrl":"https:\/\/valentinascorner.com\/wp-content\/uploads\/2024\/10\/logo-black.svg","width":265,"height":60,"caption":"Valentina's Corner"},"image":{"@id":"https:\/\/valentinascorner.com\/#\/schema\/logo\/image\/"}},{"@type":"Person","@id":"https:\/\/valentinascorner.com\/#\/schema\/person\/695a73a530ad9016494db5cf59a3aacc","name":"Valentina Ablaev","image":{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/secure.gravatar.com\/avatar\/4fc38d266ac3026c5bc1a87e805a98750f90ca7bcd4bafbbac779dca4f215144?s=96&d=blank&r=g","url":"https:\/\/secure.gravatar.com\/avatar\/4fc38d266ac3026c5bc1a87e805a98750f90ca7bcd4bafbbac779dca4f215144?s=96&d=blank&r=g","contentUrl":"https:\/\/secure.gravatar.com\/avatar\/4fc38d266ac3026c5bc1a87e805a98750f90ca7bcd4bafbbac779dca4f215144?s=96&d=blank&r=g","caption":"Valentina Ablaev"},"sameAs":["https:\/\/valentinascorner.com\/valentina-ablaev\/"]},{"@type":"Question","@id":"https:\/\/valentinascorner.com\/strawberry-shortcake-cupcakes\/#faq-question-1711736816056","position":1,"url":"https:\/\/valentinascorner.com\/strawberry-shortcake-cupcakes\/#faq-question-1711736816056","name":"Can frozen strawberries be used for this recipe?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"We recommend only using fresh strawberries, as frozen strawberries will release too much moisture. ","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https:\/\/valentinascorner.com\/strawberry-shortcake-cupcakes\/#faq-question-1711736848846","position":2,"url":"https:\/\/valentinascorner.com\/strawberry-shortcake-cupcakes\/#faq-question-1711736848846","name":"Am I able to use a boxed cake mix? ","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Make this recipe even easier by using a boxed cake mix!","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https:\/\/valentinascorner.com\/strawberry-shortcake-cupcakes\/#faq-question-1711736861529","position":3,"url":"https:\/\/valentinascorner.com\/strawberry-shortcake-cupcakes\/#faq-question-1711736861529","name":"Is there a different frosting I can use? ","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"You can use a vanilla whipped cream frosting or even a cheesecake frosting. ","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https:\/\/valentinascorner.com\/strawberry-shortcake-cupcakes\/#faq-question-1711736872525","position":4,"url":"https:\/\/valentinascorner.com\/strawberry-shortcake-cupcakes\/#faq-question-1711736872525","name":"What can I substitute for strawberry jelly?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"You can use a strawberry jam or make your own strawberry jam.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Recipe","name":"Strawberry Shortcake Cupcakes","author":{"@id":"https:\/\/valentinascorner.com\/#\/schema\/person\/695a73a530ad9016494db5cf59a3aacc"},"description":"These strawberry shortcake cupcakes are the most scrumptious dessert. Each bite of soft vanilla cupcake is full of glazed strawberries and topped with a rich cream cheese frosting. This recipe is easy to follow and will inspire you to get creative with your cupcakes.","datePublished":"2024-04-26T14:00:00+00:00","image":["https:\/\/valentinascorner.com\/wp-content\/uploads\/2024\/04\/Strawberry-Shortcake-Cupcake-5.jpg","https:\/\/valentinascorner.com\/wp-content\/uploads\/2024\/04\/Strawberry-Shortcake-Cupcake-5-500x500.jpg","https:\/\/valentinascorner.com\/wp-content\/uploads\/2024\/04\/Strawberry-Shortcake-Cupcake-5-500x375.jpg","https:\/\/valentinascorner.com\/wp-content\/uploads\/2024\/04\/Strawberry-Shortcake-Cupcake-5-480x270.jpg"],"recipeYield":["12","12 cupcakes"],"prepTime":"PT20M","cookTime":"PT15M","totalTime":"PT35M","recipeIngredient":["1 1\/4 cup all-purpose flour (measured then sifted)","1½ tsp baking powder","¼ tsp salt","8 Tbsps unsalted butter (room temperature)","3\/4 cup granulated sugar","2 tsp vanilla extract","1\/3 cup whole milk","3 Tbsps sour cream","2  large eggs","1 Tbsp oil","8 oz cream cheese (room temp)","1 cup unsalted butter (room temp (2 sticks))","2 tsp vanilla extract","3 cups powdered sugar","8 oz fresh strawberries (cubed)","3 Tbsp strawberry jelly"],"recipeInstructions":[{"@type":"HowToSection","name":"bake the cupcakes -","itemListElement":[{"@type":"HowToStep","text":"Preheat the oven to 350°F and line the cupcake pan with cupcake liners.","name":"Preheat the oven to 350°F and line the cupcake pan with cupcake liners.","url":"https:\/\/valentinascorner.com\/strawberry-shortcake-cupcakes\/#wprm-recipe-322388-step-0-0"},{"@type":"HowToStep","text":"In a large bowl, sift together flour, baking powder, and salt.","name":"In a large bowl, sift together flour, baking powder, and salt.","url":"https:\/\/valentinascorner.com\/strawberry-shortcake-cupcakes\/#wprm-recipe-322388-step-0-1"},{"@type":"HowToStep","text":"In a separate bowl, beat butter until creamy. Add sugar and beat until light and fluffy. Beat in vanilla, milk, sour cream, eggs, and oil. Mix until combined.","name":"In a separate bowl, beat butter until creamy. Add sugar and beat until light and fluffy. Beat in vanilla, milk, sour cream, eggs, and oil. Mix until combined.","url":"https:\/\/valentinascorner.com\/strawberry-shortcake-cupcakes\/#wprm-recipe-322388-step-0-2"},{"@type":"HowToStep","text":"Add dry ingredients to the wet batter and gently mix in. Divide the batter evenly between the cupcake liners.","name":"Add dry ingredients to the wet batter and gently mix in. Divide the batter evenly between the cupcake liners.","url":"https:\/\/valentinascorner.com\/strawberry-shortcake-cupcakes\/#wprm-recipe-322388-step-0-3"},{"@type":"HowToStep","text":"Bake for 16-18 minutes or until the tops are golden. Remove the cupcakes from the oven and set on a cooling rack. Let cupcakes fully cool before frosting.","name":"Bake for 16-18 minutes or until the tops are golden. Remove the cupcakes from the oven and set on a cooling rack. Let cupcakes fully cool before frosting.","url":"https:\/\/valentinascorner.com\/strawberry-shortcake-cupcakes\/#wprm-recipe-322388-step-0-4"}]},{"@type":"HowToSection","name":"frosting -","itemListElement":[{"@type":"HowToStep","text":"Using an electric stand mixer, cream together cream cheese and butter with the paddle attachment.","name":"Using an electric stand mixer, cream together cream cheese and butter with the paddle attachment.","url":"https:\/\/valentinascorner.com\/strawberry-shortcake-cupcakes\/#wprm-recipe-322388-step-1-0"},{"@type":"HowToStep","text":"Once the mixture is light and fluffy, add vanilla extract and powdered sugar. Beat until the frosting is fluffy. Refrigerate until ready to use.","name":"Once the mixture is light and fluffy, add vanilla extract and powdered sugar. Beat until the frosting is fluffy. Refrigerate until ready to use.","url":"https:\/\/valentinascorner.com\/strawberry-shortcake-cupcakes\/#wprm-recipe-322388-step-1-1"}]},{"@type":"HowToSection","name":"assemble cupcakes -","itemListElement":[{"@type":"HowToStep","text":"Cut the strawberries into cubes. In a small bowl, combine strawberries with jelly.","name":"Cut the strawberries into cubes. In a small bowl, combine strawberries with jelly.","url":"https:\/\/valentinascorner.com\/strawberry-shortcake-cupcakes\/#wprm-recipe-322388-step-2-0"},{"@type":"HowToStep","text":"Once the cupcakes are cooled, hollow out each cupcake about ½ an inch deep.","name":"Once the cupcakes are cooled, hollow out each cupcake about ½ an inch deep.","url":"https:\/\/valentinascorner.com\/strawberry-shortcake-cupcakes\/#wprm-recipe-322388-step-2-1"},{"@type":"HowToStep","text":"Fill each hole of the cupcake with the strawberry glaze. Pipe the frosting on top of each cupcake.","name":"Fill each hole of the cupcake with the strawberry glaze. Pipe the frosting on top of each cupcake.","url":"https:\/\/valentinascorner.com\/strawberry-shortcake-cupcakes\/#wprm-recipe-322388-step-2-2"},{"@type":"HowToStep","text":"Garnish the cupcakes with more glaze or sliced strawberries.","name":"Garnish the cupcakes with more glaze or sliced strawberries.","url":"https:\/\/valentinascorner.com\/strawberry-shortcake-cupcakes\/#wprm-recipe-322388-step-2-3"},{"@type":"HowToStep","text":"Serve and enjoy friends!","name":"Serve and enjoy friends!","url":"https:\/\/valentinascorner.com\/strawberry-shortcake-cupcakes\/#wprm-recipe-322388-step-2-4"}]}],"aggregateRating":{"@type":"AggregateRating","ratingValue":"5","ratingCount":"7","reviewCount":"3"},"review":[{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"It was very delicious! My family loved it!","author":{"@type":"Person","name":"Inessa"},"datePublished":"2025-09-27"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Talk about amazing. These were SO GOOD.","author":{"@type":"Person","name":"April"},"datePublished":"2022-04-05"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"These are so good!! We love strawberries &amp; finding ways to enjoy them in desserts, is the best!!","author":{"@type":"Person","name":"Kristyn"},"datePublished":"2022-04-05"}],"recipeCategory":["Dessert"],"recipeCuisine":["American"],"keywords":"strawberry shortcake cupcakes","nutrition":{"@type":"NutritionInformation","calories":"536 kcal","carbohydrateContent":"59 g","proteinContent":"4 g","fatContent":"32 g","saturatedFatContent":"19 g","transFatContent":"1 g","cholesterolContent":"110 mg","sodiumContent":"128 mg","fiberContent":"1 g","sugarContent":"47 g","unsaturatedFatContent":"11 g","servingSize":"1 serving"},"@id":"https:\/\/valentinascorner.com\/strawberry-shortcake-cupcakes\/#recipe","isPartOf":{"@id":"https:\/\/valentinascorner.com\/strawberry-shortcake-cupcakes\/#article"},"mainEntityOfPage":"https:\/\/valentinascorner.com\/strawberry-shortcake-cupcakes\/"}]}</script>

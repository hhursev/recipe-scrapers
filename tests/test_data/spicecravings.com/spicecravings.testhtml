	<script type="application/ld+json" class="yoast-schema-graph">{"@context":"https://schema.org","@graph":[{"@type":"Article","@id":"https://spicecravings.com/aloo-tikki#article","isPartOf":{"@id":"https://spicecravings.com/aloo-tikki"},"author":{"name":"Aneesha Gupta","@id":"https://spicecravings.com/#/schema/person/46606db61f3dd51782895e853e728f54"},"headline":"Aloo Tikki","datePublished":"2022-02-11T19:00:00+00:00","dateModified":"2022-02-12T05:44:32+00:00","wordCount":1995,"commentCount":0,"publisher":{"@id":"https://spicecravings.com/#organization"},"image":{"@id":"https://spicecravings.com/aloo-tikki#primaryimage"},"thumbnailUrl":"https://spicecravings.com/wp-content/uploads/2022/02/Aloo-Tikki-Featured-1.jpg","articleSection":["30 Minutes Recipes","Appetizers","Game Day Recipes","Gluten Free","Indian Recipes","Stove Top","Vegan","Vegetarian"],"inLanguage":"en-US","potentialAction":[{"@type":"CommentAction","name":"Comment","target":["https://spicecravings.com/aloo-tikki#respond"]}]},{"@type":["WebPage","FAQPage"],"@id":"https://spicecravings.com/aloo-tikki","url":"https://spicecravings.com/aloo-tikki","name":"Aloo Tikki - Spice Cravings","isPartOf":{"@id":"https://spicecravings.com/#website"},"primaryImageOfPage":{"@id":"https://spicecravings.com/aloo-tikki#primaryimage"},"image":{"@id":"https://spicecravings.com/aloo-tikki#primaryimage"},"thumbnailUrl":"https://spicecravings.com/wp-content/uploads/2022/02/Aloo-Tikki-Featured-1.jpg","datePublished":"2022-02-11T19:00:00+00:00","dateModified":"2022-02-12T05:44:32+00:00","description":"Easy 25-minute recipe for┬ĀAloo Tikki,┬Āa popular Indian snack, in which potato and peas patties are pan-fried until golden brown and crispy.","breadcrumb":{"@id":"https://spicecravings.com/aloo-tikki#breadcrumb"},"mainEntity":[{"@id":"https://spicecravings.com/aloo-tikki#faq-question-1644243834550"},{"@id":"https://spicecravings.com/aloo-tikki#faq-question-1644243827904"},{"@id":"https://spicecravings.com/aloo-tikki#faq-question-1644242808947"},{"@id":"https://spicecravings.com/aloo-tikki#faq-question-1644243822888"}],"inLanguage":"en-US","potentialAction":[{"@type":"ReadAction","target":["https://spicecravings.com/aloo-tikki"]}]},{"@type":"ImageObject","inLanguage":"en-US","@id":"https://spicecravings.com/aloo-tikki#primaryimage","url":"https://spicecravings.com/wp-content/uploads/2022/02/Aloo-Tikki-Featured-1.jpg","contentUrl":"https://spicecravings.com/wp-content/uploads/2022/02/Aloo-Tikki-Featured-1.jpg","width":1200,"height":1200,"caption":"plate of aloo tikki and chutney from above"},{"@type":"BreadcrumbList","@id":"https://spicecravings.com/aloo-tikki#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://spicecravings.com/"},{"@type":"ListItem","position":2,"name":"All Recipes","item":"https://spicecravings.com/recipe-index"},{"@type":"ListItem","position":3,"name":"Appetizers","item":"https://spicecravings.com/category/appetizers"},{"@type":"ListItem","position":4,"name":"Aloo Tikki"}]},{"@type":"WebSite","@id":"https://spicecravings.com/#website","url":"https://spicecravings.com/","name":"Spice Cravings","description":"Easy, Flavorful &amp; Simplified Global Recipes","publisher":{"@id":"https://spicecravings.com/#organization"},"potentialAction":[{"@type":"SearchAction","target":{"@type":"EntryPoint","urlTemplate":"https://spicecravings.com/?s={search_term_string}"},"query-input":{"@type":"PropertyValueSpecification","valueRequired":true,"valueName":"search_term_string"}}],"inLanguage":"en-US"},{"@type":"Organization","@id":"https://spicecravings.com/#organization","name":"Spice Cravings","url":"https://spicecravings.com/","logo":{"@type":"ImageObject","inLanguage":"en-US","@id":"https://spicecravings.com/#/schema/logo/image/","url":"https://spicecravings.com/wp-content/uploads/2018/04/Logo-300-X-300White.jpg","contentUrl":"https://spicecravings.com/wp-content/uploads/2018/04/Logo-300-X-300White.jpg","width":300,"height":300,"caption":"Spice Cravings"},"image":{"@id":"https://spicecravings.com/#/schema/logo/image/"},"sameAs":["https://www.facebook.com/spicecravings/","https://x.com/spicecravings","https://www.instagram.com/spicecravings/","https://www.pinterest.com/spicecravings/","https://www.youtube.com/spicecravings"]},{"@type":"Person","@id":"https://spicecravings.com/#/schema/person/46606db61f3dd51782895e853e728f54","name":"Aneesha Gupta","sameAs":["https://spicecravings.com/about-spice-cravings","spicecravings","https://x.com/spicecravings","https://www.youtube.com/spicecravings"]},{"@type":"Question","@id":"https://spicecravings.com/aloo-tikki#faq-question-1644243834550","position":1,"url":"https://spicecravings.com/aloo-tikki#faq-question-1644243834550","name":"What is aloo tikki called in English?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Aloo means potatoes and tikki means patty. So aloo tikki literally translates to potato patties! ","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https://spicecravings.com/aloo-tikki#faq-question-1644243827904","position":2,"url":"https://spicecravings.com/aloo-tikki#faq-question-1644243827904","name":"Who invented tikki?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Aloo tikki originated in the Indian subcontinent but are now served in various ways all over the world.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https://spicecravings.com/aloo-tikki#faq-question-1644242808947","position":3,"url":"https://spicecravings.com/aloo-tikki#faq-question-1644242808947","name":"Why do my aloo tikki fall apart?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"If your aloo tikki is falling apart, chances are there is too much moisture or not enough binding agent present in the mixture. To prevent this, be careful not to over-cook the potatoes. Additionally, let the cooked potatoes cool slightly before combining them with the rest of the ingredients.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https://spicecravings.com/aloo-tikki#faq-question-1644243822888","position":4,"url":"https://spicecravings.com/aloo-tikki#faq-question-1644243822888","name":"Is aloo tikki vegan?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Yes! This aloo tikki recipe is made without any eggs or dairy, so it's completely vegan. Unless, of course, you choose to serve it with yogurt.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Recipe","name":"Aloo Tikki","author":{"@id":"https://spicecravings.com/#/schema/person/46606db61f3dd51782895e853e728f54"},"description":"Easy 25-minute recipe for┬ĀAloo Tikki,┬Āa popular north-Indian street food! Mashed┬Āpotato and peas are formed into patties then pan-fried until golden brown and crispy.","datePublished":"2022-02-11T11:00:00+00:00","image":["https://spicecravings.com/wp-content/uploads/2022/02/Aloo-Tikki-Featured-1.jpg","https://spicecravings.com/wp-content/uploads/2022/02/Aloo-Tikki-Featured-1-500x500.jpg","https://spicecravings.com/wp-content/uploads/2022/02/Aloo-Tikki-Featured-1-500x375.jpg","https://spicecravings.com/wp-content/uploads/2022/02/Aloo-Tikki-Featured-1-480x270.jpg"],"video":{"name":"Aloo Tikki Recipe","description":"Easy 25-minute recipe for Aloo Tikki, an extremely popular north-Indian street food. Mashed potatoes, green peas, herbs, and seasonings are combined and formed into patties, then pan-fried until golden brown and crispy.\n\nFull Recipe: https://spicecravings.com/aloo-tikki\n\nEnjoy them with cilantro and tamarind chutney, with a cup of chai, or combine with spiced yogurt for classic Aloo Tikki Chaat!\n\nFor more easy recipes Ō×Ī’ĖÅ  SUBSCRIBE to Spice Cravings at https://spicecravings.com\n\nJoin us on your favorite Social media channel:\nFACEBOOK: https://www.facebook.com/spicecravings/\nINSTAGRAM: https://instagram.com/spicecravings/\nPINTEREST: https://www.pinterest.com/spicecravings/\nTIKTOK: https://www.tiktok.com/@spicecravings\nTWITTER: https://twitter.com/spicecravings\n\nThanks for watching!","uploadDate":"2022-02-11T19:00:05+00:00","duration":"PT58S","thumbnailUrl":"https://i.ytimg.com/vi/7H9MFLO1anA/hqdefault.jpg","embedUrl":"https://www.youtube.com/embed/7H9MFLO1anA?feature=oembed","contentUrl":"https://www.youtube.com/watch?v=7H9MFLO1anA","@type":"VideoObject"},"recipeYield":["8","8 Tikkis"],"prepTime":"PT15M","cookTime":"PT10M","totalTime":"PT25M","recipeIngredient":["3-4  boiled gold potatoes (2 cups grated potato)","┬Į cup green peas","┬Į cup chopped onion (1 small white or red onion)","1 teaspoon grated ginger","1  serrano chili (finely chopped (remove seeds for mild heat))","2 tablespoons chopped cilantro leaves","1 teaspoon Himalayan salt (or ┬Š teaspoon regular salt)","┬Į teaspoon dry mango powder","┬Į teaspoon chaat masala","1 teaspoon coriander powder","┬Į teaspoon cumin powder","┬╝ teaspoon red chili powder or cayenne (adjust to taste)","2 tablespoons cornstarch + 2 teaspoons for dusting (or rice flour)","┬Į cup avocado oil for frying (or any clear oil)","Cilantro chutney","tamarind chutney","seasoned yogurt"],"recipeInstructions":[{"@type":"HowToStep","text":"Prepare Potatoes: Start by boiling the potatoes in the microwave using the &#39;potatoes&#39; preset, or in the Instant Pot. Cool and grate them to make roughly 2 cups of grated potatoes.","name":"Prepare Potatoes: Start by boiling the potatoes in the microwave using the &#39;potatoes&#39; preset, or in the Instant Pot. Cool and grate them to make roughly 2 cups of grated potatoes.","url":"https://spicecravings.com/aloo-tikki#wprm-recipe-31321-step-0-0"},{"@type":"HowToStep","text":"Steam Peas: If frozen, thaw the peas overnight in the fridge, or in the microwave. Add ┬Į cup water to a frypan and bring it to a simmer. Add peas, cover, and cook for 5 minutes, or until the peas are steamed. Alternatively, sprinkle some water over them and microwave in 30-second increments, until thawed.","name":"Steam Peas: If frozen, thaw the peas overnight in the fridge, or in the microwave. Add ┬Į cup water to a frypan and bring it to a simmer. Add peas, cover, and cook for 5 minutes, or until the peas are steamed. Alternatively, sprinkle some water over them and microwave in 30-second increments, until thawed.","url":"https://spicecravings.com/aloo-tikki#wprm-recipe-31321-step-0-1"},{"@type":"HowToStep","text":"Assemble: In a large mixing bowl, add grated potatoes, peas, chopped onion, cilantro, grated ginger, and all the spices. Mix well.","name":"Assemble: In a large mixing bowl, add grated potatoes, peas, chopped onion, cilantro, grated ginger, and all the spices. Mix well.","url":"https://spicecravings.com/aloo-tikki#wprm-recipe-31321-step-0-2"},{"@type":"HowToStep","text":"Add cornstarch: Now add 2 tablespoons cornstarch (or rice flour) and mix again until fully integrated.","name":"Add cornstarch: Now add 2 tablespoons cornstarch (or rice flour) and mix again until fully integrated.","url":"https://spicecravings.com/aloo-tikki#wprm-recipe-31321-step-0-3"},{"@type":"HowToStep","text":"Form Patties: Divide the mixture into 8 portions. Apply a little oil on your palms and shape each portion into a round patty, about ┬Į-inch thick. Repeat this process to form all the tikkis.","name":"Form Patties: Divide the mixture into 8 portions. Apply a little oil on your palms and shape each portion into a round patty, about ┬Į-inch thick. Repeat this process to form all the tikkis.","url":"https://spicecravings.com/aloo-tikki#wprm-recipe-31321-step-0-4"},{"@type":"HowToStep","text":"Dust Patties (optional step): Rub 1 teaspoon rice flour or cornstarch in your hands and lightly dust each patty with it. Wipe off any excess using a kitchen towel. Dusting dries up any excess moisture on the surface and seals the patties, resulting in a crispier tikki. This step is optional though.","name":"Dust Patties (optional step): Rub 1 teaspoon rice flour or cornstarch in your hands and lightly dust each patty with it. Wipe off any excess using a kitchen towel. Dusting dries up any excess moisture on the surface and seals the patties, resulting in a crispier tikki. This step is optional though.","url":"https://spicecravings.com/aloo-tikki#wprm-recipe-31321-step-0-5"},{"@type":"HowToStep","text":"Shallow Fry: Add oil to a large frypan and heat it on medium-high heat. Check the temperature of oil by dropping a small crumb. If it starts sizzling, the oil is ready. Discard the crumb and add the tikkis without overcrowding the pan.","name":"Shallow Fry: Add oil to a large frypan and heat it on medium-high heat. Check the temperature of oil by dropping a small crumb. If it starts sizzling, the oil is ready. Discard the crumb and add the tikkis without overcrowding the pan.","url":"https://spicecravings.com/aloo-tikki#wprm-recipe-31321-step-0-6"},{"@type":"HowToStep","text":"Cook till Golden Brown: Cook till the base of the aloo tikki turns golden brown, takes about 4 minutes. Carefully flip the patties and cook on this side until golden brown. Flip them again if needed to brown them evenly.","name":"Cook till Golden Brown: Cook till the base of the aloo tikki turns golden brown, takes about 4 minutes. Carefully flip the patties and cook on this side until golden brown. Flip them again if needed to brown them evenly.","url":"https://spicecravings.com/aloo-tikki#wprm-recipe-31321-step-0-7"},{"@type":"HowToStep","text":"Cool and serve: Remove fried aloo tikkis on a kitchen towel-lined plate. Cool for 5 minutes, then serve with cilantro chutney and tamarind chutney. You can also make Aloo Tikki Chaat by adding seasoned yogurt.","name":"Cool and serve: Remove fried aloo tikkis on a kitchen towel-lined plate. Cool for 5 minutes, then serve with cilantro chutney and tamarind chutney. You can also make Aloo Tikki Chaat by adding seasoned yogurt.","url":"https://spicecravings.com/aloo-tikki#wprm-recipe-31321-step-0-8"}],"aggregateRating":{"@type":"AggregateRating","ratingValue":"5","ratingCount":"1"},"recipeCategory":["Appetizer","Snack"],"recipeCuisine":["Indian"],"suitableForDiet":["https://schema.org/GlutenFreeDiet","https://schema.org/VeganDiet","https://schema.org/VegetarianDiet"],"keywords":"Aloo Tikki, Aloo Tikki chaat, aloo tikki recipe, how to make aloo tikki","nutrition":{"@type":"NutritionInformation","calories":"191 kcal","carbohydrateContent":"16 g","proteinContent":"2 g","fatContent":"14 g","saturatedFatContent":"2 g","sodiumContent":"296 mg","fiberContent":"2 g","sugarContent":"2 g","unsaturatedFatContent":"12 g","servingSize":"1 serving"},"@id":"https://spicecravings.com/aloo-tikki#recipe","isPartOf":{"@id":"https://spicecravings.com/aloo-tikki#article"},"mainEntityOfPage":"https://spicecravings.com/aloo-tikki"}]}</script>
	<!-- / Yoast SEO Premium plugin. -->



<div class="adthrive-video-player in-post" itemscope itemtype="https://schema.org/VideoObject" data-video-id="SZ7bP5Vj" data-player-type="default" override-embed="default">
			<meta itemprop="uploadDate" content="2022-02-11T19:00:00.000Z" />
		<meta itemprop="name" content="Aloo Tikki" />
		<meta itemprop="description" content="Easy 25-minute recipe for&nbsp;Aloo Tikki,&nbsp;an extremely popular north-Indian street food. Mashed potatoes, green peas, herbs, and seasonings are combined and formed into patties, then pan-fried until golden brown and crispy. " />
		<meta itemprop="thumbnailUrl" content="https://content.jwplatform.com/thumbs/SZ7bP5Vj-720.jpg" />

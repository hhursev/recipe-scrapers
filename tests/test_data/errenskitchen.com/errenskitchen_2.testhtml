w.errenskitchen.com\/#\/schema\/person\/82e1344eb773af20b602fa19136754d7","name":"Erren Hart","pronouns":"she\/her","image":{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/www.errenskitchen.com\/wp-content\/uploads\/2025\/10\/Erren-square.jpg","url":"https:\/\/www.errenskitchen.com\/wp-content\/uploads\/2025\/10\/Erren-square.jpg","contentUrl":"https:\/\/www.errenskitchen.com\/wp-content\/uploads\/2025\/10\/Erren-square.jpg","width":1200,"height":1200,"caption":"Erren Hart"},"logo":{"@id":"https:\/\/www.errenskitchen.com\/wp-content\/uploads\/2025\/10\/Erren-square.jpg"},"description":"Erren’s mission is to help readers discover the magic of cooking, one delicious recipe at a time, while continuing to grow the Erren’s Kitchen community worldwide.","sameAs":["https:\/\/www.errenskitchen.com\/author\/errenhart\/","https:\/\/www.facebook.com\/errenskitchen\/","https:\/\/www.instagram.com\/errenskitchen","https:\/\/www.linkedin.com\/in\/erren-hart\/","https:\/\/www.pinterest.com\/errenskitchen\/","https:\/\/x.com\/ErrensKitchen","https:\/\/www.youtube.com\/@ErrensKitchen","https:\/\/www.msn.com\/en-us\/channel\/source\/ErrensKitchen\/sr-cid-ec438c0e24dc00eb","https:\/\/chopped.academy\/the-path-to-success-with-erren-hart\/"],"gender":"female","award":["Featured on Chopped Podcast","Featured contributor on MSN","Featured in Better Homes & Gardens","Featured in Cosmopolitan","Featured in HuffPost","Featured on BuzzFeed","Featured in Parade"],"knowsAbout":["Recipe development","Italian-American cuisine","Classic comfort food","International home cooking","Baking","Tested family-friendly meals","Culinary techniques","Home cooking education"],"knowsLanguage":["English"],"jobTitle":"Founder & Director, Recipe Developer","worksFor":"Erren's Kitchen","url":"https:\/\/www.errenskitchen.com\/author\/errenhart\/"},{"@type":"Question","@id":"https:\/\/www.errenskitchen.com\/cinnamon-crumb-buns\/#faq-question-1599216003957","position":1,"url":"https:\/\/www.errenskitchen.com\/cinnamon-crumb-buns\/#faq-question-1599216003957","name":"Why didn’t my dough rise?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":" The most common cause is milk that’s too hot or yeast that’s expired. The yeast should foam before moving forward.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https:\/\/www.errenskitchen.com\/cinnamon-crumb-buns\/#faq-question-1601581444828","position":2,"url":"https:\/\/www.errenskitchen.com\/cinnamon-crumb-buns\/#faq-question-1601581444828","name":"Can I make these overnight?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":" Yes. Assemble the buns, cover, and refrigerate overnight. Let them come to room temperature and rise before baking.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https:\/\/www.errenskitchen.com\/cinnamon-crumb-buns\/#faq-question-1778035015417","position":3,"url":"https:\/\/www.errenskitchen.com\/cinnamon-crumb-buns\/#faq-question-1778035015417","name":"Why is my crumb topping melting?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":" It likely wasn’t chilled long enough. Cold crumbs hold their shape better in the oven.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https:\/\/www.errenskitchen.com\/cinnamon-crumb-buns\/#faq-question-1778035036341","position":4,"url":"https:\/\/www.errenskitchen.com\/cinnamon-crumb-buns\/#faq-question-1778035036341","name":"Can I make smaller buns?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":" Absolutely. Slice into more pieces and reduce bake time slightly, checking for golden tops and set centers.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Recipe","name":"Cinnamon Crumb Buns","author":{"@type":"Person","name":"Erren Hart"},"description":"This classic Cinnamon Crumb Buns recipe is the perfect bake to enjoy for breakfast or with your afternoon cup of coffee. Who could resist a crumb-filled bun, hot from the oven?","datePublished":"2026-05-08T07:00:00+00:00","image":["https:\/\/www.errenskitchen.com\/wp-content\/uploads\/2017\/12\/Cinnamon-Crumb-Buns.jpg","https:\/\/www.errenskitchen.com\/wp-content\/uploads\/2017\/12\/Cinnamon-Crumb-Buns-500x500.jpg","https:\/\/www.errenskitchen.com\/wp-content\/uploads\/2017\/12\/Cinnamon-Crumb-Buns-500x375.jpg","https:\/\/www.errenskitchen.com\/wp-content\/uploads\/2017\/12\/Cinnamon-Crumb-Buns-480x270.jpg"],"video":{"name":"Cinnamon Crumb Buns","description":"Learn how to make soft cinnamon crumb buns with a buttery topping and simple cream cheese icing.","thumbnailUrl":"https:\/\/content.jwplatform.com\/thumbs\/TyH9MmGo-720.jpg","contentUrl":"https:\/\/content.jwplatform.com\/videos\/TyH9MmGo.mp4","uploadDate":"2026-05-08T12:55:57+00:00","@type":"VideoObject"},"recipeYield":["8","8 buns"],"prepTime":"PT180M","cookTime":"PT30M","totalTime":"PT210M","recipeIngredient":["1¼ cups hot milk (about 110°F \/ 43°C)","1  packet (2¼ tsp instant dry yeast)","¼ cup granulated sugar","1  large egg (room temperature)","¼ cup unsalted butter (melted, plus more for greasing)","4 cups all-purpose flour (plus more as needed)","1 teaspoon salt","4 tablespoons unsalted butter (½ stick very soft )","½ teaspoon vanilla","¼ cup dark brown sugar (packed )","2 tablespoons granulated sugar","1 pinch table salt (optional)","1 teaspoon ground cinnamon","1½ cups all-purpose flour","½ cup dark brown sugar (packed )","2 tablespoons granulated sugar","1 teaspoon kosher salt","1 teaspoon ground cinnamon","10 tablespoons  unsalted butter (1¼ sticks, melted and slightly cooled)","6 tablespoons softened cream cheese","3 tablespoons unsalted butter (softened )","½ cup powdered sugar","½ teaspoon vanilla extract","3 tablespoons milk (warmed, plus more until desired consistency)"],"recipeInstructions":[{"@type":"HowToSection","name":"Make the Dough:","itemListElement":[{"@type":"HowToStep","text":"In a large mixing bowl, whisk together hot milk and sugar. Sprinkle yeast on top and let it sit for 5–10 minutes until foamy.","name":"In a large mixing bowl, whisk together hot milk and sugar. Sprinkle yeast on top and let it sit for 5–10 minutes until foamy.","url":"https:\/\/www.errenskitchen.com\/cinnamon-crumb-buns\/#wprm-recipe-7528-step-0-0"},{"@type":"HowToStep","text":"Add the egg and melted butter, whisk to combine.","name":"Add the egg and melted butter, whisk to combine.","url":"https:\/\/www.errenskitchen.com\/cinnamon-crumb-buns\/#wprm-recipe-7528-step-0-1"},{"@type":"HowToStep","text":"Mix in salt and 3 cups of flour. Stir until a shaggy dough forms.","name":"Mix in salt and 3 cups of flour. Stir until a shaggy dough forms.","url":"https:\/\/www.errenskitchen.com\/cinnamon-crumb-buns\/#wprm-recipe-7528-step-0-2"},{"@type":"HowToStep","text":"Knead by hand or with a mixer for 6–8 minutes, adding more flour as needed until the dough is smooth and slightly tacky.","name":"Knead by hand or with a mixer for 6–8 minutes, adding more flour as needed until the dough is smooth and slightly tacky.","url":"https:\/\/www.errenskitchen.com\/cinnamon-crumb-buns\/#wprm-recipe-7528-step-0-3"},{"@type":"HowToStep","text":"Place in a greased bowl, cover, and let rise for 1 to 1½ hours, or until doubled in size.","name":"Place in a greased bowl, cover, and let rise for 1 to 1½ hours, or until doubled in size.","url":"https:\/\/www.errenskitchen.com\/cinnamon-crumb-buns\/#wprm-recipe-7528-step-0-4"}]},{"@type":"HowToSection","name":"Make the Fillings:","itemListElement":[{"@type":"HowToStep","text":"Mix butter, vanilla, brown sugar, granulated sugar, salt, and cinnamon until smooth and spreadable.","name":"Mix butter, vanilla, brown sugar, granulated sugar, salt, and cinnamon until smooth and spreadable.","url":"https:\/\/www.errenskitchen.com\/cinnamon-crumb-buns\/#wprm-recipe-7528-step-1-0"}]},{"@type":"HowToSection","name":"Crumb Topping:","itemListElement":[{"@type":"HowToStep","text":"In a medium bowl, mix flour, both sugars, salt, and cinnamon.","name":"In a medium bowl, mix flour, both sugars, salt, and cinnamon.","url":"https:\/\/www.errenskitchen.com\/cinnamon-crumb-buns\/#wprm-recipe-7528-step-2-0"},{"@type":"HowToStep","text":"Pour in melted butter and stir with a fork until large crumbs form.","name":"Pour in melted butter and stir with a fork until large crumbs form.","url":"https:\/\/www.errenskitchen.com\/cinnamon-crumb-buns\/#wprm-recipe-7528-step-2-1"},{"@type":"HowToStep","text":"Set the crumbs aside while the dough finishes rising.","name":"Set the crumbs aside while the dough finishes rising.","url":"https:\/\/www.errenskitchen.com\/cinnamon-crumb-buns\/#wprm-recipe-7528-step-2-2"}]},{"@type":"HowToSection","name":"Assemble the Rolls:","itemListElement":[{"@type":"HowToStep","text":"Roll out risen dough on a floured surface into a 9x14-inch rectangle.","name":"Roll out risen dough on a floured surface into a 9x14-inch rectangle.","url":"https:\/\/www.errenskitchen.com\/cinnamon-crumb-buns\/#wprm-recipe-7528-step-3-0"},{"@type":"HowToStep","text":"Spread the cinnamon sugar butter evenly over the dough, leaving a ½-inch border on one long edge.","name":"Spread the cinnamon sugar butter evenly over the dough, leaving a ½-inch border on one long edge.","url":"https:\/\/www.errenskitchen.com\/cinnamon-crumb-buns\/#wprm-recipe-7528-step-3-1"},{"@type":"HowToStep","text":"Sprinkle the ½ the crumb topping evenly over the butter layer. Lightly press to help it stick. Reserve the other ½ of the crumb mixture for sprinkling on top of the buns later.","name":"Sprinkle the ½ the crumb topping evenly over the butter layer. Lightly press to help it stick. Reserve the other ½ of the crumb mixture for sprinkling on top of the buns later.","url":"https:\/\/www.errenskitchen.com\/cinnamon-crumb-buns\/#wprm-recipe-7528-step-3-2"},{"@type":"HowToStep","text":"Roll up tightly from the opposite long side and pinch the edge to seal.","name":"Roll up tightly from the opposite long side and pinch the edge to seal.","url":"https:\/\/www.errenskitchen.com\/cinnamon-crumb-buns\/#wprm-recipe-7528-step-3-3"},{"@type":"HowToStep","text":"Slice into 6–8 even rolls and place into a greased or parchment-lined baking dish.","name":"Slice into 6–8 even rolls and place into a greased or parchment-lined baking dish.","url":"https:\/\/www.errenskitchen.com\/cinnamon-crumb-buns\/#wprm-recipe-7528-step-3-4"}]},{"@type":"HowToSection","name":"Final Rise:","itemListElement":[{"@type":"HowToStep","text":"Cover the pan and let rolls rise for 30–45 minutes, until puffy and touching.","name":"Cover the pan and let rolls rise for 30–45 minutes, until puffy and touching.","url":"https:\/\/www.errenskitchen.com\/cinnamon-crumb-buns\/#wprm-recipe-7528-step-4-0"}]},{"@type":"HowToSection","name":"Add Crumbs and Bake:","itemListElement":[{"@type":"HowToStep","text":"Preheat oven to 350°F (175°C).","name":"Preheat oven to 350°F (175°C).","url":"https:\/\/www.errenskitchen.com\/cinnamon-crumb-buns\/#wprm-recipe-7528-step-5-0"},{"@type":"HowToStep","text":"Once rolls have risen, sprinkle the reserved crumb topping over the tops for that golden, bakery-style finish.","name":"Once rolls have risen, sprinkle the reserved crumb topping over the tops for that golden, bakery-style finish.","url":"https:\/\/www.errenskitchen.com\/cinnamon-crumb-buns\/#wprm-recipe-7528-step-5-1"},{"@type":"HowToStep","text":"Bake for 25–30 minutes, until rolls are set and tops are golden brown. Tent with foil halfway if needed to prevent over-browning.","name":"Bake for 25–30 minutes, until rolls are set and tops are golden brown. Tent with foil halfway if needed to prevent over-browning.","url":"https:\/\/www.errenskitchen.com\/cinnamon-crumb-buns\/#wprm-recipe-7528-step-5-2"}]},{"@type":"HowToSection","name":"Make the Icing:","itemListElement":[{"@type":"HowToStep","text":"Beat together softened cream cheese and butter until smooth.","name":"Beat together softened cream cheese and butter until smooth.","url":"https:\/\/www.errenskitchen.com\/cinnamon-crumb-buns\/#wprm-recipe-7528-step-6-0"},{"@type":"HowToStep","text":"Add powdered sugar and vanilla. Mix well.","name":"Add powdered sugar and vanilla. Mix well.","url":"https:\/\/www.errenskitchen.com\/cinnamon-crumb-buns\/#wprm-recipe-7528-step-6-1"},{"@type":"HowToStep","text":"Slowly add warm milk, 1 tablespoon at a time, until you reach a smooth, pourable consistency.","name":"Slowly add warm milk, 1 tablespoon at a time, until you reach a smooth, pourable consistency.","url":"https:\/\/www.errenskitchen.com\/cinnamon-crumb-buns\/#wprm-recipe-7528-step-6-2"}]},{"@type":"HowToSection","name":"Finish and Serve:","itemListElement":[{"@type":"HowToStep","text":"Let buns cool slightly, then drizzle with icing. Serve warm and melty!","name":"Let buns cool slightly, then drizzle with icing. Serve warm and melty!","url":"https:\/\/www.errenskitchen.com\/cinnamon-crumb-buns\/#wprm-recipe-7528-step-7-0"}]}],"aggregateRating":{"@type":"AggregateRating","ratingValue":"5","ratingCount":"4","reviewCount":"4"},"review":[{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"These are just to die for","author":{"@type":"Person","name":"Mary"},"datePublished":"2022-01-17"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"I adore crumb buns and this recipe really worked!","author":{"@type":"Person","name":"Lindsey"},"datePublished":"2018-07-21"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"The crumb is the best part and having it all through the bun was a home run!  Thank you!!","author":{"@type":"Person","name":"Courtney"},"datePublished":"2018-05-14"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Delicious!  Thanks for posting.","author":{"@type":"Person","name":"Kathy"},"datePublished":"2016-03-01"}],"recipeCategory":["Breakfast","brunch","Dessert","Snack"],"recipeCuisine":["American","Baking"],"suitableForDiet":["https:\/\/schema.org\/VegetarianDiet"],"keywords":"cinnamon bun dough, cinnamon buns from scratch, Cinnamon Crumb Buns, gooey cinnamon buns","nutrition":{"@type":"NutritionInformation","calories":"807 kcal","carbohydrateContent":"109 g","proteinContent":"12 g","fatContent":"36 g","saturatedFatContent":"22 g","cholesterolContent":"116 mg","sodiumContent":"657 mg","sugarContent":"42 g","transFatContent":"1 g","fiberContent":"3 g","unsaturatedFatContent":"11 g","servingSize":"1 serving"},"@id":"https:\/\/www.errenskitchen.com\/cinnamon-crumb-buns\/#recipe","isPartOf":{"@id":"https:\/\/www.errenskitchen.com\/cinnamon-crumb-buns\/#article"},"mainEntityOfPage":"https:\/\/www.errenskitchen.com\/cinnamon-crumb-buns\/"}]}</script>

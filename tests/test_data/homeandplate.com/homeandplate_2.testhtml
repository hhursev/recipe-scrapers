omeandplate.com\/#organization"},"alternateName":"H&P","potentialAction":[{"@type":"SearchAction","target":{"@type":"EntryPoint","urlTemplate":"https:\/\/www.homeandplate.com\/?s={search_term_string}"},"query-input":{"@type":"PropertyValueSpecification","valueRequired":true,"valueName":"search_term_string"}}],"inLanguage":"en-US"},{"@type":"Organization","@id":"https:\/\/www.homeandplate.com\/#organization","name":"Home & Plate","alternateName":"H&P","url":"https:\/\/www.homeandplate.com\/","logo":{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/www.homeandplate.com\/#\/schema\/logo\/image\/","url":"https:\/\/www.homeandplate.com\/wp-content\/uploads\/2019\/01\/home-and-late-favicon-2-01.png","contentUrl":"https:\/\/www.homeandplate.com\/wp-content\/uploads\/2019\/01\/home-and-late-favicon-2-01.png","width":834,"height":834,"caption":"Home & Plate"},"image":{"@id":"https:\/\/www.homeandplate.com\/#\/schema\/logo\/image\/"},"sameAs":["http:\/\/www.facebook.com\/homeandplate","http:\/\/instagram.com\/homeandplate","https:\/\/www.pinterest.com\/homeandplate"]},{"@type":"Person","@id":"https:\/\/www.homeandplate.com\/#\/schema\/person\/c56781eda867ca84f0a7f2bf3bc12673","name":"Ali Randall","image":{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/secure.gravatar.com\/avatar\/60cb72da9b662f59813f50cb8d7ff4b51ffe6eaba8febffdc716009224369a47?s=96&d=mm&r=g","url":"https:\/\/secure.gravatar.com\/avatar\/60cb72da9b662f59813f50cb8d7ff4b51ffe6eaba8febffdc716009224369a47?s=96&d=mm&r=g","contentUrl":"https:\/\/secure.gravatar.com\/avatar\/60cb72da9b662f59813f50cb8d7ff4b51ffe6eaba8febffdc716009224369a47?s=96&d=mm&r=g","caption":"Ali Randall"},"sameAs":["https:\/\/www.homeandplate.com","https:\/\/www.facebook.com\/homeandplate","https:\/\/x.com\/homeandplate"],"url":"https:\/\/www.homeandplate.com\/blog\/author\/homeandplateadmin\/"},{"@type":"Recipe","name":"Perfect Sugar Cookie Recipe","author":{"@id":"https:\/\/www.homeandplate.com\/#\/schema\/person\/c56781eda867ca84f0a7f2bf3bc12673"},"description":"This is the perfect sugar cookie recipe for all your holiday baking. These sugar cookies are soft yet chewy and keep their shape while baking. ","datePublished":"2019-12-17T10:00:00+00:00","image":["https:\/\/www.homeandplate.com\/wp-content\/uploads\/2019\/12\/perfect-sugar-cookie-recipe-2.jpg"],"recipeYield":["2","2 dozen"],"prepTime":"PT20M","cookTime":"PT8M","totalTime":"PT30M","recipeIngredient":["1 cup butter room temperature (very soft)","1 cup granulated sugar","2 tsp vanilla extract","1  egg","3 cups flour","2 tsp baking powder","Sprinkles, sugars and nonpareils","For frosting:","4 oz. cream cheese (softened)","3 tablespoons butter (softened)","1\/2 teaspoon vanilla extract","1.5 cup confectioners sugar"],"recipeInstructions":[{"@type":"HowToStep","text":"Preheat oven to 350°.","name":"Preheat oven to 350°.","url":"https:\/\/www.homeandplate.com\/blog\/perfect-sugar-cookie-recipe\/#wprm-recipe-10413-step-0-0"},{"@type":"HowToStep","text":"Cream together the butter and sugar in the bowl of a stand mixer for 3 minutes until light and fluffy.","name":"Cream together the butter and sugar in the bowl of a stand mixer for 3 minutes until light and fluffy.","url":"https:\/\/www.homeandplate.com\/blog\/perfect-sugar-cookie-recipe\/#wprm-recipe-10413-step-0-1"},{"@type":"HowToStep","text":"Add in vanilla and egg, scraping down the bowl and beat until combined.","name":"Add in vanilla and egg, scraping down the bowl and beat until combined.","url":"https:\/\/www.homeandplate.com\/blog\/perfect-sugar-cookie-recipe\/#wprm-recipe-10413-step-0-2"},{"@type":"HowToStep","text":"Add baking powder and one cup of flour at a time to the bowl. Mix slowly to keep the flour in the bowl and increase the speed until the dough is well formed. The dough will be moldable and easy to handle.","name":"Add baking powder and one cup of flour at a time to the bowl. Mix slowly to keep the flour in the bowl and increase the speed until the dough is well formed. The dough will be moldable and easy to handle.","url":"https:\/\/www.homeandplate.com\/blog\/perfect-sugar-cookie-recipe\/#wprm-recipe-10413-step-0-3"},{"@type":"HowToStep","text":"Scoop the dough with a spoon into the desired size and roll in your hands into a smooth ball. Place the rolled ball on a prepared baking sheet  and press gently with the bottom of a glass.","name":"Scoop the dough with a spoon into the desired size and roll in your hands into a smooth ball. Place the rolled ball on a prepared baking sheet  and press gently with the bottom of a glass.","url":"https:\/\/www.homeandplate.com\/blog\/perfect-sugar-cookie-recipe\/#wprm-recipe-10413-step-0-4"},{"@type":"HowToStep","text":"To roll and use cookie cutters, turn the dough onto a floured surface and roll to 1\/4 inch thickness. Use cookie cutters and transfer the cookies to a silicone lined cookie sheet or one lined with parchment paper.","name":"To roll and use cookie cutters, turn the dough onto a floured surface and roll to 1\/4 inch thickness. Use cookie cutters and transfer the cookies to a silicone lined cookie sheet or one lined with parchment paper.","url":"https:\/\/www.homeandplate.com\/blog\/perfect-sugar-cookie-recipe\/#wprm-recipe-10413-step-0-5"},{"@type":"HowToStep","text":"Bake at 350° for 6-8 minutes. Allow the cookies to cool for 5 minutes before transferring them to a cooking rack.","name":"Bake at 350° for 6-8 minutes. Allow the cookies to cool for 5 minutes before transferring them to a cooking rack.","url":"https:\/\/www.homeandplate.com\/blog\/perfect-sugar-cookie-recipe\/#wprm-recipe-10413-step-0-6"},{"@type":"HowToStep","text":"Enjoy plain or frost and decorate the cookies using sprinkles, sugars and nonpareils.","name":"Enjoy plain or frost and decorate the cookies using sprinkles, sugars and nonpareils.","url":"https:\/\/www.homeandplate.com\/blog\/perfect-sugar-cookie-recipe\/#wprm-recipe-10413-step-0-7"}],"aggregateRating":{"@type":"AggregateRating","ratingValue":"5","ratingCount":"5","reviewCount":"5"},"review":[{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"I tried this recipe and it turned out really good. Thanks for the recipe. \r\n&nbsp;","author":{"@type":"Person","name":"Rosse"},"datePublished":"2022-09-19"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"It's so funny that I have so many sugar cookies recipes but not one go to recipe.  I don't have one that is a no fail. This one looks perfect and they are so many helpful instructions and photos that I almost can't fail.  Love how  you decorated them especially the reindeer!","author":{"@type":"Person","name":"Karen @ Seasonal Cravings"},"datePublished":"2019-12-18"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"These were so wonderful. they turned out perfect for our holiday cookie swap at the office.","author":{"@type":"Person","name":"Heidy L. McCallum"},"datePublished":"2019-12-18"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Me and my son had so much fun making these and even more fun eating them. I will be making more for Christmas,","author":{"@type":"Person","name":"stephanie"},"datePublished":"2019-12-18"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"These sugar cookies are going on my  Christmas cookie list. I love all the ways they can be decorated!","author":{"@type":"Person","name":"Jacqueline Debono"},"datePublished":"2019-12-18"}],"recipeCategory":["Dessert"],"recipeCuisine":["American"],"keywords":"Perfect Sugar Cookies, Sugar Cookies","@id":"https:\/\/www.homeandplate.com\/blog\/perfect-sugar-cookie-recipe\/#recipe","isPartOf":{"@id":"https:\/\/www.homeandplate.com\/blog\/perfect-sugar-cookie-recipe\/#article"},"mainEntityOfPage":"https:\/\/www.homeandplate.com\/blog\/perfect-sugar-cookie-recipe\/"}]}</script>  <link rel='dns-prefetch' href='//scripts.medi
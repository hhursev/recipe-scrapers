	<script type="application/ld+json" class="yoast-schema-graph">{"@context":"https:\/\/schema.org","@graph":[{"@type":"Article","@id":"https:\/\/www.fifteenspatulas.com\/blueberry-galatte\/#article","isPartOf":{"@id":"https:\/\/www.fifteenspatulas.com\/blueberry-galatte\/"},"author":{"name":"Taylor","@id":"https:\/\/www.fifteenspatulas.com\/#\/schema\/person\/a12dfff3bbca74bfee1717a030ec0e95"},"headline":"Blueberry Galette","datePublished":"2025-11-04T18:41:33+00:00","dateModified":"2025-11-04T18:41:36+00:00","wordCount":1246,"commentCount":2,"publisher":{"@id":"https:\/\/www.fifteenspatulas.com\/#organization"},"image":{"@id":"https:\/\/www.fifteenspatulas.com\/blueberry-galatte\/#primaryimage"},"thumbnailUrl":"https:\/\/www.fifteenspatulas.com\/wp-content\/uploads\/2025\/06\/Blueberry-Galette.jpg","articleSection":["All Recent Posts","Dessert"],"inLanguage":"en-US","potentialAction":[{"@type":"CommentAction","name":"Comment","target":["https:\/\/www.fifteenspatulas.com\/blueberry-galatte\/#respond"]}]},{"@type":["WebPage","FAQPage"],"@id":"https:\/\/www.fifteenspatulas.com\/blueberry-galatte\/","url":"https:\/\/www.fifteenspatulas.com\/blueberry-galatte\/","name":"Easy Blueberry Galette Recipe (Summer Dessert) - Fifteen Spatulas","isPartOf":{"@id":"https:\/\/www.fifteenspatulas.com\/#website"},"primaryImageOfPage":{"@id":"https:\/\/www.fifteenspatulas.com\/blueberry-galatte\/#primaryimage"},"image":{"@id":"https:\/\/www.fifteenspatulas.com\/blueberry-galatte\/#primaryimage"},"thumbnailUrl":"https:\/\/www.fifteenspatulas.com\/wp-content\/uploads\/2025\/06\/Blueberry-Galette.jpg","datePublished":"2025-11-04T18:41:33+00:00","dateModified":"2025-11-04T18:41:36+00:00","description":"This blueberry galette recipe is packed with juicy berries and baked in a golden crust. Easier than pie and ready in under an hour, perfect for summer!","breadcrumb":{"@id":"https:\/\/www.fifteenspatulas.com\/blueberry-galatte\/#breadcrumb"},"mainEntity":[{"@id":"https:\/\/www.fifteenspatulas.com\/blueberry-galatte\/#faq-question-1750801696299"},{"@id":"https:\/\/www.fifteenspatulas.com\/blueberry-galatte\/#faq-question-1750801743340"},{"@id":"https:\/\/www.fifteenspatulas.com\/blueberry-galatte\/#faq-question-1750802147344"}],"inLanguage":"en-US","potentialAction":[{"@type":"ReadAction","target":["https:\/\/www.fifteenspatulas.com\/blueberry-galatte\/"]}]},{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/www.fifteenspatulas.com\/blueberry-galatte\/#primaryimage","url":"https:\/\/www.fifteenspatulas.com\/wp-content\/uploads\/2025\/06\/Blueberry-Galette.jpg","contentUrl":"https:\/\/www.fifteenspatulas.com\/wp-content\/uploads\/2025\/06\/Blueberry-Galette.jpg","width":1200,"height":1803,"caption":"Blueberry Galette on plate topped with Vanilla Icecream"},{"@type":"BreadcrumbList","@id":"https:\/\/www.fifteenspatulas.com\/blueberry-galatte\/#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https:\/\/www.fifteenspatulas.com\/"},{"@type":"ListItem","position":2,"name":"Recipes","item":"https:\/\/www.fifteenspatulas.com\/recipes\/"},{"@type":"ListItem","position":3,"name":"Dessert","item":"https:\/\/www.fifteenspatulas.com\/recipes\/dessert\/"},{"@type":"ListItem","position":4,"name":"Blueberry Galette"}]},{"@type":"WebSite","@id":"https:\/\/www.fifteenspatulas.com\/#website","url":"https:\/\/www.fifteenspatulas.com\/","name":"Fifteen Spatulas","description":"Easy Everyday Recipes from Scratch","publisher":{"@id":"https:\/\/www.fifteenspatulas.com\/#organization"},"potentialAction":[{"@type":"SearchAction","target":{"@type":"EntryPoint","urlTemplate":"https:\/\/www.fifteenspatulas.com\/?s={search_term_string}"},"query-input":{"@type":"PropertyValueSpecification","valueRequired":true,"valueName":"search_term_string"}}],"inLanguage":"en-US"},{"@type":"Organization","@id":"https:\/\/www.fifteenspatulas.com\/#organization","name":"Fifteen Spatulas","url":"https:\/\/www.fifteenspatulas.com\/","logo":{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/www.fifteenspatulas.com\/#\/schema\/logo\/image\/","url":"https:\/\/www.fifteenspatulas.com\/wp-content\/uploads\/2016\/01\/FifteenSpatulas.jpg","contentUrl":"https:\/\/www.fifteenspatulas.com\/wp-content\/uploads\/2016\/01\/FifteenSpatulas.jpg","width":640,"height":427,"caption":"Fifteen Spatulas"},"image":{"@id":"https:\/\/www.fifteenspatulas.com\/#\/schema\/logo\/image\/"},"sameAs":["http:\/\/www.facebook.com\/fifteenspatulas","https:\/\/x.com\/fifteenspatulas","http:\/\/instagram.com\/fifteenspatulas","http:\/\/www.pinterest.com\/fifteenspatulas","http:\/\/www.youtube.com\/user\/FifteenSpatulas"]},{"@type":"Person","@id":"https:\/\/www.fifteenspatulas.com\/#\/schema\/person\/a12dfff3bbca74bfee1717a030ec0e95","name":"Taylor","sameAs":["http:\/\/fifteenspatulas.com"],"url":"https:\/\/www.fifteenspatulas.com\/author\/t4yl0r05029693bl0xom\/"},{"@type":"Question","@id":"https:\/\/www.fifteenspatulas.com\/blueberry-galatte\/#faq-question-1750801696299","position":1,"url":"https:\/\/www.fifteenspatulas.com\/blueberry-galatte\/#faq-question-1750801696299","name":"Can I use frozen blueberries?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Yes, But do not thaw them. I like to add an extra 1\/2 tablespoon of cornstarch to account for extra moisture.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https:\/\/www.fifteenspatulas.com\/blueberry-galatte\/#faq-question-1750801743340","position":2,"url":"https:\/\/www.fifteenspatulas.com\/blueberry-galatte\/#faq-question-1750801743340","name":"How do I fold a galette?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"roll to a 1\/4 inch dough, leave a 2 inch border around your filling, pinch cracks around the edge and fold over and pleate covering your filling leaving the middle open.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https:\/\/www.fifteenspatulas.com\/blueberry-galatte\/#faq-question-1750802147344","position":3,"url":"https:\/\/www.fifteenspatulas.com\/blueberry-galatte\/#faq-question-1750802147344","name":"Can I Use other Fruits?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Absolutley! My <a href=\"https:\/\/www.fifteenspatulas.com\/fresh-peach-crostata\/\">Peach Crostata<\/a> is great with fresh peaches","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Recipe","name":"Blueberry Galette","author":{"@id":"https:\/\/www.fifteenspatulas.com\/#\/schema\/person\/a12dfff3bbca74bfee1717a030ec0e95"},"description":"","datePublished":"2025-11-04T13:41:33+00:00","image":["https:\/\/www.fifteenspatulas.com\/wp-content\/uploads\/2025\/06\/Blueberry-Galette.jpg","https:\/\/www.fifteenspatulas.com\/wp-content\/uploads\/2025\/06\/Blueberry-Galette-500x500.jpg","https:\/\/www.fifteenspatulas.com\/wp-content\/uploads\/2025\/06\/Blueberry-Galette-500x375.jpg","https:\/\/www.fifteenspatulas.com\/wp-content\/uploads\/2025\/06\/Blueberry-Galette-480x270.jpg"],"recipeYield":["8","8 Slices"],"prepTime":"PT15M","cookTime":"PT26M","totalTime":"PT70M","recipeIngredient":["1 1\/4 Cup All-Purpose Flour","8 TBSP Cold Butter","2 TBSP Granulated Sugar","1\/4 tsp Salt","2 1\/2 TBSP Ice Cold Water (+\/- 1 TBSP)","4 Cups Blueberries","1\/3 Cup Granulated Sugar","2 TBSP Lemon Juice","2 TBSP Cornstarch","2 tsp Lemon Zest","1  Egg","2 TBSP Water","Pinch Coarse Sugar (Sprinkled on top)"],"recipeInstructions":[{"@type":"HowToStep","text":"In a food processor, add the flour, sugar, and salt. Pulse a few times to combine.","name":"In a food processor, add the flour, sugar, and salt. Pulse a few times to combine.","url":"https:\/\/www.fifteenspatulas.com\/blueberry-galatte\/#wprm-recipe-47487-step-0-0"},{"@type":"HowToStep","text":"Add the butter and pulse until the butter is the size of small peas. Add 2 ½ tablespoons of water and pulse to combine. Open the lid, grab a small handful, and squeeze. If it holds together, don’t add more water. If it’s still super crumbly even after squeezing in your hand, add an additional ½-1 tablespoon of water and pulse a few more times. (It will still look crumbly)","name":"Add the butter and pulse until the butter is the size of small peas. Add 2 ½ tablespoons of water and pulse to combine. Open the lid, grab a small handful, and squeeze. If it holds together, don’t add more water. If it’s still super crumbly even after squeezing in your hand, add an additional ½-1 tablespoon of water and pulse a few more times. (It will still look crumbly)","url":"https:\/\/www.fifteenspatulas.com\/blueberry-galatte\/#wprm-recipe-47487-step-0-1"},{"@type":"HowToStep","text":"Tip the bowl to place the mixture onto a clean counter and quickly knead a few times to get it to come together. Shape it into about an 8–9-inch disk. Wrap in plastic wrap and refrigerate for 30 minutes. ","name":"Tip the bowl to place the mixture onto a clean counter and quickly knead a few times to get it to come together. Shape it into about an 8–9-inch disk. Wrap in plastic wrap and refrigerate for 30 minutes. ","url":"https:\/\/www.fifteenspatulas.com\/blueberry-galatte\/#wprm-recipe-47487-step-0-2"},{"@type":"HowToStep","text":"While the dough chills (about the last 5 minutes of refrigeration time), make the filling by tossing the blueberries, sugar, lemon juice, and zest together. Sprinkle the cornstarch over the top and toss again. Set aside. ","name":"While the dough chills (about the last 5 minutes of refrigeration time), make the filling by tossing the blueberries, sugar, lemon juice, and zest together. Sprinkle the cornstarch over the top and toss again. Set aside. ","url":"https:\/\/www.fifteenspatulas.com\/blueberry-galatte\/#wprm-recipe-47487-step-0-3"},{"@type":"HowToStep","text":"Make the egg wash by whisking the egg and water together. Set aside.","name":"Make the egg wash by whisking the egg and water together. Set aside.","url":"https:\/\/www.fifteenspatulas.com\/blueberry-galatte\/#wprm-recipe-47487-step-0-4"},{"@type":"HowToStep","text":"Preheat your oven to 425°F.","name":"Preheat your oven to 425°F.","url":"https:\/\/www.fifteenspatulas.com\/blueberry-galatte\/#wprm-recipe-47487-step-0-5"},{"@type":"HowToStep","text":"On a sheet of parchment paper, sprinkle a little flour and roll out the dough into about a 12-inch circle. Use a 9-inch cake pan or plate (optional) to make a very soft indent in the dough. This will create a border so you know where to keep your blueberries and a good place to bring up the edges. ","name":"On a sheet of parchment paper, sprinkle a little flour and roll out the dough into about a 12-inch circle. Use a 9-inch cake pan or plate (optional) to make a very soft indent in the dough. This will create a border so you know where to keep your blueberries and a good place to bring up the edges. ","url":"https:\/\/www.fifteenspatulas.com\/blueberry-galatte\/#wprm-recipe-47487-step-0-6"},{"@type":"HowToStep","text":"Add the blueberries to the middle of the dough and fold up the edges, lifting as you go every 3-4 inches, creating pleats. ","name":"Add the blueberries to the middle of the dough and fold up the edges, lifting as you go every 3-4 inches, creating pleats. ","url":"https:\/\/www.fifteenspatulas.com\/blueberry-galatte\/#wprm-recipe-47487-step-0-7"},{"@type":"HowToStep","text":"Brush the egg wash all over the outside edge of the crust and sprinkle with coarse sugar, if desired.","name":"Brush the egg wash all over the outside edge of the crust and sprinkle with coarse sugar, if desired.","url":"https:\/\/www.fifteenspatulas.com\/blueberry-galatte\/#wprm-recipe-47487-step-0-8"},{"@type":"HowToStep","text":"Lift the parchment paper with the assembled galette up onto a baking sheet and bake for about 26-31 minutes, or until the crust is golden brown and the filling is bubbly. Let the galette cool for about 10 minutes before slicing and serving.","name":"Lift the parchment paper with the assembled galette up onto a baking sheet and bake for about 26-31 minutes, or until the crust is golden brown and the filling is bubbly. Let the galette cool for about 10 minutes before slicing and serving.","url":"https:\/\/www.fifteenspatulas.com\/blueberry-galatte\/#wprm-recipe-47487-step-0-9"}],"aggregateRating":{"@type":"AggregateRating","ratingValue":"5","ratingCount":"1","reviewCount":"1"},"review":[{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"This looks amazing and I can't wait to try it!  Thank you!","author":{"@type":"Person","name":"Penny Thomas"},"datePublished":"2026-03-20"}],"recipeCategory":["Dessert"],"recipeCuisine":["American"],"keywords":"Blueberry galette","@id":"https:\/\/www.fifteenspatulas.com\/blueberry-galatte\/#recipe","isPartOf":{"@id":"https:\/\/www.fifteenspatulas.com\/blueberry-galatte\/#article"},"mainEntityOfPage":"https:\/\/www.fifteenspatulas.com\/blueberry-galatte\/"}]}</script>

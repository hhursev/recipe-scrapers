	</div>
			<textarea name="wprm-user-rating-comment" class="wprm-user-rating-modal-comment" placeholder="Share your thoughts! What did you like about this recipe?" oninput="window.WPRecipeMaker.userRatingModal.checkFields();" aria-label="Comment"></textarea>
	<input type="hidden" name="wprm-user-rating-recipe-id" value="" />
	<div class="wprm-user-rating-modal-comment-meta">
				<div class="wprm-user-rating-modal-field">
			<label for="wprm-user-rating-name">Name *</label>
			<input type="text" id="wprm-user-rating-name" name="wprm-user-rating-name" value="" placeholder="" />		</div>
		<div class="wprm-user-rating-modal-field">
			<label for="wprm-user-rating-email">Email *</label>
			<input type="email" id="wprm-user-rating-email" name="wprm-user-rating-email" value="" placeholder="" />
		</div>	</div>
	<footer class="wprm-popup-modal__footer">
				<button type="submit" class="wprm-popup-modal__btn wprm-user-rating-modal-submit-comment">Rate and Review Recipe</button>
		<div id="wprm-user-rating-modal-errors">
			<div id="wprm-user-rating-modal-error-rating">A rating is required</div>
			<div id="wprm-user-rating-modal-error-name">A name is required</div>
			<div id="wprm-user-rating-modal-error-email">An email is required</div>
		</div>
		<div id="wprm-user-rating-modal-waiting">
			<div class="wprm-loader"></div>
		</div>
	</footer>
</form>
<div id="wprm-user-ratings-modal-message"></div>			</div>

					</div>
  	</div>
	</div><div  id="wprm-popup-modal-2" class="wprm-popup-modal wprm-popup-modal-user-rating-summary" data-type="user-rating-summary" aria-hidden="true">
		<div class="wprm-popup-modal__overlay" tabindex="-1">
		<div  class="wprm-popup-modal__container" role="dialog" aria-modal="true" aria-labelledby="wprm-popup-modal-2-title">
			<header class="wprm-popup-modal__header">
				<h2 class="wprm-popup-modal__title" id="wprm-popup-modal-2-title">
					Recipe Ratings without Comment				</h2>

				<button class="wprm-popup-modal__close" aria-label="Close" data-micromodal-close></button>
			</header>

			<div class="wprm-popup-modal__content" id="wprm-popup-modal-2-content">
				<div class="wprm-loader"></div>
<div class="wprm-popup-modal-user-rating-summary-ratings"></div>
<div class="wprm-popup-modal-user-rating-summary-error">Something went wrong. Please try again.</div>			</div>

					</div>
  	</div>
	</div><style type="text/css">/* Header */
.cwp-food-header {
	background: var(--wp--preset--color--octonary);
	border-top: 1px solid var(--wp--preset--color--quinary);
	padding: var(--wp--custom--layout--padding);
	font-size: var(--wp--preset--font-size--small);
}

.cwp-food-header .wprm-recipe-name,
.cwp-food-header__rating,
.cwp-food-header .wprm-recipe-summary {
	text-align: center;
}

.cwp-food-header .wprm-recipe-name {
	font-size: var(--wp--preset--font-size--huge);
}

.cwp-food-header .wprm-recipe-rating.wprm-recipe-rating-inline {
	font-size: var(--wp--preset--font-size--min);
	color: var(--wp--custom--color--neutral-700);
	--wp--custom--color--star: var(--wp--preset--color--quaternary);
}

.cwp-food-header .wprm-recipe-rating.wprm-recipe-rating-inline .wprm-recipe-rating-details {
	margin-left: 2px;
	text-transform: uppercase;
}

.cwp-food-header .wprm-recipe-image img {
	margin-bottom: 12px;
	width: 100%;
}

.cwp-food-buttons {
	display: flex;
	flex-wrap: wrap;
	gap: 6px;
	text-align: center;
	padding: 24px 0;
}

.cwp-food-buttons a {
	flex: 1 1 0;
	min-width: 0;
	background: var(--wp--preset--color--quaternary);
	border: 1px solid var(--wp--preset--color--tertiary);
	font-family: var(--wp--custom--typography--interface--font-family);
	letter-spacing: var(--wp--custom--typography--interface--letter-spacing);
	text-transform: var(--wp--custom--typography--interface--text-transform);
	font-weight: 700;
	line-height: var(--wp--custom--line-height--medium);
	font-size: var(--wp--preset--font-size--small);
	padding: 8px 11px;
}

/* Collapse hidden favorites button so visible buttons stretch full width */
.cwp-food-buttons a.wprm-recipe-slickstream[style*="visibility: hidden"],
.cwp-food-buttons a.wprm-recipe-slickstream[style*="visibility:hidden"] {
	display: none;
}


.cwp-food-header .wprm-recipe-meta-container {
	display: flex;
	flex-wrap: nowrap;
	justify-content: center;
	gap: 16px;
}

.cwp-food-header .wprm-recipe-meta-container .wprm-recipe-block-container-inline {
	margin-right: 0;
}

.cwp-food-header .wprm-recipe-block-container-separated .wprm-recipe-details-label,
.cwp-food-header .cwp-food-header__servings-author .wprm-recipe-details-label {
	font-size: var(--wp--preset--font-size--min);
	color: var(--wp--custom--color--neutral-700);
	font-weight: 400;
	line-height: var(--wp--custom--line-height--small);
	letter-spacing: var(--wp--custom--letter-spacing--loose);
	text-transform: uppercase;
}

.cwp-food-header .wprm-recipe-block-container-separated .wprm-recipe-time,
.cwp-food-header .cwp-food-header__servings-author .wprm-recipe-details {
	font-size: var(--wp--preset--font-size--tiny);
	color: var(--wp--custom--color--neutral-700);
	font-weight: 700;
	line-height: var(--wp--custom--line-height--small);
	letter-spacing: var(--wp--custom--letter-spacing--none);
	text-transform: uppercase;
}

.cwp-food-header .wprm-recipe-time-container {
	text-align: center;
}

.cwp-food-header .cwp-food-header__servings-author {
	display: flex;
	justify-content: center;
	gap: 16px;
}

.cwp-food-header .cwp-food-header__left > * + * {
	margin-top: 16px;
}

.cwp-food-header__left,
.cwp-food-header__right {
	margin-bottom: 16px;
}

@media only screen and (min-width: 600px) {
	.cwp-food-header {
		display: grid;
		grid-template-columns: 1fr;
		grid-template-areas:
			'left'
			'buttons';
		column-gap: var(--wp--custom--layout--padding);
		border-inline: 1px solid var(--wp--preset--color--quinary);
	}

	.cwp-food-header__left {
		grid-area: left;
	}

	/* Hide recipe thumbnail on desktop — kept on mobile only.
	   Per Ali (2026-04): on desktop the thumbnail just creates
	   blank space at the top of the card; on mobile it fills it. */
	.cwp-food-header__right {
		display: none;
	}

	.cwp-food-header .cwp-food-buttons {
		grid-area: buttons;
		width: 100%;
	}

	.cwp-food-header .wprm-recipe-summary {
		grid-column: 1 / -1;
	}
}

@media only screen and (max-width: 599px) {
	.cwp-food-header__right {
		display: flex;
		flex-direction: column-reverse;
		row-gap: 12px;
	}

	.cwp-food-buttons a {
		flex: 1 1 0;
	}

	.cwp-food-content .wprm-recipe-jump-to-section-container {
		overflow-x: hidden;
	}

	.cwp-food-content .wprm-recipe-jump-to-section-container a.wprm-recipe-jump-to-section {
		flex: 1 1 calc(50% - 6px);
		white-space: normal;
	}
}

/* Save Recipe (outside content div) */

.wprm-recipe-template-cwp-food div.wpforms-container,
.wprm-recipe-template-cwp-food div.wpforms-container.one-line {
	background: var(--wp--preset--color--quaternary);
	border: none;
	border-left: 1px solid var(--wp--preset--color--quinary);
	border-right: 1px solid var(--wp--preset--color--quinary);
	padding: 16px var(--wp--custom--layout--padding);
	margin: 0;
}

.wprm-recipe-template-cwp-food div.wpforms-container .wpforms-title {
	font-size: var(--wp--preset--font-size--x-large);
	margin-bottom: 8px;
}

.wprm-recipe-template-cwp-food div.wpforms-container .wpforms-description {
	font-size: var(--wp--preset--font-size--small);
}

.wprm-recipe-template-cwp-food div.wpforms-container .wpforms-head-container > *:last-child {
	margin: 0;
}

.wprm-recipe-template-cwp-food div.wpforms-container .wpforms-form,
.wprm-recipe-template-cwp-food div.wpforms-container .wpforms-form > fieldset[disabled] {
	display: grid;
	grid-template-columns: 1fr fit-content(300px);
	column-gap: var(--wp--custom--layout--block-gap);
}

.wprm-recipe-template-cwp-food div.wpforms-container .wpforms-head-container {
	grid-column: 1 / -1;
}

.wprm-recipe-template-cwp-food div.wpforms-container .wpforms-field-container {
	display: flex;
	gap: var(--wp--custom--layout--block-gap);
}

.wprm-recipe-template-cwp-food div.wpforms-container .wpforms-field {
	margin: 0;
	flex-basis: 0;
	flex-grow: 1;
}

.wprm-recipe-template-cwp-food div.wpforms-container .wpforms-field-label {
	min-height: 26px;
}

.wprm-recipe-template-cwp-food div.wpforms-container .wpforms-submit-container {
	margin: 0;
	padding-top: 26px;
}

.wprm-recipe-template-cwp-food div.wpforms-container.one-line .wpforms-submit-container {
	padding-top: 0;
}

.wprm-recipe-template-cwp-food div.wpforms-container.one-line.no-labels .wpforms-field-label {
	display: none;
}

@media only screen and (min-width: 768px) {

	.wprm-recipe-template-cwp-food div.wpforms-container .wpforms-form,
	.wprm-recipe-template-cwp-food div.wpforms-container.one-line .wpforms-form {
		grid-template-columns: 300px 1fr fit-content(300px);
		align-items: flex-end;
	}

	.wprm-recipe-template-cwp-food div.wpforms-container .wpforms-head-container,
	.wprm-recipe-template-cwp-food div.wpforms-container.one-line .wpforms-head-container {
		grid-column: span 1;
	}
}

@media only screen and (max-width: 767px) {
	.wprm-recipe-template-cwp-food div.wpforms-container,
	.wprm-recipe-template-cwp-food div.wpforms-container.one-line {
		border-left: 0;
		border-right: 0;
	}
}

/* Content */
.cwp-food-content {
	background: var(--wp--preset--color--octonary);
	border-left: 1px solid var(--wp--preset--color--quinary);
	border-right: 1px solid var(--wp--preset--color--quinary);
	padding: 0 var(--wp--custom--layout--padding) var(--wp--custom--layout--padding);
}

.cwp-food-content:last-child {
	/* border-bottom: 1px solid var(--wp--preset--color--foreground); */
}

.cwp-food-content > div {
	margin-top: 40px;
	padding-top: 40px;
	border-top: 1px solid var(--wp--preset--color--quinary);
	position: relative;
}

.cwp-food-content > div::before {
	content: '';
	position: absolute;
	top: 4px;
	left: 0;
	width: 100%;
	height: 1px;
	background: var(--wp--preset--color--quinary);
}

.cwp-food-content > div:first-child,
.cwp-food-content > div#recipe-video,
.cwp-food-content > div#recipe-video + *,
.cwp-food-content > .wprm-recipe-video-container,
.cwp-food-content > div.wprm-spacer,
.cwp-food-content > .wpforms-container + * {
	margin-top: 0;
	padding-top: 0;
	border-top: 0;
}

.cwp-food-content > div:first-child::before,
.cwp-food-content > div#recipe-video::before,
.cwp-food-content > div#recipe-video + *::before,
.cwp-food-content > .wprm-recipe-video-container::before,
.cwp-food-content > div.wprm-spacer::before,
.cwp-food-content > .wpforms-container + *::before {
	display: none;
}

.cwp-food-content .wprm-recipe-header,
.cwp-food-content .wprm-recipe-ingredient-group-name,
.cwp-food-content .wprm-recipe-instruction-group-name {
	font-family: var(--wp--custom--typography--heading--font-family);
	font-weight: 525;
	letter-spacing: normal;
	line-height: var(--wp--custom--line-height--small);
	text-transform: none;
}

.cwp-food-content .wprm-recipe-header {
	font-size: 2rem;
	margin-bottom: 24px;
}

.cwp-food-content .wprm-recipe-ingredient-group-name,
.cwp-food-content .wprm-recipe-instruction-group-name {
	font-size: 1.93rem;
	color: var(--wp--preset--color--foreground);
}

.wprm-recipe-template-cwp-food .wprm-recipe-details-unit {
	font-size: inherit;
}

.cwp-food-content .wprm-recipe-equipment,
.cwp-food-content .wprm-recipe-ingredient-group,
.cwp-food-content .wprm-recipe-ingredients,
.cwp-food-content .wprm-recipe-instruction-group,
.cwp-food-content .wprm-recipe-instructions,
.cwp-food-content .wprm-recipe-notes {
	margin-block-start: 16px;
}

@media only screen and (min-width: 768px) {
	.wprm-recipe-template-cwp-food {
		--wp--custom--layout--padding: 40px;
	}

	.cwp-food-content .wprm-recipe-header > *:first-child:not(.wprm-decoration-line) {
		margin-left: auto;
	}

}
@media only screen and (max-width: 767px) {
	.wprm-recipe-template-cwp-food {
		margin-left: calc( -1 * var(--wp--custom--layout--padding) );
		margin-right: calc( -1 * var(--wp--custom--layout--padding) );
		width: calc( 100% + 2 * var(--wp--custom--layout--padding) );
	}

	.cwp-food-content {
		border-left: 0;
		border-right: 0;
	}
}

/* Jump to Section */
.cwp-food-content .wprm-recipe-jump-to-section-container {
	margin-top: 24px;
	margin-bottom: 24px;
	border: none;
	padding: 0;
	display: flex;
	flex-wrap: wrap;
	gap: 6px;
}

.cwp-food-content .wprm-recipe-jump-to-section-container::before {
	display: none;
}

.cwp-food-content .wprm-recipe-jump-to-section-container a.wprm-recipe-jump-to-section {
	flex: 1 1;
	justify-content: center;
	text-align: center;
	background: var(--wp--preset--color--quinary);
	border: 1px solid var(--wp--preset--color--tertiary);
	border-radius: 0;
	font-family: var(--wp--custom--typography--interface--font-family);
	letter-spacing: var(--wp--custom--typography--interface--letter-spacing);
	text-transform: var(--wp--custom--typography--interface--text-transform);
	font-weight: 400;
	font-size: .7rem;
	text-decoration: none;
	padding: 4px;
}

/* Collapsible Section Toggles */
.cwp-food-content .wprm-recipe-header .wprm-header-toggle a.wprm-expandable-button {
	border: 1px solid var(--wp--preset--color--tertiary);
	border-radius: 50%;
	width: 30px;
	height: 30px;
	align-items: center;
	justify-content: center;
}

.wprm-expandable-container-separated.wprm-expandable-collapsed .wprm-expandable-button-show,
.wprm-expandable-container-separated.wprm-expandable-expanded .wprm-expandable-button-hide {
	display: flex;
}

.cwp-food-content .wprm-recipe-header .wprm-recipe-icon.wprm-collapsible-icon {
	margin: 0;
	line-height: 19px;
}

.cwp-food-content .wprm-recipe-header .wprm-recipe-icon.wprm-collapsible-icon svg {
	width: 1.2rem;
	height: 1.2rem;
}

/* Checkboxes (shared for equipment, ingredients, instructions) */
.cwp-food-content .wprm-recipe-equipment li .wprm-checkbox-container,
.cwp-food-content .wprm-recipe-ingredients li .wprm-checkbox-container,
.cwp-food-content .wprm-recipe-instructions li .wprm-checkbox-container {
	top: 0.3rem;
}

.cwp-food-content .wprm-checkbox-container label::before {
	border: 2px solid var(--wp--preset--color--tertiary);
	border-radius: 6px;
}

/* Equipment */

.cwp-food-content .wprm-recipe-equipment li {
	margin-top: 8px;
}

/* Ingredients */

.cwp-food-content .wprm-unit-conversion-container {
	display: flex;
	justify-content: flex-end;
}

.cwp-food-content .wprm-unit-conversion-container-buttons button.wprm-unit-conversion,
.cwp-food-content .wprm-toggle-container button.wprm-toggle {
	font-family: var(--wp--custom--typography--interface--font-family);
	letter-spacing: var(--wp--custom--typography--interface--letter-spacing);
	text-transform: var(--wp--custom--typography--interface--text-transform);
	font-weight: 700;
	line-height: var(--wp--custom--line-height--medium);
	font-size: var(--wp--preset--font-size--small);
	padding: 11px 12px;
}

/* Servings Adjuster Buttons (0.5x, 1x, 2x) */
.cwp-food-content .wprm-recipe-adjustable-servings-container {
	display: flex;
	color: var(--wp--preset--color--foreground) !important;
	gap: 4px;
	border: none;
	margin-bottom: 24px;
}

.cwp-food-content .wprm-recipe-adjustable-servings-container > * {
	border: 1px solid var(--wp--preset--color--tertiary) !important;
	font-family: var(--wp--custom--typography--interface--font-family) !important;
	font-size: var(--wp--preset--font-size--small) !important;
	font-weight: 700 !important;
	text-transform: var(--wp--custom--typography--interface--text-transform) !important;
	letter-spacing: var(--wp--custom--typography--interface--letter-spacing) !important;
	padding-block: 8px !important;
	flex-basis: 0;
	flex-grow: 1;
	text-align: center;
}

.cwp-food-content .wprm-recipe-adjustable-servings-container > .wprm-toggle-active,
.cwp-food-content .wprm-recipe-adjustable-servings-container button.wprm-toggle:not(.wprm-toggle-active):hover {
	color: var(--wp--preset--color--foreground) !important;
	background: var(--wp--preset--color--background) !important;
}

.cwp-food-content .wprm-recipe-adjustable-servings-container button.wprm-toggle:not(.wprm-toggle-active) {
	background: var(--wp--preset--color--octonary) !important;
}

.cwp-food-content .wprm-recipe-header.wprm-header-has-actions {
	row-gap: 16px;
}

.cwp-food-content .wprm-recipe-ingredient-group-name {
	margin-bottom: 8px;
}

.cwp-food-content .wprm-recipe-ingredients-container {
	font-size: var(--wp--preset--font-size--medium);
	margin-left: 0;
}

.cwp-food-content .wprm-recipe-ingredients ul {
	padding-left: 0;
	margin: 0;
}

.cwp-food-content .wprm-recipe-ingredient-group h4.wprm-recipe-ingredient-group-name {
	font-size: var(--wp--preset--font-size--medium);
	font-weight: 400;
	font-family: var(--wp--preset--font-family--body);
	margin: 0;
	line-height: 1.6;
}

.cwp-food-content .wprm-recipe-ingredient-group:not(:last-of-type) {
	margin-bottom: 8px;
}

/* Ingredient disc bullets - gray circles */
.cwp-food-content .wprm-recipe-ingredients ul {
	list-style: none !important;
}

.cwp-food-content .wprm-recipe-ingredients li {
	list-style: none !important;
	padding-left: 18px;
	position: relative;
	margin-left: 5px;
}

.cwp-food-content .wprm-recipe-ingredients li::before {
	content: "";
	display: block;
	background-color: #aaaaaa;
	width: 8px;
	height: 8px;
	border-radius: 50%;
	position: absolute;
	left: 0;
	top: 0.6em;
}

/* Ingredient spacing between amount, unit, name, notes */
/* WPRM injects a literal space between these spans, so no margin needed.
   Previously 0.25em, which compounded to a visible double-space. */
.cwp-food-content .wprm-recipe-ingredients .wprm-recipe-ingredient-amount,
.cwp-food-content .wprm-recipe-ingredients .wprm-recipe-ingredient-unit {
	margin-right: 0;
}

.cwp-food-content .wprm-recipe-ingredients .wprm-recipe-ingredient-notes {
	margin-left: 0.15em;
}

/* Cook Mode / Prevent sleep */
.cwp-food-content .wprm-toggle-switch input {
	width: 0;
}

/* Photo Toggle Switch (Show/Hide Photos) */
.cwp-food-content .wprm-toggle-switch .wprm-toggle-switch-slider {
	background: var(--wp--preset--color--background);
	border: 1px solid var(--wp--preset--color--tertiary);
	border-radius: 18px;
	--switch-height: 36px;
	--knob-size: 15px;
	padding-left: 36px;
}

.cwp-food-content .wprm-toggle-switch .wprm-toggle-switch-slider:before {
	background: var(--wp--preset--color--primary);
	border: 1px solid var(--wp--preset--color--foreground);
	left: 12px;
}

.cwp-food-content .wprm-toggle-switch-inside .wprm-toggle-switch-text .wprm-toggle-switch-off,
.cwp-food-content .wprm-toggle-switch-inside .wprm-toggle-switch-text .wprm-toggle-switch-on {
	font-size: var(--wp--preset--font-size--small);
}

/* Instructions */

.cwp-food-content ul.wprm-recipe-instructions li {
	margin-top: 8px;
}

.cwp-food-content .wprm-recipe-instructions-container .wprm-media-toggle-checkbox {
	display: none;
}

.cwp-food-content .wprm-recipe-instruction-media img {
	max-width: 292px;
}

/* Video */

.cwp-food-content #recipe-video {
	display: none;
}

.cwp-food-content .wprm-recipe-video iframe {
	width: 100%;
	height: 100%;
	aspect-ratio: 16 / 9;
}

/* Notes */

/* Private Notes */
.cwp-food-content .wprm-private-notes-wrapper {
	margin-top: 24px;
	border-top: 1px solid var(--wp--preset--color--quinary);
	padding-top: 24px;
}

.cwp-food-content .wprm-private-notes-container {
	background: var(--wp--preset--color--background);
	border: 1px solid var(--wp--preset--color--tertiary);
	padding: 16px 20px;
	min-height: 102px;
	font-size: var(--wp--preset--font-size--small);
}

.cwp-food-content .wprm-private-notes-container.wprm-private-notes-editing {
	padding: 0;
}

.cwp-food-content .wprm-private-notes-container textarea {
	padding: 16px 20px;
}

.cwp-food-content .wprm-private-notes-placeholder a {
	text-decoration: none;
}

/* Nutrition */

.cwp-food-nutrition .wprm-recipe-header,
.cwp-food-nutrition__title {
	font-family: var(--wp--custom--typography--heading--font-family);
	font-weight: 525;
	font-size: 2rem;
	letter-spacing: normal;
	line-height: var(--wp--custom--line-height--small);
	text-transform: none;
	margin: 0 0 8px;
}

.cwp-food-nutrition .wprm-expandable-container {
	margin: 0;
}

.cwp-food-nutrition .wprm-expandable-container a.wprm-expandable-button {
	font-family: var(--wp--preset--font-family--body);
	font-size: var(--wp--preset--font-size--tiny);
	font-weight: 500;
	text-transform: uppercase;
	letter-spacing: 0.08em;
	text-decoration: underline;
	text-underline-offset: 4px;
	color: var(--wp--preset--color--foreground);
}

/* Hide the default triangle icon so "Show/Hide details" sits flush-left under the Nutrition title */
.cwp-food-nutrition .wprm-expandable-container a.wprm-expandable-button .wprm-recipe-icon {
	display: none;
}

.cwp-food-nutrition .wprm-recipe-header .wprm-header-toggle a.wprm-expandable-button {
	border: 1px solid var(--wp--preset--color--tertiary);
	border-radius: 50%;
	width: 30px;
	height: 30px;
	align-items: center;
	justify-content: center;
}

.cwp-food-nutrition .wprm-recipe-header .wprm-recipe-icon.wprm-collapsible-icon {
	margin: 0;
	line-height: 19px;
}

.cwp-food-nutrition .wprm-recipe-header .wprm-recipe-icon.wprm-collapsible-icon svg {
	width: 1.2rem;
	height: 1.2rem;
}

.cwp-food-nutrition .wprm-nutrition-label-container,
.wprm-nutrition-toggle {
	margin: 16px 0;
}

.cwp-food-nutrition .wprm-nutrition-label-container {
	font-size: var(--wp--preset--font-size--min);
}

.cwp-food-nutrition .wprm-nutrition-label-container-grouped > span,
.cwp-food-nutrition .wprm-nutrition-label-text-nutrition-label {
	white-space: normal;
	word-break: normal;
	overflow-wrap: break-word;
}

.cwp-food-nutrition .wprm-nutrition-label-container-grouped {
	font-weight: 700;
	text-transform: uppercase;
	line-height: 1;
	gap: 24px 16px;
	display: grid;
	grid-template-columns: repeat( 2, minmax( 0, 1fr ) );
	margin-bottom: 24px;
}

.cwp-food-nutrition .wprm-nutrition-label-text-nutrition-label {
	font-weight: 400;
	text-transform: uppercase;
	display: block;
	margin-bottom: 8px;
}

.cwp-food-nutrition .wprm-nutrition-label-container-label .wprm-nutrition-label {
	margin: 0 0 8px;
}

.cwp-food-nutrition .wprm-nutrition-label-text-nutrition-value,
.cwp-food-nutrition .wprm-nutrition-label-text-nutrition-unit {
	font-weight: 700;
}

.cwp-food-nutrition .wprm-nutrition-label-text-nutrition-unit {
	margin-inline: 2px;
}

.cwp-food-nutrition .cwp-food-nutrition__disclaimer {
	font-size: var(--wp--preset--font-size--min);
	font-style: italic;
}

@media only screen and (min-width: 768px) {
	.cwp-food-nutrition .wprm-nutrition-label-container-grouped {
		grid-template-columns: repeat( 4, minmax( 0, 1fr ) );
	}
}

/* Meta */

.cwp-food-meta .wprm-recipe-meta-container {
	margin: 16px 0 0;
}

.cwp-food-meta .wprm-recipe-meta-container > div + div {
	margin-top: 8px;
}

/* CTA */

.wprm-recipe-template-cwp-food .wprm-call-to-action {
	padding: var(--wp--custom--layout--padding);
	justify-content: flex-start;
	flex-wrap: nowrap;
	align-items: center;
}

.wprm-recipe-template-cwp-food .wprm-call-to-action.wprm-call-to-action-simple .wprm-call-to-action-text-container {
	text-align: left;
	margin: 0;
}

.wprm-recipe-template-cwp-food .wprm-call-to-action.wprm-call-to-action-simple .wprm-call-to-action-text-container .wprm-call-to-action-header {
	font-family: var(--wp--custom--typography--interface--font-family);
	letter-spacing: var(--wp--custom--typography--interface--letter-spacing);
	text-transform: var(--wp--custom--typography--interface--text-transform);
	line-height: var(--wp--custom--line-height--medium);
	font-size: var(--wp--preset--font-size--large);
	font-weight: 700;
}

.wprm-recipe-template-cwp-food .wprm-call-to-action-text {
	font-size: var(--wp--preset--font-size--small);
	line-height: var(--wp--custom--line-height--medium);
}

.wprm-recipe-template-cwp-food .wprm-call-to-action.wprm-call-to-action-simple .wprm-call-to-action-icon {
	/* margin: 0 16px 0 0; */
	width: 64px;
	height: 64px;
}

.wprm-recipe-template-cwp-food .wprm-call-to-action.wprm-call-to-action-simple .wprm-call-to-action-icon img {
	border-radius: 50%;
	object-fit: cover;
}

/* =========================================================
   Rating modal (?rate= and "Rate" button trigger)
   The modal is global — fires from any WPRM card on the
   site. Selectors are NOT scoped to wprm-recipe-template-cwp-food.
   ========================================================= */

/* Overlay */
.wprm-popup-modal__overlay {
	background: rgba(39, 36, 37, 0.7); /* var(--wp--preset--color--foreground) at 0.7 */
}

/* Container */
.wprm-popup-modal__container {
	background: var(--wp--preset--color--octonary);
	border: 1px solid var(--wp--preset--color--quinary);
	border-radius: 0;
	color: var(--wp--preset--color--foreground);
	font-family: var(--wp--preset--font-family--body);
	max-width: 560px;
}

/* Header */
.wprm-popup-modal__header {
	background: var(--wp--preset--color--octonary);
	border-bottom: 1px solid var(--wp--preset--color--quinary);
	padding: var(--wp--custom--layout--padding);
}

.wprm-popup-modal__title {
	font-family: var(--wp--custom--typography--heading--font-family);
	font-weight: 525;
	font-size: 1.93rem;
	line-height: var(--wp--custom--line-height--small);
	letter-spacing: normal;
	text-transform: none;
	color: var(--wp--preset--color--foreground);
	margin: 0;
}

.wprm-popup-modal__close {
	color: var(--wp--preset--color--foreground);
}

.wprm-popup-modal__close:hover {
	color: var(--wp--preset--color--tertiary);
}

/* Content */
.wprm-popup-modal__content {
	padding: var(--wp--custom--layout--padding);
}

.wprm-user-ratings-modal-recipe-name {
	font-family: var(--wp--custom--typography--heading--font-family);
	font-weight: 525;
	font-size: var(--wp--preset--font-size--large);
	line-height: var(--wp--custom--line-height--small);
	color: var(--wp--preset--color--foreground);
	text-align: center;
	margin-bottom: 16px;
}

/* Stars — recolor empty + filled to brand yellow.
   WPRM uses inline SVG with `stroke` attribute, so we override via
   CSS attribute selectors. */
.wprm-user-ratings-modal-stars-container {
	text-align: center;
	margin-bottom: 24px;
}

.wprm-user-ratings-modal-stars legend {
	font-family: var(--wp--custom--typography--interface--font-family);
	letter-spacing: var(--wp--custom--typography--interface--letter-spacing);
	text-transform: var(--wp--custom--typography--interface--text-transform);
	font-size: var(--wp--preset--font-size--min);
	color: var(--wp--custom--color--neutral-700);
	margin-bottom: 8px;
}

.wprm-user-ratings-modal-stars svg path[stroke="#FFD700"] {
	stroke: var(--wp--preset--color--quaternary) !important;
}

.wprm-user-ratings-modal-stars svg path.wprm-modal-star-full,
.wprm-user-ratings-modal-stars svg path[fill="#FFD700"] {
	fill: var(--wp--preset--color--quaternary) !important;
	stroke: var(--wp--preset--color--quaternary) !important;
}

/* Form fields */
.wprm-user-rating-modal-field {
	margin-bottom: 16px;
}

.wprm-user-rating-modal-field label {
	font-family: var(--wp--custom--typography--interface--font-family);
	letter-spacing: var(--wp--custom--typography--interface--letter-spacing);
	text-transform: var(--wp--custom--typography--interface--text-transform);
	font-weight: 700;
	font-size: var(--wp--preset--font-size--min);
	color: var(--wp--custom--color--neutral-700);
	display: block;
	margin-bottom: 4px;
}

.wprm-user-rating-modal-field input,
.wprm-user-rating-modal-comment {
	width: 100%;
	background: var(--wp--preset--color--background);
	border: 1px solid var(--wp--preset--color--tertiary);
	border-radius: 0;
	padding: 8px 12px;
	font-family: var(--wp--preset--font-family--body);
	font-size: var(--wp--preset--font-size--small);
	color: var(--wp--preset--color--foreground);
}

.wprm-user-rating-modal-comment {
	min-height: 96px;
	resize: vertical;
}

.wprm-user-rating-modal-field input:focus,
.wprm-user-rating-modal-comment:focus {
	outline: none;
	border-color: var(--wp--preset--color--foreground);
}

/* Buttons — match the yellow .cwp-food-buttons style */
.wprm-user-rating-modal-submit-comment,
.wprm-popup-modal__btn {
	background: var(--wp--preset--color--quaternary);
	border: 1px solid var(--wp--preset--color--tertiary);
	border-radius: 0;
	color: var(--wp--preset--color--foreground);
	font-family: var(--wp--custom--typography--interface--font-family);
	letter-spacing: var(--wp--custom--typography--interface--letter-spacing);
	text-transform: var(--wp--custom--typography--interface--text-transform);
	font-weight: 700;
	line-height: var(--wp--custom--line-height--medium);
	font-size: var(--wp--preset--font-size--small);
	padding: 8px 16px;
	cursor: pointer;
}

.wprm-user-rating-modal-submit-comment:hover,
.wprm-popup-modal__btn:hover {
	background: var(--wp--preset--color--background);
}

/* Footer */
.wprm-popup-modal__footer {
	border-top: 1px solid var(--wp--preset--color--quinary);
	padding: 16px var(--wp--custom--layout--padding);
	display: flex;
	justify-content: flex-end;

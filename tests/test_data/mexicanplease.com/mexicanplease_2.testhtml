<style id='feast-global-styles-inline-css' type='text/css'>
.feast-social-media {
	display: flex;
	flex-wrap: wrap;
	align-items: center;
	justify-content: center;
	column-gap: 18px;
	row-gap: 9px;
	width: 100%;
	padding: 27px 0;
}
.feast-social-media a {
	display: flex;
	align-items: center;
	justify-content: center;
	padding: 12px;
}
@media(max-width:600px) {
	.feast-social-media a {
		min-height: 50px;
		min-width: 50px;
	}
}

</style>

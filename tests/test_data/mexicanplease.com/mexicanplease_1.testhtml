lAction":[{"@type":"ReadAction","target":["https://www.mexicanplease.com/homemade-corn-tortillas/"]}]},{"@type":"ImageObject","inLanguage":"en-US","@id":"https://www.mexicanplease.com/homemade-corn-tortillas/#primaryimage","url":"https://www.mexicanplease.com/wp-content/uploads/2016/03/Stack-of-homemade-corn-tortillas-on-towel.jpg","contentUrl":"https://www.mexicanplease.com/wp-content/uploads/2016/03/Stack-of-homemade-corn-tortillas-on-towel.jpg","width":816,"height":680,"caption":"14 corn tortillas after cooking on comal"},{"@type":"BreadcrumbList","@id":"https://www.mexicanplease.com/homemade-corn-tortillas/#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://www.mexicanplease.com/"},{"@type":"ListItem","position":2,"name":"Mexican Cooking 101","item":"https://www.mexicanplease.com/category/mexican-cooking-101/"},{"@type":"ListItem","position":3,"name":"Homemade Corn Tortillas"}]},{"@type":"WebSite","@id":"https://www.mexicanplease.com/#website","url":"https://www.mexicanplease.com/","name":"Mexican Please","description":"Mexican Food Recipes and Authentic Mexican Cooking Techniques.","publisher":{"@id":"https://www.mexicanplease.com/#organization"},"potentialAction":[{"@type":"SearchAction","target":{"@type":"EntryPoint","urlTemplate":"https://www.mexicanplease.com/?s={search_term_string}"},"query-input":"required name=search_term_string"}],"inLanguage":"en-US"},{"@type":"Organization","@id":"https://www.mexicanplease.com/#organization","name":"Mexican Please","url":"https://www.mexicanplease.com/","logo":{"@type":"ImageObject","inLanguage":"en-US","@id":"https://www.mexicanplease.com/#/schema/logo/image/","url":"https://www.mexicanplease.com/wp-content/uploads/2018/04/mexicanplease-logo-first-draft.jpg","contentUrl":"https://www.mexicanplease.com/wp-content/uploads/2018/04/mexicanplease-logo-first-draft.jpg","width":1112,"height":1112,"caption":"Mexican Please"},"image":{"@id":"https://www.mexicanplease.com/#/schema/logo/image/"},"sameAs":["https://www.facebook.com/MexicanPlease","https://twitter.com/MexPlease","https://www.pinterest.com/MexicanPlease/"]},{"@type":"Person","@id":"https://www.mexicanplease.com/#/schema/person/29ed2b1f7e86e83c2fd922e0ed154bcb","name":"Patrick","url":"https://www.mexicanplease.com/author/patrick/"},{"@type":"Recipe","name":"Homemade Corn Tortillas","author":{"@type":"Person","name":"Mexican Please"},"description":"Keep some Masa Harina in the cupboard and you&#039;ll always have the option of making a quick batch of warm, delicious corn tortillas!","datePublished":"2020-06-27T12:24:43+00:00","image":["https://www.mexicanplease.com/wp-content/uploads/2016/03/homemade-corn-tortillas-stacked-after-cooking-angled.jpg"],"recipeYield":["4","4 (12-16 tortillas)"],"prepTime":"PT15M","cookTime":"PT15M","totalTime":"PT30M","recipeIngredient":["2 cups Masa Harina","1/2 teaspoon salt","1.5 cups warm water"],"recipeInstructions":[{"@type":"HowToStep","text":"Add 2 cups Masa Harina and 1/2 teaspoon salt to a mixing bowl.  Add 1 cup of the warm water and stir until the water is absorbed.  Add the rest of the water incrementally until the flour melds into a dough.  Use your hands to knead the dough into a cohesive ball.  ","name":"Add 2 cups Masa Harina and 1/2 teaspoon salt to a mixing bowl.  Add 1 cup of the warm water and stir until the water is absorbed.  Add the rest of the water incrementally until the flour melds into a dough.  Use your hands to knead the dough into a cohesive ball.  ","url":"https://www.mexicanplease.com/homemade-corn-tortillas/#wprm-recipe-3276-step-0-0"},{"@type":"HowToStep","text":"If the dough is sticking to your hands simply add a few sprinklings of Masa Harina to dry it out.  Conversely, if the dough is still crumbly then you can add splashes of water until it becomes cohesive.","name":"If the dough is sticking to your hands simply add a few sprinklings of Masa Harina to dry it out.  Conversely, if the dough is still crumbly then you can add splashes of water until it becomes cohesive.","url":"https://www.mexicanplease.com/homemade-corn-tortillas/#wprm-recipe-3276-step-0-1"},{"@type":"HowToStep","text":"Separate the dough into golf ball sized chunks, this will make tortillas approximately 4 inches across.","name":"Separate the dough into golf ball sized chunks, this will make tortillas approximately 4 inches across.","url":"https://www.mexicanplease.com/homemade-corn-tortillas/#wprm-recipe-3276-step-0-2"},{"@type":"HowToStep","text":"Flatten the dough balls using a  flat bottomed pan or a tortilla press.  Be sure to line each side of the dough ball with plastic or Ziploc pieces.  I usually just cut off the top of a gallon sized Ziploc bag and then make slits down the sides, leaving it connected at the bottom.","name":"Flatten the dough balls using a  flat bottomed pan or a tortilla press.  Be sure to line each side of the dough ball with plastic or Ziploc pieces.  I usually just cut off the top of a gallon sized Ziploc bag and then make slits down the sides, leaving it connected at the bottom.","url":"https://www.mexicanplease.com/homemade-corn-tortillas/#wprm-recipe-3276-step-0-3"},{"@type":"HowToStep","text":"Heat a skillet or comal to medium-high heat.  (Lately I use a tad over medium heat on my stove and this will have brown spots forming in about 60 seconds.)","name":"Heat a skillet or comal to medium-high heat.  (Lately I use a tad over medium heat on my stove and this will have brown spots forming in about 60 seconds.)","url":"https://www.mexicanplease.com/homemade-corn-tortillas/#wprm-recipe-3276-step-0-4"},{"@type":"HowToStep","text":"Add a tortilla to the skillet and flip it after 10 seconds. Then cook each side for about a minute or until light brown spots are forming on the underside.","name":"Add a tortilla to the skillet and flip it after 10 seconds. Then cook each side for about a minute or until light brown spots are forming on the underside.","url":"https://www.mexicanplease.com/homemade-corn-tortillas/#wprm-recipe-3276-step-0-5"},{"@type":"HowToStep","text":"Continue cooking the rest of the tortillas.   I usually put one in the skillet and flatten the next one to expedite the process.   Once cooked you can keep them warm by wrapping them in a tea towel or using a dedicated tortilla warmer.  Serve immediately.","name":"Continue cooking the rest of the tortillas.   I usually put one in the skillet and flatten the next one to expedite the process.   Once cooked you can keep them warm by wrapping them in a tea towel or using a dedicated tortilla warmer.  Serve immediately.","url":"https://www.mexicanplease.com/homemade-corn-tortillas/#wprm-recipe-3276-step-0-6"},{"@type":"HowToStep","text":"Store leftovers tortillas in an airtight container in the fridge.  To reheat, cook them in a dry skillet over medium heat until warm and crispy.","name":"Store leftovers tortillas in an airtight container in the fridge.  To reheat, cook them in a dry skillet over medium heat until warm and crispy.","url":"https://www.mexicanplease.com/homemade-corn-tortillas/#wprm-recipe-3276-step-0-7"}],"aggregateRating":{"@type":"AggregateRating","ratingValue":"4.16","ratingCount":"268"},"recipeCategory":["Side Dish"],"recipeCuisine":["Mexican"],"nutrition":{"@type":"NutritionInformation","calories":"208 kcal","carbohydrateContent":"43 g","proteinContent":"5 g","fatContent":"2 g","saturatedFatContent":"1 g","sodiumContent":"294 mg","fiberContent":"4 g","servingSize":"1 serving"},"@id":"https://www.mexicanplease.com/homemade-corn-tortillas/#recipe","isPartOf":{"@id":"https://www.mexicanplease.com/homemade-corn-tortillas/#article"},"mainEntityOfPage":"https://www.mexicanplease.com/homemade-corn-tortillas/"}]}</script>

p-content/uploads/2016/03/homemade-corn-tortillas-stacked-after-cooking-angled-150x150.jpg 150w, https://www.mexicanplease.com/wp-content/uploads/2016/03/homemade-corn-tortillas-stacked-after-cooking-angled-320x320.jpg 320w" sizes="(max-width: 200px) 100vw, 200px" /></noscript></div>
<div class="wprm-recipe-template-current-version-of-cutout-template-container">
	<div class="wprm-recipe-template-current-version-of-cutout-template-header">
		<h2 class="wprm-recipe-name wprm-block-text-bold">Homemade Corn Tortillas</h2>
		<div class="wprm-spacer" style="height: 5px"></div>
		<div class="wprm-recipe-summary wprm-block-text-normal"><span style="display: block;">Keep some Masa Harina in the cupboard and you&#039;ll always have the option of making a quick batch of warm, delicious corn tortillas!</span></div>
		<div class="wprm-spacer" style="height: 15px"></div>

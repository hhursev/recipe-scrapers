	</div><style type="text/css">.wprm-recipe-template-cast-iron-keto-custom-recipe-card {
    margin: 20px auto;
    background-color: #ffffff; /*wprm_background type=color*/
    font-family: inherit; /*wprm_main_font_family type=font*/
    font-size: 16px; /*wprm_main_font_size type=font_size*/
    line-height: 1.5em !important; /*wprm_main_line_height type=font_size*/
    color: #333333; /*wprm_main_text type=color*/
    max-width: 650px; /*wprm_max_width type=size*/
}
.wprm-recipe-template-cast-iron-keto-custom-recipe-card a {
    color: #4d8095; /*wprm_link type=color*/
}
.wprm-recipe-template-cast-iron-keto-custom-recipe-card p, .wprm-recipe-template-cast-iron-keto-custom-recipe-card li {
    font-family: inherit; /*wprm_main_font_family type=font*/
    font-size: 1em !important;
    line-height: 1.5em !important; /*wprm_main_line_height type=font_size*/
}
.wprm-recipe-template-cast-iron-keto-custom-recipe-card li {
    margin: 0 0 0 32px !important;
    padding: 0 !important;
}
.wprm-recipe-template-cast-iron-keto-custom-recipe-card ol, .wprm-recipe-template-cast-iron-keto-custom-recipe-card ul {
    margin: 0 !important;
    padding: 0 !important;
}
.wprm-recipe-template-cast-iron-keto-custom-recipe-card br {
    display: none;
}
.wprm-recipe-template-cast-iron-keto-custom-recipe-card .wprm-recipe-name,
.wprm-recipe-template-cast-iron-keto-custom-recipe-card .wprm-recipe-header {
    font-family: Helvetica, sans-serif; /*wprm_header_font_family type=font*/
    color: #000000; /*wprm_header_text type=color*/
    line-height: 1.3em; /*wprm_header_line_height type=font_size*/
}
.wprm-recipe-template-cast-iron-keto-custom-recipe-card h1,
.wprm-recipe-template-cast-iron-keto-custom-recipe-card h2,
.wprm-recipe-template-cast-iron-keto-custom-recipe-card h3,
.wprm-recipe-template-cast-iron-keto-custom-recipe-card h4,
.wprm-recipe-template-cast-iron-keto-custom-recipe-card h5,
.wprm-recipe-template-cast-iron-keto-custom-recipe-card h6 {
    font-family: Helvetica, sans-serif; /*wprm_header_font_family type=font*/
    color: #000000; /*wprm_header_text type=color*/
    line-height: 1.3em; /*wprm_header_line_height type=font_size*/
    margin: 0 !important;
    padding: 0 !important;
}
.wprm-recipe-template-cast-iron-keto-custom-recipe-card .wprm-recipe-header {
    margin-top: 1.2em !important;
}
.wprm-recipe-template-cast-iron-keto-custom-recipe-card h1 {
    font-size: 2em; /*wprm_h1_size type=font_size*/
}
.wprm-recipe-template-cast-iron-keto-custom-recipe-card h2 {
    font-size: 1.8em; /*wprm_h2_size type=font_size*/
}
.wprm-recipe-template-cast-iron-keto-custom-recipe-card h3 {
    font-size: 1.2em; /*wprm_h3_size type=font_size*/
}
.wprm-recipe-template-cast-iron-keto-custom-recipe-card h4 {
    font-size: 1em; /*wprm_h4_size type=font_size*/
}
.wprm-recipe-template-cast-iron-keto-custom-recipe-card h5 {
    font-size: 1em; /*wprm_h5_size type=font_size*/
}
.wprm-recipe-template-cast-iron-keto-custom-recipe-card h6 {
    font-size: 1em; /*wprm_h6_size type=font_size*/
}.wprm-recipe-template-cast-iron-keto-custom-recipe-card {
	position: relative;
	border-style: solid; /*wprm_border_style type=border*/
	border-width: 1px; /*wprm_border_width type=size*/
	border-color: #254343; /*wprm_border type=color*/
	border-radius: 10px; /*wprm_border_radius type=size*/
	margin: 120px auto 20px auto;
	overflow: visible;
}
.wprm-recipe-template-cast-iron-keto-custom-recipe-card-container {
	overflow: hidden;
	padding: 0 10px 10px 10px;
	border: 0;
	border-radius: 7px; /*wprm_inner_border_radius type=size*/
}
.wprm-recipe-template-cast-iron-keto-custom-recipe-card .wprm-recipe-image {
	position: absolute;
	margin-top: -100px;
	margin-left: -100px;
	left: 50%;
}
.wprm-recipe-template-cast-iron-keto-custom-recipe-card-header {
	margin: 0 -10px 10px -10px;
	padding: 110px 10px 10px 10px;
	text-align: center;
	background-color: #254343; /*wprm_top_header_background type=color*/
	color: #ffffff; /*wprm_top_header_text type=color*/
}
.wprm-recipe-template-cast-iron-keto-custom-recipe-card-header a {
	color: #ffffff; /*wprm_top_header_link type=color*/
}
.wprm-recipe-template-cast-iron-keto-custom-recipe-card-header .wprm-recipe-name {
	color: #ffffff; /*wprm_top_header_text type=color*/
}.wprm-recipe-template-snippet-basic-buttons {
    font-family: inherit; /* wprm_font_family type=font */
    font-size: 0.9em; /* wprm_font_size type=font_size */
    text-align: center; /* wprm_text_align type=align */
    margin-top: 0px; /* wprm_margin_top type=size */
    margin-bottom: 10px; /* wprm_margin_bottom type=size */
}
.wprm-recipe-template-snippet-basic-buttons a  {
    margin: 5px; /* wprm_margin_button type=size */
    margin: 5px; /* wprm_margin_button type=size */
}

.wprm-recipe-template-snippet-basic-buttons a:first-child {
    margin-left: 0;
}
.wprm-recipe-template-snippet-basic-buttons a:last-child {
    margin-right: 0;

:["https://www.castironketo.net/blog/keto-spanakopita/"]}]},{"@type":"ImageObject","inLanguage":"en-US","@id":"https://www.castironketo.net/blog/keto-spanakopita/#primaryimage","url":"https://www.castironketo.net/wp-content/uploads/2023/07/keto-spanakopita-featured-image.jpg","contentUrl":"https://www.castironketo.net/wp-content/uploads/2023/07/keto-spanakopita-featured-image.jpg","width":1200,"height":1200,"caption":"Keto Spanakopita"},{"@type":"BreadcrumbList","@id":"https://www.castironketo.net/blog/keto-spanakopita/#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://www.castironketo.net/"},{"@type":"ListItem","position":2,"name":"Keto Spanakopita (Easy Greek Spinach Pie Recipe) 🥙"}]},{"@type":"WebSite","@id":"https://www.castironketo.net/#website","url":"https://www.castironketo.net/","name":"Cast Iron Keto","description":"Tasty Keto Recipes","publisher":{"@id":"https://www.castironketo.net/#organization"},"potentialAction":[{"@type":"SearchAction","target":{"@type":"EntryPoint","urlTemplate":"https://www.castironketo.net/?s={search_term_string}"},"query-input":"required name=search_term_string"}],"inLanguage":"en-US"},{"@type":"Organization","@id":"https://www.castironketo.net/#organization","name":"Cast Iron Keto","url":"https://www.castironketo.net/","logo":{"@type":"ImageObject","inLanguage":"en-US","@id":"https://www.castironketo.net/#/schema/logo/image/","url":"https://www.castironketo.net/wp-content/uploads/2023/12/CastIronketo-retina-logo.png","contentUrl":"https://www.castironketo.net/wp-content/uploads/2023/12/CastIronketo-retina-logo.png","width":784,"height":91,"caption":"Cast Iron Keto"},"image":{"@id":"https://www.castironketo.net/#/schema/logo/image/"},"sameAs":["https://facebook.com/castironketo","https://instagram.com/castiron_keto","https://pinterest.com/castironketo"]},{"@type":"Person","@id":"https://www.castironketo.net/#/schema/person/3346a74d01cebe8770b71ae50e6faff4","name":"Feyza Kırmacı","description":"Feyza is a chef, food stylist, and photographer based in Istanbul, with a passion for creating mouth-watering dishes that cater to different diet preferences such as keto and vegan. Her culinary expertise is rooted in Turkish and Mediterranean cuisine.","sameAs":["https://www.castironketo.net/about/feyza-kirmaci/","https://www.linkedin.com/in/feyza-kirmaci-durutuna/"],"jobTitle":"Chef and Food Photographer","url":"https://www.castironketo.net/blog/author/feyzakirmaci/"},{"@type":"Recipe","name":"Keto Spanakopita","author":{"@id":"https://www.castironketo.net/#/schema/person/3346a74d01cebe8770b71ae50e6faff4"},"description":"Enjoy the scrumptious flavors of this Keto Spanakopita, where crispy phyllo and creamy spinach filling come together to create a low-carb Greek masterpiece.","datePublished":"2023-07-13T04:00:12+00:00","image":["https://www.castironketo.net/wp-content/uploads/2023/07/keto-spanakopita-featured-image.jpg","https://www.castironketo.net/wp-content/uploads/2023/07/keto-spanakopita-featured-image-500x500.jpg","https://www.castironketo.net/wp-content/uploads/2023/07/keto-spanakopita-featured-image-500x375.jpg","https://www.castironketo.net/wp-content/uploads/2023/07/keto-spanakopita-featured-image-480x270.jpg"],"video":{"name":"Keto Spanakopita: Quick & Easy Greek Spinach Pie | Classic Greek Recipe","description":"Looking for a low-carb, gluten-free twist on a classic Greek dish? Welcome to our step-by-step guide on how to make Keto Spanakopita! 🥬🧀 In this video, we'll take you through a mouthwatering culinary journey from whisking the perfect phyllo dough to creating a savory spinach and feta filling - all in under 90 minutes. 👩‍🍳👨‍🍳\n\nBut we're not stopping there! To get the full recipe, including ingredient substitutions, chef's notes, and time-saving tips, click the link below! We have designed this recipe to be flexible and user-friendly, making it perfect for both keto beginners and experienced cooks. 👇\n\n🌐  https://www.castironketo.net/blog/keto-spanakopita/\n\nAnd while you're at it, don't forget to LIKE, COMMENT and SUBSCRIBE for more delicious keto-friendly recipes! Enjoy your Keto Spanakopita and keep those carbs in check! 🥳\n\nFollow us on:\nWebsite: https://www.castironketo.net/\nInstagram: https://www.instagram.com/castiron_keto/\nFacebook: https://www.facebook.com/castironketo/\n\n#Spanakopita #KetoRecipes #LowCarbLiving #HealthyEating #GreekRecipes #KetoDiet #HealthyRecipes #GreekCuisine #EasyCooking #StepByStepRecipes #KetoLifestyle #CastIronKeto","uploadDate":"2023-07-07T09:59:38+00:00","duration":"PT2M32S","thumbnailUrl":"https://i.ytimg.com/vi/p9q66II9SLk/hqdefault.jpg","embedUrl":"https://www.youtube.com/embed/p9q66II9SLk?feature=oembed","contentUrl":"https://www.youtube.com/watch?v=p9q66II9SLk","@type":"VideoObject"},"recipeYield":["4"],"prepTime":"PT60M","cookTime":"PT25M","totalTime":"PT85M","recipeIngredient":["4  large egg whites","1 cup water","1.2 ounces melted butter","1.1 ounces fine coconut flour","¼ teaspoon xanthan gum","12 ounces frozen baby spinach","2  spring onions (chopped)","1  egg yolk","¼ cup feta cheese (crumbled)","½ teaspoon red pepper flakes","½ teaspoon onion powder","½ teaspoon garlic powder","⅛ teaspoon black pepper","¼ teaspoon salt","⅓ cup melted butter"],"recipeInstructions":[{"@type":"HowToSection","name":"Make the phyllo batter","itemListElement":[{"@type":"HowToStep","text":"Whisk the egg whites and water until foamy in a medium bowl.","name":"Whisk the egg whites and water until foamy in a medium bowl.","url":"https://www.castironketo.net/blog/keto-spanakopita/#wprm-recipe-12809-step-0-0"},{"@type":"HowToStep","text":"Add the melted butter, xanthan gum, and coconut flour to the bowl.","name":"Add the melted butter, xanthan gum, and coconut flour to the bowl.","url":"https://www.castironketo.net/blog/keto-spanakopita/#wprm-recipe-12809-step-0-1"},{"@type":"HowToStep","text":"Mix everything until well combined.","name":"Mix everything until well combined.","url":"https://www.castironketo.net/blog/keto-spanakopita/#wprm-recipe-12809-step-0-2"}]},{"@type":"HowToSection","name":"Make the spinach mixture","itemListElement":[{"@type":"HowToStep","text":"Combine the raw spinach, chopped spring onions, egg yolk, crumbled feta cheese, and the aromatics in a large bowl.","name":"Combine the raw spinach, chopped spring onions, egg yolk, crumbled feta cheese, and the aromatics in a large bowl.","url":"https://www.castironketo.net/blog/keto-spanakopita/#wprm-recipe-12809-step-1-0"},{"@type":"HowToStep","text":"Thoroughly stir the mixture until you achieve an even distribution of all ingredients.","name":"Thoroughly stir the mixture until you achieve an even distribution of all ingredients.","url":"https://www.castironketo.net/blog/keto-spanakopita/#wprm-recipe-12809-step-1-1"}]},{"@type":"HowToSection","name":"Whip up the phyllo sheets","itemListElement":[{"@type":"HowToStep","text":"Prepare a double boiling set: Fill a pot with water and bring it to a boil. Then, place a pan on top of it.","name":"Prepare a double boiling set: Fill a pot with water and bring it to a boil. Then, place a pan on top of it.","url":"https://www.castironketo.net/blog/keto-spanakopita/#wprm-recipe-12809-step-2-0"},{"@type":"HowToStep","text":"Lightly grease the pan with cooking spray for the first phyllo. Pour approximately 3 tablespoons of phyllo batter into the pan.","name":"Lightly grease the pan with cooking spray for the first phyllo. Pour approximately 3 tablespoons of phyllo batter into the pan.","url":"https://www.castironketo.net/blog/keto-spanakopita/#wprm-recipe-12809-step-2-1"},{"@type":"HowToStep","text":"Shake the pan to spread the mixture evenly and cook for about 3-4 minutes, until the edges separate from the pan.","name":"Shake the pan to spread the mixture evenly and cook for about 3-4 minutes, until the edges separate from the pan.","url":"https://www.castironketo.net/blog/keto-spanakopita/#wprm-recipe-12809-step-2-2"},{"@type":"HowToStep","text":"Carefully remove the cooked phyllo and set it on a wire rack.","name":"Carefully remove the cooked phyllo and set it on a wire rack.","url":"https://www.castironketo.net/blog/keto-spanakopita/#wprm-recipe-12809-step-2-3"},{"@type":"HowToStep","text":"Repeat the process with the remaining batter.","name":"Repeat the process with the remaining batter.","url":"https://www.castironketo.net/blog/keto-spanakopita/#wprm-recipe-12809-step-2-4"}]},{"@type":"HowToSection","name":"Assemble the pie","itemListElement":[{"@type":"HowToStep","text":"On a baking dish, lay one phyllo sheet and brush it with melted butter. Continue to stack and brush each phyllo sheet until you have a total of 4-6 layers.","name":"On a baking dish, lay one phyllo sheet and brush it with melted butter. Continue to stack and brush each phyllo sheet until you have a total of 4-6 layers.","url":"https://www.castironketo.net/blog/keto-spanakopita/#wprm-recipe-12809-step-3-0"},{"@type":"HowToStep","text":"Next, spread the cooked spinach filling evenly on top of the sheets.","name":"Next, spread the cooked spinach filling evenly on top of the sheets.","url":"https://www.castironketo.net/blog/keto-spanakopita/#wprm-recipe-12809-step-3-1"},{"@type":"HowToStep","text":"Repeat the layering process with the remaining phyllo sheets.","name":"Repeat the layering process with the remaining phyllo sheets.","url":"https://www.castironketo.net/blog/keto-spanakopita/#wprm-recipe-12809-step-3-2"},{"@type":"HowToStep","text":"Then, cut the assembled pie into squares and pour the remaining melted butter over it.","name":"Then, cut the assembled pie into squares and pour the remaining melted butter over it.","url":"https://www.castironketo.net/blog/keto-spanakopita/#wprm-recipe-12809-step-3-3"}]},{"@type":"HowToSection","name":"Bake the spanakopita","itemListElement":[{"@type":"HowToStep","text":"Preheat your oven to 355°F (180°C).","name":"Preheat your oven to 355°F (180°C).","url":"https://www.castironketo.net/blog/keto-spanakopita/#wprm-recipe-12809-step-4-0"},{"@type":"HowToStep","text":"Transfer the baking dish to it and bake for 20-25 minutes, until the phyllo is golden and crispy.","name":"Transfer the baking dish to it and bake for 20-25 minutes, until the phyllo is golden and crispy.","url":"https://www.castironketo.net/blog/keto-spanakopita/#wprm-recipe-12809-step-4-1"},{"@type":"HowToStep","text":"Once done, remove it from the oven and let it cool off before serving.","name":"Once done, remove it from the oven and let it cool off before serving.","url":"https://www.castironketo.net/blog/keto-spanakopita/#wprm-recipe-12809-step-4-2"}]}],"aggregateRating":{"@type":"AggregateRating","ratingValue":"5","ratingCount":"3"},"review":[{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"where i live coconut flour isn't an option, but we do have almond flour. I do have small shredded coconut flakes... should I make flour out of that in a blender? Can you let us know what other options there are besides xantham gum. Thank you for the beautiful recipe.","author":{"@type":"Person","name":"Neda"},"datePublished":"2024-08-31"}],"recipeCategory":["Main Course"],"recipeCuisine":["Greek"],"keywords":"keto, low carb, Spanakopita","nutrition":{"@type":"NutritionInformation","calories":"310 kcal","carbohydrateContent":"9 g","proteinContent":"9 g","fatContent":"27 g","saturatedFatContent":"17 g","transFatContent":"1 g","cholesterolContent":"116 mg","sodiumContent":"578 mg","fiberContent":"5 g","sugarContent":"1 g","unsaturatedFatContent":"8 g","servingSize":"1 serving"},"@id":"https://www.castironketo.net/blog/keto-spanakopita/#recipe","isPartOf":{"@id":"https://www.castironketo.net/blog/keto-spanakopita/#article"},"mainEntityOfPage":"https://www.castironketo.net/blog/keto-spanakopita/"}]}</script>

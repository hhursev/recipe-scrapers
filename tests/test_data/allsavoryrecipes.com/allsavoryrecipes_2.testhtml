     crossorigin="anonymous"></script><link rel="icon" href="https://www.allsavoryrecipes.com/wp-content/uploads/2024/12/allsavoryrecipes-all-savory-recipes-favicon-logo.svg" sizes="32x32" /><link rel="icon" href="https://www.allsavoryrecipes.com/wp-content/uploads/2024/12/allsavoryrecipes-all-savory-recipes-favicon-logo.svg" sizes="192x192" /><link rel="apple-touch-icon" href="https://www.allsavoryrecipes.com/wp-content/uploads/2024/12/allsavoryrecipes-all-savory-recipes-favicon-logo.svg" /><meta name="msapplication-TileImage" content="https://www.allsavoryrecipes.com/wp-content/uploads/2024/12/allsavoryrecipes-all-savory-recipes-favicon-logo.svg" /><style id="wp-custom-css">/*
 * AllSavoryRecipes — Palette & Typography
 * Palette : --primary #17497D / --dark #565656 / Qualion Round
 * Dernière mise à jour : responsive + TOC aligné sur FAQ + couleurs inversées
 */

/*--------------------------------------------------------------
# 1. Variables & Root
--------------------------------------------------------------*/
:root {
    --primary:       #17497D;
    --primary-light: #DFE9EE;
    --bg-soft:       #FCF6EE;
    --form:          #FCF6EE;
    --dark:          #565656;
    --font-family:   "Qualion Round", Arial, Helvetica, sans-serif;
}

/*--------------------------------------------------------------
# 2. Typography & Base
--------------------------------------------------------------*/
body {
    font-family:    var(--font-family);
    font-size:      18px;
    line-height:    1.7;
    letter-spacing: 0.3px;
    color:          var(--dark);
}

p {
    margin-bottom:  1.5em;
    line-height:    1.8;
    letter-spacing: 0.3px;
}

h1, h2, h3, h4, h5, h6 {
    font-family:    var(--font-family);
    letter-spacing: 0.5px;
    line-height:    1.4;
    color:          var(--dark);
}

h1 { font-size: 2.5rem; }
h2 { font-size: 2rem; }
h3 { font-size: 1.7rem; }
h4 { font-size: 1.4rem; }
h5 { font-size: 1.2rem; }
h6 { font-size: 1.1rem; }

/*--------------------------------------------------------------
# 3. Navigation Typography
--------------------------------------------------------------*/
.main-navigation a,
.main-navigation .menu-toggle,
.main-navigation .menu-bar-items {
    font-family:    var(--font-family);
    font-weight:    900;
    text-transform: capitalize;
    font-size:      22px;
    letter-spacing: 0.8px;
}

/*--------------------------------------------------------------
# 4. Entry Meta
--------------------------------------------------------------*/
.entry-meta {
    font-family:    var(--font-family);
    font-weight:    300;
    font-size:      15px;
    letter-spacing: 0.3px;
    line-height:    1.6;
}

.entry-meta a       { color: var(--dark); }
.entry-meta a:hover { color: var(--primary); }
time.entry-date.published { color: var(--dark); }

/*--------------------------------------------------------------
# 5. Buttons & Interactive Elements
--------------------------------------------------------------*/
.content-area input:focus,
.content-area textarea:focus {
    border-color: var(--primary) !important;
    box-shadow:   0 0 0 1px var(--primary), 0px 1px 2px rgba(0,0,0,0.15) !important;
}

/*--------------------------------------------------------------
# 6. Separator
--------------------------------------------------------------*/
.wp-block-separator {
    border-bottom: 4px dotted var(--primary-light);
    background:    transparent;
    color:         transparent;
    opacity:       0.6;
}

/*--------------------------------------------------------------
# 7. Pagination
--------------------------------------------------------------*/
.paging-navigation .nav-links .current {
    background:      var(--primary);
    color:           #ffffff;
    font-family:     var(--font-family);
    width:           44px !important;
    height:          44px !important;
    font-size:       17px;
    border-radius:   50px;
    display:         inline-flex;
    align-items:     center;
    justify-content: center;
}

.paging-navigation .nav-links .page-numbers:not(.next, .current, .prev, .page-numbers.dots) {
    font-family:     var(--font-family);
    border:          1px solid var(--primary);
    color:           var(--primary) !important;
    width:           44px !important;
    height:          44px !important;
    font-size:       17px;
    border-radius:   50px;
    display:         inline-flex;
    align-items:     center;
    justify-content: center;
}

.paging-navigation .nav-links .page-numbers:not(.next, .current, .prev, .page-numbers.dots):hover {
    background: var(--primary);
    color:      #ffffff !important;
}

.nav-links           { display: flex; align-items: center; gap: 10px; }
.paging-navigation a { color: var(--dark); }
.page-numbers.dots   { color: var(--primary); font-size: 17px; }

/*--------------------------------------------------------------
# 8. Breadcrumb
--------------------------------------------------------------*/
.breadcrumb {
    font-family:    var(--font-family);
    font-size:      16px;
    letter-spacing: 0.3px;
    color:          var(--dark);
    opacity:        0.7;
    padding:        10px 15px;
    margin-bottom:  20px;
}

.breadcrumb a:hover { color: var(--primary); }

/*--------------------------------------------------------------
# 10. Table of Contents (Rank Math) — aligné sur FAQ, couleurs inversées
# Repos : fond --bg-soft | Ouvert : fond blanc
--------------------------------------------------------------*/
.wp-block-rank-math-toc-block {
    background:    var(--bg-soft);
    border-radius: 0;
    box-shadow:    none;
    margin:        30px 0;
    overflow:      hidden;
    border:        none;
    padding:       0 !important;
}

/* Titre — repos : bg-soft */
.wp-block-rank-math-toc-block h2 {
    font-family:      var(--font-family);
    font-size:        1.8rem;
    font-weight:      600;
    letter-spacing:   0.3px;
    text-transform:   none;
    color:            var(--dark);
    padding:          18px 55px 18px 22px !important;
    background-color: var(--bg-soft);
    margin:           0 !important;
    display:          block;
    position:         relative;
    cursor:           pointer;
    border-bottom:    none;
    line-height:      1.5;
    transition:       background 0.3s ease, color 0.3s ease;
}

/* Icône + au repos */
.wp-block-rank-math-toc-block h2:after {
    content:     "+";
    position:    absolute;
    right:       20px;
    top:         50%;
    transform:   translateY(-50%);
    font-size:   1.6rem;
    color:       var(--primary);
    font-weight: 400;
    font-family: var(--font-family);
    transition:  transform 0.3s ease;
    line-height: 1;
    display:     inline-block;
}

/* Icône − quand ouvert */
.wp-block-rank-math-toc-block:not(.toc-collapsed) h2:after {
    content:   "−";
    transform: translateY(-50%) rotate(180deg);
}

/* Titre — ouvert : fond blanc */
.wp-block-rank-math-toc-block:not(.toc-collapsed) h2 {
    background: #ffffff;
    color:      var(--primary);
}

.wp-block-rank-math-toc-block h2:hover {
    background: #ffffff;
}

/* Contenu — fond blanc */
.wp-block-rank-math-toc-block nav {
    padding:    0 22px 20px 22px;
    transition: max-height 0.5s ease, opacity 0.3s ease, padding 0.3s ease;
    max-height: 2000px;
    opacity:    1;
    overflow:   hidden;
    background: #ffffff;
}

.wp-block-rank-math-toc-block.toc-collapsed nav {
    max-height:     0;
    opacity:        0;
    padding-top:    0;
    padding-bottom: 0;
}

.wp-block-rank-math-toc-block ul { list-style: none !important; padding: 0 !important; margin: 0 !important; }
.wp-block-rank-math-toc-block li { margin-bottom: 18px !important; padding-left: 0 !important; position: relative; }

.wp-block-rank-math-toc-block a {
    font-family:     var(--font-family) !important;
    display:         flex !important;
    align-items:     center !important;
    text-decoration: underline !important;
    color:           var(--primary) !important;
    font-size:       1.1rem !important;
    letter-spacing:  0.3px !important;
    padding-left:    36px !important;
    position:        relative !important;
    line-height:     1.5 !important;
    transition:      color 0.2s, opacity 0.2s !important;
    opacity:         0.85;
}

.wp-block-rank-math-toc-block a:hover {
    color:   var(--dark) !important;
    opacity: 1;
}

.wp-block-rank-math-toc-block a:before {
    content:         "»";
    position:        absolute;
    left:            0;
    top:             50%;
    transform:       translateY(-50%);
    display:         flex;
    align-items:     center;
    justify-content: center;
    width:           26px;
    height:          26px;
    background:      var(--bg-soft);
    border-radius:   50%;
    font-size:       1rem;
    font-weight:     400;
    color:           var(--primary);
    line-height:     1;
}

.wp-block-rank-math-toc-block a:after { display: none; }

/*--------------------------------------------------------------
# 11. FAQ (Rank Math)
--------------------------------------------------------------*/
#rank-math-faq {
    background: var(--form);
    margin:     30px 0;
    padding:    0;
    overflow:   hidden;
}

#rank-math-faq > div > h2,
#rank-math-faq h2,
#fa-qs {
    font-family:      var(--font-family) !important;
    font-size:        24px !important;
    font-weight:      400 !important;
    letter-spacing:   3px !important;
    text-transform:   uppercase !important;
    color:            var(--dark) !important;
    padding:          28px 28px 20px !important;
    background-color: var(--form) !important;
    margin:           0 !important;
    border:           none !important;
    box-shadow:       none !important;
}

#fa-qs::before,
#rank-math-faq h2::before { display: none !important; }

#rank-math-faq .rank-math-list-item {
    border:        none;
    border-radius: 0;
    margin-bottom: 18px !important;
    overflow:      visible;
    background:    transparent;
    padding:       0 28px;
    position:      relative;
}

#rank-math-faq .rank-math-list-item input {
    position: absolute;
    opacity:  0;
    z-index:  2;
    cursor:   pointer;
    width:    100%;
    height:   100%;
    left:     0;
    top:      0;
    margin:   0;
}

#rank-math-faq .rank-math-question {
    font-family:     var(--font-family);
    font-weight:     400;
    font-size:       1.05rem;
    color:           var(--primary) !important;
    padding:         0 0 0 36px;
    cursor:          pointer;
    position:        relative;
    background:      transparent;
    text-decoration: underline;
    line-height:     1.5;
    transition:      color 0.2s;
}

#rank-math-faq .rank-math-question:hover {
    color:      var(--dark) !important;
    background: transparent;
}

#rank-math-faq .rank-math-question::before {
    content:         "»";
    position:        absolute;
    left:            0;
    top:             50%;
    transform:       translateY(-50%);
    display:         flex;
    align-items:     center;
    justify-content: center;
    width:           26px;
    height:          26px;
    background:      var(--bg-soft);
    border-radius:   50%;
    font-size:       1rem;
    color:           var(--primary);
    line-height:     1;
    text-decoration: none;
}

#rank-math-faq .rank-math-question::after { display: none !important; }

#rank-math-faq .rank-math-answer {
    max-height:  0;
    overflow:    hidden;
    padding:     0 0 0 36px;
    transition:  max-height 0.4s ease, padding 0.3s ease, opacity 0.3s ease;
    font-size:   1rem;
    line-height: 1.7;
    color:       var(--dark);
    font-family: var(--font-family);
    opacity:     0;
}

#rank-math-faq .rank-math-list-item input:checked ~ .rank-math-answer {
    max-height: 600px;
    padding:    10px 0 10px 36px;
    opacity:    1;
}

#rank-math-faq .rank-math-list-item input:checked ~ .rank-math-question {
    color:      var(--dark) !important;
    background: transparent;
}

#rank-math-faq .rank-math-list-item input:checked ~ .rank-math-question::before {
    background: var(--primary-light);
    color:      var(--dark);
}

/*--------------------------------------------------------------
# 12. FAQ natif — details/summary
# Repos : fond --bg-soft | Ouvert : fond blanc
--------------------------------------------------------------*/
.faq-block {
    margin: 30px 0;
}

.faq-block details {
    border-radius: 0;
    margin-bottom: 12px;
    overflow:      hidden;
    background:    var(--bg-soft);
    transition:    background 0.3s ease;
}

.faq-block details[open] {
    background: #ffffff;
}

.faq-block details summary {
    font-family: var(--font-family);
    font-size:   1.1rem;
    font-weight: 400;
    color:       var(--dark);
    padding:     18px 55px 18px 22px;
    cursor:      pointer;
    position:    relative;
    list-style:  none;
    line-height: 1.5;
    transition:  background 0.3s ease, color 0.3s ease;
}

.faq-block details summary::-webkit-details-marker { display: none; }
.faq-block details summary::marker               { display: none; }

.faq-block details summary::after {
    content:     "+";
    position:    absolute;
    right:       20px;
    top:         50%;
    transform:   translateY(-50%);
    font-size:   1.6rem;
    color:       var(--primary);
    transition:  transform 0.3s ease;
    line-height: 1;
}

.faq-block details[open] summary::after {
    content:   "−";
    transform: translateY(-50%) rotate(180deg);
}

.faq-block details[open] summary {
    background: #ffffff;
    color:      var(--primary);
}

.faq-block details summary:hover {
    background: #ffffff;
}

.faq-block details > div {
    padding:     0 22px 20px 22px;
    font-family: var(--font-family);
    font-size:   1rem;
    line-height: 1.75;
    color:       var(--dark);
    background:  #ffffff;
}

.faq-block details > div p {
    margin: 15px 0 0;
}

/*--------------------------------------------------------------
# 13. Category
--------------------------------------------------------------*/
.category .post-image img,
.category .entry-image img,
.category article img {
    aspect-ratio: 1 / 1;
    object-fit:   cover;
    width:        100%;
}

.category .entry-title {
    text-align:  left;
    font-size:   22px;
    line-height: 1.4;
    margin:      10px 0;
}

/*==============================================================
   RESPONSIVE — Tablette (≤ 768px)
==============================================================*/
@media (max-width: 768px) {

    body { font-size: 17px; }

    h1 { font-size: 2rem; }
    h2 { font-size: 1.7rem; }
    h3 { font-size: 1.45rem; }
    h4 { font-size: 1.25rem; }
    h5 { font-size: 1.1rem; }
    h6 { font-size: 1rem; }

    .main-navigation a,
    .main-navigation .menu-toggle,
    .main-navigation .menu-bar-items { font-size: 18px; }

    .breadcrumb { font-size: 14px; padding: 8px 12px; }
    .entry-meta { font-size: 14px; }

    .entry-content h2:not(.wp-block-rank-math-toc-block h2, .wprm-recipe h2),
    .post-content  h2:not(.wp-block-rank-math-toc-block h2, .wprm-recipe h2) {
        font-size:     1.35rem;
        padding:       12px 18px 12px 22px;
        margin-top:    35px;
        margin-bottom: 20px;
    }

    .wp-block-rank-math-toc-block h2  { font-size: 1rem; padding: 16px 50px 16px 18px !important; }
    .wp-block-rank-math-toc-block a   { font-size: 1rem !important; padding-left: 32px !important; }
    .wp-block-rank-math-toc-block nav { padding: 0 18px 18px; }

    #rank-math-faq .rank-math-list-item { padding: 0 20px; }
    #rank-math-faq .rank-math-question  { font-size: 0.95rem; }
    #rank-math-faq .rank-math-answer    { font-size: 0.9rem; }

    .faq-block details summary  { font-size: 1rem; padding: 16px 50px 16px 18px; }
    .faq-block details > div    { font-size: 0.95rem; padding: 0 18px 18px; }
}

/*==============================================================
   RESPONSIVE — Mobile (≤ 480px)
==============================================================*/
@media (max-width: 480px) {

    body { font-size: 16px; line-height: 1.65; }

    h1 { font-size: 1.7rem; }
    h2 { font-size: 1.45rem; }
    h3 { font-size: 1.25rem; }
    h4 { font-size: 1.1rem; }
    h5 { font-size: 1rem; }
    h6 { font-size: 0.95rem; }

    .main-navigation a,
    .main-navigation .menu-toggle,
    .main-navigation .menu-bar-items { font-size: 16px; letter-spacing: 0.4px; }

    .breadcrumb { font-size: 13px; padding: 6px 10px; }
    .entry-meta { font-size: 13px; }

    .entry-content h2:not(.wp-block-rank-math-toc-block h2, .wprm-recipe h2),
    .post-content  h2:not(.wp-block-rank-math-toc-block h2, .wprm-recipe h2) {
        font-size:     1.2rem;
        padding:       10px 14px 10px 18px;
        margin-top:    30px;
        margin-bottom: 18px;
    }

    .paging-navigation .nav-links .current,
    .paging-navigation .nav-links .page-numbers:not(.next, .current, .prev, .page-numbers.dots) {
        font-size: 14px;
        width:     38px !important;
        height:    38px !important;
    }

    .page-numbers.dots { font-size: 14px; }

    .wp-block-rank-math-toc-block h2  { font-size: 0.95rem; padding: 14px 44px 14px 16px !important; }
    .wp-block-rank-math-toc-block a   { font-size: 0.95rem !important; padding-left: 30px !important; }
    .wp-block-rank-math-toc-block nav { padding: 0 16px 16px; }

    #rank-math-faq > div > h2,
    #rank-math-faq h2,
    #fa-qs { font-size: 11px !important; letter-spacing: 2px !important; padding: 18px 16px !important; }

    #rank-math-faq .rank-math-list-item { padding: 0 16px; }
    #rank-math-faq .rank-math-question  { font-size: 0.9rem; }
    #rank-math-faq .rank-math-answer    { font-size: 0.88rem; }

    .faq-block details summary  { font-size: 0.95rem; padding: 14px 44px 14px 16px; }
    .faq-block details > div    { font-size: 0.9rem; padding: 0 16px 16px; }

    .category .entry-title { font-size: 18px; }
}</style></head><body class="wp-singular post-template-default single single-post postid-18127 single-format-standard wp-custom-logo wp-embed-responsive wp-theme-generatepress post-image-above-header post-image-aligned-center sticky-menu-fade right-sidebar nav-float-right separate-containers header-aligned-left dropdown-hover" itemtype="https://schema.org/Blog" itemscope>

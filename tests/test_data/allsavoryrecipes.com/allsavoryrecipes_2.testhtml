ion"],"@id":"https://www.allsavoryrecipes.com/#person","name":"allsavoryrecipes.com","sameAs":["https://www.facebook.com/people/Allsavoryrecipes/61567060755766/","https://twitter.com/llsavoryrecipes","https://www.pinterest.com/Allsavoryrecipe/","https://www.youtube.com/@Allsavoryrecipes"],"logo":{"@type":"ImageObject","@id":"https://www.allsavoryrecipes.com/#logo","url":"https://www.allsavoryrecipes.com/wp-content/uploads/2024/12/All-Savory-recipes.svg","contentUrl":"https://www.allsavoryrecipes.com/wp-content/uploads/2024/12/All-Savory-recipes.svg","caption":"allsavoryrecipes.com","inLanguage":"en-US","width":"638","height":"144"},"image":{"@type":"ImageObject","@id":"https://www.allsavoryrecipes.com/#logo","url":"https://www.allsavoryrecipes.com/wp-content/uploads/2024/12/All-Savory-recipes.svg","contentUrl":"https://www.allsavoryrecipes.com/wp-content/uploads/2024/12/All-Savory-recipes.svg","caption":"allsavoryrecipes.com","inLanguage":"en-US","width":"638","height":"144"}},{"@type":"WebSite","@id":"https://www.allsavoryrecipes.com/#website","url":"https://www.allsavoryrecipes.com","name":"allsavoryrecipes.com","publisher":{"@id":"https://www.allsavoryrecipes.com/#person"},"inLanguage":"en-US"},{"@type":"ImageObject","@id":"https://www.allsavoryrecipes.com/wp-content/uploads/2026/02/Easy-Paprika-Chicken-Comfort-Bowl.webp","url":"https://www.allsavoryrecipes.com/wp-content/uploads/2026/02/Easy-Paprika-Chicken-Comfort-Bowl.webp","width":"896","height":"1344","caption":"Easy Paprika Chicken Comfort Bowl","inLanguage":"en-US"},{"@type":"BreadcrumbList","@id":"https://www.allsavoryrecipes.com/paprika-chicken-comfort-bowl/#breadcrumb","itemListElement":[{"@type":"ListItem","position":"1","item":{"@id":"https://www.allsavoryrecipes.com","name":"Home"}},{"@type":"ListItem","position":"2","item":{"@id":"https://www.allsavoryrecipes.com/category/all-recipes/","name":"All Recipes"}},{"@type":"ListItem","position":"3","item":{"@id":"https://www.allsavoryrecipes.com/paprika-chicken-comfort-bowl/","name":"Paprika Chicken Comfort Bowl"}}]},{"@type":"WebPage","@id":"https://www.allsavoryrecipes.com/paprika-chicken-comfort-bowl/#webpage","url":"https://www.allsavoryrecipes.com/paprika-chicken-comfort-bowl/","name":"Paprika Chicken Comfort Bowl: Creamy One-Pan Dinner","datePublished":"2026-03-27T22:02:43+00:00","dateModified":"2026-03-27T22:02:46+00:00","isPartOf":{"@id":"https://www.allsavoryrecipes.com/#website"},"primaryImageOfPage":{"@id":"https://www.allsavoryrecipes.com/wp-content/uploads/2026/02/Easy-Paprika-Chicken-Comfort-Bowl.webp"},"inLanguage":"en-US","breadcrumb":{"@id":"https://www.allsavoryrecipes.com/paprika-chicken-comfort-bowl/#breadcrumb"}},{"@type":"Person","@id":"https://www.allsavoryrecipes.com/author/sophia-anderson/","name":"Sophia Anderson","url":"https://www.allsavoryrecipes.com/author/sophia-anderson/","image":{"@type":"ImageObject","@id":"https://www.allsavoryrecipes.com/wp-content/litespeed/avatar/a23ffaca2423c1d3c9f4b00cbf2e215e.jpg?ver=1774478793","url":"https://www.allsavoryrecipes.com/wp-content/litespeed/avatar/a23ffaca2423c1d3c9f4b00cbf2e215e.jpg?ver=1774478793","caption":"Sophia Anderson","inLanguage":"en-US"}},{"@type":"Article","headline":"Paprika Chicken Comfort Bowl: Creamy One-Pan Dinner","keywords":"Paprika Chicken Comfort Bowl","datePublished":"2026-03-27T22:02:43+00:00","dateModified":"2026-03-27T22:02:46+00:00","articleSection":"All Recipes, American, Chicken, Dinner, Gluten-Free, Main Course, Nut-Free, One-Bowl Recipes, Skillet, Sugar-Free","author":{"@id":"https://www.allsavoryrecipes.com/author/sophia-anderson/","name":"Sophia Anderson"},"publisher":{"@id":"https://www.allsavoryrecipes.com/#person"},"description":"This Paprika Chicken Comfort Bowl features juicy chicken breasts with aromatic spices served over creamy rice with bell peppers. A satisfying 50-minute one-pan meal perfect for weeknight dinners.","name":"Paprika Chicken Comfort Bowl: Creamy One-Pan Dinner","@id":"https://www.allsavoryrecipes.com/paprika-chicken-comfort-bowl/#richSnippet","isPartOf":{"@id":"https://www.allsavoryrecipes.com/paprika-chicken-comfort-bowl/#webpage"},"image":{"@id":"https://www.allsavoryrecipes.com/wp-content/uploads/2026/02/Easy-Paprika-Chicken-Comfort-Bowl.webp"},"inLanguage":"en-US","mainEntityOfPage":{"@id":"https://www.allsavoryrecipes.com/paprika-chicken-comfort-bowl/#webpage"}},{"@type":"Recipe","name":"Paprika Chicken Comfort Bowl","author":{"@type":"Person","name":"Emma Harper"},"description":"This Paprika Chicken Comfort Bowl features juicy chicken breasts with aromatic spices served over creamy rice with bell peppers. A satisfying 50-minute one-pan meal perfect for weeknight dinners.","datePublished":"2026-03-27T22:01:13+00:00","image":["https://www.allsavoryrecipes.com/wp-content/uploads/2026/02/Easy-Paprika-Chicken-Comfort-Bowl.webp","https://www.allsavoryrecipes.com/wp-content/uploads/2026/02/Easy-Paprika-Chicken-Comfort-Bowl-500x500.webp","https://www.allsavoryrecipes.com/wp-content/uploads/2026/02/Easy-Paprika-Chicken-Comfort-Bowl-500x375.webp","https://www.allsavoryrecipes.com/wp-content/uploads/2026/02/Easy-Paprika-Chicken-Comfort-Bowl-480x270.webp"],"recipeYield":["4","4 bowls"],"prepTime":"PT15M","cookTime":"PT35M","totalTime":"PT50M","recipeIngredient":["1 tablespoon paprika","1 teaspoon garlic powder","1 teaspoon onion powder","1/2 teaspoon salt","1/4 teaspoon black pepper","2 tablespoons olive oil","4  boneless, skinless chicken breasts (about 1 1/2 pounds total)","1 cup long-grain white rice","2 cups chicken broth","1  medium yellow onion (finely chopped)","1  red bell pepper (finely chopped)","1/2 cup sour cream (at room temperature)","2 tablespoons fresh parsley (chopped)"],"recipeInstructions":[{"@type":"HowToStep","text":"In a small bowl, combine the paprika, garlic powder, onion powder, salt, and black pepper. Pat the chicken breasts dry with paper towels, then rub the spice mixture evenly over all sides of the chicken.","name":"Step 1"},{"@type":"HowToStep","text":"Heat the olive oil in a large, deep skillet or Dutch oven over medium-high heat. Add the chicken breasts and cook for 5-7 minutes per side, until golden brown and nearly cooked through. Remove the chicken from the skillet and set it aside on a plate.","name":"Step 2"},{"@type":"HowToStep","text":"Add the chopped onion and bell pepper to the same skillet. Cook for 4-5 minutes, stirring occasionally, until the vegetables have softened.","name":"Step 3"},{"@type":"HowToStep","text":"Stir in the rice and cook for 1 minute, toasting the grains lightly. Pour in the chicken broth, scraping up any browned bits from the bottom of the pan. Bring the mixture to a boil.","name":"Step 4"},{"@type":"HowToStep","text":"Reduce the heat to low, return the chicken breasts to the skillet, and cover. Simmer gently for 18-20 minutes, or until the rice is tender and has absorbed the liquid.","name":"Step 5"},{"@type":"HowToStep","text":"Remove the skillet from the heat. Stir in the sour cream until well combined and the sauce is creamy. Sprinkle with chopped parsley before serving.","name":"Step 6"}],"recipeCategory":["Dinner"],"recipeCuisine":["American"],"keywords":"comfort food, one-pan meal, paprika chicken","nutrition":{"@type":"NutritionInformation","calories":"480 kcal","carbohydrateContent":"45 g","proteinContent":"38 g","fatContent":"16 g","saturatedFatContent":"5 g","cholesterolContent":"105 mg","sodiumContent":"780 mg","fiberContent":"3 g","sugarContent":"4 g","unsaturatedFatContent":"10 g","servingSize":"1 serving"},"@id":"https://www.allsavoryrecipes.com/paprika-chicken-comfort-bowl/#recipe","mainEntityOfPage":"https://www.allsavoryrecipes.com/paprika-chicken-comfort-bowl/#webpage","isPartOf":{"@id":"https://www.allsavoryrecipes.com/paprika-chicken-comfort-bowl/#richSnippet"}}]}</script> <link href='https://fonts.gstatic.com' crossorigin rel='preconnect' /><link href='https://fonts.googleapis.com' crossorigin rel='preconnect' /><link rel="alternate" title="oEmbed (JSON)" type="application/json+oembed" href="https://www.allsavoryrecipes.com/wp-json/oembed/1.0/embed?url=https%3A%2F%2Fwww.allsavoryrecipes.com%2Fpaprika-chicken-comfort-bowl%2F" /><link rel="alternate" title="oEmbed (XML)" type="text/xml+oembed" href="https://www.allsavoryrecipes.com/wp-json/oembed/1.0/embed?url=https%3A%2F%2Fwww.allsavoryrecipes.com%2Fpaprika-chicken-comfort-bowl%2F&#038;format=xml" /> <script id="ezoic-wp-plugin-cmp" src="https://cmp.gatekeeperconsent.com/min.js" data-cfasync="false" data-no-optimize="1" data-no-defer="1"></script> <script id="ezoic-wp-plugin-gatekeeper" src="https://the.gatekeeperconsent.com/cmp.min.js" data-cfasync="false" data-no-optimize="1" data-no-defer="1"></script> <style id='wp-img-auto-sizes-contain-inline-css'>img:is([sizes=auto i],[sizes^="auto," i]){contain-intrinsic-size:3000px 1500px}

:root {
  --wnc-toggle-size: 26px;
  --wnc-dark:    #565656;
  --wnc-light:   #DFE9EE;
  --wnc-bg:      #ffffff;
  --wnc-border:  #DFE9EE;
  --wnc-primary: #17497D;
  --wnc-font:    "Qualion Round", Arial, Helvetica, sans-serif;
}

* { box-sizing: border-box; }

/* ===== NAV ===== */
.wnc-custom-nav {
  background: var(--wnc-bg);
  border-top: 4px solid var(--wnc-primary);
  width: 100%;
  position: relative;
  z-index: 1000;
  font-family: var(--wnc-font);
}
.wnc-nav-container {
  max-width: 1280px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  padding: 0 40px;
  gap: 10px;
  position: relative;
}

/* ===== LOGO ===== */
.wnc-nav-logo { display: flex; align-items: center; flex-shrink: 0; padding: 5px 25px; }
.wnc-nav-logo img { height: 82px; width: auto; max-width: 240px; display: block; }

/* ===== MENU ===== */
.wnc-nav-menu {
  display: flex; list-style: none;
  margin: 0 0 0 auto; padding: 0; align-items: center;
}
.wnc-nav-menu > li > a {
  display: block; padding: 18px 13px;
  font-family: var(--wnc-font);
  font-size: 18px;
  font-weight: 400;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--wnc-dark); text-decoration: none;
  white-space: nowrap; transition: color 0.2s;
}
.wnc-nav-menu > li > a:hover { color: var(--wnc-primary); }

/* ===== BROWSE RECIPES ===== */
.wnc-has-browse { position: static; }

.wnc-browse-link {
  display: flex !important;
  align-items: center;
  gap: 5px;
  padding: 18px 13px !important;
  font-family: var(--wnc-font) !important;
  font-size: 18px !important;
  font-weight: 400 !important;
  letter-spacing: 2px !important;
  text-transform: uppercase !important;
  color: var(--wnc-dark) !important;
  text-decoration: none;
  white-space: nowrap;
  transition: color 0.2s;
}
.wnc-has-browse.mob-open .wnc-browse-link { color: var(--wnc-primary) !important; }
.wnc-has-browse.mob-open .wnc-arrow       { transform: rotate(180deg); }
.wnc-browse-link:hover                    { color: var(--wnc-primary) !important; }

.wnc-arrow {
  font-size: 0.55rem;
  display: inline-block;
  transition: transform 0.25s;
}

/* ===== PANNEAU BROWSE ===== */
.wnc-browse-panel {
  display: none;
  position: absolute;
  top: 100%;
  left: 50%;
  transform: translateX(-50%);
  width: 940px;
  max-width: 98vw;
  background: #fff;
  border-top: 3px solid var(--wnc-primary);
  box-shadow: 0 8px 28px rgba(0,0,0,0.10);
  z-index: 9999;
  padding: 16px 20px;
}
.wnc-has-browse.mob-open .wnc-browse-panel { display: block; }

.wnc-browse-inner {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 5px;
}

/* ===== GROUPE ===== */
.wnc-group { border-bottom: 1px solid var(--wnc-border); }

.wnc-group-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8px 10px;
  gap: 6px;
}
.wnc-group-header:hover { background: var(--wnc-light); }

.wnc-group-title {
  font-family: var(--wnc-font);
  font-size: 11px;
  font-weight: 400;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: var(--wnc-dark);
  text-decoration: none;
  transition: color 0.2s;
  flex: 1;
}
.wnc-group-title:hover { color: var(--wnc-primary); }

.wnc-group-btn {
  background: none;
  border: 1px solid var(--wnc-border);
  border-radius: 3px;
  width: 22px; height: 22px;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; flex-shrink: 0; padding: 0;
  transition: background 0.15s, border-color 0.15s;
}
.wnc-group-btn:hover { background: var(--wnc-primary); border-color: var(--wnc-primary); }
.wnc-group-btn:hover .wnc-gtoggle { color: #fff; }

.wnc-gtoggle {
  font-size: 1.1rem; font-weight: 700;
  color: var(--wnc-primary); line-height: 1;
  display: block; transition: color 0.15s;
}

.wnc-group-body {
  display: none; flex-direction: column;
  padding: 4px 0 8px 10px;
}
.wnc-group.open .wnc-group-body { display: flex; }

.wnc-group-body a {
  display: block; padding: 5px 8px;
  font-family: var(--wnc-font);
  font-size: 11px;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--wnc-dark);
  text-decoration: none;
  border-radius: 3px;
  transition: background 0.15s, color 0.15s, padding-left 0.15s;
}
.wnc-group-body a:hover {
  background: var(--wnc-light);
  color: var(--wnc-primary);
  padding-left: 14px;
}

/* ===== SEARCH DESKTOP ===== */
.wnc-nav-search { position: relative; display: flex; align-items: center; }
.wnc-search-toggle {
  display: flex; align-items: center;
  padding: 18px 12px; color: var(--wnc-dark);
  text-decoration: none; transition: color 0.2s; cursor: pointer;
}
.wnc-search-toggle:hover { color: var(--wnc-primary); }
.wnc-search-box {
  display: none; position: absolute; top: 100%; right: 0;
  background: #fff; border-top: 3px solid var(--wnc-primary);
  box-shadow: 0 8px 24px rgba(0,0,0,0.10);
  padding: 12px; min-width: 280px; z-index: 9999;
}
.wnc-search-box.open { display: block; }
.wnc-search-box form, .wnc-search-box-mobile form {
  display: flex; align-items: center;
  border: 2px solid var(--wnc-border);
  border-radius: 0; overflow: hidden; transition: border-color 0.2s;
}
.wnc-search-box form:focus-within,
.wnc-search-box-mobile form:focus-within { border-color: var(--wnc-primary); }
.wnc-search-box input, .wnc-search-box-mobile input {
  flex: 1; border: none; outline: none;
  padding: 9px 12px;
  font-family: var(--wnc-font);
  font-size: 11px;
  letter-spacing: 1px;
  color: var(--wnc-dark); background: #fff;
}
.wnc-search-box button, .wnc-search-box-mobile button {
  background: var(--wnc-dark); border: none; padding: 9px 12px;
  cursor: pointer; color: #fff; display: flex; align-items: center; transition: background 0.2s;
}
.wnc-search-box button:hover,
.wnc-search-box-mobile button:hover { background: var(--wnc-primary); }

/* ===== TOGGLE MOBILE ===== */
.wnc-nav-toggle {
  display: none; background: none;
  border: none; color: var(--wnc-dark);
  cursor: pointer; padding: 5px 8px;
  border-radius: 4px; line-height: 1; flex-shrink: 0;
}
.wnc-nav-toggle svg { width: var(--wnc-toggle-size); height: var(--wnc-toggle-size); display: block; }
.wnc-nav-toggle:hover { background: var(--wnc-light); color: var(--wnc-primary); }
.wnc-nav-search-mobile { display: none; }
.wnc-search-box-mobile  { display: none; }

/* ===== TABLET 1024px ===== */
@media (max-width: 1024px) {
  .wnc-nav-logo img { height: 44px; max-width: 170px; }
  .wnc-nav-menu > li > a,
  .wnc-browse-link { padding: 18px 8px !important; font-size: 10px !important; }
  .wnc-browse-panel { width: 720px; }
  .wnc-browse-inner { grid-template-columns: repeat(3, 1fr); }
}

/* ===== MOBILE ≤ 768px ===== */
@media (max-width: 768px) {

  .wnc-nav-container {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 10px 20px; gap: 0;
  }
  .wnc-nav-toggle {
    display: flex; align-items: center;
    justify-content: flex-start; grid-column: 1;
  }
  .wnc-nav-logo { grid-column: 2; padding: 5px 10px; justify-content: center; }
  .wnc-nav-logo img { height: 52px; max-width: 180px; }

  .wnc-nav-search-mobile {
    display: flex; grid-column: 3;
    justify-content: flex-end; align-items: center;
  }
  .wnc-nav-search-mobile a {
    color: var(--wnc-dark); display: flex;
    align-items: center; padding: 5px;
  }
  .wnc-nav-search-mobile a:hover { color: var(--wnc-primary); }
  .wnc-nav-search-desktop { display: none !important; }

  .wnc-nav-menu {
    display: none; flex-direction: column;
    width: 100%; background: #fff;
    border-top: 2px solid var(--wnc-primary);
    padding: 5px 0; margin-left: 0; grid-column: 1 / -1;
  }
  .wnc-nav-menu.open { display: flex; }
  .wnc-nav-menu > li { width: 100%; border-bottom: 1px solid #f0f0f0; }
  .wnc-nav-menu > li > a { padding: 13px 15px; font-size: 11px; display: block; }

  .wnc-browse-link {
    width: 100%;
    padding: 13px 15px !important;
    font-size: 11px !important;
    justify-content: space-between;
  }

  .wnc-browse-panel {
    position: static !important;
    transform: none !important;
    width: 100% !important;
    max-width: 100% !important;
    box-shadow: none;
    border-top: none;
    border-left: 3px solid var(--wnc-primary);
    margin: 0 0 5px 15px;
    padding: 5px 0;
    background: #f9f9f9;
  }

  .wnc-browse-inner { grid-template-columns: 1fr; gap: 0; }

  .wnc-group { border-bottom: 1px solid #eee; }
  .wnc-group-header { padding: 10px 12px; }
  .wnc-group-title { font-size: 11px; }
  .wnc-group-body a {
    padding: 7px 20px !important;
    font-size: 11px;
    border-bottom: 1px solid #eee;
  }

  .wnc-search-box-mobile {
    display: none; padding: 10px 15px;
    background: #f9f9f9;
    border-top: 1px solid #eee;
    border-bottom: 2px solid var(--wnc-primary);
  }
  .wnc-search-box-mobile.open { display: block; }

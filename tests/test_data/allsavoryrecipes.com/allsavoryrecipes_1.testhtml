    font-family: 'Qualion Round';
    src: url('https://www.allsavoryrecipes.com/wp-content/themes/generatepress/fonts/qualionround-demibold-webfont.woff2') format('woff2');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
 }

:root {
    --primary:       #17497D;
    --primary-light: #DFE9EE;
    --bg-soft:       #FCF6EE;
    --dark:          #565656;
    --font-family:   "Qualion Round", Arial, Helvetica, sans-serif;
}

/* ===== SECTION ===== */
.wnc-chicken-section {
    background: #FFF;
    padding: 60px 30px;
    width: 100%;
    box-sizing: border-box;
}

.wnc-chicken-container {
    max-width: 1200px;
    margin: 0 auto;
}

/* ===== TITLE ===== */
.wnc-chicken-title {
    font-family: var(--font-family);
    font-size: 22px;
    font-weight: 400;
    line-height: 30px;
    letter-spacing: 3px;
    text-transform: uppercase;
    text-align: center;
    color: var(--dark);
    margin: 0 0 40px;
    padding: 0;
    border: none;
}

/* ===== GRID ===== */
.wnc-chicken-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
}

/* ===== CARD ===== */
.wnc-chicken-item {
    display: flex;
    flex-direction: column;
}

.wnc-chicken-link {
    display: block;
    text-decoration: none;
}

/* Image ratio 2/3 */
.wnc-chicken-image-wrap {
    overflow: hidden;
    aspect-ratio: 2/3;
    background: var(--primary-light);
    margin-bottom: 16px;
}

.wnc-chicken-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
}

.wnc-chicken-item:hover .wnc-chicken-image-wrap img {
    transform: scale(1.05);
}

/* ===== TITLE IN CARD ===== */
.wnc-chicken-post-title {
    font-family: var(--font-family);
    font-size: 13px;
    font-weight: 400;
    line-height: 20px;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    text-align: center;
    color: var(--dark);
    text-decoration: none;
    transition: color 0.2s ease;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    padding: 0 10px;
    min-height: 60px;
}

.wnc-chicken-link:hover .wnc-chicken-post-title {
    color: var(--primary);
}

/* ===== FOOTER BUTTON ===== */
.wnc-chicken-footer {
    display: flex;
    align-items: center;
    margin-top: 40px;
    gap: 20px;
}

.wnc-chicken-footer-line {
    flex: 1;
    height: 1px;
    background: var(--primary-light);
}

.wnc-chicken-btn {
    flex-shrink: 0;
    display: inline-block;
    font-family: var(--font-family);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 2px;
    text-transform: uppercase;
    line-height: 26px;
    color: #ffffff;
    background: var(--dark);
    padding: 11px 26px;
    text-decoration: none;
    transition: background 0.2s ease, color 0.2s ease;
    white-space: nowrap;
}

.wnc-chicken-btn:hover {
    background: var(--primary);
    color: #ffffff;
}

/* ===== NO POSTS ===== */
.wnc-chicken-no-posts {
    grid-column: 1 / -1;
    text-align: center;
    padding: 40px 20px;
    color: var(--primary);
    font-style: italic;
    font-family: var(--font-family);
}

/* ===== RESPONSIVE ===== */
@media (max-width: 1024px) {
    .wnc-chicken-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
    }
}

@media (max-width: 600px) {
    .wnc-chicken-section { padding: 40px 20px; }
    .wnc-chicken-grid { grid-template-columns: repeat(2, 1fr); gap: 16px; }
    .wnc-chicken-title { font-size: 16px; letter-spacing: 2px; margin-bottom: 28px; }
    .wnc-chicken-post-title { font-size: 11px; letter-spacing: 1.2px; }
}</style><section class="wnc-chicken-section"><div class="wnc-chicken-container"><h2 class="wnc-chicken-title">WEEKDAY CHICKEN RECIPES</h2><div class="wnc-chicken-grid"><article class="wnc-chicken-item">

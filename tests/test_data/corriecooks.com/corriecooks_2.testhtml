<script type="text/javascript" >
	
	var workAroundForPerfMattersFooterInlineScript = 1;

jQuery( document ).ready(function($) {
	
	//modify the search box in mobile
	if(screen.width < 700){
		$( ".np-header-search-wrapper span.search-main" ).click(function() {
		  if($('.graysearchbg').hasClass( "active" )){
			  $('.graysearchbg').removeClass( "active" );
		  }
		  else{
			  $('.graysearchbg').addClass( "active" )
		  }
		  
		  //fix ios bug when keyboard is open
/* 			if (navigator.userAgent.match(/(iPod|iPhone|iPad)/i) {
				if (browserRatio >=1.5) {
					$container.css('min-height', '360px');
				} else {
					$container.css('min-height', '555px');
				}
			}
 */
		  
		  
		});
		$( ".graysearchbg" ).click(function() {
		  $('header#masthead .search-form-main.np-clearfix.active-search').removeClass( "active-search" );
		  $('.graysearchbg').removeClass( "active" )
		});
		
	
	
	
		
		
	}
	
	
/* 	if($('body').hasClass( "single-post" )){
		
	}
 
 
	$("#secondary .widget .widget-title, table#tablepress-2  .widget .widget-title").each(function() {
	  // Some Vars
	  var elText,
		  openSpan = '<span class="first-word">',
		  closeSpan = '</span>';
	  
	  // Make the text into array
	  elText = $(this).text().split(" ");
	  
	  // Adding the open span to the beginning of the array
	  elText.unshift(openSpan);
	  
	  // Adding span closing after the first word in each sentence
	  elText.splice(2, 0, closeSpan);
	  
	  // Make the array into string 
	  elText = elText.join(" ");
	  
	  // Change the html of each element to style it
	  $(this).html(elText);
	});	
});


	
/* 	if($('body').hasClass( "single-post" )){
		
	}
 */	
 
	$("#secondary .widget .widget-title-right-bar, table#tablepress-2  .widget .widget-title-right-bar").each(function() {
	  // Some Vars
	  var elText,
		  openSpan = '<span class="first-word">',
		  closeSpan = '</span>';
	  
	  // Make the text into array
	  elText = $(this).text().split(" ");
	  
	  // Adding the open span to the beginning of the array
	  elText.unshift(openSpan);
	  
	  // Adding span closing after the first word in each sentence
	  elText.splice(2, 0, closeSpan);
	  
	  // Make the array into string 
	  elText = elText.join(" ");
	  
	  // Change the html of each element to style it
	  $(this).html(elText);
	
	});	
});





<script>
var cls2 = ".wp-image-3385";
var hover2 = 'https://www.corriecooks.com/wp-content/uploads/2017/04/check-price-after-green.png';
var original2 = 'https://www.corriecooks.com/wp-content/uploads/2017/04/check-price-regular.png';
jQuery(cls2).attr("srcset","");
jQuery(cls2).hover(function(){
	jQuery(this).attr('src',hover2)
}).mouseout(function(){
	jQuery(this).attr('src',original2)
});
</script>



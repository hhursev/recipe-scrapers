spoons milk","½ teaspoon almond or vanilla extract","Colored sprinkles"],"recipeInstructions":[{"@type":"HowToStep","text":"Preheat oven to 350°F (175°C). Line baking sheets with parchment paper.","name":"Preheat oven to 350°F (175°C). Line baking sheets with parchment paper.","url":"https:\/\/www.corriecooks.com\/italian-christmas-cookies\/#wprm-recipe-189161-step-0-0"},{"@type":"HowToStep","text":"In a bowl, mix flour, baking powder, and salt.","name":"In a bowl, mix flour, baking powder, and salt.","url":"https:\/\/www.corriecooks.com\/italian-christmas-cookies\/#wprm-recipe-189161-step-0-1"},{"@type":"HowToStep","text":"In another bowl, beat butter and sugar until creamy.","name":"In another bowl, beat butter and sugar until creamy.","url":"https:\/\/www.corriecooks.com\/italian-christmas-cookies\/#wprm-recipe-189161-step-0-2"},{"@type":"HowToStep","text":"Add eggs and extracts. Mix well.","name":"Add eggs and extracts. Mix well.","url":"https:\/\/www.corriecooks.com\/italian-christmas-cookies\/#wprm-recipe-189161-step-0-3"},{"@type":"HowToStep","text":"Slowly add dry ingredients to wet ingredients.","name":"Slowly add dry ingredients to wet ingredients.","url":"https:\/\/www.corriecooks.com\/italian-christmas-cookies\/#wprm-recipe-189161-step-0-4"},{"@type":"HowToStep","text":"Shape dough into small balls and place on baking sheet.","name":"Shape dough into small balls and place on baking sheet.","url":"https:\/\/www.corriecooks.com\/italian-christmas-cookies\/#wprm-recipe-189161-step-0-5"},{"@type":"HowToStep","text":"Bake for 10–12 minutes until lightly golden.","name":"Bake for 10–12 minutes until lightly golden.","url":"https:\/\/www.corriecooks.com\/italian-christmas-cookies\/#wprm-recipe-189161-step-0-6"},{"@type":"HowToStep","text":"Let cool completely.","name":"Let cool completely.","url":"https:\/\/www.corriecooks.com\/italian-christmas-cookies\/#wprm-recipe-189161-step-0-7"},{"@type":"HowToStep","text":"Mix powdered sugar, milk, and extract to make glaze.","name":"Mix powdered sugar, milk, and extract to make glaze.","url":"https:\/\/www.corriecooks.com\/italian-christmas-cookies\/#wprm-recipe-189161-step-0-8"},{"@type":"HowToStep","text":"Dip tops of cookies in glaze and add sprinkles.","name":"Dip tops of cookies in glaze and add sprinkles.","url":"https:\/\/www.corriecooks.com\/italian-christmas-cookies\/#wprm-recipe-189161-step-0-9"},{"@type":"HowToStep","text":"Let glaze set before serving.","name":"Let glaze set before serving.","url":"https:\/\/www.corriecooks.com\/italian-christmas-cookies\/#wprm-recipe-189161-step-0-10"}],"aggregateRating":{"@type":"AggregateRating","ratingValue":"5","ratingCount":"1","reviewCount":"1"},"review":[{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Perfect for holiday treat.","author":{"@type":"Person","name":"Olivia"},"datePublished":"2026-02-21"}],"recipeCategory":["Dessert"],"recipeCuisine":["Italian"],"keywords":"Italian Christmas Cookies Ricotta Cheese","nutrition":{"@type":"NutritionInformation","calories":"3867 kcal","carbohydrateContent":"670 g","proteinContent":"56 g","fatContent":"109 g","saturatedFatContent":"63 g","transFatContent":"4 g","cholesterolContent":"735 mg","sodiumContent":"2648 mg","fiberContent":"10 g","sugarContent":"378 g","unsaturatedFatContent":"37 g","servingSize":"1 serving"},"@id":"https:\/\/www.corriecooks.com\/italian-christmas-cookies\/#recipe","isPartOf":{"@id":"https:\/\/www.corriecooks.com\/italian-christmas-cookies\/#article"},"mainEntityOfPage":"https:\/\/www.corriecooks.com\/italian-christmas-cookies\/"}]}</script>

	<script type="application/ld+json" class="yoast-schema-graph">{"@context":"https:\/\/schema.org","@graph":[{"@type":"Article","@id":"https:\/\/coleycooks.com\/chocolate-spice-cookies\/#article","isPartOf":{"@id":"https:\/\/coleycooks.com\/chocolate-spice-cookies\/"},"author":{"name":"Nicole Gaffney","@id":"https:\/\/coleycooks.com\/#\/schema\/person\/e566384b3df3cef47129211a6545f34e"},"headline":"Sicilian Chocolate Spice Cookies","datePublished":"2025-12-10T10:55:00+00:00","wordCount":2163,"commentCount":0,"publisher":{"@id":"https:\/\/coleycooks.com\/#organization"},"image":{"@id":"https:\/\/coleycooks.com\/chocolate-spice-cookies\/#primaryimage"},"thumbnailUrl":"https:\/\/coleycooks.com\/wp-content\/uploads\/2025\/11\/italian-chocolate-spice-cookies-16.jpg","articleSection":["Christmas","Cookies + Cakes","Italian Desserts","Sicilian Recipes"],"inLanguage":"en-US","potentialAction":[{"@type":"CommentAction","name":"Comment","target":["https:\/\/coleycooks.com\/chocolate-spice-cookies\/#respond"]}]},{"@type":["WebPage","FAQPage"],"@id":"https:\/\/coleycooks.com\/chocolate-spice-cookies\/","url":"https:\/\/coleycooks.com\/chocolate-spice-cookies\/","name":"Italian Chocolate Spice Cookie Recipe - Coley Cooks","isPartOf":{"@id":"https:\/\/coleycooks.com\/#website"},"primaryImageOfPage":{"@id":"https:\/\/coleycooks.com\/chocolate-spice-cookies\/#primaryimage"},"image":{"@id":"https:\/\/coleycooks.com\/chocolate-spice-cookies\/#primaryimage"},"thumbnailUrl":"https:\/\/coleycooks.com\/wp-content\/uploads\/2025\/11\/italian-chocolate-spice-cookies-16.jpg","datePublished":"2025-12-10T10:55:00+00:00","description":"Soft Sicilian chocolate spice cookies topped with a simple chocolate frosting. A nostalgic family recipe perfect for Christmas time.","breadcrumb":{"@id":"https:\/\/coleycooks.com\/chocolate-spice-cookies\/#breadcrumb"},"mainEntity":[{"@id":"https:\/\/coleycooks.com\/chocolate-spice-cookies\/#faq-question-1643652919521"},{"@id":"https:\/\/coleycooks.com\/chocolate-spice-cookies\/#faq-question-1713981424124"},{"@id":"https:\/\/coleycooks.com\/chocolate-spice-cookies\/#faq-question-1764797117327"},{"@id":"https:\/\/coleycooks.com\/chocolate-spice-cookies\/#faq-question-1764797128426"}],"inLanguage":"en-US","potentialAction":[{"@type":"ReadAction","target":["https:\/\/coleycooks.com\/chocolate-spice-cookies\/"]}]},{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/coleycooks.com\/chocolate-spice-cookies\/#primaryimage","url":"https:\/\/coleycooks.com\/wp-content\/uploads\/2025\/11\/italian-chocolate-spice-cookies-16.jpg","contentUrl":"https:\/\/coleycooks.com\/wp-content\/uploads\/2025\/11\/italian-chocolate-spice-cookies-16.jpg","width":1200,"height":1799,"caption":"Frosted chocolate spice cookies arranged on parchment paper, each topped with a walnut half."},{"@type":"BreadcrumbList","@id":"https:\/\/coleycooks.com\/chocolate-spice-cookies\/#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https:\/\/coleycooks.com\/"},{"@type":"ListItem","position":2,"name":"Recipes","item":"https:\/\/coleycooks.com\/recipe-index\/"},{"@type":"ListItem","position":3,"name":"Cookies + Cakes","item":"https:\/\/coleycooks.com\/category\/cookies-bars-recipes\/"},{"@type":"ListItem","position":4,"name":"Sicilian Chocolate Spice Cookies"}]},{"@type":"WebSite","@id":"https:\/\/coleycooks.com\/#website","url":"https:\/\/coleycooks.com\/","name":"Coley Cooks","description":"Classic Italian and seafood recipes made from scratch.","publisher":{"@id":"https:\/\/coleycooks.com\/#organization"},"potentialAction":[{"@type":"SearchAction","target":{"@type":"EntryPoint","urlTemplate":"https:\/\/coleycooks.com\/?s={search_term_string}"},"query-input":{"@type":"PropertyValueSpecification","valueRequired":true,"valueName":"search_term_string"}}],"inLanguage":"en-US"},{"@type":"Organization","@id":"https:\/\/coleycooks.com\/#organization","name":"Coley Cooks","url":"https:\/\/coleycooks.com\/","logo":{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/coleycooks.com\/#\/schema\/logo\/image\/","url":"https:\/\/coleycooks.com\/wp-content\/uploads\/2024\/05\/coley-cooks-submark.svg","contentUrl":"https:\/\/coleycooks.com\/wp-content\/uploads\/2024\/05\/coley-cooks-submark.svg","width":"1024","height":"1024","caption":"Coley Cooks"},"image":{"@id":"https:\/\/coleycooks.com\/#\/schema\/logo\/image\/"},"sameAs":["https:\/\/www.facebook.com\/ColeyCooks\/","https:\/\/x.com\/ColeyCooks","https:\/\/www.instagram.com\/coleycooks\/","https:\/\/www.linkedin.com\/in\/chefnicolegaffney\/","https:\/\/www.pinterest.com\/ColeyCooks\/","https:\/\/www.youtube.com\/channel\/UCJRXsvWyyquM3ZYcN_xbBNQ"]},{"@type":"Person","@id":"https:\/\/coleycooks.com\/#\/schema\/person\/e566384b3df3cef47129211a6545f34e","name":"Nicole Gaffney","description":"Coley Gaffney is the creator of Coley Cooks, a recipe website devoted to coastal Italian cooking. She’s a professionally trained chef with a background in Italian cuisine and seafood. She develops approachable, seasonal recipes inspired by her Sicilian roots and life at the Jersey Shore.","sameAs":["https:\/\/coleycooks.com\/about\/","https:\/\/www.facebook.com\/ColeyCooks\/","https:\/\/www.instagram.com\/coleycooks\/","https:\/\/www.linkedin.com\/in\/coleycooks\/","https:\/\/www.youtube.com\/coleycooks"]},{"@type":"Question","@id":"https:\/\/coleycooks.com\/chocolate-spice-cookies\/#faq-question-1643652919521","position":1,"url":"https:\/\/coleycooks.com\/chocolate-spice-cookies\/#faq-question-1643652919521","name":"What makes these Italian chocolate spice cookies different from other Italian chocolate cookies?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"This version uses a creamed mixture of shortening and oil, plenty of warm spices, and the option for chopped walnuts or chocolate chips. It bakes into soft cookies with a tender texture, then gets finished with a simple chocolate frosting that sets into a smooth, sweet layer. It’s a family recipe that's comforting and familiar while still keeping the spirit of the classic Sicilian cookie. The spices make it perfect for Christmastime!","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https:\/\/coleycooks.com\/chocolate-spice-cookies\/#faq-question-1713981424124","position":2,"url":"https:\/\/coleycooks.com\/chocolate-spice-cookies\/#faq-question-1713981424124","name":"Why is my cookie dough too sticky to roll?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Sticky dough usually means the dry ingredients weren’t fully absorbed. Letting the dough rest a few minutes helps, or you can chill it briefly. Avoid adding extra purpose flour unless absolutely necessary. If it's still sticky, coat your hands in a little bit of oil or shortening before rolling. ","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https:\/\/coleycooks.com\/chocolate-spice-cookies\/#faq-question-1764797117327","position":3,"url":"https:\/\/coleycooks.com\/chocolate-spice-cookies\/#faq-question-1764797117327","name":"How do I freeze the cookie dough?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Scoop and roll the dough into dough balls, then freeze them on a cookie sheet until solid. Transfer to plastic wrap or an airtight container. Bake from frozen, adding a little bit of extra time if needed.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https:\/\/coleycooks.com\/chocolate-spice-cookies\/#faq-question-1764797128426","position":4,"url":"https:\/\/coleycooks.com\/chocolate-spice-cookies\/#faq-question-1764797128426","name":"Can I add other types of chocolate?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Yes. You can fold in chocolate chips or chopped up chocolate bars to these delicious cookies or experiment with different types of chocolate to adjust the chocolate flavor. Just avoid adding too much or the dough may not hold together well.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Recipe","name":"Italian Chocolate Spice Cookies (Tetu)","author":{"@id":"https:\/\/coleycooks.com\/#\/schema\/person\/e566384b3df3cef47129211a6545f34e"},"description":"These Italian chocolate spice cookies are soft, tender, and warm with spices that instantly taste like the holidays. They’re simple to make, filled with nostalgia and perfect for sharing all season long.","datePublished":"2025-12-10T05:55:00+00:00","image":["https:\/\/coleycooks.com\/wp-content\/uploads\/2025\/11\/italian-chocolate-spice-cookies-17.jpg","https:\/\/coleycooks.com\/wp-content\/uploads\/2025\/11\/italian-chocolate-spice-cookies-17-500x500.jpg","https:\/\/coleycooks.com\/wp-content\/uploads\/2025\/11\/italian-chocolate-spice-cookies-17-500x375.jpg","https:\/\/coleycooks.com\/wp-content\/uploads\/2025\/11\/italian-chocolate-spice-cookies-17-480x270.jpg"],"recipeYield":["36","36 up to 48 cookies"],"prepTime":"PT30M","cookTime":"PT30M","totalTime":"PT60M","recipeIngredient":["1 cup Crisco shortening  (or butter)","1 ½ tablespoons vegetable oil  (or another neutral oil)","¾ cup sugar","2  eggs","2 ¼ cups all-purpose flour","¼ cup unsweetened cocoa powder (plus 2 tablespoons )","2 ½ teaspoons baking powder","1 teaspoon ground cinnamon","½ teaspoon ground nutmeg","½ teaspoon ground cloves","¼ teaspoon salt","½ cup walnuts (very finely chopped, optional)","½ cup chocolate chips (optional)","¼ cup butter (or 4 tablespoons )","⅓ cup unsweetened cocoa powder","1½ cups powdered sugar","2 tablespoons milk (plus 2 teaspoons or more if needed)","½ teaspoon vanilla extract","Walnut halves (for topping, optional)"],"recipeInstructions":[{"@type":"HowToSection","name":"Bake the Cookies","itemListElement":[{"@type":"HowToStep","text":"Preheat the oven to 375°F and line two baking sheets with parchment paper.","name":"Preheat the oven to 375°F and line two baking sheets with parchment paper.","url":"https:\/\/coleycooks.com\/chocolate-spice-cookies\/#wprm-recipe-80590-step-0-0"},{"@type":"HowToStep","text":"Add the shortening, oil and sugar in a large bowl and mix to combine, then mix in the eggs one at a time.","name":"Add the shortening, oil and sugar in a large bowl and mix to combine, then mix in the eggs one at a time.","url":"https:\/\/coleycooks.com\/chocolate-spice-cookies\/#wprm-recipe-80590-step-0-1"},{"@type":"HowToStep","text":"Add the flour, cocoa powder, baking powder, cinnamon, nutmeg, cloves, salt, walnuts and chocolate chips (if using), then mix until combined.","name":"Add the flour, cocoa powder, baking powder, cinnamon, nutmeg, cloves, salt, walnuts and chocolate chips (if using), then mix until combined.","url":"https:\/\/coleycooks.com\/chocolate-spice-cookies\/#wprm-recipe-80590-step-0-2"},{"@type":"HowToStep","text":"Pinch off pieces and roll into 1-inch balls. Arrange on the baking sheets with slight space between (they will not spread much).","name":"Pinch off pieces and roll into 1-inch balls. Arrange on the baking sheets with slight space between (they will not spread much).","url":"https:\/\/coleycooks.com\/chocolate-spice-cookies\/#wprm-recipe-80590-step-0-3"},{"@type":"HowToStep","text":"Bake until the cookies look set, puffed and dry on the surface but still feel soft when gently pressed, about 10-15 minutes.","name":"Bake until the cookies look set, puffed and dry on the surface but still feel soft when gently pressed, about 10-15 minutes.","url":"https:\/\/coleycooks.com\/chocolate-spice-cookies\/#wprm-recipe-80590-step-0-4"},{"@type":"HowToStep","text":"Cool completely before icing so the frosting sets rather than melting.","name":"Cool completely before icing so the frosting sets rather than melting.","url":"https:\/\/coleycooks.com\/chocolate-spice-cookies\/#wprm-recipe-80590-step-0-5"}]},{"@type":"HowToSection","name":"Make the Icing and Assemble","itemListElement":[{"@type":"HowToStep","text":"Add the melted butter to a bowl, then stir in the cocoa until smooth and glossy.","name":"Add the melted butter to a bowl, then stir in the cocoa until smooth and glossy.","url":"https:\/\/coleycooks.com\/chocolate-spice-cookies\/#wprm-recipe-80590-step-1-0"},{"@type":"HowToStep","text":"Add half of the powdered sugar, then half of the milk and beat until combined. Add the remaining powdered sugar and milk, then beat until smooth and spreadable. Stir in the vanilla.","name":"Add half of the powdered sugar, then half of the milk and beat until combined. Add the remaining powdered sugar and milk, then beat until smooth and spreadable. Stir in the vanilla.","url":"https:\/\/coleycooks.com\/chocolate-spice-cookies\/#wprm-recipe-80590-step-1-1"},{"@type":"HowToStep","text":"Spread the icing over the cooled cookies with a small spatula or knife.","name":"Spread the icing over the cooled cookies with a small spatula or knife.","url":"https:\/\/coleycooks.com\/chocolate-spice-cookies\/#wprm-recipe-80590-step-1-2"},{"@type":"HowToStep","text":"While the icing is still soft, press a walnut half on top if desired. Let the icing set before storing.","name":"While the icing is still soft, press a walnut half on top if desired. Let the icing set before storing.","url":"https:\/\/coleycooks.com\/chocolate-spice-cookies\/#wprm-recipe-80590-step-1-3"}]}],"recipeCategory":["baking","chocolate","cookies"],"recipeCuisine":["Italian"],"keywords":"chocolate, christmas cookies, spices, walnuts","nutrition":{"@type":"NutritionInformation","calories":"162 kcal","carbohydrateContent":"18 g","proteinContent":"2 g","fatContent":"10 g","saturatedFatContent":"3 g","transFatContent":"1 g","cholesterolContent":"13 mg","sodiumContent":"60 mg","fiberContent":"1 g","sugarContent":"11 g","unsaturatedFatContent":"6 g","servingSize":"1 serving"},"@id":"https:\/\/coleycooks.com\/chocolate-spice-cookies\/#recipe","isPartOf":{"@id":"https:\/\/coleycooks.com\/chocolate-spice-cookies\/#article"},"mainEntityOfPage":"https:\/\/coleycooks.com\/chocolate-spice-cookies\/"}]}</script>

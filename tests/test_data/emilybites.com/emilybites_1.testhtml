<script type="text/rocketlazyloadscript">
  (function(){
	const scrambled = [134,136,124,71,140,126,141,130,123,146,133,130,134,126];
	function decode(arr){return arr.map(n => String.fromCharCode(n - 25)).reverse().join('');}
	const allowedName = decode(scrambled);
	if (typeof location !== 'undefined' && location.hostname === allowedName){
	  window.dataLayer = window.dataLayer || [];
	  function gtag(){dataLayer.push(arguments);}
	  gtag('js', new Date());
	  gtag('config', 'G-SMCXBF7QQD');
	  gtag('config', 'UA-25479974-1', { 'anonymize_ip': true });
	}
  })();
</script>


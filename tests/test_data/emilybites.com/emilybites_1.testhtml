s:\/\/emilybites.com\/2026\/04\/creamy-tomato-pasta-with-ham.html#breadcrumb"},"inLanguage":"en-US","potentialAction":[{"@type":"ReadAction","target":["https:\/\/emilybites.com\/2026\/04\/creamy-tomato-pasta-with-ham.html"]}]},{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/emilybites.com\/2026\/04\/creamy-tomato-pasta-with-ham.html#primaryimage","url":"https:\/\/emilybites.com\/wp-content\/uploads\/2026\/04\/Creamy-Tomato-Pasta-with-Ham-5b.jpg","contentUrl":"https:\/\/emilybites.com\/wp-content\/uploads\/2026\/04\/Creamy-Tomato-Pasta-with-Ham-5b.jpg","width":1456,"height":2184,"caption":"Creamy Tomato Pasta with Ham in the pan"},{"@type":"BreadcrumbList","@id":"https:\/\/emilybites.com\/2026\/04\/creamy-tomato-pasta-with-ham.html#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https:\/\/emilybites.com\/"},{"@type":"ListItem","position":2,"name":"Creamy Tomato Pasta with Ham"}]},{"@type":"WebSite","@id":"https:\/\/emilybites.com\/#website","url":"https:\/\/emilybites.com\/","name":"Emily Bites","description":"Weight Watchers Recipes and Lightened Up Comfort Food","publisher":{"@id":"https:\/\/emilybites.com\/#organization"},"potentialAction":[{"@type":"SearchAction","target":{"@type":"EntryPoint","urlTemplate":"https:\/\/emilybites.com\/?s={search_term_string}"},"query-input":{"@type":"PropertyValueSpecification","valueRequired":true,"valueName":"search_term_string"}}],"inLanguage":"en-US"},{"@type":"Organization","@id":"https:\/\/emilybites.com\/#organization","name":"Emily Bites","url":"https:\/\/emilybites.com\/","logo":{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/emilybites.com\/#\/schema\/logo\/image\/","url":"https:\/\/emilybites.com\/wp-content\/uploads\/2022\/04\/emilybites_logo.FINAL2-01.jpg","contentUrl":"https:\/\/emilybites.com\/wp-content\/uploads\/2022\/04\/emilybites_logo.FINAL2-01.jpg","width":2250,"height":792,"caption":"Emily Bites"},"image":{"@id":"https:\/\/emilybites.com\/#\/schema\/logo\/image\/"},"sameAs":["https:\/\/www.facebook.com\/emilybites","https:\/\/www.instagram.com\/emilybitesblog\/","https:\/\/www.pinterest.com\/emilybitesblog\/"]},{"@type":"Person","@id":"https:\/\/emilybites.com\/#\/schema\/person\/15a120abf447cbb3002c306cc6a6846c","name":"Emily Bites","image":{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/secure.gravatar.com\/avatar\/37f1b988fc724aa985a83d2c78679d44dc266e33f45522de3e901304084d99c2?s=96&d=blank&r=g","url":"https:\/\/secure.gravatar.com\/avatar\/37f1b988fc724aa985a83d2c78679d44dc266e33f45522de3e901304084d99c2?s=96&d=blank&r=g","contentUrl":"https:\/\/secure.gravatar.com\/avatar\/37f1b988fc724aa985a83d2c78679d44dc266e33f45522de3e901304084d99c2?s=96&d=blank&r=g","caption":"Emily Bites"},"url":"https:\/\/emilybites.com\/author\/emily_bites"},{"@type":"Recipe","name":"Creamy Tomato Pasta with Ham","author":{"@id":"https:\/\/emilybites.com\/#\/schema\/person\/15a120abf447cbb3002c306cc6a6846c"},"description":"This Creamy Tomato Pasta with Ham is a flavorful, family-friendly meal that’s perfect for weeknights!","datePublished":"2026-04-27T04:10:00+00:00","image":["https:\/\/emilybites.com\/wp-content\/uploads\/2026\/04\/Creamy-Tomato-Pasta-with-Ham-5b.jpg","https:\/\/emilybites.com\/wp-content\/uploads\/2026\/04\/Creamy-Tomato-Pasta-with-Ham-5b-500x500.jpg","https:\/\/emilybites.com\/wp-content\/uploads\/2026\/04\/Creamy-Tomato-Pasta-with-Ham-5b-500x375.jpg","https:\/\/emilybites.com\/wp-content\/uploads\/2026\/04\/Creamy-Tomato-Pasta-with-Ham-5b-480x270.jpg"],"recipeYield":["8","8 (1 & ¼ cups) servings"],"prepTime":"PT5M","cookTime":"PT25M","totalTime":"PT30M","recipeIngredient":["1 tablespoon olive oil","⅓ cup chopped onion","4 oz sliced mushrooms ((I used Baby Bellas))","2  garlic cloves (minced)","½ - 1 teaspoon crushed red pepper flakes ((depending on how much spice you like))","8 oz cubed ham ((found by bacon or deli meat, I used Hormel Cure 81 Cubed Ham))","24.5 oz jar of tomato passata\/puree ((such as Mutti))","½ teaspoon salt","1 lb medium-sized shaped pasta ((such as penne, orecchiette, fusilli, farfalle, cavatappi, shells) )","2 oz Parmesan cheese (finely shredded)","¾ cup fat free half and half creamer"],"recipeInstructions":[{"@type":"HowToStep","text":"Fill a large pot with around 4-6 quarts of salted water and place over high heat to bring to a boil.","name":"Fill a large pot with around 4-6 quarts of salted water and place over high heat to bring to a boil.","url":"https:\/\/emilybites.com\/2026\/04\/creamy-tomato-pasta-with-ham.html#wprm-recipe-35629-step-0-0"},{"@type":"HowToStep","text":"While the water is heating, drizzle the olive oil into a large sauté pan and bring over medium heat. When the oil is hot, add the chopped onion and sliced mushrooms and stir to coat with the oil. Spread the vegetables out and sprinkle with a little salt. Cook, stirring often, for about 3 minutes until softened. Add the garlic and red pepper flakes and stir together. Cook for another 30-60 seconds until the garlic is fragrant and then add the cubed ham. Stir the contents of the pan and cook for another 2 minutes.","name":"While the water is heating, drizzle the olive oil into a large sauté pan and bring over medium heat. When the oil is hot, add the chopped onion and sliced mushrooms and stir to coat with the oil. Spread the vegetables out and sprinkle with a little salt. Cook, stirring often, for about 3 minutes until softened. Add the garlic and red pepper flakes and stir together. Cook for another 30-60 seconds until the garlic is fragrant and then add the cubed ham. Stir the contents of the pan and cook for another 2 minutes.","url":"https:\/\/emilybites.com\/2026\/04\/creamy-tomato-pasta-with-ham.html#wprm-recipe-35629-step-0-1"},{"@type":"HowToStep","text":"Add the tomato puree from the jar to the ham mixture. Scoop ¼ cup of the boiling salted water from the pot and pour it into the puree jar. Put the lid back on and shake it to loosen any remaining puree. Remove the lid and pour the tomato water into the pan with the rest of the sauce. Add the ½ teaspoon of salt and stir. Increase the heat to medium-high until the mixture begins to boil, then reduce the heat to medium-low to simmer. Simmer uncovered for 10 minutes, stirring occasionally.","name":"Add the tomato puree from the jar to the ham mixture. Scoop ¼ cup of the boiling salted water from the pot and pour it into the puree jar. Put the lid back on and shake it to loosen any remaining puree. Remove the lid and pour the tomato water into the pan with the rest of the sauce. Add the ½ teaspoon of salt and stir. Increase the heat to medium-high until the mixture begins to boil, then reduce the heat to medium-low to simmer. Simmer uncovered for 10 minutes, stirring occasionally.","url":"https:\/\/emilybites.com\/2026\/04\/creamy-tomato-pasta-with-ham.html#wprm-recipe-35629-step-0-2"},{"@type":"HowToStep","text":"When the sauce begins simmering, add the pasta to the boiling water in the pot and cook following the package directions. Drain in a colander.","name":"When the sauce begins simmering, add the pasta to the boiling water in the pot and cook following the package directions. Drain in a colander.","url":"https:\/\/emilybites.com\/2026\/04\/creamy-tomato-pasta-with-ham.html#wprm-recipe-35629-step-0-3"},{"@type":"HowToStep","text":"Remove the pan with the sauce from heat and stir in the shredded parmesan cheese until melted into the sauce. Slowly stir in the half and half until fully combined and then add the drained pasta and stir together until coated.","name":"Remove the pan with the sauce from heat and stir in the shredded parmesan cheese until melted into the sauce. Slowly stir in the half and half until fully combined and then add the drained pasta and stir together until coated.","url":"https:\/\/emilybites.com\/2026\/04\/creamy-tomato-pasta-with-ham.html#wprm-recipe-35629-step-0-4"}],"recipeCategory":["Main Course"],"recipeCuisine":["American","Italian"],"keywords":"Creamy Tomato Sauce, Easy WW Dinner, Passata, WW Pasta","@id":"https:\/\/emilybites.com\/2026\/04\/creamy-tomato-pasta-with-ham.html#recipe","isPartOf":{"@id":"https:\/\/emilybites.com\/2026\/04\/creamy-tomato-pasta-with-ham.html#article"},"mainEntityOfPage":"https:\/\/emilybites.com\/2026\/04\/creamy-tomato-pasta-with-ham.html"}]}</script>

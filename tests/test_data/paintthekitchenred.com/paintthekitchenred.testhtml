xt-align:left}.wprm-recipe-template-roundup-clean-ptkr3 .wprm-image-container{max-width:750px;position:relative}.wprm-recipe-template-roundup-clean-ptkr3 .wprm-image-container .wprm-recipe-counter{background-color:#fff;border-radius:50%;font-size:20px;height:32px;left:8px;line-height:32px;opacity:.9;position:absolute;text-align:center;top:8px;width:32px}.wprm-recipe-template-roundup-clean-ptkr3 .wprm-recipe-name{font-size:1.5em;line-height:1.5em}.wprm-recipe-template-roundup-clean-ptkr3 .wprm-summary-container{padding:10px}</style><link rel="preload" data-rocket-preload as="image" href="https://www.paintthekitchenred.com/wp-content/uploads/2019/09/Instant-Pot-Lo-Mein-with-Beef-and-Broccoli-P1-Paint-the-Kitchen-Red-683x1024.jpg" imagesrcset="https://www.paintthekitchenred.com/wp-content/uploads/2019/09/Instant-Pot-Lo-Mein-with-Beef-and-Broccoli-P1-Paint-the-Kitchen-Red-683x1024.jpg 683w, https://www.paintthekitchenred.com/wp-content/uploads/2019/09/Instant-Pot-Lo-Mein-with-Beef-and-Broccoli-P1-Paint-the-Kitchen-Red-200x300.jpg 200w, https://www.paintthekitchenred.com/wp-content/uploads/2019/09/Instant-Pot-Lo-Mein-with-Beef-and-Broccoli-P1-Paint-the-Kitchen-Red-768x1152.jpg 768w, https://www.paintthekitchenred.com/wp-content/uploads/2019/09/Instant-Pot-Lo-Mein-with-Beef-and-Broccoli-P1-Paint-the-Kitchen-Red-1024x1536.jpg 1024w, https://www.paintthekitchenred.com/wp-content/uploads/2019/09/Instant-Pot-Lo-Mein-with-Beef-and-Broccoli-P1-Paint-the-Kitchen-Red-1365x2048.jpg 1365w, https://www.paintthekitchenred.com/wp-content/uploads/2019/09/Instant-Pot-Lo-Mein-with-Beef-and-Broccoli-P1-Paint-the-Kitchen-Red-720x1080.jpg 720w, https://www.paintthekitchenred.com/wp-content/uploads/2019/09/Instant-Pot-Lo-Mein-with-Beef-and-Broccoli-P1-Paint-the-Kitchen-Red-360x540.jpg 360w, https://www.paintthekitchenred.com/wp-content/uploads/2019/09/Instant-Pot-Lo-Mein-with-Beef-and-Broccoli-P1-Paint-the-Kitchen-Red-180x270.jpg 180w, https://www.paintthekitchenred.com/wp-content/uploads/20
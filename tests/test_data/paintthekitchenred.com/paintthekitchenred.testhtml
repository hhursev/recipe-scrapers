and Tips","publisher":{"@id":"https://www.paintthekitchenred.com/#organization"},"potentialAction":[{"@type":"SearchAction","target":{"@type":"EntryPoint","urlTemplate":"https://www.paintthekitchenred.com/?s={search_term_string}"},"query-input":{"@type":"PropertyValueSpecification","valueRequired":true,"valueName":"search_term_string"}}],"inLanguage":"en-US"},{"@type":"Organization","@id":"https://www.paintthekitchenred.com/#organization","name":"Paint the Kitchen Red","url":"https://www.paintthekitchenred.com/","logo":{"@type":"ImageObject","inLanguage":"en-US","@id":"https://www.paintthekitchenred.com/#/schema/logo/image/","url":"https://www.paintthekitchenred.com/wp-content/uploads/2020/01/icon-color-outline-high-res.png","contentUrl":"https://www.paintthekitchenred.com/wp-content/uploads/2020/01/icon-color-outline-high-res.png","width":719,"height":719,"caption":"Paint the Kitchen Red"},"image":{"@id":"https://www.paintthekitchenred.com/#/schema/logo/image/"},"sameAs":["https://www.facebook.com/paintthekitchenred/","https://x.com/paintkitchenred","https://www.instagram.com/paintthekitchenred/","https://www.pinterest.com/Paintkitchenred/","https://www.youtube.com/channel/UCNGhtzrPCjbQAD5pHZNNVkw"]},{"@type":"Person","@id":"https://www.paintthekitchenred.com/#/schema/person/4ec255f3b6f1ed75f2af81fe2e9d09ed","name":"Neena Panicker","description":"Neena Panicker is an expert home chef and recipe developer specializing in tasty ethnic and international recipes provided with step by step directions and photographs. Instant Pot recipes, air fryer recipes, stovetop and oven recipes are tested multiple times and only the best recipes make it on the blog.","sameAs":["https://www.paintthekitchenred.com/about/","facebook.com/paintthekitchenred","https://www.instagram.com/paintthekitchenred/","https://www.pinterest.com/Paintkitchenred/","https://x.com/paintkitchenred","https://www.youtube.com/c/PainttheKitchenRed","https://paintthekitchenred.tumblr.com/"]},{"@type":"Recipe","name":"Instant Pot Lo Mein Noodles with Beef and Broccoli","author":{"@type":"Person","name":"Paint the Kitchen Red"},"description":"This hearty Chinese-inspired Instant Pot Lo Mein noodles recipe features an umami-rich blend of oyster sauce, soy sauce, sesame oil, and red chili flakes. The tender beef is tossed together with noodles and broccoli to make a healthy one-pot meal that’s quick and requires minimal cleanup!","datePublished":"2019-09-26T09:37:43+00:00","image":["https://www.paintthekitchenred.com/wp-content/uploads/2019/09/Instant-Pot-Lo-Mein-with-Beef-and-Broccoli-P1-Paint-the-Kitchen-Red.jpg","https://www.paintthekitchenred.com/wp-content/uploads/2019/09/Instant-Pot-Lo-Mein-with-Beef-and-Broccoli-P1-Paint-the-Kitchen-Red-500x500.jpg","https://www.paintthekitchenred.com/wp-content/uploads/2019/09/Instant-Pot-Lo-Mein-with-Beef-and-Broccoli-P1-Paint-the-Kitchen-Red-500x375.jpg","https://www.paintthekitchenred.com/wp-content/uploads/2019/09/Instant-Pot-Lo-Mein-with-Beef-and-Broccoli-P1-Paint-the-Kitchen-Red-480x270.jpg"],"video":{"name":"Instant Pot Lo Mein Noodles with Beef and Broccoli","description":"This hearty Chinese-inspired Instant Pot Lo Mein noodles recipe features an umami-rich blend of oyster sauce, soy sauce, sesame oil, and red chili flakes. The tender beef is tossed together with noodles and broccoli to make a healthy one-pot meal that’s quick and requires minimal cleanup!","thumbnailUrl":"https://mediavine-res.cloudinary.com/image/upload/s--vwZHxxri--/c_limit,f_auto,fl_lossy,h_1080,q_auto,w_1920/v1568937413/z3wtbxizctl8vekenlze.jpg","embedUrl":"https://video.mediavine.com/videos/lj40hzn9lgbi6xm19rfb.js","contentUrl":"https://mediavine-res.cloudinary.com/video/upload/t_original/v1568937052/lj40hzn9lgbi6xm19rfb.mp4","uploadDate":"2019-09-19T23:56:07+00:00","duration":"PT130S","@type":"VideoObject"},"recipeYield":["6"],"prepTime":"PT15M","cookTime":"PT22M","totalTime":"PT32M","recipeIngredient":["2 Tbsp vegetable oil","1 lb. beef chuck ((500 grams) or beef round roast, sliced very thin)","5 cups broccoli florets","1/4 cup soy sauce","2 Tbsp ginger (minced)","2 Tbsp garlic (minced)","2 cups beef broth (plus more to deglaze)","2 Tbsp Chinese rice wine (Shaoxing)","2 tsp sesame oil","2 tsp oyster sauce","1/4 tsp white pepper","1/2 tsp crushed red pepper (or to taste)","2 Tbsp brown sugar","2 cups mushrooms (sliced)","8 oz dry spaghetti ((Barilla No. 5) - 226 grams - strands broken in half)","1 1/2 tsp sesame seeds (toasted)"],"recipeInstructions":[{"@type":"HowToStep","text":"In Saute mode, heat Instant Pot.  Once Instant Pot is hot, add 1 Tbsp vegetable oil.  Saute 1 lb. beef chuck until beef is browned on all sides.  To prevent overcrowding, saute beef in batches if needed.","name":"In Saute mode, heat Instant Pot.  Once Instant Pot is hot, add 1 Tbsp vegetable oil.  Saute 1 lb. beef chuck until beef is browned on all sides.  To prevent overcrowding, saute beef in batches if needed.","url":"https://www.paintthekitchenred.com/instant-pot-lo-mein-with-beef-and-broccoli/#wprm-recipe-9863-step-0-0"},{"@type":"HowToStep","text":"Transfer beef to a medium bowl and set aside.","name":"Transfer beef to a medium bowl and set aside.","url":"https://www.paintthekitchenred.com/instant-pot-lo-mein-with-beef-and-broccoli/#wprm-recipe-9863-step-0-1"},{"@type":"HowToStep","text":"Add 1 tsp of oil to the inner pot and saute the 5 cups broccoli florets until crisp-tender.  Add 1/2 tsp soy sauce to the broccoli, saute briefly and remove to a medium bowl.","name":"Add 1 tsp of oil to the inner pot and saute the 5 cups broccoli florets until crisp-tender.  Add 1/2 tsp soy sauce to the broccoli, saute briefly and remove to a medium bowl.","url":"https://www.paintthekitchenred.com/instant-pot-lo-mein-with-beef-and-broccoli/#wprm-recipe-9863-step-0-2"},{"@type":"HowToStep","text":"Select Cancel and turn off the Instant Pot.","name":"Select Cancel and turn off the Instant Pot.","url":"https://www.paintthekitchenred.com/instant-pot-lo-mein-with-beef-and-broccoli/#wprm-recipe-9863-step-0-3"},{"@type":"HowToStep","text":"Add remaining oil to the Instant Pot.","name":"Add remaining oil to the Instant Pot.","url":"https://www.paintthekitchenred.com/instant-pot-lo-mein-with-beef-and-broccoli/#wprm-recipe-9863-step-0-4"},{"@type":"HowToStep","text":"Add 2 Tbsp ginger and 2 Tbsp garlic; stir for 30 seconds.","name":"Add 2 Tbsp ginger and 2 Tbsp garlic; stir for 30 seconds.","url":"https://www.paintthekitchenred.com/instant-pot-lo-mein-with-beef-and-broccoli/#wprm-recipe-9863-step-0-5"},{"@type":"HowToStep","text":"Deglaze the inner pot by adding a tablespoon or two of broth to the hot inner pot, and scraping until the brown bits come loose.","name":"Deglaze the inner pot by adding a tablespoon or two of broth to the hot inner pot, and scraping until the brown bits come loose.","url":"https://www.paintthekitchenred.com/instant-pot-lo-mein-with-beef-and-broccoli/#wprm-recipe-9863-step-0-6"},{"@type":"HowToStep","text":"Stir in 2 cups beef broth, 2 Tbsp Chinese rice wine, 2 tsp sesame oil, remaining soy sauce, 2 tsp oyster sauce, 1/4 tsp white pepper, 1/2 tsp crushed red pepper, 2 Tbsp brown sugar, 2 cups mushrooms and reserved beef.","name":"Stir in 2 cups beef broth, 2 Tbsp Chinese rice wine, 2 tsp sesame oil, remaining soy sauce, 2 tsp oyster sauce, 1/4 tsp white pepper, 1/2 tsp crushed red pepper, 2 Tbsp brown sugar, 2 cups mushrooms and reserved beef.","url":"https://www.paintthekitchenred.com/instant-pot-lo-mein-with-beef-and-broccoli/#wprm-recipe-9863-step-0-7"},{"@type":"HowToStep","text":"Divide 8 oz dry spaghetti into four batches. Add noodles to the inner pot in batches: add one-fourth of noodles into the broth, fanning it out. Repeat with remaining batches, in a criss-cross pattern (see blog post for step by step photos or watch the video).","name":"Divide 8 oz dry spaghetti into four batches. Add noodles to the inner pot in batches: add one-fourth of noodles into the broth, fanning it out. Repeat with remaining batches, in a criss-cross pattern (see blog post for step by step photos or watch the video).","url":"https://www.paintthekitchenred.com/instant-pot-lo-mein-with-beef-and-broccoli/#wprm-recipe-9863-step-0-8"},{"@type":"HowToStep","text":"Using a spatula, gently push down on the spaghetti until it&#x27;s submerged in the broth. This might take 20 to 30 seconds.","name":"Using a spatula, gently push down on the spaghetti until it&#x27;s submerged in the broth. This might take 20 to 30 seconds.","url":"https://www.paintthekitchenred.com/instant-pot-lo-mein-with-beef-and-broccoli/#wprm-recipe-9863-step-0-9"},{"@type":"HowToStep","text":"Close the lid and pressure cook the noodles for 8 minutes on High Pressure.","name":"Close the lid and pressure cook the noodles for 8 minutes on High Pressure.","url":"https://www.paintthekitchenred.com/instant-pot-lo-mein-with-beef-and-broccoli/#wprm-recipe-9863-step-0-10"},{"@type":"HowToStep","text":"Do a quick release, in small bursts. See Tips.   [Read More: The Different Pressure Release Methods]","name":"Do a quick release, in small bursts. See Tips.   [Read More: The Different Pressure Release Methods]","url":"https://www.paintthekitchenred.com/instant-pot-lo-mein-with-beef-and-broccoli/#wprm-recipe-9863-step-0-11"},{"@type":"HowToStep","text":"Open the lid and stir in the broccoli.","name":"Open the lid and stir in the broccoli.","url":"https://www.paintthekitchenred.com/instant-pot-lo-mein-with-beef-and-broccoli/#wprm-recipe-9863-step-0-12"},{"@type":"HowToStep","text":"If there&#x27;s too much liquid remaining in the inner pot, allow the noodles to rest for 5 to 10 minutes.  The Instant Pot Lo Mein Noodles should thicken up. *","name":"If there&#x27;s too much liquid remaining in the inner pot, allow the noodles to rest for 5 to 10 minutes.  The Instant Pot Lo Mein Noodles should thicken up. *","url":"https://www.paintthekitchenred.com/instant-pot-lo-mein-with-beef-and-broccoli/#wprm-recipe-9863-step-0-13"},{"@type":"HowToStep","text":"Select Cancel and stir in 1 1/2 tsp sesame seeds.","name":"Select Cancel and stir in 1 1/2 tsp sesame seeds.","url":"https://www.paintthekitchenred.com/instant-pot-lo-mein-with-beef-and-broccoli/#wprm-recipe-9863-step-0-14"}],"aggregateRating":{"@type":"AggregateRating","ratingValue":"4.6","ratingCount":"10","reviewCount":"6"},"review":[{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"I had to buy most of the ingredients because I didn’t have them on hand, but wow am I glad I went with this recipe instead of any of the others that I was looking at! The flavors are so deep and rich, and it was amazing how everything could be cooked in the same pot (I’m all for easy clean up!) it is safe to say I’ll be making this again","author":{"@type":"Person","name":"LFin"},"datePublished":"2021-09-06"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"I had to substitute Mirin for Shaoxing, b/c it was out of stock at my local grocery store, but it still came out beautifully. \r\n\r\nThis is the fifth dish I have tried, and loved, from your blog-- it's safe to say that if you had a fan t-shirt, I'd wear it. \r\n \r\nPlease post more recipes and videos to your YT channel!  You make dinner preparation such an easy and joyful process.  Thank you, Neena!","author":{"@type":"Person","name":"Kanwal"},"datePublished":"2021-08-31"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Excellent, no issues at all and tasted fantastic!","author":{"@type":"Person","name":"Daniel Orourke"},"datePublished":"2019-12-15"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"1"},"reviewBody":"The meat was so tough I had to throw the whole thing out.  Took a lot of time to make and followed the directions exactly.  Would have tasted better without the meat.","author":{"@type":"Person","name":"Rachel"},"datePublished":"2019-10-08"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"this is great recipe!  will definitely make again!","author":{"@type":"Person","name":"Liz Csordas"},"datePublished":"2019-10-07"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"I love how you give so detailed info i. e. to vent in burts to avoid pasta from spewing out. Not all recipes has that.\r\nI will try this. Pls, more IP recipes.\r\nThank you for sharing","author":{"@type":"Person","name":"Colleen"},"datePublished":"2019-09-28"}],"recipeCategory":["Main Dishes"],"recipeCuisine":["Asian","Chinese"],"keywords":"beef lo mein, instant pot lo mein, instant pot lo mein noodles, lo mein, lo mein noodles","nutrition":{"@type":"NutritionInformation","calories":"426 kcal","fatContent":"20 g","saturatedFatContent":"6 g","cholesterolContent":"47 mg","sodiumContent":"1015 mg","carbohydrateContent":"38 g","fiberContent":"3 g","sugarContent":"7 g","proteinContent":"24 g","servingSize":"1 serving","unsaturatedFatContent":"6 g"},"@id":"https://www.paintthekitchenred.com/instant-pot-lo-mein-with-beef-and-broccoli/#recipe","isPartOf":{"@id":"https://www.paintthekitchenred.com/instant-pot-lo-mein-with-beef-and-broccoli/#article"},"mainEntityOfPage":"https://www.paintthekitchenred.com/instant-pot-lo-mein-with-beef-and-broccoli/"}]}</script>

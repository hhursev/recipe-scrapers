    <body class="wp-singular page-template-default page page-id-2289665 wp-theme-twentyseventeen wp-child-theme-mc3-child">
        <div id="page" class="site">
        <div id="app" class="hidden"> <!-- #vue app scope -->  
    </div>
    <div id="seo" style="display:none">
        <h1>Pizza roulée low carb</h1>
        <p></p>
        <img src="https://mc-web-content-cdn.tecpal.com/wp-content/uploads/2021/11/16113839/24833rezeptfoto.jpg" >
    </div>

							.dpsp-networks-btns-wrapper.dpsp-networks-btns-content .dpsp-network-btn {--networkHover: rgba(237, 128, 116, 0.4); --networkAccent: rgba(237, 128, 116, 1);}
							.dpsp-button-style-6 .dpsp-networks-btns-follow-widget.dpsp-networks-btns-wrapper .dpsp-network-btn:not(:hover):not(:active) {
								--customNetworkColor: #f4918d;

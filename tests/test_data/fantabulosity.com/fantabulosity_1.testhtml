			.wp-block-search .wp-block-search__label {
		display: none !important;
}
select#wp-block-categories-1, select#wp-block-categories-2 {
    color: #000;
}

.site-header a img {
    margin-bottom: 9px !important;
/*     width: 145px; */
}


#savetherecipe form.seva-form.formkit-form {
	    background-color: #F7EBE3 !important;
}

body {
	overflow-x: hidden;
}
.dpsp-button-style-1 .dpsp-network-btn, .dpsp-button-style-1 .dpsp-network-btn svg {
	color: #000 !important;
}
.dpsp-button-style-1 .dpsp-network-btn .dpsp-network-icon:not(.dpsp-network-icon-outlined) .dpsp-network-icon-inner>svg {	
	fill: #000 !important;
}
/* Mediavine Sidebar Fix */

@media only screen and (min-width: 1201px) { 
    .content-sidebar .content {
        max-width: calc(100% - 330px);
    }
    .content-sidebar .sidebar {
        min-width: 300px;
    }
}
@media only screen and (max-width: 1200px) and (min-width: 1024px) {
    .content-sidebar .content {
        max-width: calc(100% - 330px)!important;
    }
    .sidebar-primary{
        width: 300px!important;
    }
}
@media only screen and (max-width: 1023px) {
    .content-sidebar .content {
        max-width: 100%!important;
        width: 100%!important;
    }
    .content-sidebar .sidebar {
        width: 100%;
        float: none;
        margin: auto;
        text-align: center;
    }
}

/* End of Fix */

/* Mobile header space */
@media only screen and (max-width: 650px) {
	#breadcrumbs, .entry-meta {
		font-size: 13px;
	}
	h1.entry-title {
		margin-top: 0;
		font-size: 28px;
	}
	#breadcrumbs {
		margin: 5px 0 !important;
	}
}

/* CLS */
.wprm-recipe.wprm-recipe-snippet {
text-align: center;
}

/* Menu font fix */
.genesis-nav-menu .menu-item {
	font-size: 13px !important;
	font-weight: 600 !important;
}

.genesis-nav-menu a {
	padding: 7px !important;
}
body {
	font-size: 20px;
}

.comment-time a, .comment-time {
	color: #000;
}

/* Home padding */
.home .site-inner {
	margin-top: 0px;
	padding-top: 0px;
}

/* Post Meta */
.entry-meta {
	font-family: -apple-system, system-ui, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol" !important;
	font-weight: 400;
}

/*Imark Color changes*/
.single-post .entry-content a {
    background-color: #F7EBE3;
    color: #212121;
}
.sidebar .feast-about-author {
    background-color: #F7EBE3;
}
.wp-block-group::not(.home) {
    background: #F7EBE3 !important;
}

#breadcrumbs {
	color: #000;
}
	.wp-block-button__link.has-black-color {
    color: black;
}
.wp-block-columns {
    
    gap: 1em;
}


.browse-recipe-btn {

	width:100% !important;
	display:flex !important;
	justify-items:center !important;
	justify-content:center !important;
	align-items:center !important;
	align-content:center !important;
}

/* Post Top fix */
@media only screen and (min-width: 1025px) {
h1.entry-title {
	font-size: 1.5em;
}
.entry-meta {
	font-size: 0.7em;
	line-height: 1.6;
}
#breadcrumbs {
	font-size: 17px;
}
}		</style>

<style>
	.site-header .search-form {
		margin-top: 0;
	}
	.site-header > .wrap {
		display: -webkit-box;
		display: -ms-flexbox;
		display: flex;
		-ms-flex-wrap: wrap;
		flex-wrap: wrap;
		-webkit-box-align: center;
		-ms-flex-align: center;
		align-items: center;
		-webkit-box-pack: justify;
		-ms-flex-pack: justify;
		justify-content: space-between;
	}
	.header-full-width .title-area {
		width: 200px;
	}
	.site-header > .wrap:after {
		display: none;
	}
	.site-header .nav-primary .wrap {
		padding: 0;
	}
	.site-header a img {
		margin-bottom: 0;
	}
	.genesis-nav-menu a {
		padding: 10px;
	}
	.header-image .site-header .widget-area {
		width: auto;
		padding: 0;
	}
	.genesis-nav-menu .search-form-input {
		min-height: auto;
		padding: 10px;
	}
	.simple-social-icons ul.aligncenter li {
		margin-bottom: 0 !important;
	}
	.genesis-nav-menu #feast-search {
		margin: 0;
		padding: 0 5px;
	}
	.genesis-nav-menu {
		display: -webkit-box;
		display: -ms-flexbox;
		display: flex;
		-webkit-box-align: center;
		-ms-flex-align: center;
		align-items: center;
	}
	.genesis-nav-menu .menu-item {
		min-height: auto;
	}
	header.site-header {
		border-bottom: 1px solid #e4e4e4;
	}
	@media only screen and ( max-width: 1200px ){
		.site-header > .wrap {
			width: 1000px;
			max-width: 100%;
		}
	}
</style>
<style>
	body, p, span, h1, h2, h3, h4, h5, h6, .before-header-bar .genesis-nav-menu > li > a, .site-header .genesis-nav-menu > li > a, .icon-menu .genesis-nav-menu > li > a, button, input[type="button"], input[type="reset"], input[type="submit"], .button, .entry-content .button { 

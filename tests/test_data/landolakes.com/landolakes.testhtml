                "datePublished": "2022-05-19",
                "mainEntityOfPage": "True",
                "description": "Butter and brown sugar topped with pineapple and maraschino cherries form the decadent topping on this classic pineapple upside-down cake.",
                "image": "https://stordfkenticomedia.blob.core.windows.net/df-us/rms/media/recipesmedia/recipes/retail/desktopimages/1997/may/2018_pineapple-upside-down-cake_5308-600.jpg?ext=.jpg",
                "recipeIngredient": ["Topping","1/3 cup  Land O Lakes® Butter ","3/4 cup firmly packed brown sugar ","12 slices pineapple, * well drained ","1 (10-ounce) jar maraschino cherries, stems removed ","Cake","2 cups all-purpose flour ","1 tablespoon baking powder ","1/4 teaspoon salt ","1 cup firmly packed brown sugar ","2/3 cup  Land O Lakes® Butter softened ","3  large Land O Lakes® Eggs ","2 1/2 teaspoons vanilla extract ","3/4 cup milk "],
                "name": "Pineapple Upside-Down Cake",
                "nutrition": {
                "@type": "NutritionInformation",
                "calories": "450 calories",
                "fatContent": "17 grams",
                "saturatedFatContent":"0 grams",
                "transfatContent": "0 grams",
                "cholesterolContent": "90 milligrams",
                "sodiumContent": "340 milligrams",
                "carbohydrateContent": "70 grams",
                "fiberContent":"2 grams",
                "sugarContent":"0 grams",
                "proteinContent":"4 grams"
                },
                "recipeInstructions":[{
"@type": "HowToStep",
"name": "Heat",
"text": "Heat oven to 350°F. "
},
{
"@type": "HowToStep",
"name": "Melt",
"text": "Melt 1/3 cup butter in 13x9-inch ungreased baking pan in oven. Stir in 3/4 cup brown sugar. Spread mixture evenly in pan."
},
{
"@type": "HowToStep",
"name": "Arrange",
"text": "Arrange 12 pineapple slices on top. Place cherry in center and between each pineapple slice, if desired."
},
{
"@type": "HowToStep",
"name": "Combine",
"text": "Combine flour, baking powder and salt in bowl; set aside. "
},
{
"@type": "HowToStep",
"name": "Combine",
"text": "Combine 1 cup brown sugar and 2/3 cup butter in bowl; beat at medium speed, scraping bowl often, until creamy. Continue beating, adding <em>1</em> egg at a time, until well mixed. Stir in vanilla. Gradually add flour mixture alternately with milk, beating at low speed and scraping bowl often after each addition."
},
{
"@type": "HowToStep",
"name": "Gently",
"text": "Gently spread batter over pineapple. Bake 35-40 minutes or until toothpick inserted in center comes out clean. Loosen sides of cake from pan by running knife around inside of pan. Invert cake onto serving platter; let stand 5 minutes. Remove pan. Cool completely."
}],

        .checkSlider {
            background-color: #ccc;
            bottom: 0;
            cursor: pointer;
            left: 0;
            position: absolute;
            right: 0;
            top: 0;
            transition: .4s;
            width: 56px;
            height: 26px;
        }

            .checkSlider:before {
                background-color: #fff;
                bottom: 3px;
                content: "";
                height: 20px;
                left: 4px;
                position: absolute;
                transition: .4s;
                width: 20px;
            }

        .checkSwitch input:checked + .checkSlider {
            background-color: #66bb6a;
        }

            .checkSwitch input:checked + .checkSlider:before {
                transform: translateX(26px);
            }

        .checkSlider.round {
            border-radius: 34px;
        }

            .checkSlider.round:before {
                border-radius: 50%;
            }

        .checkSwitch span {

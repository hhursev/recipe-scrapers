/* --- INICIO DO CSS COMIDINHAS DO CHEF quem somos --- */




/* --- ESTRUTURA E CORES --- */
    .cdc-wrapper {
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
        color: #333;
        line-height: 1.6;
        width: 100%;

        margin: 0 auto;
     
    }

    .cdc-wrapper {
        /* Cor Vinho da Marca */
        --cor-vinho: #5e1914; 
        /* Tons Neutros */
        --cor-fundo-destaque: #f9f9f9;
        --cor-borda: #e0e0e0;
    }

    /* --- TIPOGRAFIA --- */
    .cdc-title-main {
        color: var(--cor-vinho);
        font-family: Georgia, 'Times New Roman', serif;
        font-size: 2.5rem;
        text-align: center;
        margin-bottom: 40px;
        position: relative;
        padding-bottom: 15px;
    }
    .cdc-title-main::after {
        content: '';
        display: block;
        width: 60px;
        height: 4px;
        background: var(--cor-vinho);
        margin: 15px auto 0;
        opacity: 0.2;
    }

    .cdc-subtitle {
        color: var(--cor-vinho);
        font-family: Georgia, serif;
        font-size: 1.8rem;
        margin-top: 50px;
        margin-bottom: 25px;
        border-left: 5px solid var(--cor-vinho);
        padding-left: 15px;
    }

    /* --- LAYOUT DE CONTEÚDO (Z-PATTERN) --- */
    .cdc-section {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 40px;
        margin-bottom: 60px;
    }
    .cdc-section.reverse { flex-direction: row-reverse; }

    .cdc-col-text { flex: 1; min-width: 300px; font-size: 1.1rem; color: #444; }
    .cdc-col-media { flex: 1; min-width: 300px; }

    .cdc-col-media img {
        width: 100%;
        border-radius: 8px;
        box-shadow: 0 10px 20px rgba(0,0,0,0.08);
    }

    /* Destaque (Quote) */
    .cdc-highlight {
        background: var(--cor-fundo-destaque);
        border-left: 5px solid var(--cor-vinho);
        padding: 30px;
        border-radius: 0 8px 8px 0;
        font-style: italic;
        margin: 40px 0;
        font-size: 1.15rem;
    }

    /* Vídeo Responsivo */
    .cdc-video-box {
        position: relative;
        padding-bottom: 56.25%;
        height: 0;
        overflow: hidden;
        border-radius: 8px;
        box-shadow: 0 10px 20px rgba(0,0,0,0.08);
    }
    .cdc-video-box iframe { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }

    /* --- LIDERANÇA (Pedro e Camillo) --- */
    .cdc-leaders-area {
        display: grid;
        gap: 30px;
        margin-top: 40px;
        grid-template-columns: 1fr; /* Mobile: 1 coluna */
    }

    /* DESKTOP: Lado a Lado */
    @media (min-width: 768px) {
        .cdc-leaders-area {
            grid-template-columns: 1fr 1fr; 
        }
    }

    .cdc-leader-card {
        background: #fff;
        border: 1px solid var(--cor-borda);
        border-top: 5px solid var(--cor-vinho);
        border-radius: 8px;
        padding: 35px;
        text-align: center;
        box-shadow: 0 5px 15px rgba(0,0,0,0.03);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        display: flex;
        flex-direction: column;
        align-items: center;
        height: 100%;
    }
    
    .cdc-leader-card:hover { 
        transform: translateY(-5px); 
        box-shadow: 0 15px 30px rgba(0,0,0,0.1); 
    }

    .cdc-link-card {
        text-decoration: none;
        color: inherit;
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        height: 100%;
    }

    .cdc-leader-photo {
        width: 160px;
        height: 160px;
        border-radius: 50%;
        object-fit: cover; /* Garante que a foto não distorça */
        object-position: top center; /* Foca no rosto se a foto for vertical */
        margin-bottom: 20px;
        border: 1px solid #ddd;
        padding: 4px;
        background: #fff;
    }

    .cdc-leader-name {
        color: var(--cor-vinho);
        margin: 5px 0;
        font-size: 1.6rem;
        font-family: Georgia, serif;
    }

    .cdc-leader-role {
        display: block;
        color: #666;
        font-weight: bold;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 1px;
        margin-bottom: 15px;
    }

    .cdc-linkedin-btn {
        margin-top: auto;
        display: inline-block;
        color: var(--cor-vinho);
        font-weight: bold;
        font-size: 0.9rem;
        padding-top: 15px;
    }
    .cdc-linkedin-btn::after { content: ' →'; }

    /* --- TIME TÉCNICO (Grid) --- */
    .cdc-tech-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        justify-content: center;
        margin-top: 30px;
    }
    .cdc-tech-item {
        width: 150px;
        text-align: center;
        background: #fff;
        padding: 15px;
        border-radius: 8px;
        border: 1px solid #eee;
    }
    .cdc-tech-photo {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        object-fit: cover;
        margin-bottom: 10px;
        filter: grayscale(100%);
        transition: filter 0.3s;
    }
    .cdc-tech-item:hover .cdc-tech-photo { filter: grayscale(0%); }

    /* --- TIME EDITORIAL (Tags) --- */
    .cdc-editorial-tags {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 10px;
        margin-top: 20px;
    }
    .cdc-tag {
        background: #fff;
        color: #555;
        padding: 8px 15px;
        border-radius: 4px;
        font-size: 0.9rem;
        border: 1px solid #ddd;
    }

    /* Lista Hackathon */
    .cdc-list-check { list-style: none; padding: 0; }
    .cdc-list-check li {
        padding: 8px 0;
        border-bottom: 1px solid #eee;
        display: flex;
        align-items: center;
        color: #444;
    }
    .cdc-list-check li::before {
        content: '•';
        color: var(--cor-vinho);
        margin-right: 12px;
        font-size: 1.5rem;
        line-height: 1;
    }





/* --- FIM DO CSS --- */











  /* --- ESTRUTURA E CORES (Mesma identidade do Sobre Nós) --- */
    .cdc-contact-wrapper {
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
        color: #333;
        line-height: 1.6;
        width: 100%;
        max-width: 1000px;
        margin: 0 auto;
        background-color: #fff;
        padding: 20px;
    }

    .cdc-contact-wrapper {
        --cor-vinho: #5e1914; 
        --cor-cinza-bg: #f9f9f9;
        --cor-borda: #e0e0e0;
    }

    /* Títulos */
    .cdc-contact-title {
        color: var(--cor-vinho);
        font-family: Georgia, 'Times New Roman', serif;
        font-size: 2.5rem;
        text-align: center;
        margin-bottom: 20px;
        position: relative;
    }
    .cdc-contact-title::after {
        content: '';
        display: block;
        width: 60px;
        height: 4px;
        background: var(--cor-vinho);
        margin: 15px auto 0;
        opacity: 0.2;
    }

    .cdc-intro-text {
        text-align: center;
        max-width: 700px;
        margin: 0 auto 50px auto;
        font-size: 1.1rem;
        color: #555;
    }

    /* GRID DE OPÇÕES */
    .cdc-contact-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 30px;
    }
    
    @media (min-width: 768px) {
        .cdc-contact-grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    /* CARDS DE CONTATO */
    .cdc-contact-card {
        background: #fff;
        border: 1px solid var(--cor-borda);
        border-top: 5px solid var(--cor-vinho);
        border-radius: 8px;
        padding: 40px 30px;
        text-align: center;
        box-shadow: 0 5px 15px rgba(0,0,0,0.03);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .cdc-contact-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 30px rgba(94, 25, 20, 0.1);
    }

    .cdc-card-icon {
        font-size: 2.5rem;
        margin-bottom: 20px;
        color: var(--cor-vinho);
    }

    .cdc-card-title {
        font-family: Georgia, serif;
        font-size: 1.5rem;
        color: var(--cor-vinho);
        margin-bottom: 15px;
    }

    .cdc-card-desc {
        color: #666;
        margin-bottom: 30px;
        flex-grow: 1; /* Empurra o botão para baixo */
    }

    /* BOTÕES */
    .cdc-btn {
        display: inline-block;
        padding: 12px 25px;
        background-color: var(--cor-vinho);
        color: #fff;
        text-decoration: none;
        border-radius: 5px;
        font-weight: bold;
        transition: background 0.3s;
    }
    .cdc-btn:hover {
        background-color: #3e100d; /* Vinho mais escuro */
        color: #fff;
    }
    
    .cdc-btn-linkedin {
        background-color: #0077b5; /* Azul LinkedIn */
    }
    .cdc-btn-linkedin:hover {
        background-color: #005582;
    }

    /* SEÇÃO FINAL */
    .cdc-footer-note {
        text-align: center;
        margin-top: 60px;
        padding-top: 30px;
        border-top: 1px solid #eee;
        color: #888;
        font-size: 0.9rem;
    }




.cdc-policy-wrapper {
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
        color: #333;
        line-height: 1.6;
   
        margin: 0 auto;
 
        padding: 20px;
    }
    .cdc-policy-wrapper h1 { color: #5e1914; border-bottom: 3px solid #d69d28; padding-bottom: 10px; }
    .cdc-policy-wrapper h2 { color: #5e1914; margin-top: 30px; }
    .cdc-policy-wrapper h3 { color: #444; margin-top: 20px; }
    .cdc-policy-wrapper ul { margin-bottom: 20px; }
    .cdc-policy-wrapper li { margin-bottom: 10px; }
    .cdc-alert-box {
        background-color: #f9f9f9;
        border-left: 5px solid #5e1914;
        padding: 15px;
        margin: 20px 0;
        font-size: 0.95rem;
    }
    .cdc-link { color: #5e1914; font-weight: bold; text-decoration: none; }
    .cdc-link:hover { text-decoration: underline; }




.resume p {
  margin-bottom: 25px; /* ou 20px se quiser mais respiro */
  line-height: 1.9; /* melhora leitura */
}



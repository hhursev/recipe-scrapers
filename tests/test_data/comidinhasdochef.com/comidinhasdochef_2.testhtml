<!-- ═══════════════════════════════════════════════════════════════
     STICKY SIDEBAR — script único corrigido
     ═══════════════════════════════════════════════════════════════
     PROBLEMA DO ORIGINAL:
     • Dois scripts rodando juntos conflitavam entre si
     • startLeft/startY capturados em DOMContentLoaded = antes dos
       anúncios carregarem = posição errada = elemento saía da tela
     • position:fixed + left calculado errado = banner sumia à esquerda

     SOLUÇÃO:
     • position:sticky CSS nativo — não precisa de left/width
     • Carrega visível no topo de .content-sidebar (fluxo normal)
     • Segue o scroll colado abaixo do header automaticamente
     • JS só faz UMA coisa: para no .seetoo convertendo para absolute
     • Posições capturadas em window.load = layout já estável
     ═══════════════════════════════════════════════════════════════ -->
<style>
/* Desktop: sticky nativo — sem left, sem width fixo, sem conflito */
@media (min-width: 1024px) {

    /* Pai precisa de align-self:flex-start para sticky funcionar em flex */
    .content-sidebar {
        align-self: flex-start !important;
        position: relative !important; /* âncora do is-stopped */
    }

    /* Começa visível no topo da sidebar, segue o scroll */
    .content-sidebar-fixed {
        position: sticky !important;
        top: 120px !important; /* JS ajusta para altura real do header */
        width: 100% !important;
    }

    /* Quando chega no .seetoo: para de seguir o scroll */
    .content-sidebar-fixed.cxsb-anchored {
        position: absolute !important;
        /* top definido pelo JS como distância dentro de .content-sidebar */
    }
}
</style>

<script>
(function () {
    /* Só desktop */
    if (window.innerWidth < 1024) return;

    var seetoo = document.querySelector('.seetoo, #see-too');
    var els    = document.querySelectorAll('.content-sidebar-fixed');
    if (!els.length) return;

    function run() {
        /* Altura real do header — recalcula sempre (ads podem mudar tamanho) */
        var headerEl = document.querySelector('header');
        var topOffset = headerEl ? headerEl.offsetHeight + 8 : 120;

        /* Aplica top correto via CSS sticky */
        els.forEach(function (el) {
            el.style.top = topOffset + 'px';
        });

        if (!seetoo) return;

        function onScroll() {
            var seetooTop = seetoo.getBoundingClientRect().top + window.pageYOffset;

            els.forEach(function (el) {
                var sidebar = el.closest('.content-sidebar');
                if (!sidebar) return;

                var elH       = el.offsetHeight;
                var elBottom  = el.getBoundingClientRect().bottom + window.pageYOffset;
                var sidebarY  = sidebar.getBoundingClientRect().top + window.pageYOffset;
                var isStopped = el.classList.contains('cxsb-anchored');

                /* Para no seetoo */
                if (!isStopped && elBottom >= seetooTop) {
                    el.classList.add('cxsb-anchored');
                    el.style.top = (seetooTop - sidebarY - elH) + 'px';
                    return;
                }

                /* Voltou para cima — retoma sticky */
                if (isStopped && (window.pageYOffset + topOffset + elH) < seetooTop) {
                    el.classList.remove('cxsb-anchored');
                    el.style.top = topOffset + 'px';
                }
            });
        }

        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
    }

    /* window.load: aguarda anúncios/imagens — posições estáveis */
    if (document.readyState === 'complete') {
        run();
    } else {
        window.addEventListener('load', run);
    }
})();
</script>

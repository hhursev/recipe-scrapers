			/* Obrigatório: sem overflow no pai e altura livre no flex */
.content-wrapper {
  overflow: visible !important;
  align-items: flex-start !important;
}

.content-sidebar {
  overflow: visible !important;
  position: relative !important;
  align-self: flex-start !important;
}

/* O sticky em si — começa no topo da sidebar, para no fim dela */
.content-sidebar-fixed {
  position: sticky !important;
  top: 120px !important; /* ajuste para a altura do seu header */
  overflow: visible !important;
}






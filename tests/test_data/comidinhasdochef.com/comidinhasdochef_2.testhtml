<script>
(function($){

    /* ── Like button ──────────────────────────────────────────── */
    $('.info-receita-like-image:not(.active), .like button:not(.active)').on('click', function(e) {
        e.preventDefault();
        var text = $(this).html().replace('Curtir', 'Curtido');
        var id   = $(this).data('id');
        if (!localStorage.getItem('post_' + id)) {
            $(this).addClass('active').html(text);
            localStorage.setItem('post_' + id, true);
            $.post("https://comidinhasdochef.com/wp-admin/admin-ajax.php", { id: id, action: 'like_post' });
        }
    });

    $('.info-receita-like-image, .like button').each(function() {
        var id = $(this).data('id');
        if (localStorage.getItem('post_' + id)) {
            $(this).addClass('active').html($(this).html().replace('Curtir', 'Curtido'));
        }
    });

})(jQuery);
</script>



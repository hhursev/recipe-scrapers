        	<script data-cfasync="false">
	(function() {
		'use strict';

		// Neutraliza document.write (evita erros de scripts de ads legados)
		document.write = function(){};
		document.writeln = function(){};

		// Silencia mensagens de console de redes de ads
		var _terms = ['autozep','adzep','slotvisibilitychanged','anchor','adgb','document.write','article-intext','gpt-message','profiles.js','vidoomy'];
		var _shouldMute = function(args) {
			try {
				var s = Array.prototype.slice.call(args).map(function(x) {
					return typeof x === 'string' ? x : (typeof x === 'object' ? JSON.stringify(x) : '');
				}).join(' ').toLowerCase();
				return _terms.some(function(t){ return s.indexOf(t) !== -1; });
			} catch(e) { return false; }
		};
		['log','error','warn','info'].forEach(function(method) {
			var orig = console[method];
			console[method] = function() { if (!_shouldMute(arguments)) orig.apply(console, arguments); };
		});

		// Bloqueia erros globais de scripts de ads
		window.addEventListener('error', function(e) {
			if (e.message && _terms.some(function(t){ return e.message.toLowerCase().indexOf(t) !== -1; })) {
				e.stopImmediatePropagation();
				e.preventDefault();
			}
		}, true);
	})();
	</script>
	

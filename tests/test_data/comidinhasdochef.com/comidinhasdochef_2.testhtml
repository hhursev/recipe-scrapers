<script>
(function() {

  // 🎯 seletores MAIS SEGUROS (somente ads comuns)
  const selectors = [
    '.ad-slot',
    '.adsbygoogle',
    '[data-ad]',
    'iframe[src*="ad"]',
    'iframe[src*="doubleclick"]',
    'iframe[src*="googlesyndication"]'
  ];

  const forceAds = () => {
    document.querySelectorAll(selectors.join(',')).forEach(el => {

      // evita mexer em layout geral
      if (!el.closest('.ad-slot') && !el.classList.contains('adsbygoogle')) return;

      el.style.opacity = '1';
      el.style.transform = 'none';
      el.style.transition = 'none';
      el.style.animation = 'none';
      el.style.visibility = 'visible';

      // ⚠️ NÃO forçar display block global (isso quebra layout)
    });
  };

  // roda com controle (não infinito pesado)
  let runs = 0;
  const interval = setInterval(() => {
    forceAds();
    runs++;
    if (runs > 10) clearInterval(interval); // para depois
  }, 300);

  document.addEventListener('DOMContentLoaded', forceAds);
  window.addEventListener('load', forceAds);

})();
</script>

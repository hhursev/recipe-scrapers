                                                                                                                                        <h2 class="subtitle">Calda:</h2>
                                                                                                                <ul>
                                                                                                                                                                                                                                <li><label><input type="checkbox"><i></i> <span><b><span data-quantidade="1" >1</span> xícara (chá)</b> de açúcar </span></label></li>
                                                                                                                                                                                                                                                                            <li><label><input type="checkbox"><i></i> <span><b><span data-quantidade="1" >1</span> xícara (chá)</b> de Água </span></label></li>
                                                                                                                                                                                                                                                                            <li><label><input type="checkbox"><i></i> <span><b><span data-quantidade="100" >100</span> g</b> de coco em flocos </span></label></li>
                                                                                                                            </ul>
                                                                                                                                                <h2 class="subtitle">Bolo:</h2>
                                                                                                                <ul>
                                                                                                                                                                                                                                <li><label><input type="checkbox"><i></i> <span><b><span data-quantidade="2" >2</span> xícaras (chá)</b> de farinha de trigo </span></label></li>
                                                                                                                                                                                                                                                                            <li><label><input type="checkbox"><i></i> <span><b><span data-quantidade="2" >2</span> xícaras (chá)</b> de açúcar </span></label></li>
                                                                                                                                                                                                                                                                            <li><label><input type="checkbox"><i></i> <span><b><span data-quantidade="100" >100</span> g</b> de coco ralado </span></label></li>
                                                                                                                                                                                                                                                                            <li><label><input type="checkbox"><i></i> <span><b><span data-quantidade="200" >200</span> ml</b> de leite de coco </span></label></li>
                                                                                                                                                                                                                                                                            <li><label><input type="checkbox"><i></i> <span><b><span data-quantidade="3" >3</span> unidades</b> de ovos </span></label></li>
                                                                                                                                                                                                                                                                            <li><label><input type="checkbox"><i></i> <span><b><span data-quantidade="1" >1</span> colher (sopa)</b> de fermento químico em pó para bolos </span></label></li>
                                                                                                                                                                                                                                                                            <li><label><input type="checkbox"><i></i> <span><b><span data-quantidade="0.5" >1/2</span> xícara (chá)</b> de Óleo </span></label></li>

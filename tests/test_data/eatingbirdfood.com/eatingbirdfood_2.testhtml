ValueSpecification","valueRequired":true,"valueName":"search_term_string"}}],"inLanguage":"en-US"},{"@type":"Organization","@id":"https:\/\/www.eatingbirdfood.com\/#organization","name":"Eating Bird Food","url":"https:\/\/www.eatingbirdfood.com\/","logo":{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/www.eatingbirdfood.com\/#\/schema\/logo\/image\/","url":"https:\/\/www.eatingbirdfood.com\/wp-content\/uploads\/2025\/10\/square.jpg","contentUrl":"https:\/\/www.eatingbirdfood.com\/wp-content\/uploads\/2025\/10\/square.jpg","width":200,"height":200,"caption":"Eating Bird Food"},"image":{"@id":"https:\/\/www.eatingbirdfood.com\/#\/schema\/logo\/image\/"},"sameAs":["https:\/\/www.facebook.com\/eatingbirdfood","https:\/\/x.com\/eatingbirdfood","https:\/\/www.instagram.com\/eatingbirdfood","https:\/\/www.pinterest.com\/eatingbirdfood","https:\/\/www.tiktok.com\/@eatingbirdfood","https:\/\/www.youtube.com\/c\/eatingbirdfood"]},{"@type":"Person","@id":"https:\/\/www.eatingbirdfood.com\/#\/schema\/person\/51f35e8c1ea0072906e0cf99777ae3b2","name":"Brittany Mullins","image":{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/secure.gravatar.com\/avatar\/21592cbe5834ed3ee55ead5533bf7d63ea19a69e91eb55e61b9c4454a7c20f87?s=96&d=blank&r=g","url":"https:\/\/secure.gravatar.com\/avatar\/21592cbe5834ed3ee55ead5533bf7d63ea19a69e91eb55e61b9c4454a7c20f87?s=96&d=blank&r=g","contentUrl":"https:\/\/secure.gravatar.com\/avatar\/21592cbe5834ed3ee55ead5533bf7d63ea19a69e91eb55e61b9c4454a7c20f87?s=96&d=blank&r=g","caption":"Brittany Mullins"},"description":"Hey there, I’m Brittany, the creator of Eating Bird Food, cookbook author, health coach and mama of two littles. Here you'll find quick and easy recipes that make healthy fun and enjoyable for you and your family!","sameAs":["https:\/\/www.eatingbirdfood.com\/about\/","https:\/\/www.facebook.com\/eatingbirdfood","https:\/\/x.com\/eatingbirdfood"],"award":["Holistic Health Coach"],"knowsAbout":["Food Blogging. Recipe Development","Food Photography","Healthy Recipes","Vegan Recipes","Vegetarian Recipes","High-Protein Recipes","Low-Carb Recipes","Gluten-Free Recipes"],"jobTitle":"Food Blogger, Founder, Chef, Recipe Developer","worksFor":"Eating Bird Food"},{"@type":"Question","@id":"https:\/\/www.eatingbirdfood.com\/protein-cake\/#faq-question-1707450077265","position":1,"url":"https:\/\/www.eatingbirdfood.com\/protein-cake\/#faq-question-1707450077265","name":"Can I use a different frosting?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Absolutely! I love the chocolate ganache topping, but feel free to use your favorite frosting for this cake. For more of a real deal frosting try this <a href=\"https:\/\/www.eatingbirdfood.com\/vanilla-buttercream-frosting\/\">vanilla buttercream frosting<\/a> or <a href=\"https:\/\/www.eatingbirdfood.com\/strawberry-buttercream-frosting\/\">strawberry buttercream frosting<\/a>. This <a href=\"https:\/\/www.eatingbirdfood.com\/greek-yogurt-frosting\/\">peanut butter yogurt frosting<\/a> or <a href=\"https:\/\/www.eatingbirdfood.com\/healthy-chocolate-frosting\/\">healthy chocolate frosting<\/a> would also be delicious!","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https:\/\/www.eatingbirdfood.com\/protein-cake\/#faq-question-1772064762249","position":2,"url":"https:\/\/www.eatingbirdfood.com\/protein-cake\/#faq-question-1772064762249","name":"Why is my protein cake dry?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Protein cakes can turn out dry if too much protein powder or flour is used. Measuring the oat flour correctly and using Greek yogurt are key for keeping this cake moist and tender.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Recipe","name":"Protein Cake","author":{"@id":"https:\/\/www.eatingbirdfood.com\/#\/schema\/person\/51f35e8c1ea0072906e0cf99777ae3b2"},"description":"This delicious chocolate protein cake is guaranteed to be your new favorite dessert! It&#039;s rich, moist, naturally sweetened and packed with 15 grams of protein per slice.","datePublished":"2024-02-14T08:00:00+00:00","image":["https:\/\/www.eatingbirdfood.com\/wp-content\/uploads\/2024\/02\/protein-cake-hero.jpg","https:\/\/www.eatingbirdfood.com\/wp-content\/uploads\/2024\/02\/protein-cake-hero-500x500.jpg","https:\/\/www.eatingbirdfood.com\/wp-content\/uploads\/2024\/02\/protein-cake-hero-500x375.jpg","https:\/\/www.eatingbirdfood.com\/wp-content\/uploads\/2024\/02\/protein-cake-hero-480x270.jpg"],"recipeYield":["8"],"prepTime":"PT10M","cookTime":"PT35M","totalTime":"PT45M","recipeIngredient":["¾ cup oat flour","1 cup vegan chocolate protein powder (I used Sun Warrior)","¼ cup cocoa powder","1 teaspoon baking powder","½ teaspoon baking soda","½ teaspoon salt","¾ cup maple syrup","¾ cup unsweetened almond milk","½ cup full fat plain greek yogurt","¼ cup avocado oil or melted coconut oil","2 large eggs","1 teaspoon vanilla","½ cup dark chocolate chips","3 Tablespoons unsweetened almond milk"],"recipeInstructions":[{"@type":"HowToStep","text":"Preheat oven to 350F and spray a 8” round cake pan with cooking spray.","name":"Preheat","url":"https:\/\/www.eatingbirdfood.com\/protein-cake\/#wprm-recipe-143265-step-0-0"},{"@type":"HowToStep","text":"Add oat flour, protein powder, cocoa powder, baking powder, baking soda and salt to a medium mixing bowl and stir to combine.","name":"Stir dry ingredients","url":"https:\/\/www.eatingbirdfood.com\/protein-cake\/#wprm-recipe-143265-step-0-1"},{"@type":"HowToStep","text":"Add maple syrup, almond milk, yogurt, oil, eggs and vanilla to a large mixing bowl and whisk to combine.","name":"Whisk wet ingredients","url":"https:\/\/www.eatingbirdfood.com\/protein-cake\/#wprm-recipe-143265-step-0-2"},{"@type":"HowToStep","text":"Add dry ingredients to wet ingredients and stir to fully combine, until smooth.","name":"Combine","url":"https:\/\/www.eatingbirdfood.com\/protein-cake\/#wprm-recipe-143265-step-0-3"},{"@type":"HowToStep","text":"Pour batter into prepared cake pan. Bake for 35 minutes or until a toothpick inserted comes out clean.","name":"Bake","url":"https:\/\/www.eatingbirdfood.com\/protein-cake\/#wprm-recipe-143265-step-0-4"},{"@type":"HowToStep","text":"Remove from three oven and let cool completely before frosting.","name":"Cool","url":"https:\/\/www.eatingbirdfood.com\/protein-cake\/#wprm-recipe-143265-step-0-5"},{"@type":"HowToStep","text":"While cake is cooling, make the ganache frosting. Add chocolate chips to a microwave-safe bowl and microwave in 15-second increments until fully melted. This should take 45-60 seconds. Once melted add milk and stir to combine.","name":"Make frosting","url":"https:\/\/www.eatingbirdfood.com\/protein-cake\/#wprm-recipe-143265-step-0-6"},{"@type":"HowToStep","text":"Frost the top of the cake and serve!","name":"Serve","url":"https:\/\/www.eatingbirdfood.com\/protein-cake\/#wprm-recipe-143265-step-0-7"}],"aggregateRating":{"@type":"AggregateRating","ratingValue":"5","ratingCount":"26","reviewCount":"7"},"review":[{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Does this call for 1 cup or 1 scoop of protein powder? Also can i mix half chocolate half vanilla bean powder if i don’t have enough chocolate protein? Thank you!","author":{"@type":"Person","name":"Rsaaa"},"datePublished":"2026-05-07"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Thank you so much, love this recipe. \r\nAlso thank you for putting the measurements under each step, that's very thoughtful.","author":{"@type":"Person","name":"Labubu"},"datePublished":"2026-04-05"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Delicious. Made this for my husband’s birthday and we all loved it. Thanks again for another great recipe!","author":{"@type":"Person","name":"Brittany"},"datePublished":"2026-02-19"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Delicious! Made this for my husbands birthday, will definitely make again!","author":{"@type":"Person","name":"Keely"},"datePublished":"2026-02-05"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"I've made this recipe weekly and double the recipe for protein cake treats. Probably made 8 cakes at this point. I freeze one cake and then eat it to up my cals and protein. it's perfect!","author":{"@type":"Person","name":"Erin"},"datePublished":"2026-01-11"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Ive made this multiple times just cut some of the sweetness out of it and it's perfect for me","author":{"@type":"Person","name":"Erin"},"datePublished":"2025-12-03"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"This is one of the few healthy\/protein recipes that actually taste really good in both flavour and texture!\r\nI've tried your recipe as is the first time, but the second time I left out the maple syrup (since my protein powder is sweetened already) and replaced the oil by 1\/4 cup mashed banana. The result was pretty much the same!\r\nI did also use coffee flavoured vegan protein powder which worked great with the chocolate.","author":{"@type":"Person","name":"Eva"},"datePublished":"2025-03-19"}],"recipeCategory":["Dessert"],"recipeCuisine":["American"],"keywords":"Protein Cake","nutrition":{"@type":"NutritionInformation","servingSize":"1  slice","calories":"324 kcal","carbohydrateContent":"37 g","proteinContent":"15 g","fatContent":"15 g","saturatedFatContent":"4 g","cholesterolContent":"48 mg","sodiumContent":"532 mg","fiberContent":"7 g","sugarContent":"19 g","unsaturatedFatContent":"7 g"},"@id":"https:\/\/www.eatingbirdfood.com\/protein-cake\/#recipe","isPartOf":{"@id":"https:\/\/www.eatingbirdfood.com\/protein-cake\/#article"},"mainEntityOfPage":"https:\/\/www.eatingbirdfood.com\/protein-cake\/"}]}</script>

			body:not(.logged-in) .instagram-row {
    display: none !important;
}

/* Dec 29 2025 paywall tweaks */

.preview-content-row .preview-content-module .fl-col-small .fl-rich-text  > ul {
	display: none !important;
}




.preview-content-row .preview-content-module .fl-col-small .fl-rich-text > ul:first-of-type {
	display: block !important;

}

.preview-content-row .preview-content-module .fl-row:not(.recipe-hero) .fl-col-small .fl-col-content > .fl-module-rich-text ~ .fl-module-rich-text  {
	display: none !important;

}



/* Jul 28 2025 Homepage Update */
.header-search-form {
	width: 100%;
}

.header-search-form .pp-search-form--style-minimal .pp-search-form__icon {
	color: #EE3823;
}

.header-account-icon .fl-icon-wrap {
	display: block;
}

.bullet-point-line-height ul li {
	margin-bottom: 0px;
}


/*---preview fade out---*/
.preview-content-row {
	max-height: 900px;

}

	.preview-content-module  .recipe-hero h1 span  {
    color: #F8ECD8!important;
}

.preview-content-module .jupiter-button {
	display: none;
}



@media only screen and (max-width: 1140px) {
.preview-content-row {
	max-height: 1250px;
}
}

@media only screen and (max-width: 760px) {
	
	.ayoh-popup-overlay .uabb-modal-close {
    top: 20px !important;
    right: 0px !important;
}

.preview-content-row {
	max-height: 1400px;
}
	
	.preview-content-module .fl-row-content-wrap {
		padding-top: 0px !important;
	}
	
	.preview-content-module .fl-rich-text ul {
		margin-left: 20px !important;
	}	
	
	.preview-content-module  .recipe-hero .fl-row-content-wrap {
	padding-bottom: 200px !important;
}


}




/*---2024 adjustments---*/


@media(max-width: 760px) {
    .recipe-hero .fl-row-content-wrap .fl-row-content .fl-col-group .fl-col .fl-col-content {
        background-image: none!important;
    }
}

.uabb-blog-posts .uabb-post-wrapper {
	margin-left: 20px;
	margin-right: 20px;
}

h2.fl-heading {
	letter-spacing: 2px;
}

/*---Redesign - Cat---*/
body {
	background-color: #F8ECD8!important;
	font-family: favorit !important;
	font-size: 24px !important;
	color: #024DA1 !important;
}

site-container {
	background-color: #F8ECD8!important;
	
}

.post-slide ul.uabb-masonary-filters > li {
	border-bottom: 3px solid #EE3823 !important;
}

.category-swipe ul li.current-cat a {
    color: #f0ef95;
    text-decoration: underline!important;
    text-underline-offset: 7px;
}

.post-slide.red ul.uabb-masonary-filters > li {
    border-bottom: 3px solid #EE3823 !important;
}

.uabb-masonary-cat-26 .uabb-post-thumbnail::after,
.uabb-masonary-cat-34 .uabb-post-thumbnail::after, 
.secondary_category-newest-recipe .single-post-featured::after {
    content: "";
    background: url(/wp-content/uploads/popular-badge-2024.png) center center no-repeat;
	    background-size: contain;
	left: 25px;
}

.post-slide .uabb-post-thumbnail img,
.post-slide.bone .uabb-post-thumbnail img,
.category-archive-grid .pp-content-grid-post-image img,
.all-recipes-grid .pp-content-grid-post-image img{
	border: none;
	border-radius: 50px;
}

.post-slide .uabb-post-thumbnail img:hover,
.post-slide.bone .uabb-post-thumbnail img:hover,
.post-slide .uabb-post-wrapper:hover .uabb-post-thumbnail img {
	border: none!important;
}

.category-swipe ul li a {
	color: #F8ECD8;
	font-weight: 400;
}

/*Single Post Instructions*/
.instructions h3 {
	text-transform: uppercase;
	color: #024DA1 !important;
}

.single-post-featured img {
	border: none!important; 
	border-radius: 50px;
}



.recipe-hero .fl-row-content {
    max-width: 1440px!important;
}

.recipe-hero .fl-row-content-wrap {
	padding-top: 60px;
}

.post .recipe-hero h1 span,
.single-wf .recipe-hero h1 span {
	color: #F8ECD8!important;
}

.fl-node-xiavodg7hsy2 > .fl-col-content {
	background-image: none;
}

.recipe-hero .fl-module-rich-text .fl-rich-text p {
	color: #F8ECD8!important;
}

.recipe-hero h4 span {
	color: #F0EF95!important;
	font-size: 18px!important;
	font-weight: 600!important;
	letter-spacing: .3px;
	text-transform: uppercase;
}

.jupiter-button .fl-node-content:before {
	content: url('/wp-content/uploads/recipe-kick-110.png');
	margin-right: 15px;
}

.jupiter-button .pp-button-wrap:before {
	content: 'Get the ingredients delivered right to your door!';
	display: flex;
	font-size: 16px;
	font-family: Favorit;
	color: #F8ECD8;
	justify-content: center;
	margin-bottom: 10px;
}

@media screen and (max-width: 509px) {
	.jupiter-button .fl-module-content {
			display: flex!important;
			flex-direction: column;
			align-items: flex-start;
	}
}

.jupiter-button .fl-module-content {
	display: flex!important;
}

.single-post .instructions ul li:before,
.single-wf .instructions ul li:before {
    background: none!important;
}
.single-post .instructions ul li,
.single-wf .instructions ul li{
    list-style-type: disc!important;
}

.ccc-favorite-post-toggle > a::before,
.ccc-favorite-post-toggle-button {
	font-family: Favorit!important;
}

.related-grid img {
	border: none!important;
	border-radius: 50px;
}

.related-grid h3 {
	font-weight: 700!important;	
}

.single-post .fl-row .fl-row-content-wrap .fl-row-content .fl-col-group .fl-col .fl-module-heading h4 .fl-heading-text,
.single-post .fl-row .fl-row-content-wrap .fl-row-content .fl-col-group .fl-col .fl-module-heading h4 .fl-heading-text a,
.single-wf .fl-row .fl-row-content-wrap .fl-row-content .fl-col-group .fl-col .fl-module-heading h4 .fl-heading-text,
.single-wf .fl-row .fl-row-content-wrap .fl-row-content .fl-col-group .fl-col .fl-module-heading h4 .fl-heading-text a {
	color: #F4856C;
	font-family: Favorit;
	font-size: 22px;
	font-style: normal;
}

.single-post a.ccc-favorite-post-toggle-button,
.single-wf a.ccc-favorite-post-toggle-button {
	font-family: 'favorit' !important;
    background-color: #EE3823;
    border: none;
    color: #f8ecd8;
    cursor: pointer;
    padding: 15px 20px 15px !important;
    text-align: center;
    text-transform: uppercase;
    border-radius: 40px;
    width: 100%;
    max-width: 400px;
    margin-top: -5px;
    float: left;
}

.single-post .fl-module-content input[type="button"],
.single-wf .fl-module-content input[type="button"]{
		font-family: 'favorit' !important;
    background-color: #EE3823;
    border: none;
    color: #f8ecd8;
    cursor: pointer;
    cursor: pointer;
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 1px;
    padding: 20px 24px;
    text-align: center;
    text-transform: uppercase;
}

.single-post .ccc-favorite-post-toggle a.ccc-favorite-post-toggle-button:hover,
.single-post .fl-module-content input[type="button"]:hover {
	    background-color: #024DA1;
}
/* END Single Post Instructions*/

/*Comments*/
.entry-comments {
	background: #F8ECD8;
}


.entry-comments h3:before {
    content: "";
    display: block;
    /* flex-direction: column; */
    margin-bottom: -40px;
    z-index: 999;
    width: 344px;
    height: 280px;
    background: url(https://mollybaz.com/wp-content/themes/twj-child-theme-2020/images/comments-pans.png) center center no-repeat;
    margin: 0 auto -40px;
    background-size: contain;
}



h3.comment-reply-title:before {
	display: none;
}

.entry-comments h3 {
    text-align: center;
    text-transform: uppercase;
		color: var(--MIM-Red, #EE3823);
    font-family: "wt-zaft2", Verdana, Arial, sans-serif;
	font-size: 80px;
	padding-top: 80px!important;
	padding-bottom: 0!important;
	content: none;
	z-index: -999;
}

h3.comment-reply-title {
	font-family: 'favorit' !important;
	font-size: 32px;
	text-align: left;
	text-transform: none;
	font-weight: 700;
}

.comment-respond {
	background-color: transparent;
}

p.comment-form-comment textarea {
	font-family: 'favorit' !important;
	background-color: white;
    border: none;
    color: #024DA1;
	border-radius: 50px;
}

.entry-comments input[type="submit"] {
	background-color: #EE3823;
	font-family: 'favorit' !important;
	color: #F8ECD8;
	padding: 20px 24px 18px;
	font-weight: 500;
}

.entry-comments li.comment {
	border: 3px solid #ffffff;
	border-radius: 50px;
}

.entry-comments .comment-header,
.entry-comments .comment-author-name {
	font-family: 'favorit' !important;
}

.entry-comments .comment-list ul.children .comment {
	border: none;
	padding-top: 20px!important;
	padding-bottom: 0px!important;
}

.entry-comments .comment-list ul.children .comment .comment-author {
	border-top: 3px solid #EE3823;
	border-radius: 0;
	padding-top: 20px;
}

.entry-comments .comment-reply a,
.entry-comments .comment-edit-link {
	color: #F4856C!important;
		font-family: 'favorit' !important;
	font-size: 21px!important;
	font-weight: 100!important;
}

.entry-comments .comment-list li {
    padding: 60px 60px 40px!important;
}

/*END Comments*/
@media screen and (max-width: 760px) {
	.suggestion-box-layout .uabb-image .uabb-photo-img {
	width: 25%;
	}
}

.suggestion-form #nf-field-7 {
	background-color: #F0EF95!important;
	border-radius: 50px;
	font-weight: bold;
	border: none!important;
}

.suggestion-form #nf-field-7:hover {
	background-color: #024DA1!important;
	color: #F0EF95!important;
	border: none!important;
}

.bolded h1,
.bolded h2,
.bolded h3,
.bolded h4,
.bolded h5,
.bolded h6,
.bolded p,
.bolded span,
.bolded ul,
.bolded li {
	font-weight: 800;
}

@media screen and (max-width: 768px) {
	.stacked-mobile .left-title-image {
		display: flex;
		flex-direction: column;
	}
}

/* timeslots form */
.timeslots .nf-field input[type="text"],
.timeslots .nf-field input[type="email"],
.timeslots .nf-field input[type="tel"],
.timeslots .nf-field select {
	border: 1px solid #0088DB !important;
	background: #fff !important;
	color: #0088DB !important;
}

.timeslots .pp-ninja-form-content .ninja-forms-form-wrap input:not([type="radio"]):not([type="checkbox"]):not([type="submit"]):not([type="button"]):not([type="image"]):not([type="file"]), 
.timeslots .pp-ninja-form-content .ninja-forms-form-wrap select {
	height: 50px;
}

.timeslots input::placeholder {
	color: #0088DB !important;
}

.timeslots .nf-field-label span {
	font-size: 19px;
}

.timeslots .nf-form-fields-required {
	display: none !important;
}

.timeslots input[type="submit"] {
	font-family: 'favorit' !important;
    background-color: #0088DB !important;
    border: none !important;
    color: #f8ecd8 !important;
    cursor: pointer;
    padding: 15px 20px 15px !important;
    text-align: center;
    text-transform: uppercase;
    border-radius: 40px !important;
    width: 100% !important;
    max-width: 200px;
    float: left;
}

.timeslots input[type="submit"]:hover {
	background-color: #024DA1 !important;
}
	 
.timeslots .ninja-forms-req-symbol, .timeslots p, .timeslots .nf-field-label .nf-label-span, .nf-field-label label {
	color: #0088DB !important;
}

.timeslots .nf-field:has(.nf-field-description) .nf-field-label {
	margin-bottom: 0 !important;
}

.timeslots .nf-field-description {
	margin-bottom: 10px !important;
}

/* ----- CBX Faves ----- */
/* Bookmark grid */
.cbxwpbookmark_share,
.cbxbookmark_card_cat,
.cbxlbjs-item[data-privacy="1"]:after,
.cbxlbjs-item-widget[data-privacy="1"]:after {
	display: none !important;
}

.cbxbookmark_card {
	box-shadow: none !important;
}

.cbxbookmark_card a.cbxbookmark_card_teaser {
	height: auto !important;
	aspect-ratio: 1 !important;
	border-radius: 0 !important;
	border: 12px solid #EE3823 !important;
}

.cbxbookmark_card a.cbxbookmark_card_teaser:hover {
	border: 12px solid #EE3823 !important;
}
.cbxbookmark_card_title {
	text-align: center !important;
}

.cbxbookmark_card_title a {
	font-family: 'futura-pt' !important;
	font-size: 30px !important;
	font-weight: 500 !important;
	color: #024DA1 !important;
	line-height: 1.2 !important;
	letter-spacing: -0.5px !important;
}

.cbxbookmark_card_title a:hover {
	text-decoration: underline !important;
}

.cbxbookmark-category-list {
	margin: 0 !important;
	display: flex;
	gap: 24px;
	justify-content: center;
}

@media only screen and (max-width: 550px) {
	.cbxbookmark-category-list {
		flex-direction: column;
		align-items: center;
		gap: 0;
	}
}

.cbxbookmark-category-list li {
	list-style-type: none !important;
	margin-right: 15px !important;
    margin-left: 15px !important;
    border-bottom: 3px solid transparent !important;
	padding: 8px;
	font-family: futura-pt, Verdana, Arial, sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 1.3;
    letter-spacing: 1px;
    text-transform: uppercase;
	margin: 0 !important;
}

.cbxbookmark-category-list .cbxbookmark-category-list-item-active,
.cbxbookmark-category-list li:hover {
	border-bottom: 3px solid #eb4a1b !important;
	font-weight: 400 !important;
	color: #eb4a1b !important;
}

.cbxbookmark-category-list li:hover a {
	color: #eb4a1b !important;
}

.cbxwpbookmark-title i {
	font-family: futura-pt, Verdana, Arial, sans-serif;
    font-weight: 400;
    font-size: 16px !important;
    line-height: 1.3;
    letter-spacing: 1px;
	font-style: normal !important;
	margin-left: 10px;
}

/* Bookmark button */

.recipe-action-buttons {
    text-align: center;
    color: #024DA1 !important;
    font-size: 24px !important;
}

.recipe-action-buttons a.print-button,
.recipe-action-buttons a.cbxwpbkmarktrig {
    text-decoration: none !important;
    color: #024DA1 !important;
    font-size: 24px !important;
    margin: 0 !important;
}


.recipe-action-buttons a.print-button:hover,
.recipe-action-buttons a.cbxwpbkmarktrig:hover {
	color: #EE3823 !important;
}
.recipe-action-buttons a.print-button,
.recipe-action-buttons a.cbxwpbkmarktrig {
    display: flex;
    align-items: center;
    gap: 8px;
}

.recipe-action-buttons .cbxwpbkmarktrig-icon {
    width: 24px !important;
    height: 24px !important;
    background-size: 24px !important;
}

.recipe-action-buttons .cbxwpbkmarkwrap {
    font-size: 24px !important;
    line-height: 1 !important;
    color: #024DA1 !important;
}

.recipe-action-buttons .cbxwpbkmarktrig-count {
    display: none !important;
}

.recipe-action-buttons a.cbxwpbkmarktrig span {
    margin: 0 !important;
    padding: 0 !important;
}
.cbxwpbkmarktrig .cbxwpbkmarktrig-label {

}

.cbxwpbkmarktrig .cbxwpbkmarktrig-icon {
	background-image: url(https://mollybaz.com/wp-content/uploads/bookmark-outline.png);
	background-size: auto 24px !important;
}

.cbxwpbkmarktrig.cbxwpbkmarktrig-marked .cbxwpbkmarktrig-icon {
	background-image: url(https://mollybaz.com/wp-content/uploads/bookmark-filled.png) !important;
}

.cbxwpbkmarktrig:hover .cbxwpbkmarktrig-icon {
	background-image: url(https://mollybaz.com/wp-content/uploads/bookmark-outline-red.png);
	background-size: auto 24px !important;
}

.cbxwpbkmarktrig.cbxwpbkmarktrig-marked:hover .cbxwpbkmarktrig-icon {
	background-image: url(https://mollybaz.com/wp-content/uploads/bookmark-filled-red.png) !important;
}

.cbxlbjs-searchbar-wrapper {
	display: none !important;
}

.cbxwpbkmark_cat_book_list {
	padding: 0 20px 20px;
}

.addto-head {
	padding: 20px !important;
	gap: 12px !important;
	align-items: flex-start !important;
}

.addto-head .cbxwpbkmarktrig_label {
	font-size: 24px !important;
}

.cbxlbjs .cbxlbjs-list {
	height: auto !important;
}

.cbxwpbkmarklistwrap .addto-head .cbxwpbkmarktrig_close {
	border: 0 !important;
}

.cbxlbjs .cbxlbjs-list .cbxlbjs-item .cbxlbjs-item-name {
	font-size: 20px;
}

.cbxwpbookmark-title-mycat {
	display: none;
}


/* Gift Two for One Popup */
.pp-modal-content .gift-red-bg .fl-row-content-wrap {
	background: none !important;
}

.fl-node-atm36xd79v2c .pp-modal.layout-standard, #modal-atm36xd79v2c .pp-modal.layout-standard {
	max-width: 100% !important;

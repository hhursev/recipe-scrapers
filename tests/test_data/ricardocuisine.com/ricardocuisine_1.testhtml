ot;substitutes&quot;:[],&quot;isInFlyer&quot;:false},{&quot;id&quot;:1217212,&quot;title&quot;:&quot;garlic cloves&quot;,&quot;description&quot;:&quot;2 cloves garlic&quot;,&quot;uri&quot;:&quot;&quot;,&quot;substitutes&quot;:[],&quot;isInFlyer&quot;:true},{&quot;id&quot;:1217213,&quot;title&quot;:&quot;Tabasco sauce&quot;,&quot;description&quot;:&quot;Hot pepper sauce, to taste&quot;,&quot;uri&quot;:&quot;&quot;,&quot;substitutes&quot;:[],&quot;isInFlyer&quot;:false},{&quot;id&quot;:1217214,&quot;title&quot;:&quot;pork shoulder roast, with or without the bone&quot;,&quot;description&quot;:&quot;1 pork shoulder roast, about 4 lb (1.8 kg) (with or without bone, untied)&quot;,&quot;uri&quot;:&quot;&quot;,&quot;substitutes&quot;:[],&quot;isInFlyer&quot;:false},{&quot;id&quot;:1217215,&quot;title&quot;:&quot;salt and pepper&quot;,&quot;description&quot;:&quot;Salt and pepper&quot;,&quot;uri&quot;:&quot;&quot;,&quot;substitutes&quot;:[],&quot;isInFlyer&quot;:false}],&quot;description&quot;:&quot;&quot;}],&quot;preparationGroups&quot;:[{&quot;id&quot;:153972,&quot;groupOrder&quot;:1,&quot;preparations&quot;:[{&quot;id&quot;:592685,&quot;description&quot;:&quot;In a blender, pur\u00e9e all ingredients except the pork. Season with salt and pepper.&quot;,&quot;preparationOrder&quot;:1},{&quot;id&quot;:592686,&quot;description&quot;:&quot;Season the pork with salt and pepper. Place it in the slow cooker with the sauce. Cover and cook on low heat for about 8 hours. Alternatively, cook on high for 6 hours.&quot;,&quot;preparationOrder&quot;:2},{&quot;id&quot;:592687,&quot;description&quot;:&quot;Place the meat on a plate and tent with aluminum foil. Let stand 15 minutes, then shred using a fork.&quot;,&quot;preparationOrder&quot;:3},{&quot;id&quot;:592688,&quot;description&quot;:&quot;Meanwhile, in a saucepan, bring the sauce to a boil and reduce until syrupy, about half the original volume. Add the meat and coat well with the sauce.&quot;,&quot;preparationOrder&quot;:4}],&quot;description&quot;:&quot;&quot;}]}"></div>       <h2 class="c-recipe-instructions__title">Preparation</h2>
      <ul>
                                        <li>
                            <ul>
                                                        <li class="c-recipe-instructions__item">
                      <label for="preparation-592685" class="c-checkbox" id="checkbox-preparation-592685">
                        <input
                          name="preparation-592685"
                          type="checkbox"
                          id="preparation-592685"
                          value="592685"
                          class="react-bus-publisher"
                          data-bus-event="Recipe.CheckPreparationStep"
                        />
                        <div class="c-checkbox__content t-body">
                          <span class="i-icon i-check c-icon"></span>
                          <div>In a blender, purée all ingredients except the pork. Season with salt and pepper.<div>
                        </div>
                      </label>
                    </li>
                                                                                              <li class="c-recipe-instructions__item">
                      <label for="preparation-592686" class="c-checkbox" id="checkbox-preparation-592686">
                        <input
                          name="preparation-592686"
                          type="checkbox"
                          id="preparation-592686"
                          value="592686"
                          class="react-bus-publisher"
                          data-bus-event="Recipe.CheckPreparationStep"
                        />
                        <div class="c-checkbox__content t-body">
                          <span class="i-icon i-check c-icon"></span>
                          <div>Season the pork with salt and pepper. Place it in the slow cooker with the sauce. Cover and cook on low heat for about 8 hours. Alternatively, cook on high for 6 hours.<div>
                        </div>
                      </label>
                    </li>
                                                                                              <li class="c-recipe-instructions__item">
                      <label for="preparation-592687" class="c-checkbox" id="checkbox-preparation-592687">
                        <input
                          name="preparation-592687"
                          type="checkbox"
                          id="preparation-592687"
                          value="592687"
                          class="react-bus-publisher"
                          data-bus-event="Recipe.CheckPreparationStep"
                        />
                        <div class="c-checkbox__content t-body">
                          <span class="i-icon i-check c-icon"></span>
                          <div>Place the meat on a plate and tent with aluminum foil. Let stand 15 minutes, then shred using a fork.<div>
                        </div>
                      </label>
                    </li>
                                                                                              <li class="c-recipe-instructions__item">
                      <label for="preparation-592688" class="c-checkbox" id="checkbox-preparation-592688">
                        <input
                          name="preparation-592688"
                          type="checkbox"
                          id="preparation-592688"
                          value="592688"
                          class="react-bus-publisher"
                          data-bus-event="Recipe.CheckPreparationStep"
                        />
                        <div class="c-checkbox__content t-body">
                          <span class="i-icon i-check c-icon"></span>
                          <div>Meanwhile, in a saucepan, bring the sauce to a boil and reduce until syrupy, about half the original volume. Add the meat and coat well with the sauce.<div>
                        </div>
                      </label>
                    </li>
                                                                                    </ul>
            </li>
                        </ul>

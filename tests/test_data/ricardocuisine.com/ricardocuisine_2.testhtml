                                    <script type='application/ld+json'>{
    "name": "Grilled Surf and Turf Platter",
    "author": {
        "@type": "Person",
        "name": "Ricardocuisine"
    },
    "image": [
        "https://images.ricardocuisine.com/services/recipes/1x1/7308.jpg",

rtered&quot;,&quot;uri&quot;:&quot;&quot;,&quot;substitutes&quot;:[],&quot;isInFlyer&quot;:true},{&quot;id&quot;:1262455,&quot;title&quot;:&quot;zucchini&quot;,&quot;description&quot;:&quot;18\tsmall pattypan squash or 4 zucchini, cut into 3\/4 slices inch (2 cm) thick&quot;,&quot;uri&quot;:&quot;&quot;,&quot;substitutes&quot;:[],&quot;isInFlyer&quot;:false},{&quot;id&quot;:1262456,&quot;title&quot;:&quot;baby potatoes&quot;,&quot;description&quot;:&quot;12\tbaby potatoes, blanched&quot;,&quot;uri&quot;:&quot;&quot;,&quot;substitutes&quot;:[],&quot;isInFlyer&quot;:true}],&quot;description&quot;:&quot;Surf and Turf&quot;}],&quot;preparationGroups&quot;:[{&quot;id&quot;:161740,&quot;groupOrder&quot;:1,&quot;preparations&quot;:[{&quot;id&quot;:624258,&quot;description&quot;:&quot;In a small pot, bring all the ingredients to a boil. Simmer for 15\u00a0minutes or until the garlic is tender. In a blender, pur\u00e9e until smooth, then strain. Season with salt and pepper. Set aside.&quot;,&quot;preparationOrder&quot;:1}],&quot;description&quot;:&quot;Garlic Cream Sauce&quot;},{&quot;id&quot;:161741,&quot;groupOrder&quot;:2,&quot;preparations&quot;:[{&quot;id&quot;:624259,&quot;description&quot;:&quot;In a bowl, combine all the ingredients. Season with salt and pepper and set aside.&quot;,&quot;preparationOrder&quot;:1}],&quot;description&quot;:&quot;Herb Oil&quot;},{&quot;id&quot;:161742,&quot;groupOrder&quot;:3,&quot;preparations&quot;:[{&quot;id&quot;:624260,&quot;description&quot;:&quot;Preheat the grill, setting the burners to high. Oil the grate.&quot;,&quot;preparationOrder&quot;:1},{&quot;id&quot;:624261,&quot;description&quot;:&quot;On a large baking sheet, lightly oil all the ingredients. Season with salt and pepper, with the exception of the sausages. &quot;,&quot;preparationOrder&quot;:2},{&quot;id&quot;:624262,&quot;description&quot;:&quot;Grill the sausages for 5 minutes on each side or until cooked through. Cut into pieces and keep warm. Grill the quail for 3 minutes on each side or until medium doneness. Cut into 4 pieces and keep warm. Grill the squid and crayfish for 2 minutes on each side or until cooked through. Slice the squid into rings and keep warm.&quot;,&quot;preparationOrder&quot;:3},{&quot;id&quot;:624263,&quot;description&quot;:&quot;Grill the vegetables until tender and golden brown.&quot;,&quot;preparationOrder&quot;:4},{&quot;id&quot;:624264,&quot;description&quot;:&quot;On a large serving platter, arrange the sausage pieces, quail, squid, crayfish and vegetables. Drizzle with half of the herb oil. Serve with the garlic cream and the remaining herb oil on the side. &quot;,&quot;preparationOrder&quot;:5}],&quot;description&quot;:&quot;Surf and Turf&quot;}]}"></div>       <h2 class="c-recipe-instructions__title">Preparation</h2>
      <ul>
                                        <li>
                            <h3 class="c-recipe-instructions__subtitle t-body t-typo--bold">Garlic Cream Sauce</h3>
                            <ul>
                                                        <li class="c-recipe-instructions__item">
                      <label for="preparation-624258" class="c-checkbox" id="checkbox-preparation-624258">
                        <input
                          name="preparation-624258"
                          type="checkbox"
                          id="preparation-624258"
                          value="624258"
                          class="react-bus-publisher"
                          data-bus-event="Recipe.CheckPreparationStep"
                        />
                        <div class="c-checkbox__content t-body">
                          <span class="i-icon i-check c-icon"></span>
                          <div>In a small pot, bring all the ingredients to a boil. Simmer for 15 minutes or until the garlic is tender. In a blender, purée until smooth, then strain. Season with salt and pepper. Set aside.<div>
                        </div>
                      </label>
                    </li>
                                                                                    </ul>
            </li>
                                          <li>
                            <h3 class="c-recipe-instructions__subtitle t-body t-typo--bold">Herb Oil</h3>
                            <ul>
                                                        <li class="c-recipe-instructions__item">
                      <label for="preparation-624259" class="c-checkbox" id="checkbox-preparation-624259">
                        <input
                          name="preparation-624259"
                          type="checkbox"
                          id="preparation-624259"
                          value="624259"
                          class="react-bus-publisher"
                          data-bus-event="Recipe.CheckPreparationStep"
                        />
                        <div class="c-checkbox__content t-body">
                          <span class="i-icon i-check c-icon"></span>
                          <div>In a bowl, combine all the ingredients. Season with salt and pepper and set aside.<div>
                        </div>
                      </label>
                    </li>
                                                                                    </ul>
            </li>
                                          <li>
                            <h3 class="c-recipe-instructions__subtitle t-body t-typo--bold">Surf and Turf</h3>
                            <ul>
                                                        <li class="c-recipe-instructions__item">
                      <label for="preparation-624260" class="c-checkbox" id="checkbox-preparation-624260">
                        <input
                          name="preparation-624260"
                          type="checkbox"
                          id="preparation-624260"
                          value="624260"
                          class="react-bus-publisher"
                          data-bus-event="Recipe.CheckPreparationStep"
                        />
                        <div class="c-checkbox__content t-body">
                          <span class="i-icon i-check c-icon"></span>
                          <div>Preheat the grill, setting the burners to high. Oil the grate.<div>
                        </div>
                      </label>
                    </li>
                                                                                              <li class="c-recipe-instructions__item">
                      <label for="preparation-624261" class="c-checkbox" id="checkbox-preparation-624261">
                        <input
                          name="preparation-624261"
                          type="checkbox"
                          id="preparation-624261"
                          value="624261"
                          class="react-bus-publisher"
                          data-bus-event="Recipe.CheckPreparationStep"
                        />
                        <div class="c-checkbox__content t-body">
                          <span class="i-icon i-check c-icon"></span>
                          <div>On a large baking sheet, lightly oil all the ingredients. Season with salt and pepper, with the exception of the sausages. <div>
                        </div>
                      </label>
                    </li>
                                                                                              <li class="c-recipe-instructions__item">
                      <label for="preparation-624262" class="c-checkbox" id="checkbox-preparation-624262">
                        <input
                          name="preparation-624262"
                          type="checkbox"
                          id="preparation-624262"
                          value="624262"
                          class="react-bus-publisher"
                          data-bus-event="Recipe.CheckPreparationStep"
                        />
                        <div class="c-checkbox__content t-body">
                          <span class="i-icon i-check c-icon"></span>
                          <div>Grill the sausages for 5 minutes on each side or until cooked through. Cut into pieces and keep warm. Grill the quail for 3 minutes on each side or until medium doneness. Cut into 4 pieces and keep warm. Grill the squid and crayfish for 2 minutes on each side or until cooked through. Slice the squid into rings and keep warm.<div>
                        </div>
                      </label>
                    </li>
                                                                                              <li class="c-recipe-instructions__item">
                      <label for="preparation-624263" class="c-checkbox" id="checkbox-preparation-624263">
                        <input
                          name="preparation-624263"
                          type="checkbox"
                          id="preparation-624263"
                          value="624263"
                          class="react-bus-publisher"
                          data-bus-event="Recipe.CheckPreparationStep"
                        />
                        <div class="c-checkbox__content t-body">
                          <span class="i-icon i-check c-icon"></span>
                          <div>Grill the vegetables until tender and golden brown.<div>
                        </div>
                      </label>
                    </li>
                                                                                              <li class="c-recipe-instructions__item">
                      <label for="preparation-624264" class="c-checkbox" id="checkbox-preparation-624264">
                        <input
                          name="preparation-624264"
                          type="checkbox"
                          id="preparation-624264"
                          value="624264"
                          class="react-bus-publisher"
                          data-bus-event="Recipe.CheckPreparationStep"
                        />
                        <div class="c-checkbox__content t-body">
                          <span class="i-icon i-check c-icon"></span>
                          <div>On a large serving platter, arrange the sausage pieces, quail, squid, crayfish and vegetables. Drizzle with half of the herb oil. Serve with the garlic cream and the remaining herb oil on the side. <div>
                        </div>
                      </label>
                    </li>
                                                                                    </ul>
            </li>
                        </ul>
    </section>
  </div>
</div>
        
<section class="c-recipe-notes">

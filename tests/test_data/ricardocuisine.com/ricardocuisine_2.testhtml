        "https://images.ricardocuisine.com/services/recipes/16x9/7308.jpg"
    ],
    "datePublished": "2018-05-08T10:27:00-04:00",
    "prepTime": "PT30M",
    "cookTime": "PT30M",
    "recipeIngredient": [
        "1 cup\t(250 ml) chicken broth",
        "1/2 cup\t(125 ml) 35% heavy cream",
        "1/4 cup\t(60 ml) water",
        "18\tgarlic cloves, halved ",
        "1/2 cup\t(125 ml) olive oil",
        "1/4 cup\t(10 g) chopped flat-leaf parsley ",
        "1\tlemon, zest finely grated",
        "2 tbsp\t(30 ml) lemon juice",
        "2 tbsp\tchopped chives",
        "2 tbsp\tchopped fennel fronds",
        "1/2 tsp\tred pepper flakes",
        "4\tItalian sausages, mild or spicy",
        "4\twhole quail, partially deboned and butterflied  (see note)",
        "2\tsquid, cleaned, the head and tentacles separated",
        "3/4 lb\t(340 g) crayfish",
        "2\tfennel bulbs, quartered",
        "18\tsmall pattypan squash or 4 zucchini, cut into 3/4 slices inch (2 cm) thick",
        "12\tbaby potatoes, blanched"
    ],
    "recipeInstructions": [
        {
            "@type": "HowToSection",
            "name": "Garlic Cream Sauce",
            "itemListElement": [
                {
                    "@type": "HowToStep",
                    "text": "In a small pot, bring all the ingredients to a boil. Simmer for 15\u00a0minutes or until the garlic is tender. In a blender, pur\u00e9e until smooth, then strain. Season with salt and pepper. Set aside."
                }
            ]
        },
        {
            "@type": "HowToSection",
            "name": "Herb Oil",
            "itemListElement": [
                {
                    "@type": "HowToStep",
                    "text": "In a bowl, combine all the ingredients. Season with salt and pepper and set aside."
                }
            ]
        },
        {
            "@type": "HowToSection",
            "name": "Surf and Turf",
            "itemListElement": [
                {
                    "@type": "HowToStep",
                    "text": "Preheat the grill, setting the burners to high. Oil the grate."
                },
                {
                    "@type": "HowToStep",
                    "text": "On a large baking sheet, lightly oil all the ingredients. Season with salt and pepper, with the exception of the sausages. "
                },
                {
                    "@type": "HowToStep",
                    "text": "Grill the sausages for 5 minutes on each side or until cooked through. Cut into pieces and keep warm. Grill the quail for 3 minutes on each side or until medium doneness. Cut into 4 pieces and keep warm. Grill the squid and crayfish for 2 minutes on each side or until cooked through. Slice the squid into rings and keep warm."
                },
                {
                    "@type": "HowToStep",
                    "text": "Grill the vegetables until tender and golden brown."
                },
                {
                    "@type": "HowToStep",
                    "text": "On a large serving platter, arrange the sausage pieces, quail, squid, crayfish and vegetables. Drizzle with half of the herb oil. Serve with the garlic cream and the remaining herb oil on the side. "
                }
            ]
        }
    ],
    "recipeYield": "6 serving(s)",
    "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": 4,
        "ratingCount": 4,
        "bestRating": "5",
        "worstRating": "1"
    },
    "description": "Grilled Surf and Turf Platter",
    "recipeCategory": "Main Dishes",

	<meta name="description" content="Make-ahead freezer breakfast sandwiches made with homemade patties, baked eggs &amp; spinach—easy, protein-packed, and perfect for busy mornings!" />
	<link rel="canonical" href="https://www.halfbakedharvest.com/freezer-breakfast-sandwiches/" />
	<meta property="og:locale" content="en_US" />
	<meta property="og:type" content="article" />
	<meta property="og:title" content="Chicken &amp; Egg Freezer Breakfast Sandwiches (Make-Ahead!)" />
	<meta property="og:description" content="These chicken &amp; egg freezer breakfast sandwiches are easy, protein-packed, and perfect for busy mornings. Make a batch and stash them in the freezer for quick, grab-and-go breakfasts all week!" />

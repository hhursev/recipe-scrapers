<img data-lazyloaded="1" src="data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSIxMDI0IiBoZWlnaHQ9IjEwMjQiIHZpZXdCb3g9IjAgMCAxMDI0IDEwMjQiPjxyZWN0IHdpZHRoPSIxMDAlIiBoZWlnaHQ9IjEwMCUiIHN0eWxlPSJmaWxsOiNjZmQ0ZGI7ZmlsbC1vcGFjaXR5OiAwLjE7Ii8+PC9zdmc+" decoding="async" width="1024" height="1024" alt="Easy Cute Ice Cream Aesthetic Designs" data-media-id="12090" class="gb-media-1b7e96f0" data-src="https://www.cookfastrecipes.com/wp-content/uploads/2026/01/easy-cute-ice-cream-aesthetic-designs-1-1.webp" data-srcset="https://www.cookfastrecipes.com/wp-content/uploads/2026/01/easy-cute-ice-cream-aesthetic-designs-1-1.webp 1024w, https://www.cookfastrecipes.com/wp-content/uploads/2026/01/easy-cute-ice-cream-aesthetic-designs-1-1-300x300.webp 300w, https://www.cookfastrecipes.com/wp-content/uploads/2026/01/easy-cute-ice-cream-aesthetic-designs-1-1-150x150.webp 150w, https://www.cookfastrecipes.com/wp-content/uploads/2026/01/easy-cute-ice-cream-aesthetic-designs-1-1-768x768.webp 768w, https://www.cookfastrecipes.com/wp-content/uploads/2026/01/easy-cute-ice-cream-aesthetic-designs-1-1-500x500.webp 500w" data-sizes="(max-width: 1024px) 100vw, 1024px" /><style>:root {
    --primary: #fba312;
  }

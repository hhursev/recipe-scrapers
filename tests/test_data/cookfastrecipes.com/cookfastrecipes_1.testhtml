  "recipeIngredient": [
    "4 large egg yolks",
    "1/2 cup granulated sugar",
    "2 tablespoons unsweetened cocoa powder",
    "1/2 teaspoon Morton kosher salt",
    "1 1/2 cups whole milk, divided use",
    "4 ounces semisweet chocolate, roughly chopped or chips",
    "1 1/2 cups heavy cream",
    "1 teaspoon pure vanilla extract",
    "1/2 cup sliced, toasted almonds",
    "1 cup plant based mini marshmallows",
    "1/3 cup chocolate shavings"
  ],
  "recipeInstructions": [
    {"@type": "HowToStep","text": "Start by chilling your ice cream machine bowl according to the manufacturer's instructions until it is very well frozen."},
    {"@type": "HowToStep","text": "In a heatproof medium sized bowl, whisk together the egg yolks, granulated sugar, cocoa powder, and salt. Add 1/4 cup of the whole milk and whisk until the mixture is well combined and smooth."},
    {"@type": "HowToStep","text": "Pour the remaining 1 1/4 cups of milk into a medium saucepan and place it over medium heat until it is just steaming. Do not let it boil."},
    {"@type": "HowToStep","text": "Slowly drizzle the warm milk into the egg yolk mixture, whisking constantly. This tempers the eggs to prevent them from scrambling."},
    {"@type": "HowToStep","text": "Pour the tempered mixture back into the saucepan. Stir constantly over medium-low heat for about 5 minutes, until it thickens into a custard that coats the back of a wooden spoon."},
    {"@type": "HowToStep","text": "Pour the custard through a fine mesh sieve into a clean bowl. Add the chopped chocolate and whisk until it's fully melted and smooth. Whisk in the heavy cream and vanilla."},
    {"@type": "HowToStep","text": "Place plastic wrap directly on the surface of the custard base to prevent a skin from forming. Chill in the refrigerator for at least 4 hours, or overnight, until very cold."},

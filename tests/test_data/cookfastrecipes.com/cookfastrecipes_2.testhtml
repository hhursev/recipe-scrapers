    overflow: hidden;
    border: 1px solid var(--border-light);
    font-family: 'Montserrat', sans-serif;
    color: var(--text-dark);
  }

  .recipe-header {
    min-height: 280px;
    text-align: center;
    padding: 50px 20px 25px;
    background-image:
      linear-gradient(rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.6)),
      url('https://www.cookfastrecipes.com/wp-content/uploads/2026/02/high-protein-cinnamon-roll-bread-with-cottage-cheese-recipe-for-breakfast-1.webp');
    background-size: cover;
    background-position: center;
    border-bottom: 3px solid var(--primary);
    color: var(--white);
  }

  .recipe-header h2 {
    font-size: 2.8rem;
    color: var(--white);
    font-weight: 800;
    margin: 0 0 10px;
    text-shadow: 0 2px 5px rgba(0, 0, 0, 0.8);
  }

  .rating-stars {
    font-size: 1.8rem;
    color: var(--star-color);
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.6);
  }

  .summary-text {
    padding: 25px 35px;
    font-size: 1.2rem;
    color: var(--text-light);
    border-bottom: 1px dashed var(--border-light);
    line-height: 1.6;
  }

  .action-buttons {
    display: flex;
    justify-content: center;
    gap: 15px;
    padding: 20px;
  }

  /* --- ACTION BUTTON STYLE --- */
  .action-buttons button {
    background: var(--white);
    border: 2px solid var(--primary);
    color: var(--primary);
    padding: 12px 24px;
    border-radius: 999px;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 5px rgba(0, 0, 0, 0.05);
  }

  .recipe-stats {
    display: flex;
    justify-content: space-evenly;
    flex-wrap: wrap;
    background: var(--occent);
    padding: 15px 25px;
    border-top: 1px solid var(--border-separator);
    border-bottom: 1px solid var(--border-separator);
  }

  .stat-item {
    background: var(--white);
    padding: 10px 18px;
    border-radius: 999px;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.05);
    font-size: 0.9rem;
    margin: 6px;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .section-title {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--primary);
    padding: 20px 35px 10px;
    border-left: 5px solid var(--primary);
    /* Default light background for headers */
    background: var(--primary-light-bg); 
    margin: 0;
  }

  /* --- INGREDIENTS LIST CONTENT (Light background) --- */
  .ingredients-list {
    padding: 15px 35px 30px;
    /* Default background is the card's white background */
  }

  .instructions-list {
    padding: 15px 35px 30px;
  }
  
  /* --- PRODUCT GRID STYLES (Light background for Requirements content) --- */
  .product-section-content {
    padding: 20px 35px 30px;
    background-color: var(--primary-light-bg); 
    border-bottom: 1px solid var(--border-separator);
  }

  /* MOBILE-FIRST: Default to a single column on small screens */
  .product-grid-static {
    display: grid;
    grid-template-columns: 1fr; /* Single column on mobile */
    gap: 1.5rem;
  }
  
  /* Media query to switch to two columns on wider screens */
  @media (min-width: 600px) {
    .product-grid-static {
      grid-template-columns: repeat(2, 1fr); 
    }
  }

  .product-card { 
      background-color: #ffff; 
      padding: 0.75rem; 
      border-radius: 1rem; 
      box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); 
      display: flex; 
      align-items: center; 
      text-decoration: none; 
      color: var(--text-dark);
  }

  .image-container-small {
      width: 70px; 
      height: 70px; 
      flex-shrink: 0; 
      overflow: hidden; 
      border-radius: 8px; 
      margin-right: 15px;
  }

  .image-container-small img {
      width: 100%;
      height: 100%;
      object-fit: contain; 
      display: block;
      border-radius: 8px; 
  }

  .product-title-small { 
      font-size: 1rem; 
      font-weight: 600; 
      line-height: 1.3; 
      flex-grow: 1; 
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
  }

  /* Ensure figcaption injected by WP is hidden */
  #wp-gemini-recipe-card .product-card figcaption {
    display: none !important;
  }
  /* --- END NEW PRODUCT GRID STYLES --- */

  .ingredient-item {
    display: flex;
    align-items: center;
    padding: 8px 0;
    border-bottom: 1px solid var(--border-ingredient); 
  }

  .ingredient-item input[type="checkbox"] {
    width: 20px;
    height: 20px;
    margin-right: 12px;
    border: 2px solid var(--primary); 
    border-radius: 4px;
    appearance: none;
    cursor: pointer;
    position: relative;
    transition: 0.2s;
  }

  .ingredient-item input[type="checkbox"]:checked {
    background: var(--primary); 
  }

  .ingredient-item input[type="checkbox"]:checked::after {
    content: '✔';
    color: var(--white); 
    font-size: 14px;
    position: absolute;
    top: 50%; left: 50%; transform: translate(-50%, -50%);
  }

  .ingredient-item label {
    color: var(--text-dark); 
    font-size: 1.2rem;
    flex: 1;
  }

  .ingredient-item input:checked + label {
    text-decoration: line-through;
    color: var(--text-light);
  }

  .notes-section {
    background: var(--occent);
    padding: 25px 35px;
    border-top: 2px solid var(--primary);
  }

  .notes-section p {
    margin: 0 0 12px;
    color: var(--text-light);
    font-style: italic;
    border-left: 4px solid var(--primary);
    padding-left: 10px;
  }

  .nutrition-section {
    padding: 25px 35px;
    background: var(--white);
    border-top: 3px solid var(--primary);
  }

  .nutrition-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 12px;
  }

  .nutrition-item {
    background: var(--bg-nutrition);
    padding: 10px;
    border-radius: 6px;
    text-align: center;
    font-size: 0.9rem;
  }

  @media print {
    body * { visibility: hidden; }
    #wp-gemini-recipe-card, #wp-gemini-recipe-card * { visibility: visible; }
    #wp-gemini-recipe-card {
      position: absolute;
      left: 0; top: 0;
      width: 100%;
      box-shadow: none;
      border: none;
    }
    .action-buttons, .ingredient-item input, .product-card, .slider-btn { display: none !important; }
  }</style><div id="wp-gemini-recipe-card"><div class="recipe-header"><h2>High Protein Cottage Cheese Cinnamon Roll Bread</h2><div class="rating-stars">★★★★★</div></div><p class="summary-text">This High Protein Cottage Cheese Cinnamon Roll Bread is soft, moist, and tastes just like dessert. Packed with over 20g of protein per slice, it is a perfect, no-fuss breakfast or snack that comes together quickly in a blender.</p><div class="action-buttons">

sition":3,"name":"Entrees","item":"https:\/\/www.averiecooks.com\/category\/entrees\/"},{"@type":"ListItem","position":4,"name":"Sides, Salads &amp; Vegetables","item":"https:\/\/www.averiecooks.com\/category\/entrees\/vegetables\/"},{"@type":"ListItem","position":5,"name":"Balsamic Watermelon and Cucumber Salad"}]},{"@type":"WebSite","@id":"https:\/\/www.averiecooks.com\/#website","url":"https:\/\/www.averiecooks.com\/","name":"Averie Cooks","description":"Fast and easy recipes for real life!","publisher":{"@id":"https:\/\/www.averiecooks.com\/#organization"},"potentialAction":[{"@type":"SearchAction","target":{"@type":"EntryPoint","urlTemplate":"https:\/\/www.averiecooks.com\/?s={search_term_string}"},"query-input":{"@type":"PropertyValueSpecification","valueRequired":true,"valueName":"search_term_string"}}],"inLanguage":"en-US"},{"@type":"Organization","@id":"https:\/\/www.averiecooks.com\/#organization","name":"Averie Cooks","url":"https:\/\/www.averiecooks.com\/","logo":{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/www.averiecooks.com\/#\/schema\/logo\/image\/","url":"https:\/\/www.averiecooks.com\/wp-content\/uploads\/2022\/05\/Averie_Logo_Large.png","contentUrl":"https:\/\/www.averiecooks.com\/wp-content\/uploads\/2022\/05\/Averie_Logo_Large.png","width":1200,"height":1200,"caption":"Averie Cooks"},"image":{"@id":"https:\/\/www.averiecooks.com\/#\/schema\/logo\/image\/"},"sameAs":["https:\/\/www.facebook.com\/AverieCooks","https:\/\/x.com\/AverieCooks","https:\/\/www.pinterest.com\/averie\/","https:\/\/instagram.com\/averiesunshine\/","https:\/\/www.averieinreallife.com\/"]},{"@type":"Person","@id":"https:\/\/www.averiecooks.com\/#\/schema\/person\/2d4a7851df13b6e90f8ea007e52897af","name":"Averie Sunshine","image":{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/www.averiecooks.com\/wp-content\/uploads\/2023\/01\/cropped-averie-cooks-barcelona-crop-96x96.jpg","url":"https:\/\/www.averiecooks.com\/wp-content\/uploads\/2023\/01\/cropped-averie-cooks-barcelona-crop-96x96.jpg","contentUrl":"https:\/\/www.averiecooks.com\/wp-content\/uploads\/2023\/01\/cropped-averie-cooks-barcelona-crop-96x96.jpg","caption":"Averie Sunshine"},"description":"Welcome to AverieCooks! Here you’ll find fast and easy recipes that taste amazing and are geared for real life. Nothing fussy or complicated, just awesome tasting dishes everyone loves!","sameAs":["https:\/\/www.averiecooks.com\/about-averie\/"]},{"@type":"Question","@id":"https:\/\/www.averiecooks.com\/balsamic-watermelon-and-cucumber-salad\/#faq-question-1717749248871","position":1,"url":"https:\/\/www.averiecooks.com\/balsamic-watermelon-and-cucumber-salad\/#faq-question-1717749248871","name":"How Can I adjust the sweetness level of the balsamic glaze?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"I used a 500 milliliter (about 17 ounces) bottle of balsamic vinegar and added close to 1 cup sugar. You can start with 1\/2 to 3\/4 cup sugar and taste your sauce when it looks like it's about halfway done, but for me that's not quite sweet enough and it's too intensely vinegary, so I went with closer to 1 cup for this batch.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https:\/\/www.averiecooks.com\/balsamic-watermelon-and-cucumber-salad\/#faq-question-1717749294707","position":2,"url":"https:\/\/www.averiecooks.com\/balsamic-watermelon-and-cucumber-salad\/#faq-question-1717749294707","name":"Can I Add a Protein Source to the Salad?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Yes! I bet u003ca href=u0022https:\/\/www.averiecooks.com\/tag\/grilled-chicken\/u0022u003egrilled chickenu003c\/au003e would pair wonderfully with this cucumber watermelon salad. ","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https:\/\/www.averiecooks.com\/balsamic-watermelon-and-cucumber-salad\/#faq-question-1717749316884","position":3,"url":"https:\/\/www.averiecooks.com\/balsamic-watermelon-and-cucumber-salad\/#faq-question-1717749316884","name":"Can I Use a store-bought balsamic glaze?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Of course! u003ca href=u0022https:\/\/amzn.to\/3eXBH0mu0022 target=u0022_blanku0022 rel=u0022noreferrer noopener nofollowu0022u003eTrader Joe'su003c\/au003e is one I tend to keep on hand for times like this and there are many other brands out there these days if you don't have a Trader Joe's in your area.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https:\/\/www.averiecooks.com\/balsamic-watermelon-and-cucumber-salad\/#faq-question-1717749374422","position":4,"url":"https:\/\/www.averiecooks.com\/balsamic-watermelon-and-cucumber-salad\/#faq-question-1717749374422","name":"Can the goat cheese be omitted or substituted?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"As written, this is a naturally vegetarian salad recipe, but you can make it vegan by skipping the goat cheese or using a vegan cheese. u003cbr\/u003eu003cbr\/u003eAnd if you just don't like goat cheese, try using feta instead! ","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https:\/\/www.averiecooks.com\/balsamic-watermelon-and-cucumber-salad\/#faq-question-1717749436642","position":5,"url":"https:\/\/www.averiecooks.com\/balsamic-watermelon-and-cucumber-salad\/#faq-question-1717749436642","name":"Can the salad be made in advance?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Not really. The watermelon releases juice quickly and will cause the cucumber and arugula to soften. However, you can prep the individual fruits and veggies and store them in separate containers in the fridge up to 48 hours before tossing the salad. The balsamic glaze can be prepared weeks in advance. ","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Recipe","name":"Balsamic Watermelon Cucumber Salad","author":{"@type":"Person","name":"Averie Sunshine"},"description":"🥗🍉🥒 An EASY, healthy, and light salad with watermelon, cucumber, arugula, goat cheese, candied nuts, and drizzled with a homemade balsamic glaze! A PERFECT summer salad for those days when it&#039;s too hot to cook!","datePublished":"2020-07-15T00:01:46+00:00","image":["https:\/\/www.averiecooks.com\/wp-content\/uploads\/2020\/07\/watermelonsalad-5.jpg","https:\/\/www.averiecooks.com\/wp-content\/uploads\/2020\/07\/watermelonsalad-5-500x500.jpg","https:\/\/www.averiecooks.com\/wp-content\/uploads\/2020\/07\/watermelonsalad-5-500x375.jpg","https:\/\/www.averiecooks.com\/wp-content\/uploads\/2020\/07\/watermelonsalad-5-480x270.jpg"],"recipeYield":["2"],"prepTime":"PT5M","cookTime":"PT15M","totalTime":"PT20M","recipeIngredient":["500 milliliters balsamic vinegar","1 cup granulated sugar (divided)","3 cups watermelon (seeded and cubed (I recommend seedless, firm watermelon))","1  large cucumber or English cucumber (peeled and cubed)","1 cup arugula (1 heaping handful)","1\/3 cup goat cheese (crumbled or as desired)","1\/3 cup candied nuts ((store-bought or homemade))"],"recipeInstructions":[{"@type":"HowToStep","text":"To a high-sided medium\/large kettle (use one bigger than you think you need), add the vinegar, 1\/2 cup sugar, and heat over medium to medium-high until mixture boils and can sustain a fast rolling boil.","name":"To a high-sided medium\/large kettle (use one bigger than you think you need), add the vinegar, 1\/2 cup sugar, and heat over medium to medium-high until mixture boils and can sustain a fast rolling boil.","url":"https:\/\/www.averiecooks.com\/balsamic-watermelon-and-cucumber-salad\/#wprm-recipe-75024-step-0-0"},{"@type":"HowToStep","text":"Boil for about 15 to 20 minutes, or until reduced by about 80% and has thickened and is syrupy; stir intermittently and keep an eye on it so it doesn't bubble over.","name":"Boil for about 15 to 20 minutes, or until reduced by about 80% and has thickened and is syrupy; stir intermittently and keep an eye on it so it doesn't bubble over.","url":"https:\/\/www.averiecooks.com\/balsamic-watermelon-and-cucumber-salad\/#wprm-recipe-75024-step-0-1"},{"@type":"HowToStep","text":"When the sauce looks like it's about halfway done, taste the sauce, and if it's too vinegary and bitter for you, add part of or all of the remaining sugar. I personally use almost 1 cup. Sauce will thicken up more as it cools.","name":"When the sauce looks like it's about halfway done, taste the sauce, and if it's too vinegary and bitter for you, add part of or all of the remaining sugar. I personally use almost 1 cup. Sauce will thicken up more as it cools.","url":"https:\/\/www.averiecooks.com\/balsamic-watermelon-and-cucumber-salad\/#wprm-recipe-75024-step-0-2"},{"@type":"HowToStep","text":"To a medium bowl, add all the remaining ingredients, stir to combine, and drizzle as much of the balsamic reduction as desired.","name":"To a medium bowl, add all the remaining ingredients, stir to combine, and drizzle as much of the balsamic reduction as desired.","url":"https:\/\/www.averiecooks.com\/balsamic-watermelon-and-cucumber-salad\/#wprm-recipe-75024-step-0-3"},{"@type":"HowToStep","text":"Salad is best consumed fresh, although extra glaze will keep for many weeks airtight in the fridge.","name":"Salad is best consumed fresh, although extra glaze will keep for many weeks airtight in the fridge.","url":"https:\/\/www.averiecooks.com\/balsamic-watermelon-and-cucumber-salad\/#wprm-recipe-75024-step-0-4"}],"aggregateRating":{"@type":"AggregateRating","ratingValue":"5","ratingCount":"18","reviewCount":"9"},"review":[{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"great","author":{"@type":"Person","name":"Averie"},"datePublished":"2022-05-25"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"great","author":{"@type":"Person","name":"Averie Sunshine"},"datePublished":"2022-05-01"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Hands down, one of the most delicious salads I've ever eaten. Was a huge hit at my dinner party, and what a beautiful presentation it makes. Buy the Trader Joe's glaze for an easy, delicious sauce.","author":{"@type":"Person","name":"sharlyn a spates"},"datePublished":"2021-07-12"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Hands down, one of the most delicious salads I've ever eaten. Was a huge hit at my dinner party, and what a beautiful presentation it makes. Buy the Trader Joe's glaze for an easy, delicious sauce.","author":{"@type":"Person","name":"sharlyn a spates"},"datePublished":"2021-07-12"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"great","author":{"@type":"Person","name":"averie"},"datePublished":"2021-06-15"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"This is one of the most fantastic salads I have ever had! Incredible mix of flavors but the balsamic reduction is what pulls everything together. I made my own candied pecans in a skillet with some butter and honey (the little store bought bags were kind of pricey)!","author":{"@type":"Person","name":"Paula"},"datePublished":"2020-07-26"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"This is one of the most fantastic salads I have ever had! Incredible mix of flavors but the balsamic reduction is what pulls everything together. I made my own candied pecans in a skillet with some butter and honey (the little store bought bags were kind of pricey)!","author":{"@type":"Person","name":"Paula"},"datePublished":"2020-07-26"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Hi Averie.  Today we had this Balsamic Watermelon and Cucumber Salad for dinner with grilled chicken.  It knocked our socks off!!!  Thank you.  Textures, color, flavors  -- Wow!  Hubby could not get enough.  Each mouthful had its own surprise: first the pop of pepper from the arugula, second the tang of the cheese, then the sweet crunchiness of the nuts.   My only problem was with the balsamic dressing itself.  I cooked it as directed and after 15 minutes, it had the texture of candy.  As it cooled it hardened, so there was no way I could drizzle it.  I ended up just mixing balsamic vinegar and sugar until I liked the taste, and then drizzling that over the salad.  No cooking at all.  I'm not sure what I did wrong, but it turned out well.","author":{"@type":"Person","name":"MarissaB"},"datePublished":"2020-07-17"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Hi Averie.  Today we had this Balsamic Watermelon and Cucumber Salad for dinner with grilled chicken.  It knocked our socks off!!!  Thank you.  Textures, color, flavors  -- Wow!  Hubby could not get enough.  Each mouthful had its own surprise: first the pop of pepper from the arugula, second the tang of the cheese, then the sweet crunchiness of the nuts.   My only problem was with the balsamic dressing itself.  I cooked it as directed and after 15 minutes, it had the texture of candy.  As it cooled it hardened, so there was no way I could drizzle it.  I ended up just mixing balsamic vinegar and sugar until I liked the taste, and then drizzling that over the salad.  No cooking at all.  I'm not sure what I did wrong, but it turned out well.","author":{"@type":"Person","name":"MarissaB"},"datePublished":"2020-07-16"}],"recipeCategory":["Sides, Salads &amp; Vegetables"],"recipeCuisine":["American"],"keywords":"watermelon cucumber salad","nutrition":{"@type":"NutritionInformation","servingSize":"1 salad","calories":"893 kcal","carbohydrateContent":"171 g","proteinContent":"12 g","fatContent":"16 g","saturatedFatContent":"6 g","cholesterolContent":"17 mg","sodiumContent":"289 mg","fiberContent":"3 g","sugarContent":"160 g","unsaturatedFatContent":"2.3 g"},"@id":"https:\/\/www.averiecooks.com\/balsamic-watermelon-and-cucumber-salad\/#recipe","isPartOf":{"@id":"https:\/\/www.averiecooks.com\/balsamic-watermelon-and-cucumber-salad\/#article"},"mainEntityOfPage":"https:\/\/www.averiecooks.com\/balsamic-watermelon-and-cucumber-salad\/"}]}</script>

	<script type="application/ld+json" class="yoast-schema-graph">{"@context":"https://schema.org","@graph":[{"@type":"Article","@id":"https://theunlikelybaker.com/easy-cherry-cake-recipe-from-scratch/#article","isPartOf":{"@id":"https://theunlikelybaker.com/easy-cherry-cake-recipe-from-scratch/"},"author":{"name":"Jolina","@id":"https://theunlikelybaker.com/#/schema/person/4752cdf062d051d1f1bd208d4d9a39de"},"headline":"Easy Cherry Cake Recipe from Scratch","datePublished":"2019-06-12T11:00:57+00:00","dateModified":"2021-06-28T13:28:15+00:00","wordCount":1240,"commentCount":20,"publisher":{"@id":"https://theunlikelybaker.com/#organization"},"image":{"@id":"https://theunlikelybaker.com/easy-cherry-cake-recipe-from-scratch/#primaryimage"},"thumbnailUrl":"https://theunlikelybaker.com/wp-content/uploads/2019/06/Easy-Cherry-Cake-Recipe-Feature.jpg","articleSection":["Buttermilk Recipes","Cakes","Dessert Recipes","Recipes"],"inLanguage":"en-US","potentialAction":[{"@type":"CommentAction","name":"Comment","target":["https://theunlikelybaker.com/easy-cherry-cake-recipe-from-scratch/#respond"]}]},{"@type":["WebPage","FAQPage"],"@id":"https://theunlikelybaker.com/easy-cherry-cake-recipe-from-scratch/","url":"https://theunlikelybaker.com/easy-cherry-cake-recipe-from-scratch/","name":"Easy Cherry Cake Recipe from Scratch","isPartOf":{"@id":"https://theunlikelybaker.com/#website"},"primaryImageOfPage":{"@id":"https://theunlikelybaker.com/easy-cherry-cake-recipe-from-scratch/#primaryimage"},"image":{"@id":"https://theunlikelybaker.com/easy-cherry-cake-recipe-from-scratch/#primaryimage"},"thumbnailUrl":"https://theunlikelybaker.com/wp-content/uploads/2019/06/Easy-Cherry-Cake-Recipe-Feature.jpg","datePublished":"2019-06-12T11:00:57+00:00","dateModified":"2021-06-28T13:28:15+00:00","description":"This easy cherry cake recipe is so easy to make and so delicious you’d want to bake it all summer long. Soft, not too sweet, bursting with cherry flavour.","breadcrumb":{"@id":"https://theunlikelybaker.com/easy-cherry-cake-recipe-from-scratch/#breadcrumb"},"mainEntity":[{"@id":"https://theunlikelybaker.com/easy-cherry-cake-recipe-from-scratch/#faq-question-1659030405895"},{"@id":"https://theunlikelybaker.com/easy-cherry-cake-recipe-from-scratch/#faq-question-1659030435574"},{"@id":"https://theunlikelybaker.com/easy-cherry-cake-recipe-from-scratch/#faq-question-1659030467259"},{"@id":"https://theunlikelybaker.com/easy-cherry-cake-recipe-from-scratch/#faq-question-1659030508154"}],"inLanguage":"en-US","potentialAction":[{"@type":"ReadAction","target":["https://theunlikelybaker.com/easy-cherry-cake-recipe-from-scratch/"]}]},{"@type":"ImageObject","inLanguage":"en-US","@id":"https://theunlikelybaker.com/easy-cherry-cake-recipe-from-scratch/#primaryimage","url":"https://theunlikelybaker.com/wp-content/uploads/2019/06/Easy-Cherry-Cake-Recipe-Feature.jpg","contentUrl":"https://theunlikelybaker.com/wp-content/uploads/2019/06/Easy-Cherry-Cake-Recipe-Feature.jpg","width":680,"height":680,"caption":"Easy Cherry Cake Recipe from Scratch"},{"@type":"BreadcrumbList","@id":"https://theunlikelybaker.com/easy-cherry-cake-recipe-from-scratch/#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://theunlikelybaker.com/"},{"@type":"ListItem","position":2,"name":"Recipes","item":"https://theunlikelybaker.com/category/recipes/"},{"@type":"ListItem","position":3,"name":"Cakes","item":"https://theunlikelybaker.com/category/recipes/cake-pies/"},{"@type":"ListItem","position":4,"name":"Easy Cherry Cake Recipe from Scratch"}]},{"@type":"WebSite","@id":"https://theunlikelybaker.com/#website","url":"https://theunlikelybaker.com/","name":"The Unlikely Baker®","description":"Easy and Delicious Recipes for the Home Baker!","publisher":{"@id":"https://theunlikelybaker.com/#organization"},"potentialAction":[{"@type":"SearchAction","target":{"@type":"EntryPoint","urlTemplate":"https://theunlikelybaker.com/?s={search_term_string}"},"query-input":{"@type":"PropertyValueSpecification","valueRequired":true,"valueName":"search_term_string"}}],"inLanguage":"en-US"},{"@type":"Organization","@id":"https://theunlikelybaker.com/#organization","name":"The Unlikely Baker®","url":"https://theunlikelybaker.com/","logo":{"@type":"ImageObject","inLanguage":"en-US","@id":"https://theunlikelybaker.com/#/schema/logo/image/","url":"https://theunlikelybaker.com/wp-content/uploads/2016/03/Logo.png","contentUrl":"https://theunlikelybaker.com/wp-content/uploads/2016/03/Logo.png","width":800,"height":340,"caption":"The Unlikely Baker®"},"image":{"@id":"https://theunlikelybaker.com/#/schema/logo/image/"},"sameAs":["https://www.facebook.com/theunlikelybaker/","https://x.com/unlikely_baker","https://www.instagram.com/iamtheunlikelybaker/","https://www.pinterest.com/unlikelybaker/","https://www.youtube.com/theunlikelybaker"]},{"@type":"Person","@id":"https://theunlikelybaker.com/#/schema/person/4752cdf062d051d1f1bd208d4d9a39de","name":"Jolina","sameAs":["https://theunlikelybaker.com/about-me/"]},{"@type":"Question","@id":"https://theunlikelybaker.com/easy-cherry-cake-recipe-from-scratch/#faq-question-1659030405895","position":1,"url":"https://theunlikelybaker.com/easy-cherry-cake-recipe-from-scratch/#faq-question-1659030405895","name":"How to make homemade buttermilk","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"<br/>This recipe only needs 1/2 cup of buttermilk and if you’re like me and can only buy it in 1L bottles, you need to plan out your week and make all things buttermilk (here’s a great <a href=\"https://theunlikelybaker.com/ways-to-use-leftover-buttermilk/\"><strong>collection of recipes to help you use that leftover buttermilk</strong></a>).<br/><br/>Or, you can make buttermilk at home so you have just the right amount you need.<br/>It’s so simple: I just mix a cup of milk and a tablespoon of lemon juice, stir then let it sit in room temperature for 30 minutes.<br/><br/>Homemade buttermilk doesn’t get quite as thick as the one you buy at the store though. Good news is I haven’t noticed a significant difference in my baking yet. So I don’t hesitate to make homemade buttermilk in a pinch.<br/><br/>Here’s an interesting read on <a href=\"https://www.thekitchn.com/is-there-a-difference-between-commercial-homemade-buttermilk-223086\" target=\"_blank\" rel=\"noreferrer noopener nofollow\">commercial vs. homemade buttermilk</a>, if you’re curious.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https://theunlikelybaker.com/easy-cherry-cake-recipe-from-scratch/#faq-question-1659030435574","position":2,"url":"https://theunlikelybaker.com/easy-cherry-cake-recipe-from-scratch/#faq-question-1659030435574","name":"How to pit cherries without a cherry pitter","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"<br/>I love cherries - eating them fresh and baking with them (or making <a href=\"https://theunlikelybaker.com/roasted-cherry-choco-chip-ice-cream-video/\"><strong>homemade roasted</strong> <strong>cherry chocolate ice cream</strong></a> - so good!).<br/><br/>Over the years (and countless days of cherry red hands later) I’ve realized that a <a href=\"https://www.amazon.com/gp/product/B008FWD4HQ/ref=as_li_tl?ie=UTF8&amp;camp=1789&amp;creative=9325&amp;creativeASIN=B008FWD4HQ&amp;linkCode=as2&amp;tag=theunlbak-20&amp;linkId=7c16b99c18cee28d974358e845d6aef0\" target=\"_blank\" rel=\"noreferrer noopener sponsored nofollow\">cherry pitter</a> might be one of the best inventions of mankind ever.<br/><br/>Invest in one and you won’t look back.<br/><br/>If you don’t have one though, there are many ways to pit a cherry. From using a straw (didn’t work for me) to using a paper clip (this one hurt!). Here’s one <a href=\"https://www.kitchentreaty.com/the-easiest-way-to-pit-a-cherry-without-a-pitter/\" target=\"_blank\" rel=\"noreferrer noopener sponsored nofollow\">using a piping/icing tip</a> (I haven’t tried this but it looks very promising).<br/><br/>See what method works best for you (or invest in a pitter already!).","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https://theunlikelybaker.com/easy-cherry-cake-recipe-from-scratch/#faq-question-1659030467259","position":3,"url":"https://theunlikelybaker.com/easy-cherry-cake-recipe-from-scratch/#faq-question-1659030467259","name":"Can I use frozen cherries for this recipe?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"<br/>If you want to avoid all that drama altogether, you might be wondering if you can just use frozen cherries for this recipe. The answer is you can.<br/><br/>When cherries are $1 a basket, we tend to hoard buy more than normal people would and freeze them ourselves so we can have cherry parties all year.<br/><br/>When the craving hits and I want to bake cherry cake from scratch, I simply thaw them in the fridge. <br/><br/>I just make sure to remove any excess moisture before I use them so my cake doesn’t end up being too mushy.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https://theunlikelybaker.com/easy-cherry-cake-recipe-from-scratch/#faq-question-1659030508154","position":4,"url":"https://theunlikelybaker.com/easy-cherry-cake-recipe-from-scratch/#faq-question-1659030508154","name":"How do I store this cake?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"<br/>You can store this cherry buttermilk cake in an airtight container in the fridge. It will be good for up to 2 days.<br/><br/>We like eating this cake chilled too so we don’t usually bring it down to room temperature before serving.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Recipe","name":"Easy Cherry Cake Recipe from Scratch","author":{"@id":"https://theunlikelybaker.com/#/schema/person/4752cdf062d051d1f1bd208d4d9a39de"},"description":"This easy cherry cake recipe is so easy to make and so delicious you’d want to bake it all summer long. Dense but soft, not too sweet, bursting with wonderful cherry flavour.","datePublished":"2019-06-12T07:00:57+00:00","image":["https://theunlikelybaker.com/wp-content/uploads/2019/06/Easy-Cherry-Cake-Recipe-Feature.jpg","https://theunlikelybaker.com/wp-content/uploads/2019/06/Easy-Cherry-Cake-Recipe-Feature-500x500.jpg","https://theunlikelybaker.com/wp-content/uploads/2019/06/Easy-Cherry-Cake-Recipe-Feature-500x375.jpg","https://theunlikelybaker.com/wp-content/uploads/2019/06/Easy-Cherry-Cake-Recipe-Feature-480x270.jpg"],"video":{"name":"Easy Cherry Cake Recipe from Scratch","description":"This easy cherry cake recipe is so easy to make and so delicious you’d want to bake it all summer long. Dense but soft, not too sweet, bursting with wonderful cherry flavour.","thumbnailUrl":"https://mediavine-res.cloudinary.com/image/upload/s--jdv79IBp--/c_limit,f_auto,fl_lossy,h_1080,q_auto,w_1920/v1560279406/yppszxuds3gvejqwj6hs.jpg","embedUrl":"https://video.mediavine.com/videos/oujwjq8iqkvn7uwo1rq6.js","contentUrl":"https://mediavine-res.cloudinary.com/video/upload/t_original/v1560279277/oujwjq8iqkvn7uwo1rq6.mp4","uploadDate":"2019-06-11T18:56:37+00:00","duration":"PT30S","@type":"VideoObject"},"recipeYield":["16","16 servings"],"prepTime":"PT20M","cookTime":"PT40M","totalTime":"PT60M","recipeIngredient":["1 1/2 cups all-purpose flour","1 1/2 tsp baking powder","1/2 tsp salt","6 tbsp unsalted butter (room temperature)","3/4 cup granulated sugar","1 pc large egg (room temperature)","1/2 cup buttermilk","1 tsp vanilla extract","1 lb fresh sweet cherries (pitted and halved)"],"recipeInstructions":[{"@type":"HowToStep","text":"Preheat oven to 350F. Line a 9x9 inch square baking pan with parchment paper with slight overhang on each side. Set aside.","name":"Preheat oven to 350F. Line a 9x9 inch square baking pan with parchment paper with slight overhang on each side. Set aside.","url":"https://theunlikelybaker.com/easy-cherry-cake-recipe-from-scratch/#wprm-recipe-5561-step-0-0"},{"@type":"HowToStep","text":"In a large bowl, sift 1 1/2 cups all purpose flour, 1 1/2 tsp baking powder and 1/2 tsp salt. Set aside.","name":"In a large bowl, sift 1 1/2 cups all purpose flour, 1 1/2 tsp baking powder and 1/2 tsp salt. Set aside.","url":"https://theunlikelybaker.com/easy-cherry-cake-recipe-from-scratch/#wprm-recipe-5561-step-0-1"},{"@type":"HowToStep","text":"Using a handheld electric mixer or a stand mixer fitted with the paddle attachment, cream 6 tbsp of butter with 3/4 cup of sugar until light and fluffy (about 3-5 minutes on medium-high speed).","name":"Using a handheld electric mixer or a stand mixer fitted with the paddle attachment, cream 6 tbsp of butter with 3/4 cup of sugar until light and fluffy (about 3-5 minutes on medium-high speed).","url":"https://theunlikelybaker.com/easy-cherry-cake-recipe-from-scratch/#wprm-recipe-5561-step-0-2"},{"@type":"HowToStep","text":"Then in goes the egg, ½ cup buttermilk and 1 tsp vanilla extract. Mix until incorporated.","name":"Then in goes the egg, ½ cup buttermilk and 1 tsp vanilla extract. Mix until incorporated.","url":"https://theunlikelybaker.com/easy-cherry-cake-recipe-from-scratch/#wprm-recipe-5561-step-0-3"},{"@type":"HowToStep","text":"Switch the mixer to low speed and gradually add your flour mixture. Stir just until combined. Remember to scrape the bottom and sides of your bowl.","name":"Switch the mixer to low speed and gradually add your flour mixture. Stir just until combined. Remember to scrape the bottom and sides of your bowl.","url":"https://theunlikelybaker.com/easy-cherry-cake-recipe-from-scratch/#wprm-recipe-5561-step-0-4"},{"@type":"HowToStep","text":"Transfer your batter into your prepared pan and smoothen the top with a spatula. Place cherries on top (you may want to lightly press some of the cherries into the batter) and bake for 30-40 minutes or until a toothpick inserted in the centre of the cake comes out clean.","name":"Transfer your batter into your prepared pan and smoothen the top with a spatula. Place cherries on top (you may want to lightly press some of the cherries into the batter) and bake for 30-40 minutes or until a toothpick inserted in the centre of the cake comes out clean.","url":"https://theunlikelybaker.com/easy-cherry-cake-recipe-from-scratch/#wprm-recipe-5561-step-0-5"},{"@type":"HowToStep","text":"Place the pan on a wire rack to cool. Serve with a dusting of confectioner&#x27;s sugar or a scoop of ice cream.","name":"Place the pan on a wire rack to cool. Serve with a dusting of confectioner&#x27;s sugar or a scoop of ice cream.","url":"https://theunlikelybaker.com/easy-cherry-cake-recipe-from-scratch/#wprm-recipe-5561-step-0-6"}],"aggregateRating":{"@type":"AggregateRating","ratingValue":"5","ratingCount":"2","reviewCount":"1"},"review":[{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Excellent (and easy) recipe!  I could not fit anywhere near 1 lb of cherries, and I weighed them prior to pitting.  I wound up using 36 halves.  I am freezing the rest of the halves, so the next time I make this, it will go even faster.  Thank you for a great recipe!","author":{"@type":"Person","name":"Malibu"},"datePublished":"2025-07-14"}],"recipeCategory":["Dessert"],"recipeCuisine":["North American"],"keywords":"Easy, Picnic, Summer","nutrition":{"@type":"NutritionInformation","calories":"141 kcal","carbohydrateContent":"23 g","proteinContent":"2 g","fatContent":"5 g","saturatedFatContent":"3 g","cholesterolContent":"13 mg","sodiumContent":"82 mg","fiberContent":"1 g","sugarContent":"13 g","servingSize":"1 serving"},"@id":"https://theunlikelybaker.com/easy-cherry-cake-recipe-from-scratch/#recipe","isPartOf":{"@id":"https://theunlikelybaker.com/easy-cherry-cake-recipe-from-scratch/#article"},"mainEntityOfPage":"https://theunlikelybaker.com/easy-cherry-cake-recipe-from-scratch/"}]}</script>

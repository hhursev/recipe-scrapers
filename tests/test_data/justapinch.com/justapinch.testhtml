                <div class="d-flex flex-column">
                    <div class="bg-rcp-white text-break">
                                                <div class="d-flex align-items-center justify-content-start mb-3">
                <div class="position-relative mr-3">
                    <a href="https://www.justapinch.com/me/torrey" rel="nofollow">
                        <img
                            src="https://lh3.googleusercontent.com/pMgFVhpo3-Xh32jpEDiia6jdqAfrCiPFuoGNaep_B-OSfC5GGWWuCOfADRsEaX7S9vW3S6vrB7Xnrr9WnrF2qWZbEW-0-CxwrbZQKV0=s90-p"
                            alt="Torrey avatar"
                            class="shadow rounded-circle"
                            data-profile-name="Torrey Moseley"
                        />

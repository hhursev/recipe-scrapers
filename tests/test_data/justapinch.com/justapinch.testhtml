            <div class="mb-3">
                
    <h1 class="text-capitalize">
       <span class="blue-ribbon-icon"></span>       2-hour turkey, really.    </h1>

                <div id="recipe-stats" class="d-flex align-items-center mb-3 text-uppercase text-muted">
                    <div class="pr-3">    <div id="recipe-stars" class="d-flex align-items-center justify-content-center">

ng_size\",\"sodium_content\":\"651\",\"_sodium_content\":\"field_recipe_sodium_content\",\"sugar_content\":\"12\",\"_sugar_content\":\"field_recipe_sugar_content\",\"trans_fat_content\":\"\",\"_trans_fat_content\":\"field_recipe_trans_fat_content\",\"unsaturated_fat_content\":\"\",\"_unsaturated_fat_content\":\"field_recipe_unsaturated_fat_content\",\"ingredients_0_section_title\":\"\",\"_ingredients_0_section_title\":\"field_recipe_ingredients_section_title\",\"ingredients_0_section_items_0_quantity\":\"\",\"_ingredients_0_section_items_0_quantity\":\"field_recipe_ingredients_section_items_quantity\",\"ingredients_0_section_items_0_measurement\":\"\",\"_ingredients_0_section_items_0_measurement\":\"field_recipe_ingredients_section_items_measurement\",\"ingredients_0_section_items_0_ingredient\":\"1 medium butternut squash (1\\u00be lb.)\",\"_ingredients_0_section_items_0_ingredient\":\"field_recipe_ingredients_section_items_ingredient\",\"ingredients_0_section_items_1_quantity\":\"\",\"_ingredients_0_section_items_1_quantity\":\"field_recipe_ingredients_section_items_quantity\",\"ingredients_0_section_items_1_measurement\":\"\",\"_ingredients_0_section_items_1_measurement\":\"field_recipe_ingredients_section_items_measurement\",\"ingredients_0_section_items_1_ingredient\":\"1 tablespoon extra-virgin olive oil (optional, \u003ca href=\\\"#h-tips\\\"\u003elearn more\u003c\\/a\u003e)\",\"_ingredients_0_section_items_1_ingredient\":\"field_recipe_ingredients_section_items_ingredient\",\"ingredients_0_section_items_2_quantity\":\"\",\"_ingredients_0_section_items_2_quantity\":\"field_recipe_ingredients_section_items_quantity\",\"ingredients_0_section_items_2_measurement\":\"\",\"_ingredients_0_section_items_2_measurement\":\"field_recipe_ingredients_section_items_measurement\",\"ingredients_0_section_items_2_ingredient\":\"1 onion, finely chopped (1 cup)\",\"_ingredients_0_section_items_2_ingredient\":\"field_recipe_ingredients_section_items_ingredient\",\"ingredients_0_section_items_3_quantity\":\"\",\"_ingredients_0_section_items_3_quantity\":\"field_recipe_ingredients_section_items_quantity\",\"ingredients_0_section_items_3_measurement\":\"\",\"_ingredients_0_section_items_3_measurement\":\"field_recipe_ingredients_section_items_measurement\",\"ingredients_0_section_items_3_ingredient\":\"4 cloves garlic, minced\",\"_ingredients_0_section_items_3_ingredient\":\"field_recipe_ingredients_section_items_ingredient\",\"ingredients_0_section_items_4_quantity\":\"\",\"_ingredients_0_section_items_4_quantity\":\"field_recipe_ingredients_section_items_quantity\",\"ingredients_0_section_items_4_measurement\":\"\",\"_ingredients_0_section_items_4_measurement\":\"field_recipe_ingredients_section_items_measurement\",\"ingredients_0_section_items_4_ingredient\":\"\\u00bd teaspoon finely chopped fresh thyme\",\"_ingredients_0_section_items_4_ingredient\":\"field_recipe_ingredients_section_items_ingredient\",\"ingredients_0_section_items_5_quantity\":\"\",\"_ingredients_0_section_items_5_quantity\":\"field_recipe_ingredients_section_items_quantity\",\"ingredients_0_section_items_5_measurement\":\"\",\"_ingredients_0_section_items_5_measurement\":\"field_recipe_ingredients_section_items_measurement\",\"ingredients_0_section_items_5_ingredient\":\"1 cup unsweetened, unflavored plant milk\",\"_ingredients_0_section_items_5_ingredient\":\"field_recipe_ingredients_section_items_ingredient\",\"ingredients_0_section_items_6_quantity\":\"\",\"_ingredients_0_section_items_6_quantity\":\"field_recipe_ingredients_section_items_quantity\",\"ingredients_0_section_items_6_measurement\":\"\",\"_ingredients_0_section_items_6_measurement\":\"field_recipe_ingredients_section_items_measurement\",\"ingredients_0_section_items_6_ingredient\":\"2 tablespoons nutritional yeast\",\"_ingredients_0_section_items_6_ingredient\":\"field_recipe_ingredients_section_items_ingredient\",\"ingredients_0_section_items_7_quantity\":\"\",\"_ingredients_0_section_items_7_quantity\":\"field_recipe_ingredients_section_items_quantity\",\"ingredients_0_section_items_7_measurement\":\"\",\"_ingredients_0_section_items_7_measurement\":\"field_recipe_ingredients_section_items_measurement\",\"ingredients_0_section_items_7_ingredient\":\"1 tablespoon white wine vinegar\",\"_ingredients_0_section_items_7_ingredient\":\"field_recipe_ingredients_section_items_ingredient\",\"ingredients_0_section_items_8_quantity\":\"\",\"_ingredients_0_section_items_8_quantity\":\"field_recipe_ingredients_section_items_quantity\",\"ingredients_0_section_items_8_measurement\":\"\",\"_ingredients_0_section_items_8_measurement\":\"field_recipe_ingredients_section_items_measurement\",\"ingredients_0_section_items_8_ingredient\":\"\\u00bd teaspoon sea salt\",\"_ingredients_0_section_items_8_ingredient\":\"field_recipe_ingredients_section_items_ingredient\",\"ingredients_0_section_items_9_quantity\":\"\",\"_ingredients_0_section_items_9_quantity\":\"field_recipe_ingredients_section_items_quantity\",\"ingredients_0_section_items_9_measurement\":\"\",\"_ingredients_0_section_items_9_measurement\":\"field_recipe_ingredients_section_items_measurement\",\"ingredients_0_section_items_9_ingredient\":\"\\u215b teaspoon freshly ground black pepper\",\"_ingredients_0_section_items_9_ingredient\":\"field_recipe_ingredients_section_items_ingredient\",\"ingredients_0_section_items_10_quantity\":\"\",\"_ingredients_0_section_items_10_quantity\":\"field_recipe_ingredients_section_items_quantity\",\"ingredients_0_section_items_10_measurement\":\"\",\"_ingredients_0_section_items_10_measurement\":\"field_recipe_ingredients_section_items_measurement\",\"ingredients_0_section_items_10_ingredient\":\"3 cups dried whole grain penne pasta (8 oz.)\",\"_ingredients_0_section_items_10_ingredient\":\"field_recipe_ingredients_section_items_ingredient\",\"ingredients_0_section_items_11_quantity\":\"\",\"_ingredients_0_section_items_11_quantity\":\"field_recipe_ingredients_section_items_quantity\",\"ingredients_0_section_items_11_measurement\":\"\",\"_ingredients_0_section_items_11_measurement\":\"field_recipe_ingredients_section_items_measurement\",\"ingredients_0_section_items_11_ingredient\":\"3 cups small broccoli florets\",\"_ingredients_0_section_items_11_ingredient\":\"field_recipe_ingredients_section_items_ingredient\",\"ingredients_0_section_items_12_quantity\":\"\",\"_ingredients_0_section_items_12_quantity\":\"field_recipe_ingredients_section_items_quantity\",\"ingredients_0_section_items_12_measurement\":\"\",\"_ingredients_0_section_items_12_measurement\":\"field_recipe_ingredients_section_items_measurement\",\"ingredients_0_section_items_12_ingredient\":\"Fresh basil leaves\",\"_ingredients_0_section_items_12_ingredient\":\"field_recipe_ingredients_section_items_ingredient\",\"ingredients_0_section_items\":13,\"_ingredients_0_section_items\":\"field_recipe_ingredients_section_items\",\"ingredients_0_section\":\"\",\"_ingredients_0_section\":\"field_recipe_ingredients_section\",\"ingredients\":1,\"_ingredients\":\"field_recipe_ingredients\",\"instructions_0_section_name\":\"\",\"_instructions_0_section_name\":\"field_recipe_instructions_section_name\",\"instructions_0_section_text\":\"Peel squash; halve squash and remove seeds. Cut squash into large pieces. Place squash pieces in a steamer basket in a large pan. Add water to saucepan to just below basket. Bring to boiling. Steam, covered, about 12 minutes or until tender.\",\"_instructions_0_section_text\":\"field_recipe_instructions_section_text\",\"instructions_0_section\":\"\",\"_instructions_0_section\":\"field_recipe_instructions_section\",\"instructions_1_section_name\":\"\",\"_instructions_1_section_name\":\"field_recipe_instructions_section_name\",\"instructions_1_section_text\":\"For oil-free: Heat a medium saucepan over medium. Add onion, garlic, thyme, and \\u00bc cup water to pan. Cook about 6 minutes or until onion is tender, stirring occasionally and adding water, 1 to 2 tablespoons. at a time, as needed to prevent sticking. \u003cem\u003e(If using oil: In a medium saucepan, heat olive oil, then add onion, garlic, and thyme. Cook about 6 minutes or until onion is tender, stirring occasionally.)\u003c\\/em\u003e\",\"_instructions_1_section_text\":\"field_recipe_instructions_section_text\",\"instructions_1_section\":\"\",\"_instructions_1_section\":\"field_recipe_instructions_section\",\"instructions_2_section_name\":\"\",\"_instructions_2_section_name\":\"field_recipe_instructions_section_name\",\"instructions_2_section_text\":\"Transfer onion mixture to a blender. Add squash and the next five ingredients (through pepper). Cover and blend until smooth. Pour squash mixture into a large saucepan.\",\"_instructions_2_section_text\":\"field_recipe_instructions_section_text\",\"instructions_2_section\":\"\",\"_instructions_2_section\":\"field_recipe_instructions_section\",\"instructions_3_section_name\":\"\",\"_instructions_3_section_name\":\"field_recipe_instructions_section_name\",\"instructions_3_section_text\":\"Cook pasta according to package directions, adding broccoli the last 5 minutes of cooking; drain. Add drained pasta and broccoli to squash mixture; toss to coat. Serve warm topped with fresh basil.\",\"_instructions_3_section_text\":\"field_recipe_instructions_section_text\",\"instructions_3_section\":\"\",\"_instructions_3_section\":\"field_recipe_instructions_section\",\"instructions\":4,\"_instructions\":\"field_recipe_instructions\"},\"mode\":\"auto\"}","recipe":{"author":null,"category":"Vegan Noodles \u0026amp; Pasta Recipes","cook_time":{"days":"0","hours":"0","minutes":"30"},"cuisine":"","suitable_for_diet":null,"chicory":null,"description":"","image":"https://www.forksoverknives.com/uploads/butternut-broccoli-mac-and-cheese-wordpress.jpg?auto=webp","ingredients":[{"title":"","items":[{"ingredient":"1 medium butternut squash (1¾ lb.)","measurement":"","quantity":""},{"ingredient":"1 tablespoon extra-virgin olive oil (optional, \u003ca href=\"#h-tips\"\u003elearn more\u003c/a\u003e)","measurement":"","quantity":""},{"ingredient":"1 onion, finely chopped (1 cup)","measurement":"","quantity":""},{"ingredient":"4 cloves garlic, minced","measurement":"","quantity":""},{"ingredient":"½ teaspoon finely chopped fresh thyme","measurement":"","quantity":""},{"ingredient":"1 cup unsweetened, unflavored plant milk","measurement":"","quantity":""},{"ingredient":"2 tablespoons nutritional yeast","measurement":"","quantity":""},{"ingredient":"1 tablespoon white wine vinegar","measurement":"","quantity":""},{"ingredient":"½ teaspoon sea salt","measurement":"","quantity":""},{"ingredient":"⅛ teaspoon freshly ground black pepper","measurement":"","quantity":""},{"ingredient":"3 cups dried whole grain penne pasta (8 oz.)","measurement":"","quantity":""},{"ingredient":"3 cups small broccoli florets","measurement":"","quantity":""},{"ingredient":"Fresh basil leaves","measurement":"","quantity":""}]}],"instructions":[{"text":"Peel squash; halve squash and remove seeds. Cut squash into large pieces. Place squash pieces in a steamer basket in a large pan. Add water to saucepan to just below basket. Bring to boiling. Steam, covered, about 12 minutes or until tender.","name":""},{"text":"For oil-free: Heat a medium saucepan over medium. Add onion, garlic, thyme, and ¼ cup water to pan. Cook about 6 minutes or until onion is tender, stirring occasionally and adding water, 1 to 2 tablespoons. at a time, as needed to prevent sticking. \u003cem\u003e(If using oil: In a medium saucepan, heat olive oil, then add onion, garlic, and thyme. Cook about 6 minutes or until onion is tender, stirring occasionally.)\u003c/em\u003e","name":""},{"text":"Transfer onion mixture to a blender. Add squash and the next five ingredients (through pepper). Cover and blend until smooth. Pour squash mixture into a large saucepan.","name":""},{"text":"Cook pasta according to package directions, adding broccoli the last 5 minutes of cooking; drain. Add drained pasta and broccoli to squash mixture; toss to coat. Serve warm topped with fresh basil.","name":""}],"keywords":"","name":"Butternut Squash Mac and Cheese with Broccoli","nutrition":"490","carbohydrate_content":"104","cholesterol_content":"0","fat_content":"5","fiber_content":"10","protein_content":"22","saturated_fat_content":"0","serving_size":"2 cups","sodium_content":"651","sugar_content":"12","trans_fat_content":"","unsaturated_fat_content":"","prep_time":{"days":"0","hours":"0","minutes":"30"},"pub_date":"2020-09-01 11:32:50","serves":"Makes 6 cups","mealplannerRecipeId":"8238"},"innerBlocks":[]}]}}},"dataUpdateCount":1,"dataUpdatedAt":1778948478409,"error":null,"errorUpdateCount":0,"errorUpdatedAt":0,"fetchFailureCount":0,"fetchFailureReason":null,"fetchMeta":null,"isInvalidated":false,"status":"success","fetchStatus":"idle"},"queryKey":[["url"],"/recipes/vegan-pasta-noodles/butternut-mac-and-cheese-broccoli/","/recipes/vegan-pasta-noodles/butternut-mac-and-cheese-broccoli/","",0,25,"DATE"],"queryHash":"[[\"url\"],\"/recipes/vegan-pasta-noodles/butternut-mac-and-cheese-broccoli/\",\"/recipes/vegan-pasta-noodles/butternut-mac-and-cheese-broccoli/\",\"\",0,25,\"DATE\"]"},{"state":{"data":{"post":{"rating":5,"reviewCount":67,"databaseId":128191,"comments":{"nodes":[{"databaseId":78629,"date":"2025-11-11 00:20:11","parentDatabaseId":0,"rawContent":"Had absolutely no flavour. FOK recipes I've tried so far have been fantastic but this was a definite miss.","rating":"2","author":{"node":{"name":"Jerrie"}}},{"databaseId":76997,"date":"2025-04-15 13:23:26","parentDatabaseId":0,"rawContent":"I did not read the comments before making this recipe.  Saying that, I made a few adjustments such as I added the cubed butternut squash after sautéing the onion, garlic and thyme, I left it in the pan, covered until the squash was almost tender, then I uncovered the pan and allowed the liquid to evaporate until there was only about half a cupful or so of liquid left in the pan. (Even if you steam the squash, it still contains a lot of liquid.)  Then added all the other ingredients and used a stick blender.  I thought it was a good sauce recipe.  You can add more ingredients and have as a soup if you wanted to, just add some stock and roasted red peppers from a jar,  pinch of cayenne pepper and a little smoked paprika before blending and serve with a swirl of vegan natural yogurt. I found the sauce to be thick enough to coat the pasta. I gave mine a swirl of sriracha once served in the dish.  I think this is a nice recipe. I do have plenty of sauce left so I will use with spaghetti and maybe add peas too. It’s easy to adapt to your own liking - thank you for the recipe. ","rating":"4","author":{"node":{"name":"Maria"}}},{"databaseId":75465,"date":"2025-02-01 04:24:05","parentDatabaseId":0,"rawContent":"","rating":"","author":{"node":{"name":"Julie"}}},{"databaseId":75419,"date":"2025-01-28 00:23:34","parentDatabaseId":0,"rawContent":"This was so, so bland even though I added garlic powder, onion powder, tons of red pepper flakes, and more salt. Just not a great flavor and my palate is quite accustomed to WFPB diet so can't blame that! I wish I'd read some of the suggestions beforehand, I really don't think I'll try it again (no one in my family could even finish one serving). I do agree with some comments that I'd rather use one of my go-to fake queso recipes and just add pasta and broccoli.","rating":"2","author":{"node":{"name":"Anne"}}},{"databaseId":75363,"date":"2025-01-23 20:06:59","parentDatabaseId":0,"rawContent":"I had more sauce than needed, so I added oat milk because I was out of almond milk and some white mayo and a drizzle of maple syrup and made a soup soup out of the leftover sauce. It was pretty good.","rating":"","author":{"node":{"name":"Sandy"}}},{"databaseId":75355,"date":"2025-01-23 04:00:07","parentDatabaseId":0,"rawContent":"I just made this.  It’s delicious but needed more nutritional yeast \u0026amp; salt. ","rating":"","author":{"node":{"name":"Deborah W"}}},{"databaseId":75339,"date":"2025-01-21 23:14:09","parentDatabaseId":0,"rawContent":"I only had Oat milk, and the sauce was very watery. Not sure if 2 cups was too much or if it was the consistency of oat milk. But what a great recipe! I also used Garbanzo Bean Macaroni for more protein.","rating":"","author":{"node":{"name":"Linda Watkins"}}},{"databaseId":75333,"date":"2025-01-21 14:53:31","parentDatabaseId":0,"rawContent":"Someone stated in a post that they make oat yogurt. I would love to have a recipes for that if you would not mind sharing.","rating":"","author":{"node":{"name":"DD"}}},{"databaseId":75331,"date":"2025-01-21 07:55:54","parentDatabaseId":0,"rawContent":"","rating":"5","author":{"node":{"name":"Владимир"}}},{"databaseId":75330,"date":"2025-01-21 04:10:15","parentDatabaseId":0,"rawContent":"Is it possible to leave out the nutritional yeast?","rating":"","author":{"node":{"name":"Mary Beth Johnson"}}},{"databaseId":75324,"date":"2025-01-20 22:40:39","parentDatabaseId":0,"rawContent":"After reading all the comments, I was nervous of the sweetness factor.  Instead I added half a roasted acorn squash to the Forks Over Knives Queso https://www.forksoverknives.com/recipes/vegan-sauces-condiments/vegan-queso-sauce/  It was good.","rating":"","author":{"node":{"name":"SJ"}}},{"databaseId":75323,"date":"2025-01-20 20:46:14","parentDatabaseId":0,"rawContent":"","rating":"","author":{"node":{"name":"Fay"}}},{"databaseId":75322,"date":"2025-01-20 18:49:44","parentDatabaseId":0,"rawContent":"Thank you for your recipe. I know when I started eating a WFPB diet it was hard as there wasn’t the junk in it and but I felt better after eating it. Because it’s real food. I would like to encourage others to adjust the recipe to suit your taste buds and sharing your additions to help others stay on the path of healthier eating. \nAs Chef John says, “you’ll be the winner of how you make your own dinner”. ","rating":"5","author":{"node":{"name":"Joyce"}}},{"databaseId":75314,"date":"2025-01-20 17:58:02","parentDatabaseId":75280,"rawContent":"I also don't have a sweet tooth and found the sweetness off-putting for mac and \"cheese\".  I loved the idea and texture though, so I tried various modifications to cut the sweetness.  Adding more acid (lemon juice or vinegar) didn't work for me at all, and I even tried lactic acid powder.  Blending in a handful of cashews helped some, but I sure don't need all those extra calories.  Another time I had a half can of white beans in the fridge I needed to use, and a bag of already steamed yellow potatoes, so I tossed the beans and a few little potatoes into the blender along with the other ingredients, and added a big dollop of homemade oat yogurt and a small squirt of dijon, which both cut and masked the sweetness. Suited my tastes much better.  \nI get why recipes trying to stand-in for forbidden favorites are named after them, but I also think getting set up for the expectation of same is usually pretty disappointing.  I really do like butternut squash, but not as an imposter for \"cheese\";  there are other sauces I prefer for that.  This is one of them right here... https://www.forksoverknives.com/recipes/vegan-sauces-condiments/vegan-queso-sauce/","rating":"","author":{"node":{"name":"VeggieT8r"}}},{"databaseId":75311,"date":"2025-01-20 17:17:47","parentDatabaseId":0,"rawContent":"I made this with silken tofu plus just enough soy milk to get it to thr consistency I wanted. I thought it was too bland, so added 2 tablespoons of white miso and a bit of liquid smoke, as well as smoked paprika and lemon juice and cider. \n\nIt was so delicious, that I ate some with crackers and some mixed  with tomato salsa and tortilla chips chips. I will make batches of this to then serve in various ways. I cooked chickpea pasta to up my protein when I ate it as intended. ","rating":"","author":{"node":{"name":"Marilyn Kircus"}}},{"databaseId":75310,"date":"2025-01-20 16:55:46","parentDatabaseId":0,"rawContent":"I've not made this recipe yet but wanted to read the comments/suggestions before doing so. Lots of folks mentioned it being too sweet and not savory enough. A suggestion is to consider adding store-bought \"poultry seasoning\" which is a mixture of spices that add savory flavors. One can also add Better Than Bouillon to deepen the flavoring: https://www.betterthanbouillon.com/products/seasoned-vegetable-base/?srsltid=AfmBOoqkM-o3FPPwIPgZhQm1W7ZTcmIf8ABcoy9BkN8UkoU8Gf5dYVU_\n\nBetter Than Bouillon also has an entire line of vegan/vegetarian bouillon flavorings:  https://www.betterthanbouillon.com/our-products/?group=vegetarian\nThey can be high in salt but they also have low salt versions of some products. \nI am not affiliated with them, just want to share some helpful tips.","rating":"5","author":{"node":{"name":"Rachel"}}},{"databaseId":75309,"date":"2025-01-20 16:38:11","parentDatabaseId":0,"rawContent":"You did not have to give a one star though. I thought that was kind of cheesy. Someone was nice enough to share a recipe. ","rating":"","author":{"node":{"name":"Paul"}}},{"databaseId":75280,"date":"2025-01-19 05:10:26","parentDatabaseId":0,"rawContent":"I’m going to be completely honest, although I’ve only been on the plant-based diet for only two weeks now. This recipe was super tough for me. I tried to spruce up the “butternut cheese sauce” by adding more white wine vinegar, salt, and nutritional yeast. But it just didn’t do it for me. I couldn’t even finish the meal. I’ve seen other recipes where people have used nuts like cashews and water and mixed it into a blender, so I’m going to try that as a “cheese sauce” next. Super sad, this one just didn’t do it for me. I also don’t have a sweet tooth so the sweetness from the butternut squash was too over powering for me. Thank you for the thoughtful recipe but my taste buds did not enjoy this unfortunately","rating":"1","author":{"node":{"name":"Nancy"}}},{"databaseId":75010,"date":"2024-12-28 23:08:08","parentDatabaseId":0,"rawContent":"..searching for vegan recipe for a long time…I will never cook regular Mac and cheese again this is so good with broccoli! Thank you for this recipe!! ..reduced the salt and sub yeast with coconut amino acid. ","rating":"5","author":{"node":{"name":"Amy"}}},{"databaseId":74411,"date":"2024-11-04 22:06:07","parentDatabaseId":0,"rawContent":"I made this after reviewing the comments. Only used 1 cup of almond milk. Perfect consistency. I also roasted the squash in the oven (with some garlic powder)  as opposed to steaming it. Great flavor. I did not find it to be too sweet. A great recipe with some minor tweaks.","rating":"5","author":{"node":{"name":"Jan"}}},{"databaseId":74147,"date":"2024-10-09 20:18:28","parentDatabaseId":0,"rawContent":"I made this today and it was delicious! I used unsweetened almond milk.","rating":"5","author":{"node":{"name":"D. Doyne"}}},{"databaseId":73103,"date":"2024-07-01 15:59:34","parentDatabaseId":0,"rawContent":"love love love this recipe. Highly recommend reading the comments for lots of ideas for variations","rating":"","author":{"node":{"name":"Kate"}}},{"databaseId":71930,"date":"2024-02-24 03:44:28","parentDatabaseId":0,"rawContent":"I used Kabocha squash and one cup of milk omitted the vinegar. Add extra nutritional yeast. It was very delicious. Add milk as needed 😋 ","rating":"","author":{"node":{"name":"C Powell"}}},{"databaseId":71844,"date":"2024-02-16 00:48:40","parentDatabaseId":0,"rawContent":"This was wayyyy too sweet. We felt like we were eating “pudding pasta.” My son loved it, but my husband and I had to muscle through it. Won’t be making this again. ","rating":"1","author":{"node":{"name":"Teresa"}}},{"databaseId":71402,"date":"2024-01-13 23:38:07","parentDatabaseId":0,"rawContent":"I make this often.  I use a 12 ounce package of frozen butternut squash cubes (I cut the recipe in half for the two of us), and add mushrooms.  The thyme didn’t do it for me so I use curry powder instead.","rating":"","author":{"node":{"name":"Genie"}}},{"databaseId":71182,"date":"2023-12-29 16:37:54","parentDatabaseId":0,"rawContent":"My changes include add half the amount of milk, roast a Kuri squash, roast a head of garlic and the best part: stir in roasted walnuts just before serving.","rating":"5","author":{"node":{"name":"Marry"}}},{"databaseId":70808,"date":"2023-11-25 02:26:46","parentDatabaseId":0,"rawContent":"Can I make this without yeast and vinegar? Thanks!","rating":"","author":{"node":{"name":"AllergyCity"}}},{"databaseId":70531,"date":"2023-11-05 13:30:00","parentDatabaseId":0,"rawContent":"Yummy, but too soupy! I would add only one cup of milk instead of two. I used a whole box 12oz. of Jovial GF fusilli which has been the best GF pasta I have found to date. Of course I added a little extra salt and pepper! I wonder about putting some chili flakes for a little heat. Maybe next time!","rating":"4","author":{"node":{"name":"Rebecca Waldron-Geranis"}}},{"databaseId":70513,"date":"2023-11-04 17:51:25","parentDatabaseId":0,"rawContent":"What a great recipe!  Used frozen sweet potatoes, two 10 oz bags, cooked in microwave for recommended time.  Everything else followed as written.  Used julienned snow peas   instead of broccoli, and love, love, love this recipe!  I prefer this Mac and “cheese” version over the cashew one.  I’m really loving learning to cook all over again with fok!","rating":"","author":{"node":{"name":"Granny K"}}},{"databaseId":69995,"date":"2023-09-21 22:28:53","parentDatabaseId":0,"rawContent":"Found this recipe to be disappointing. Read the other reviews that were helpful, but the butternut squash was too sweet. It tasted better the next day, but I will not make this again.","rating":"3","author":{"node":{"name":"Jill"}}},{"databaseId":69962,"date":"2023-09-17 20:18:46","parentDatabaseId":69466,"rawContent":"This is a great recipe, but I highly recommend you use kabocha or kuri squash instead.  Kuri squash in particular has a lovely creamy consistency that will make for a better sauce. Also, if you have time to roast the squash instead of boil, I think it tastes better. I roasted my squash, added it to cashew milk as it was heating in a saucepan,  mashed it (an immersion blender works well here), till it was to my liking. Also start with less milk than you think you'll need and add more as you go.","rating":"4","author":{"node":{"name":"Gabriella Durango"}}},{"databaseId":69466,"date":"2023-07-31 11:20:47","parentDatabaseId":0,"rawContent":"Delicious!! I added one more table spoon of nutritional yeast and instrad of broccoli i used spinach and extra garlic its delicious and healthy!!","rating":"5","author":{"node":{"name":"Fatima Delgado"}}},{"databaseId":69106,"date":"2023-06-28 17:05:35","parentDatabaseId":65850,"rawContent":"Nutmeg and cayenne","rating":"","author":{"node":{"name":"Em"}}},{"databaseId":68882,"date":"2023-06-10 13:48:38","parentDatabaseId":0,"rawContent":"My son made it for me and it was great!","rating":"","author":{"node":{"name":"Paul Simpson Sr"}}},{"databaseId":68607,"date":"2023-05-16 11:23:22","parentDatabaseId":0,"rawContent":"Why won't this recipe print or any of the recipes from the email received from FOKs dated May 13, 2023 @ 11:08.\r\n\"MOST POPULAR FOK RECIPES\r\nOUR TOP 25 FAN-FAVORITES\"?","rating":"","author":{"node":{"name":"Kate"}}},{"databaseId":68526,"date":"2023-05-09 22:42:54","parentDatabaseId":0,"rawContent":"I used doubled the yeast and added vegetable stock tablets for a more \"cheesy\" taste, I also put the blended mixture back in a pot on the oven to thicken a little before adding the pasta and broccoli, it tastes great.","rating":"","author":{"node":{"name":"Esther"}}},{"databaseId":68330,"date":"2023-04-24 09:38:32","parentDatabaseId":0,"rawContent":"After reading the other reviews, I only added 1 cup of oat milk. That have me perfect clingy texture. It was a little sweet but after adding extra salt and pepper it was good. I'm at the beginning of my wfpb journey so hopefully after my taste buds adjust I won't need so much salt.","rating":"4","author":{"node":{"name":"Amanda L"}}},{"databaseId":68161,"date":"2023-04-11 16:48:24","parentDatabaseId":0,"rawContent":"So yummy. I didn’t realize we were out of broccoli until it was time to add it, so I used spinach instead. It was great.","rating":"5","author":{"node":{"name":"Whit"}}},{"databaseId":67754,"date":"2023-03-12 19:10:38","parentDatabaseId":67753,"rawContent":"If you try this recipe again, add a sweet potato and perhaps less squash. The touch of sweetness is really nice.","rating":"","author":{"node":{"name":"Linda Aikey"}}},{"databaseId":67753,"date":"2023-03-12 19:03:03","parentDatabaseId":0,"rawContent":"When I have too much of a soupy version I add some oatmeal, perhaps a cup ground in food processor. Then because of it being mac and cheese, more nutritional yeast. Then I sprinkle to taste between 1/8 to 1/4 tsp: sea salt, garlic powder, onion powder, turmeric, ginger, curry, dry mustard, paprika, cumin and cayenne pepper. Lemon juice works for me too. It zings up the taste buds.","rating":"","author":{"node":{"name":"Linda Aikey"}}},{"databaseId":67740,"date":"2023-03-12 08:15:17","parentDatabaseId":66848,"rawContent":"I'm a part time vegan but 2 of my kids are plus 2 grand kids. I've found the Non Fortified nutritional yeast is by far the best tasting. The fortified has B vitamins added and yuck, it's awful. \r\nPlus I don't call it cheese or Mac n cheese. For my non vegans this conjures up a certain look and taste. I just call it creamy pasta.","rating":"","author":{"node":{"name":"Patti"}}},{"databaseId":67727,"date":"2023-03-11 12:53:39","parentDatabaseId":66848,"rawContent":"Keep trying :) I find it gets better and better as your taste buds get a custom to good food :)","rating":"","author":{"node":{"name":"Thea Lesnik"}}},{"databaseId":67705,"date":"2023-03-10 09:22:31","parentDatabaseId":67691,"rawContent":"Anyone know the calorie count for this?","rating":"","author":{"node":{"name":"Brian Rogers"}}},{"databaseId":67691,"date":"2023-03-09 18:36:53","parentDatabaseId":0,"rawContent":"BeautifuL!!! Thank you!! ","rating":"","author":{"node":{"name":"Arturo"}}},{"databaseId":67134,"date":"2023-02-04 23:26:42","parentDatabaseId":66848,"rawContent":"Violife Parmesan cheese is a great substitute for nutritional yeast.  You could purchase it at Fresh Thyme in your area.  Substituting the white wine vinegar with fresh lemon juice gives it a clean and fresh taste.  At times when I find a recipe, I tweak it with flavors I like.","rating":"5","author":{"node":{"name":"Margarita Crupe"}}},{"databaseId":67121,"date":"2023-02-04 15:24:42","parentDatabaseId":66848,"rawContent":"I always add Franks hot sauce- you can’t go wrong (I put that $h*t on everything)","rating":"","author":{"node":{"name":"Lou"}}},{"databaseId":67114,"date":"2023-02-04 12:19:15","parentDatabaseId":66848,"rawContent":"I’m finding the recipes on this site bland as well. There’s a lot of vegan Mac n cheese out there that are super tasty. Just don’t expect them to taste exactly like cheese. Keep searching!","rating":"","author":{"node":{"name":"Dena O’Neill"}}},{"databaseId":67103,"date":"2023-02-04 07:17:55","parentDatabaseId":65814,"rawContent":"It’s printable- select print/save, then open in browser, then print like you would from your phone","rating":"","author":{"node":{"name":"Janine"}}},{"databaseId":67102,"date":"2023-02-04 07:04:36","parentDatabaseId":34994,"rawContent":"Making a roux to mix in with the butter squash will give it more creaminess. I also add nutmeg and a splash of maggi or liquid aminos for a better taste.","rating":"","author":{"node":{"name":"Gabrielle"}}},{"databaseId":66902,"date":"2023-01-24 10:29:14","parentDatabaseId":64958,"rawContent":"Just add more nutritional yeast. I put 6-8 tablespoons in my “cheese” sauces, along with plenty of sea salt, black pepper, a teaspoon of Miso, a heaped tsp or two of onion and garlic granules. For extra richness you can also add some soya cream (i use Alpro or Oatly).","rating":"","author":{"node":{"name":"Mandy"}}},{"databaseId":66848,"date":"2023-01-21 18:45:49","parentDatabaseId":0,"rawContent":"This recipe definitely didn't do it for me. I don't know why I keep expecting miracles from vegan recipes. This did not taste cheesy at all. It's my first time using nutritional yeast as a \"cheesy\" substitute and I'll probably never use it again.","rating":"2","author":{"node":{"name":"Casey"}}},{"databaseId":66188,"date":"2022-12-14 16:09:05","parentDatabaseId":0,"rawContent":"Used 1 1/2 cups of almond milk instead of 2. Perfect consistency and delicious!!\r\nThank you for this recipe!","rating":"5","author":{"node":{"name":"Lorraine"}}},{"databaseId":66061,"date":"2022-12-09 18:37:07","parentDatabaseId":65749,"rawContent":"MAKE IT 2 WEEKS BEFORE, this is not a one and done! See comments about soupy and bland.","rating":"1","author":{"node":{"name":"Sammie J"}}},{"databaseId":65890,"date":"2022-11-30 15:28:33","parentDatabaseId":0,"rawContent":"","rating":"5","author":{"node":{"name":"Chris"}}},{"databaseId":65865,"date":"2022-11-28 17:37:16","parentDatabaseId":65850,"rawContent":"It was pretty good.  I did add more nutritional yeast and hot sauce.","rating":"4","author":{"node":{"name":"Chili Dave"}}},{"databaseId":65864,"date":"2022-11-28 17:35:31","parentDatabaseId":0,"rawContent":"","rating":"2","author":{"node":{"name":"Mary"}}},{"databaseId":65850,"date":"2022-11-27 17:03:51","parentDatabaseId":0,"rawContent":"Was pretty good. Took others comments into account and added more nutritional yeast, used lemon juice instead of vinegar, added some hot sauce, used leeks instead of onion, but still a bit bland and soupy. Added some chopped Kale with broccoli. Needs something else.....","rating":"4","author":{"node":{"name":"Elsa"}}},{"databaseId":65837,"date":"2022-11-27 08:33:00","parentDatabaseId":65814,"rawContent":"There is a print recipe option at the top of the recipe.  I just saved it as a pdf.","rating":"","author":{"node":{"name":"Candace Lamoree"}}},{"databaseId":65836,"date":"2022-11-27 08:09:39","parentDatabaseId":65814,"rawContent":"Agreed.  It's ridiculous.\r\n\r\nAs to the suggestion in a reply to your comment, using the file\u0026gt;print function (at least in Safari) results in a ridiculously wonky printout with giant empty spaces, overlapping type, instructions cut off or left out, and having to figure out which pages you need because otherwise it will print the entire webpage (upwards of 30 pages of paper).","rating":"","author":{"node":{"name":"Doireann"}}},{"databaseId":65831,"date":"2022-11-27 04:33:20","parentDatabaseId":0,"rawContent":"How many cups of cubed squash would that be?","rating":"","author":{"node":{"name":"Beth"}}},{"databaseId":65820,"date":"2022-11-26 10:57:22","parentDatabaseId":0,"rawContent":"Can i substitute nutritional yeast or leave out all together?","rating":"","author":{"node":{"name":"Joanne"}}},{"databaseId":65819,"date":"2022-11-26 10:28:49","parentDatabaseId":65814,"rawContent":"And to print, in the new screen that opens, in Chrome there should be a print button and in Safari go to File at the very top of the browser bar, click that and then click print","rating":"","author":{"node":{"name":"Ralph"}}},{"databaseId":65818,"date":"2022-11-26 10:26:09","parentDatabaseId":65814,"rawContent":"That’s always annoying!  They are printable from the app at least","rating":"","author":{"node":{"name":"Jasmine"}}},{"databaseId":65817,"date":"2022-11-26 10:25:27","parentDatabaseId":65814,"rawContent":"It is. At the top of the article is a print/save button. Click on that and it will open it as a pdf. Hold your curser near the bottom of the page and a little box with four options should open. The last, the down arrow, is the download button. Click that and download to your desktop or downloads folder. (I'm using safari but it works in Chrome browser too. In Chrome in the new window that opens, the download button is the down arrow at the top of the screen.","rating":"","author":{"node":{"name":"Ralph"}}},{"databaseId":65816,"date":"2022-11-26 10:19:51","parentDatabaseId":0,"rawContent":"","rating":"5","author":{"node":{"name":"DORRIE MCMONIGAL"}}},{"databaseId":65814,"date":"2022-11-26 09:15:57","parentDatabaseId":0,"rawContent":"Why can these recipes not be printable","rating":"","author":{"node":{"name":"Gail Fuson"}}},{"databaseId":65812,"date":"2022-11-26 06:27:37","parentDatabaseId":60981,"rawContent":"Chick peas is the move!Oh and playing with the spices.  I like coconut and oat milk but someone suggested coconut cream.  That’s what I used. Very good!  Great recipe!!! Glad I bought that squash even though I decided not to make what I’d planned.","rating":"","author":{"node":{"name":"Sharon"}}},{"databaseId":65749,"date":"2022-11-22 10:43:42","parentDatabaseId":0,"rawContent":"Because my husband and I will be attending a Thanksgiving dinner and we are now plant-based, I'll be trying this recipe to bring for us.  Glad I read all of the other comments as it'll give me a better idea for what to add and what to change.  THANKS!","rating":"","author":{"node":{"name":"Peggy"}}},{"databaseId":65682,"date":"2022-11-18 05:59:20","parentDatabaseId":0,"rawContent":"Made this last night using suggestions by other commenters.  Doubled up on the nutritional yeast and only used one cup of milk.  Added hot sauce and some Taijin seasoning.  It tasted pretty darn good.  I'd make it again.","rating":"4","author":{"node":{"name":"Steve"}}},{"databaseId":65273,"date":"2022-10-24 20:37:06","parentDatabaseId":64488,"rawContent":"Pretty good! Play with the seasoning to ensure you get it right. I added a little crushed red pepper for some heat and a lot more “nooch”. I also added sage. That helped.","rating":"3","author":{"node":{"name":"JC"}}},{"databaseId":65242,"date":"2022-10-22 20:12:53","parentDatabaseId":64958,"rawContent":"You can always add flour to the sauce.  There's also either cornstarch or arrowroot powder.","rating":"","author":{"node":{"name":"Julia"}}},{"databaseId":65200,"date":"2022-10-19 18:33:12","parentDatabaseId":0,"rawContent":"THIS is so delicious! Honestly, I was doubtful but wow was I 100% wrong. I will definitely prepare this again!","rating":"5","author":{"node":{"name":"Steph"}}},{"databaseId":64958,"date":"2022-10-05 14:55:24","parentDatabaseId":0,"rawContent":"I followed the directions exactly, and it was WAY too soupy. Any suggestions for thickening it up so this whole batch isn’t wasted?  Thank you.","rating":"2","author":{"node":{"name":"Ami Ross"}}},{"databaseId":64716,"date":"2022-09-20 12:12:25","parentDatabaseId":62759,"rawContent":"As a southern gal who grew up on yellow summer squash, I'd say no. The water content in summer squash is much higher than in winter squash.","rating":"","author":{"node":{"name":"D'Awn"}}},{"databaseId":64711,"date":"2022-09-19 17:58:51","parentDatabaseId":64596,"rawContent":"Trying it, looks good.","rating":"4","author":{"node":{"name":"Amy"}}},{"databaseId":64596,"date":"2022-09-11 16:19:04","parentDatabaseId":0,"rawContent":"Good!  Really needed more salt and mine was a little too soupy .  But I used peas instead of broccoli which would have taken up more volume.  But I love butternut squash, so I loved the taste.","rating":"4","author":{"node":{"name":"Susan Packwood"}}},{"databaseId":64488,"date":"2022-09-02 17:09:30","parentDatabaseId":0,"rawContent":"I really enjoyed this meal, and will make it again. As others stated, it was a bit bland. I did what one suggested and doubled the Nutritional Yeast. Then when I heated it to eat again, I sprinkled more Nutrtional Yeast, Onion Powder, and Thyme.","rating":"4","author":{"node":{"name":"Debbie"}}},{"databaseId":64017,"date":"2022-08-02 09:56:34","parentDatabaseId":0,"rawContent":"Have been wanting to find a good vegan mac and cheese recipe and this fills the spot. Easy to prepare. I used acorn squash as that is what I had on hand. It all came together so easily.","rating":"4","author":{"node":{"name":"DiAne"}}},{"databaseId":62937,"date":"2022-05-23 17:09:52","parentDatabaseId":62759,"rawContent":"They are two different types of squash so I'm not certain that would be a good substitute.","rating":"","author":{"node":{"name":"Betty"}}},{"databaseId":62837,"date":"2022-05-16 18:37:05","parentDatabaseId":0,"rawContent":"What are nutrients values?","rating":"","author":{"node":{"name":"Karole"}}},{"databaseId":62829,"date":"2022-05-16 15:55:20","parentDatabaseId":57770,"rawContent":"The sauce was sweet and an unusual taste… I added a bit of Frank’s hot sauce to counteract but ultimately I ended up adding tomato sauce and it was actually very good, just not a Mac n cheese dish","rating":"","author":{"node":{"name":"cathleen morris"}}},{"databaseId":62759,"date":"2022-05-14 11:12:38","parentDatabaseId":0,"rawContent":"Can you use Yellow summer squash?","rating":"","author":{"node":{"name":"Connie Reilly"}}},{"databaseId":62057,"date":"2022-03-29 17:05:05","parentDatabaseId":0,"rawContent":"OK this was really good. I did doctor it up a little bit though, I didn’t have any plant-based milk so I used a can of coconut cream. Everything else was pretty much the same I also added the franks hot sauce like some of the other readers commented. I will make this again.","rating":"4","author":{"node":{"name":"Josa Mendoza"}}},{"databaseId":61578,"date":"2022-03-01 18:09:59","parentDatabaseId":60981,"rawContent":"I like your addition of chickpeas!  When I make it I may add sweet peas, too, or maybe 1 inch cuts of steamed fresh green beans.","rating":"","author":{"node":{"name":"Carol"}}},{"databaseId":61577,"date":"2022-03-01 18:07:27","parentDatabaseId":0,"rawContent":"Beautiful - the colors are radiant.  I love Broccoli, I love Butternut Squash, and I Love Pasta!  I am in the third week of a 6 week juice fast and I am adding this recipe to the list of those I will be making after my cleanse is over.\r\nThank you for posting it!","rating":"5","author":{"node":{"name":"Carol"}}},{"databaseId":60981,"date":"2022-02-01 13:35:03","parentDatabaseId":0,"rawContent":"I made this to bring to work and I like it. Added a little extra nutritional yeast and vinegar. The basil really makes it for me. I'm going to add chickpeas and eat it with a side of broccoli when I go to work.","rating":"4","author":{"node":{"name":"Sarah"}}},{"databaseId":60973,"date":"2022-02-01 08:54:31","parentDatabaseId":0,"rawContent":"I was looking forward to try this recipe, but I must say I'm disappointed. The dish was way too bland, I was hoping for a deeper, more cheezy taste.Maybe with less milk and more nutritional yeast it would be better. But it definitely needs something to spice it up.","rating":"2","author":{"node":{"name":"Maja"}}},{"databaseId":60961,"date":"2022-01-31 22:37:39","parentDatabaseId":55457,"rawContent":"I didn’t know what to expect out of this but it was better than I thought. I, like others, added more spice as I felt it was a bit bland. I also added more pasta too to have a better pasta/sauce ratio.","rating":"3","author":{"node":{"name":"Colleen"}}},{"databaseId":60958,"date":"2022-01-31 18:42:21","parentDatabaseId":0,"rawContent":"Thank you for this recipe. I wanted to try this because I love squash. It wasn't a fantastic dish but it wasn't bad either. It definitely needs some extra spice. I added some garlic powder,  onion powder, and next time maybe some veggie broth while cooking the onions instead of water. I used the whole wheat elbows which is new for me also, getting used to that flavor. (my kids don't like the wheat pastas). It made a lot for just me eating it so I froze some hoping it will be good later. I'm new to plant based eating but open to try most any recipe.","rating":"","author":{"node":{"name":"Deb"}}},{"databaseId":60671,"date":"2022-01-21 10:52:40","parentDatabaseId":0,"rawContent":"I made this and it was super delicious! I will definitely add it to my plant-based recipe collection. I used about 800g of cubed butternut (we use the metric system in Namibia where I'm from), and my sauce had the perfect consistency and clung to the pasta very well.u","rating":"5","author":{"node":{"name":"Wilhelm van Greunen"}}},{"databaseId":60644,"date":"2022-01-19 23:32:33","parentDatabaseId":0,"rawContent":"Very tasty recipe. I roasted the cubed butternut squash instead of steaming it, and used oat milk. Yes, it is very saucy, but it is yummy squash puree, so all is forgiven.","rating":"5","author":{"node":{"name":"Valerie Russell"}}},{"databaseId":60523,"date":"2022-01-15 17:07:34","parentDatabaseId":0,"rawContent":"Best vegan Mac and cheese recipe I've made so far. It made alot of sauce. Next time I'll make twice as much pasta I think. A little bland but nothing some hot sauce couldn't fix","rating":"","author":{"node":{"name":"Elizabeth Conley"}}},{"databaseId":59414,"date":"2021-11-26 07:39:28","parentDatabaseId":0,"rawContent":"I don't think I'll make this again. The sauce was grainy and didn't cover the pasta, just sunk down to the bottom. I also had to add more seasoning.","rating":"3","author":{"node":{"name":"Jane"}}},{"databaseId":59336,"date":"2021-11-22 10:15:59","parentDatabaseId":0,"rawContent":"","rating":"5","author":{"node":{"name":"Karen Christie"}}},{"databaseId":59279,"date":"2021-11-20 09:45:03","parentDatabaseId":59268,"rawContent":"It works well with sweet potato and potato mix or just sweet potato. Carrot might work too.","rating":"","author":{"node":{"name":"Anna"}}},{"databaseId":59278,"date":"2021-11-20 09:28:24","parentDatabaseId":58891,"rawContent":"Linda, what size can of pumpkin puree did you use?  Thanks!","rating":"","author":{"node":{"name":"Carol"}}},{"databaseId":59268,"date":"2021-11-20 06:42:36","parentDatabaseId":0,"rawContent":"I love pasta, mac and cheese and broccoli, but I really don't like squash. And sub suggestions or is it a bust for me?","rating":"","author":{"node":{"name":"edith"}}},{"databaseId":59092,"date":"2021-11-13 09:48:24","parentDatabaseId":0,"rawContent":"We love this recipe. I didn’t have broccoli so I used carrots instead and it is so good. We will be having this again and again. I have also shared it with other, even if they are not plant based.","rating":"5","author":{"node":{"name":"Diane Cutler"}}},{"databaseId":59057,"date":"2021-11-11 15:39:29","parentDatabaseId":0,"rawContent":"This is not my favorite FoK recipe. I added lots more vegetables and some hot sauce.","rating":"3","author":{"node":{"name":"K Boyd"}}},{"databaseId":58932,"date":"2021-11-04 09:15:59","parentDatabaseId":58891,"rawContent":"Thanks for this review and all your tips! I’m going to try your suggestions :)","rating":"","author":{"node":{"name":"Sparti"}}},{"databaseId":58891,"date":"2021-11-02 06:35:31","parentDatabaseId":0,"rawContent":"Tasty and easy! I made a few modifications based on the reviews. I reduced the amount of oat milk to 1 cup, used a jar of pumpkin puree instead of butternut squash (lazy weeknight!), substituted lemon juice for the vinegar, and also roasted the onion, garlic, and broccoli in the oven. I topped the pasta with toasted pine nuts, a spring of rosemary, and chopped red chilis which added a nice spice. I'll definitely make this one again.","rating":"","author":{"node":{"name":"Linda"}}},{"databaseId":58334,"date":"2021-10-04 06:10:16","parentDatabaseId":0,"rawContent":"Easy to make and quite surprisingly creamy. It won't replace exactly the flavour of what you expect from a mac and cheese but enjoying it as an alternative and being open to trying something different, this delivers! It was a bit on the sweet side so I added a little more white wine vinegar and some miso paste. A tasty and healthy alternative to a comforting dish. We will definitely make again!","rating":"5","author":{"node":{"name":"Christina"}}},{"databaseId":58087,"date":"2021-09-21 18:58:32","parentDatabaseId":52274,"rawContent":"Wayyyy too much milk in this recipe. It came out more like squash soup with pasta and broccoli in it. That said, it was tasty. I would just use about half the amount of milk next time.","rating":"","author":{"node":{"name":"Peg"}}},{"databaseId":58084,"date":"2021-09-21 15:52:49","parentDatabaseId":52274,"rawContent":"New to this, I knew it wasn't going to be what I'm used to, but I do love my veggies. I felt it had way too much onion in it. Towards the end of my bowl, that's all I tasted. I also think it needs another seasoning added to it.\r\nOther than that, it was very healthy.","rating":"2","author":{"node":{"name":"Kris"}}},{"databaseId":57854,"date":"2021-09-10 04:21:05","parentDatabaseId":0,"rawContent":"","rating":"5","author":{"node":{"name":"Julie"}}},{"databaseId":57839,"date":"2021-09-09 07:44:36","parentDatabaseId":52274,"rawContent":"I’ve made this recipe many times. Delicious!","rating":"","author":{"node":{"name":"Marlo"}}},{"databaseId":57788,"date":"2021-09-05 16:21:47","parentDatabaseId":0,"rawContent":"It was delicious! Made a lot of sauce, so asking if can be frozen?","rating":"4","author":{"node":{"name":"Francine Shogel"}}},{"databaseId":57770,"date":"2021-09-04 15:19:32","parentDatabaseId":0,"rawContent":"Not made but will try for sure...could I sub low fat COCONUT milk/cream?","rating":"","author":{"node":{"name":"GP"}}},{"databaseId":57544,"date":"2021-08-27 06:30:59","parentDatabaseId":0,"rawContent":"As someone who didn't grow up with mac and cheese I really had no expectations and found this recipe to be better than anticipated (only roughly stuck to the proportions given though). The sauce was creamy and extremely filling (had it over leftover rice and steamed vegetables) and I didn't mind the sweet taste of the butternut squash. I substituted the plant milk with a couple of teaspoons of cashew butter and water. Next time I will use lemon juice instead of vinegar. Thyme wasn't at hand. Nutmeg might be good in this recipe. The only thing I didn't enjoy so much about this sauce was the oniony aftertaste due to the onions being cooked rather than fried/sautéed.","rating":"5","author":{"node":{"name":"EH"}}},{"databaseId":56836,"date":"2021-08-23 08:13:02","parentDatabaseId":0,"rawContent":"Wouldn’t normally take the time to comment but this was delicious! Will add more yeast and add salt at the table to taste. Creamy and nourishing!","rating":"5","author":{"node":{"name":"MB"}}},{"databaseId":55457,"date":"2021-08-14 14:55:06","parentDatabaseId":0,"rawContent":"This tastes delicious! Added less plant-based milk because it would have been too much. Was still plenty!","rating":"5","author":{"node":{"name":"Tina"}}},{"databaseId":55050,"date":"2021-08-11 15:06:59","parentDatabaseId":52181,"rawContent":"How many calories does this have per serving?","rating":"","author":{"node":{"name":"Sharyn"}}},{"databaseId":52274,"date":"2021-07-25 08:21:00","parentDatabaseId":0,"rawContent":"Sadly, this recipe didn't do it for me. Even with unsweetened milked, this meal tasted sweet and not savory. Also, it might be helpful to suggested squash quantity rather than \"medium\" as it I felt like there was too much squash. \r\n\r\nI am never a fan when I have to throw out food (grew up in a family where this was a practically a sin), but this meal could not be eatened.","rating":"1","author":{"node":{"name":"Sharon"}}},{"databaseId":52224,"date":"2021-07-24 10:53:57","parentDatabaseId":0,"rawContent":"Love butternut squash.","rating":"","author":{"node":{"name":"Geana a Johnson"}}},{"databaseId":52181,"date":"2021-07-24 06:45:44","parentDatabaseId":0,"rawContent":"This was simple to make but the flavor was a little too sweet for the family.","rating":"4","author":{"node":{"name":"Candice"}}},{"databaseId":50732,"date":"2021-07-15 21:24:20","parentDatabaseId":0,"rawContent":"I really wanted to love this! I felt it was too much sauce to pasta ratio and it wasn’t a bold enough flavour for me, maybe with less milk would have been better and more nutritional yeast. Thankyou for the recipe, Nice to give it a try, just wasn’t for me :)","rating":"1","author":{"node":{"name":"CJ"}}},{"databaseId":50545,"date":"2021-07-14 11:42:59","parentDatabaseId":0,"rawContent":"Really yummy! I've made another vegan Mac \u0026amp; cheese before and it was not half as delicious as this one. Great texture as well. And I like that it incorporates broccoli, which includes a green vegetable.","rating":"","author":{"node":{"name":"Didi Lacroix"}}},{"databaseId":50115,"date":"2021-07-13 06:56:56","parentDatabaseId":49640,"rawContent":"In point 3 the instruction is \"add the next five ingredients\", this includes the vinegar. ","rating":"","author":{"node":{"name":"Hilary Thompson"}}},{"databaseId":49640,"date":"2021-07-09 23:30:30","parentDatabaseId":0,"rawContent":"When is the vinegar added? I can't se it in the instructions.","rating":"","author":{"node":{"name":"Deb Lee"}}},{"databaseId":45743,"date":"2021-06-25 09:12:28","parentDatabaseId":18943,"rawContent":"Absolutely","rating":"","author":{"node":{"name":"Sueathome"}}},{"databaseId":45737,"date":"2021-06-25 09:11:37","parentDatabaseId":0,"rawContent":"I made this and it is divine! I replace vinegar with lemon juice. I never use the yeast. It was superb!","rating":"5","author":{"node":{"name":"Sueathome"}}},{"databaseId":37934,"date":"2021-06-16 17:56:36","parentDatabaseId":18948,"rawContent":"Can't wait to try this!","rating":"","author":{"node":{"name":"Kathleen Baas"}}},{"databaseId":34994,"date":"2021-06-15 14:42:49","parentDatabaseId":0,"rawContent":"This is absolutely delicious!!\r\nIs the nutritional information available?","rating":"5","author":{"node":{"name":"Melinda W"}}},{"databaseId":28807,"date":"2021-06-13 22:38:19","parentDatabaseId":0,"rawContent":"A very tasty and healthy recipe. Not too complicated to make. Great for taking to work and reheating too.","rating":"5","author":{"node":{"name":"Angie"}}},{"databaseId":18948,"date":"2021-05-29 03:32:25","parentDatabaseId":0,"rawContent":"Even when I was not a vegetarian or a vegan I put broccoli, or cauliflower, in my macaroni and cheese.  I can't wait to make this!","rating":"5","author":{"node":{"name":"Mary Ciulla"}}},{"databaseId":18943,"date":"2021-05-28 22:07:35","parentDatabaseId":0,"rawContent":"Wondering if I can use frozen butternut squash??","rating":"","author":{"node":{"name":"Corinne Krepel"}}},{"databaseId":18403,"date":"2021-05-24 20:02:38","parentDatabaseId":12054,"rawContent":"This dish is delicious. I’m the only vegan in my household and getting my husband and kids on board can be a challenge. This dish is a hit with my entire family. Including my father who is a diehard vegan critic","rating":"5","author":{"node":{"name":"Dannielle"}}},{"databaseId":13828,"date":"2021-04-26 09:31:47","parentDatabaseId":0,"rawContent":"Never thought it would be this good!","rating":"5","author":{"node":{"name":"Jennifer"}}},{"databaseId":13718,"date":"2021-04-25 02:18:00","parentDatabaseId":0,"rawContent":"What a lovely,  creamy dish. This dish was very easy to make, and tasted great, I will definitely make this again","rating":"5","author":{"node":{"name":"Jackie Heath"}}},{"databaseId":12596,"date":"2021-04-19 18:29:17","parentDatabaseId":0,"rawContent":"This was delicious! 10/10 will make again!","rating":"5","author":{"node":{"name":"Allyson"}}},{"databaseId":12054,"date":"2021-04-17 21:18:29","parentDatabaseId":0,"rawContent":"Yummy comfort food","rating":"5","author":{"node":{"name":"Marg"}}},{"databaseId":11940,"date":"2021-04-17 08:40:40","parentDatabaseId":0,"rawContent":"My kids and I love this!  I use elbow style macaroni and plenty of broccoli.","rating":"5","author":{"node":{"name":"Donna"}}},{"databaseId":11844,"date":"2021-04-16 14:06:09","parentDatabaseId":0,"rawContent":"I have no idea why broccoli is so good with cheese but it is - and that nutritional yeast always gives food a nice cheesy flavor!","rating":"5","author":{"node":{"name":"aram"}}}]}}},"dataUpdateCount":1,"dataUpdatedAt":1778948479546,"error":null,"errorUpdateCount":0,"errorUpdatedAt":0,"fetchFailureCount":0,"fetchFailureReason":null,"fetchMeta":null,"isInvalidated":false,"status":"success","fetchStatus":"idle"},"queryKey":["template-query","FokcommentsQuery","128191"],"queryHash":"[\"template-query\",\"FokcommentsQuery\",\"128191\"]"},{"state":{"data":{"authorTag":{"author":{"authorBio":"\u003cp\u003eDarshana Thacker Wendel is a whole-food, plant-based chef and former culinary projects manager for Forks Over Knives. A graduate of the Natural Gourmet Institute, she is the author of\u003ca target=\"_self\" href=\"https://shop.forksoverknives.com//products/forks-over-knives-flavor\"\u003e \u003cem\u003eForks Over Knives: Flavor!\u003c/em\u003e\u003c/a\u003e She created the recipes for\u003cem\u003e\u003ca target=\"_self\" href=\"https://shop.forksoverknives.com/products/forks-over-knives-family\"\u003e Forks Over Knives Family\u003c/a\u003e\u003c/em\u003e and was a lead recipe contributor to the New York Times bestseller\u003cem\u003e\u003ca rel=\"sponsored nofollow noopener noreferrer\" target=\"_blank\" href=\"https://www.amazon.com/gp/product/1476753296/ref=as_li_qf_sp_asin_il_tl?ie=UTF8\u0026camp=1789\u0026creative=9325\u0026creativeASIN=1476753296\u0026linkCode=as2\u0026tag=flexpress-no-tag-20\u0026asc_source=browser\u0026asc_refurl=https%3A%2F%2Fcms.forksoverknives.com%2Fwp%2Fgraphql\u0026ascsubtag=0000FOK0000000000O0000000020260516160000\"\u003e The Forks Over Knives Plan\u003c/a\u003e\u003c/em\u003e. Her recipes have been published in\u003cem\u003e\u003ca href=\"https://www.amazon.com/dp/B00JPR5JE6/ref=dp-kindle-redirect?_encoding=UTF8\u0026btkr=1\u0026tag=flexpress-no-tag-20\u0026asc_source=browser\u0026asc_refurl=https%3A%2F%2Fcms.forksoverknives.com%2Fwp%2Fgraphql\u0026ascsubtag=0000FOK0000000000O0000000020260516160000\" target=\"_blank\" rel=\"sponsored nofollow noopener noreferrer\"\u003e The Prevent and Reverse Heart Disease Cookbook\u003c/a\u003e\u003c/em\u003e, \u003cem\u003e\u003ca href=\"https://shop.forksoverknives.com/products/forks-over-knives-the-cookbook\" target=\"_self\" rel=\"noopener\"\u003eForks Over Knives—The Cookbook\u003c/a\u003e\u003c/em\u003e,\u003cem\u003e\u003ca target=\"_self\" href=\"https://shop.forksoverknives.com/products/forks-over-knives-the-plant-based-way-to-health\"\u003e Forks Over Knives: The Plant-Based Way to Health\u003c/a\u003e\u003c/em\u003e, and LA Yoga magazine online.\u003c/p\u003e\n"}}},"dataUpdateCount":1,"dataUpdatedAt":1778948479169,"error":null,"errorUpdateCount":0,"errorUpdatedAt":0,"fetchFailureCount":0,"fetchFailureReason":null,"fetchMeta":null,"isInvalidated":false,"status":"success","fetchStatus":"idle"},"queryKey":["template-query","authorBioQuery","10016"],"queryHash":"[\"template-query\",\"authorBioQuery\",\"10016\"]"},{"state":{"data":{"post":{"totalShareCount":11813}},"dataUpdateCount":1,"dataUpdatedAt":1778948479218,"error":null,"errorUpdateCount":0,"errorUpdatedAt":0,"fetchFailureCount":0,"fetchFailureReason":null,"fetchMeta":null,"isInvalidated":false,"status":"success","fetchStatus":"idle"},"queryKey":["template-query","socialShareQuery","128191"],"queryHash":"[\"template-query\",\"socialShareQuery\",\"128191\"]"},{"state":{"data":{"forkAds":null},"dataUpdateCount":1,"dataUpdatedAt":1778948479222,"error":null,"errorUpdateCount":0,"errorUpdatedAt":0,"fetchFailureCount":0,"fetchFailureReason":null,"fetchMeta":null,"isInvalidated":false,"status":"success","fetchStatus":"idle"},"queryKey":["template-query","fokAdsQuery",[40240,626,600]],"queryHash":"[\"template-query\",\"fokAdsQuery\",[40240,626,600]]"},{"state":{"data":{"posts":{"nodes":[{"databaseId":205736,"featuredImage":{"node":{"altText":"Doctor reviews lab test results with an older male patient during a medical consultation","sourceUrl":"https://www.forksoverknives.com/uploads/2026/02/doctor-reviews-lab-tests-with-heart-disease-patient.jpg?auto=webp","databaseId":205742}},"date":"2026-02-04T11:58:46","excerpt":"\u003cp\u003eAdopting a whole-food, plant-based (WFPB) diet is one of the most effective lifestyle changes a person can make to reduce cardiovascular disease\u0026#8230;\u003c/p\u003e\n","title":"Eating Plant-Based for Your Heart? These Are the Best Lab Tests to Track Your Progress","uri":"/wellness/best-blood-tests-for-heart-disease-plant-based-diet/","categories":{"nodes":[{"name":"Wellness","uri":"/wellness/"}]}}]}},"dataUpdateCount":1,"dataUpdatedAt":1778948478411,"error":null,"errorUpdateCount":0,"errorUpdatedAt":0,"fetchFailureCount":0,"fetchFailureReason":null,"fetchMeta":null,"isInvalidated":false,"status":"success","fetchStatus":"idle"},"queryKey":["template-query","cacheSeparately","getLatestPostQuery"],"queryHash":"[\"template-query\",\"cacheSeparately\",\"getLatestPostQuery\"]"}]}},"__N_SSP":true},"page":"/[[...path]]","query":{"path":["recipes","vegan-pasta-noodles","butternut-mac-and-cheese-broccoli"]},"buildId":"0W4bdTwOJL8faodRz9DyG","runtimeConfig":{"wpDomain":"cms.forksoverknives.com","sentryDsn":"https://564a441bed254f5d907d5fb70abe0f06@o472819.ingest.sentry.io/6229499","disableFrontendSentry":false,"noindex":false,"protocol":"https","env":"production","trailingSlash":true},"isFallback":false,"dynamicIds":[59489],"gssp":true,"appGip":true,"scriptLoader":[]}</script></body></html>
l&lossy=1&ssl=1","width":640,"height":340,"caption":"Recipe Teacher"},"image":{"@id":"https://recipeteacher.com/#/schema/logo/image/"},"sameAs":["https://www.pinterest.com/recipe_teacher/"]},{"@type":"Person","@id":"https://recipeteacher.com/#/schema/person/6c0cddc88f9556b9a840578939d9fe12","name":"RecipeTeacher","sameAs":["https://recipeteacher.com/about/"]},{"@context":"https://schema.org/","@type":"Recipe","name":"Best Damn Roasted Pork Tenderloin","description":"Mouthwatering, buttery tender pork tenderloin seasoned to perfection and roasted in the oven for about 30 minutes.","author":{"@type":"Person","name":"RecipeTeacher"},"image":["https://recipeteacher.com/wp-content/uploads/2021/01/oven-roasted-pork-tenderloin-feature-225x225.jpg","https://recipeteacher.com/wp-content/uploads/2021/01/oven-roasted-pork-tenderloin-feature-260x195.jpg","https://recipeteacher.com/wp-content/uploads/2021/01/oven-roasted-pork-tenderloin-feature-320x180.jpg","https://recipeteacher.com/wp-content/uploads/2021/01/oven-roasted-pork-tenderloin-feature.jpg"],"url":"https://recipeteacher.com/best-damn-oven-roasted-pork-tenderloin/","recipeIngredient":["2 pork tenderloins (3/4lb-1.25lbs each)","3 tbs brown sugar","1.5 tbs paprika","1.5 tsp salt","1.5 tsp ground mustard","1 tsp black pepper","1 tsp onion powder","1/2 tsp garlic powder","1-2 tbs olive oil"],"recipeInstructions":[{"@type":"HowToStep","text":"Preheat oven to 425°(F).","url":"https://recipeteacher.com/best-damn-oven-roasted-pork-tenderloin/#instruction-step-1"},{"@type":"HowToStep","text":"Mix all dry ingredients in a small bowl.","url":"https://recipeteacher.com/best-damn-oven-roasted-pork-tenderloin/#instruction-step-2"},{"@type":"HowToStep","text":"Trim pork tenderloin of any excess fat or silverskin. Pat pork dry and coat with olive oil.","url":"https://recipeteacher.com/best-damn-oven-roasted-pork-tenderloin/#instruction-step-3"},{"@type":"HowToStep","text":"Rub seasoning mix all over pork tenderloin.","url":"https://recipeteacher.com/best-damn-oven-roasted-pork-tenderloin/#instruction-step-4"},{"@type":"HowToStep","text":"Place seasoned pork into a shallow baking dish and bake in oven 25-30 minutes (internal temp should be at least 145°)","url":"https://recipeteacher.com/best-damn-oven-roasted-pork-tenderloin/#instruction-step-5"},{"@type":"HowToStep","text":"Remove from oven and place pork tenderloin on a plate and let rest at least 5 minutes before slicing.","url":"https://recipeteacher.com/best-damn-oven-roasted-pork-tenderloin/#instruction-step-6"}],"prepTime":"PT5M","cookTime":"PT-492011H47M11S","totalTime":"","recipeYield":["4","4 servings"],"recipeCategory":"Dinner","cookingMethod":"Oven","recipeCuisine":"American","aggregateRating":{"@type":"AggregateRating","reviewCount":"191","ratingValue":"4.9"},"video":{"@context":"http://schema.org","@type":"VideoObject","name":"Oven Roasted Pork Tenderloin.mp4","description":"Mouthwatering, juicy and tender pork tenderloin is expertly seasoned and roasted to perfection in the oven. ","contentUrl":"https://content.jwplatform.com/videos/65Pm0n2F.mp4","thumbnailUrl":["https://content.jwplatform.com/thumbs/65Pm0n2F-720.jpg"],"uploadDate":"2022-10-22T02:55:23+00:00"},"review":[{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"author":{"@type":"Person","name":"Dianne M. Considine"},"datePublished":"2025-12-28","reviewBody":"Flavorful doesn't begin to describe it"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"author":{"@type":"Person","name":"Lisa T."},"datePublished":"2026-01-18","reviewBody":"This pork was very moist and very tasty!  It was also easy to prepare!  Great recipe!  Thanks for sharing!"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"author":{"@type":"Person","name":"Kylee Sexauer"},"datePublished":"2026-01-26","reviewBody":"This is now the only pork tenderloin recipe we make. So moist Everytime. So flavorful, and delicious.  If I want to show off- I make this exact recipe with mashed potatoes and real green beans. 20 stars!"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"4"},"author":{"@type":"Person","name":"Kaycee A."},"datePublished":"2026-02-01","reviewBody":"Simple, easy to put together - and delicious. I kind of wish it had a little more \"bite\" to complement the sweetness. I'll have to try a few spices with some \"heat\" to see what I can create. Great recipe - juicy! Be careful not to overcook the meat. I only cooked one tenderloin - so for me 25 minutes was a few minutes too long. Still tasted wonderful &amp; tender, though. Had a wonderful \"crust\" to it, too - which was a great surprise!"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"author":{"@type":"Person","name":"Nic"},"datePublished":"2026-02-10","reviewBody":"This came out way better than I was expecting."}],"datePublished":"2021-01-21","@id":"https://recipeteacher.com/best-damn-oven-roasted-pork-tenderloin/#recipe","isPartOf":{"@id":"https://recipeteacher.com/best-damn-oven-roasted-pork-tenderloin/#article"},"mainEntityOfPage":"https://recipeteacher.com/best-damn-oven-roasted-pork-tenderloin/"}]}</script>

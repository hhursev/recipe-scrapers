nt:2; column-gap:2em; column-width:100px;"><div class="wordpress-print-posts link-wrapper"><a href="https://thomas-kocht.de/rezepte/pfannkuchen-mit-diesen-tricks-werden-sie-perfekt/?print-posts=pdf" target="_blank"><!DOCTYPE html> <html> <head> <style> .button {   border: none;   color: white;   padding: 15px 32px;   text-align: center;   text-decoration: none;   display: inline-block;   font-size: 16px;   margin: 4px 2px;   cursor: pointer; }  .button1 {background-color: #278cbf;} /* PDF */  </style> </head> <body>  <button class="button button1">PDF</button> </body> </html></a><a href="#"
    	onclick="print(); return false;" target="_blank"><!DOCTYPE html> <html> <head> <style> .button {   border: none;   color: white;   padding: 15px 32px;   text-align: center;   text-decoration: none;   display: inline-block;   font-size: 16px;   margin: 4px 2px;   cursor: pointer; }  .button1 {background-color: #278cbf;} /* PDF */  </style> </head> <body>  <button class="button button1">Drucken</button> </body> </html></a>

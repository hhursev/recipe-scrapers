if(pos>1){newid=oldid.substring(pos);}else{newid=oldid;}
err=valwpcrform_2(newid,oldid,err);if(newid!=="rating_val"&&newid!=="fconfirm1"&&newid!=="fconfirm3"&&newid!=="frating")
{queryString+=oldid+"="+elements.item(i).value+"&";}}
queryString+="frating="+frating;if(err.length){var err2=err.join("\n");document.getElementById("f_status_msg").innerHTML=err2;return false;}
else
{return true;}}
function valwpcrform_2(newid,oldid,err){var myval="";var mobj="";mobj=document.getElementById(oldid);if(mobj!==null)
{myval=mobj.value;}
if(newid==="fname")

d":"https://sundaysuppermovement.com/smoked-short-ribs/#faq-question-1699295578930"}],"inLanguage":"en-US","potentialAction":[{"@type":"ReadAction","target":["https://sundaysuppermovement.com/smoked-short-ribs/"]}]},{"@type":"ImageObject","inLanguage":"en-US","@id":"https://sundaysuppermovement.com/smoked-short-ribs/#primaryimage","url":"https://sundaysuppermovement.com/wp-content/uploads/2023/11/smoked-short-ribs-featured.jpg","contentUrl":"https://sundaysuppermovement.com/wp-content/uploads/2023/11/smoked-short-ribs-featured.jpg","width":1200,"height":1200,"caption":"smoked short ribs sliced in a bowl"},{"@type":"BreadcrumbList","@id":"https://sundaysuppermovement.com/smoked-short-ribs/#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://sundaysuppermovement.com/"},{"@type":"ListItem","position":2,"name":"Recipes","item":"https://sundaysuppermovement.com/recipe-index/"},{"@type":"ListItem","position":3,"name":"Smoking","item":"https://sundaysuppermovement.com/smoking/"},{"@type":"ListItem","position":4,"name":"Easy Smoked Short Ribs Recipe for Juicy, Tender Beef"}]},{"@type":"WebSite","@id":"https://sundaysuppermovement.com/#website","url":"https://sundaysuppermovement.com/","name":"Sunday Supper Movement","description":"Bringing back Sunday Supper around the family dinner table.","publisher":{"@id":"https://sundaysuppermovement.com/#organization"},"potentialAction":[{"@type":"SearchAction","target":{"@type":"EntryPoint","urlTemplate":"https://sundaysuppermovement.com/?s={search_term_string}"},"query-input":{"@type":"PropertyValueSpecification","valueRequired":true,"valueName":"search_term_string"}}],"inLanguage":"en-US"},{"@type":"Organization","@id":"https://sundaysuppermovement.com/#organization","name":"Sunday Supper","url":"https://sundaysuppermovement.com/","logo":{"@type":"ImageObject","inLanguage":"en-US","@id":"https://sundaysuppermovement.com/#/schema/logo/image/","url":"https://sundaysuppermovement.com/wp-content/uploads/2023/06/full-SSM-logo-2023.png","contentUrl":"https://sundaysuppermovement.com/wp-content/uploads/2023/06/full-SSM-logo-2023.png","width":1200,"height":908,"caption":"Sunday Supper"},"image":{"@id":"https://sundaysuppermovement.com/#/schema/logo/image/"},"sameAs":["https://www.facebook.com/familyfoodie/","https://x.com/familyfoodie","https://www.instagram.com/familyfoodie/","https://www.linkedin.com/company/sunday-supper-llc","https://www.pinterest.com/thesundaysupper/","https://www.youtube.com/user/sundaysuppermovement"]},{"@type":"Person","@id":"https://sundaysuppermovement.com/#/schema/person/da079af2ea44eddf3939aa447b6ec095","name":"Isabel Laessig","image":{"@type":"ImageObject","inLanguage":"en-US","@id":"https://sundaysuppermovement.com/#/schema/person/image/","url":"https://sundaysuppermovement.com/wp-content/uploads/2020/04/isabel-portrait-96x96.jpg","contentUrl":"https://sundaysuppermovement.com/wp-content/uploads/2020/04/isabel-portrait-96x96.jpg","caption":"Isabel Laessig"},"description":"Hi! I’m Isabel Laessig, also known as Family Foodie, creator of Sunday Supper Movement and author of the Sunday Supper Cookbook. Sunday Supper is my mission to bring family back around the dinner table. Join me in making family meal-time a tradition to celebrate! » About Me","sameAs":["https://sundaysuppermovement.com/isabel-laessig/","https://www.facebook.com/familyfoodie","https://www.instagram.com/familyfoodie","http://www.pinterest.com/familyfoodie","https://x.com/@familyfoodie"]},{"@type":"Question","@id":"https://sundaysuppermovement.com/smoked-short-ribs/#faq-question-1699295578930","position":1,"url":"https://sundaysuppermovement.com/smoked-short-ribs/#faq-question-1699295578930","name":"Do you wrap beef ribs when smoking?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Some recipes will wrap the ribs in peach butcher paper or aluminum foil for the last bit of smoking, but in my experience, you don't need to wrap beef ribs. I recommend not wrapping them and instead spritzing them every hour to keep the meat moist.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Recipe","name":"Smoked Beef Short Ribs","author":{"@id":"https://sundaysuppermovement.com/#/schema/person/da079af2ea44eddf3939aa447b6ec095"},"description":"My Smoked Short Ribs Recipe takes only three steps and six easy ingredients to make ribs so juicy, you&#039;ll be making them over and over again!","datePublished":"2024-02-23T07:50:18+00:00","image":["https://sundaysuppermovement.com/wp-content/uploads/2023/11/smoked-short-ribs-featured.jpg","https://sundaysuppermovement.com/wp-content/uploads/2023/11/smoked-short-ribs-featured-500x500.jpg","https://sundaysuppermovement.com/wp-content/uploads/2023/11/smoked-short-ribs-featured-500x375.jpg","https://sundaysuppermovement.com/wp-content/uploads/2023/11/smoked-short-ribs-featured-480x270.jpg"],"recipeYield":["4","4 servings"],"prepTime":"PT5M","cookTime":"PT240M","totalTime":"PT245M","recipeIngredient":["4  Beef short ribs","2 Tablespoons Paprika","1 Tablespoon Coarse salt","1 Tablespoon Black pepper","1 Tablespoon Garlic powder","Apple cider vinegar"],"recipeInstructions":[{"@type":"HowToStep","text":"Optional: The night before, season your ribs generously with salt. Let them rest in the fridge overnight, uncovered.","name":"Brine","url":"https://sundaysuppermovement.com/smoked-short-ribs/#wprm-recipe-181691-step-0-0"},{"@type":"HowToStep","text":"Preheat the smoker to 285°F and prepare a spray bottle with apple cider vinegar. Mix your remaining seasonings, then thoroughly season the meat on all sides, patting it down firmly.","name":"Season","url":"https://sundaysuppermovement.com/smoked-short-ribs/#wprm-recipe-181691-step-0-1"},{"@type":"HowToStep","text":"Smoke the ribs for 4 hours, spritzing it every hour with apple cider vinegar to keep it moist. You&#39;ll know it&#39;s done when a meat thermometer pierces the meat without any resistance!","name":"Smoke","url":"https://sundaysuppermovement.com/smoked-short-ribs/#wprm-recipe-181691-step-0-2"},{"@type":"HowToStep","text":"Remove the ribs from the smoker and serve! Best served alongside homemade BBQ sauce.","name":"Serve","url":"https://sundaysuppermovement.com/smoked-short-ribs/#wprm-recipe-181691-step-0-3"}],"aggregateRating":{"@type":"AggregateRating","ratingValue":"5","ratingCount":"1"},"recipeCategory":["Main Course","Main Dish"],"recipeCuisine":["American"],"keywords":"beef short ribs smoked, smoked beef short ribs, smoked short ribs, smoking beef short ribs","nutrition":{"@type":"NutritionInformation","servingSize":"1 serving","calories":"643 kcal","carbohydrateContent":"4 g","proteinContent":"70 g","fatContent":"37 g","saturatedFatContent":"16 g","cholesterolContent":"212 mg","sodiumContent":"1982 mg","fiberContent":"2 g","sugarContent":"1 g","unsaturatedFatContent":"18 g"},"@id":"https://sundaysuppermovement.com/smoked-short-ribs/#recipe","isPartOf":{"@id":"https://sundaysuppermovement.com/smoked-short-ribs/#article"},"mainEntityOfPage":"https://sundaysuppermovement.com/smoked-short-ribs/"}]}</script>

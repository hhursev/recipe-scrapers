	<script type="application/ld+json" class="yoast-schema-graph">{"@context":"https://schema.org","@graph":[{"@type":"Article","@id":"https://afullliving.com/steak-and-seafood-garlic-parmesan-cream-sauce/#article","isPartOf":{"@id":"https://afullliving.com/steak-and-seafood-garlic-parmesan-cream-sauce/"},"author":{"name":"Briana","@id":"https://afullliving.com/#/schema/person/56738f48c9ca57ce0ae1cd1e86acced3"},"headline":"Steak and Shrimp Skillet with Garlic Parmesan Cream Sauce","datePublished":"2021-03-25T05:16:11+00:00","dateModified":"2026-02-11T04:35:40+00:00","wordCount":1844,"commentCount":56,"publisher":{"@id":"https://afullliving.com/#organization"},"image":{"@id":"https://afullliving.com/steak-and-seafood-garlic-parmesan-cream-sauce/#primaryimage"},"thumbnailUrl":"https://afullliving.com/wp-content/uploads/2026/02/Creamy-Parmesan-Steak-and-Shrimp-Skillet-Featured-Image.jpg","articleSection":["Beef","Easter Recipes","Main Courses","Seafood","Spring Recipes","Valentine's Day","Winter Recipes"],"inLanguage":"en-US","potentialAction":[{"@type":"CommentAction","name":"Comment","target":["https://afullliving.com/steak-and-seafood-garlic-parmesan-cream-sauce/#respond"]}]},{"@type":"WebPage","@id":"https://afullliving.com/steak-and-seafood-garlic-parmesan-cream-sauce/","url":"https://afullliving.com/steak-and-seafood-garlic-parmesan-cream-sauce/","name":"Steak and Shrimp Skillet with Garlic Parmesan Cream Sauce - A Full Living","isPartOf":{"@id":"https://afullliving.com/#website"},"primaryImageOfPage":{"@id":"https://afullliving.com/steak-and-seafood-garlic-parmesan-cream-sauce/#primaryimage"},"image":{"@id":"https://afullliving.com/steak-and-seafood-garlic-parmesan-cream-sauce/#primaryimage"},"thumbnailUrl":"https://afullliving.com/wp-content/uploads/2026/02/Creamy-Parmesan-Steak-and-Shrimp-Skillet-Featured-Image.jpg","datePublished":"2021-03-25T05:16:11+00:00","dateModified":"2026-02-11T04:35:40+00:00","description":"Juicy steak and shrimp in a luscious garlic parmesan cream sauce with spinach and lemon. This one-skillet surf and turf is restaurant-quality and easy!","breadcrumb":{"@id":"https://afullliving.com/steak-and-seafood-garlic-parmesan-cream-sauce/#breadcrumb"},"inLanguage":"en-US","potentialAction":[{"@type":"ReadAction","target":["https://afullliving.com/steak-and-seafood-garlic-parmesan-cream-sauce/"]}]},{"@type":"ImageObject","inLanguage":"en-US","@id":"https://afullliving.com/steak-and-seafood-garlic-parmesan-cream-sauce/#primaryimage","url":"https://afullliving.com/wp-content/uploads/2026/02/Creamy-Parmesan-Steak-and-Shrimp-Skillet-Featured-Image.jpg","contentUrl":"https://afullliving.com/wp-content/uploads/2026/02/Creamy-Parmesan-Steak-and-Shrimp-Skillet-Featured-Image.jpg","width":1200,"height":1200,"caption":"Creamy parmesan steak and shrimp skillet with garlic cream sauce."},{"@type":"BreadcrumbList","@id":"https://afullliving.com/steak-and-seafood-garlic-parmesan-cream-sauce/#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"A Full Living","item":"https://afullliving.com/"},{"@type":"ListItem","position":2,"name":"Recipes","item":"https://afullliving.com/recipes/"},{"@type":"ListItem","position":3,"name":"Main Courses","item":"https://afullliving.com/category/main-courses/"},{"@type":"ListItem","position":4,"name":"Steak and Shrimp Skillet with Garlic Parmesan Cream Sauce"}]},{"@type":"WebSite","@id":"https://afullliving.com/#website","url":"https://afullliving.com/","name":"A Full Living","description":"Approachable &amp; delicious wholesome recipes","publisher":{"@id":"https://afullliving.com/#organization"},"potentialAction":[{"@type":"SearchAction","target":{"@type":"EntryPoint","urlTemplate":"https://afullliving.com/?s={search_term_string}"},"query-input":{"@type":"PropertyValueSpecification","valueRequired":true,"valueName":"search_term_string"}}],"inLanguage":"en-US"},{"@type":"Organization","@id":"https://afullliving.com/#organization","name":"A Full Living","url":"https://afullliving.com/","logo":{"@type":"ImageObject","inLanguage":"en-US","@id":"https://afullliving.com/#/schema/logo/image/","url":"https://afullliving.com/wp-content/uploads/2022/01/A-Full-Living-1000x1000-1.png","contentUrl":"https://afullliving.com/wp-content/uploads/2022/01/A-Full-Living-1000x1000-1.png","width":1000,"height":1000,"caption":"A Full Living"},"image":{"@id":"https://afullliving.com/#/schema/logo/image/"},"sameAs":["https://www.facebook.com/afullliving","https://x.com/afullliving","http://www.instagram.com/afullliving","https://www.pinterest.com/afullliving/"]},{"@type":"Person","@id":"https://afullliving.com/#/schema/person/56738f48c9ca57ce0ae1cd1e86acced3","name":"Briana","sameAs":["https://afullliving.com/about/"]},{"@type":"Recipe","name":"Steak and Shrimp Skillet with Garlic Parmesan Cream Sauce","author":{"@id":"https://afullliving.com/#/schema/person/56738f48c9ca57ce0ae1cd1e86acced3"},"description":"This Steak and Shrimp Skillet with Garlic Parmesan Cream Sauce is one of our most popular recipes for good reason! Juicy ribeye steak and perfectly seared shrimp nestle into the most luscious, creamy garlic parmesan sauce with fresh spinach and a bright squeeze of lemon. It tastes like something you&#39;d order at an upscale steakhouse, but it all comes together in one skillet in under an hour. Perfect for date night, Valentine&#39;s Day, anniversaries, or any time you want to feel fancy without the fuss. This surf and turf dinner has earned 75+ five-star reviews from readers who love how impressive it looks and how easy it actually is to make!","datePublished":"2021-03-25T00:16:11+00:00","image":["https://afullliving.com/wp-content/uploads/2026/02/Creamy-Parmesan-Steak-and-Shrimp-Skillet-Featured-Image.jpg","https://afullliving.com/wp-content/uploads/2026/02/Creamy-Parmesan-Steak-and-Shrimp-Skillet-Featured-Image-500x500.jpg","https://afullliving.com/wp-content/uploads/2026/02/Creamy-Parmesan-Steak-and-Shrimp-Skillet-Featured-Image-500x375.jpg","https://afullliving.com/wp-content/uploads/2026/02/Creamy-Parmesan-Steak-and-Shrimp-Skillet-Featured-Image-480x270.jpg"],"recipeYield":["6","6 servings"],"prepTime":"PT15M","cookTime":"PT30M","totalTime":"PT45M","recipeIngredient":["1½ pounds steak (ribeye, sirloin, strip steak, or your favorite cut)","1½ teaspoons kosher salt (to taste)","½ teaspoon coarse ground black pepper (to taste)","2 tablespoons neutral oil","1 pound jumbo or larger shrimp (16/20 count or larger, peeled and deveined)","1 teaspoon kosher salt (to taste)","½ teaspoon coarse ground black pepper","¼ teaspoon red pepper flakes (optional and to taste)","¼ teaspoon smoked paprika (to taste)","2 tablespoons unsalted butter","2 tablespoons unsalted butter","1 medium onion (diced)","¼ teaspoon kosher salt (to taste)","6-8 cloves garlic (minced)","5-6 cups fresh spinach (chopped (about 8 ounces))","1 teaspoon lemon zest (zest of about 1 lemon)","½ cup chicken broth (could use seafood stock, vegetable broth, or dry white wine)","1 cup heavy whipping cream","1 cup freshly grated parmesan cheese (about 4 ounces, shred it yourself!)","2-3 tablespoons fresh lemon juice (juice of about 1 lemon)","Parsley and parmesan cheese for garnish"],"recipeInstructions":[{"@type":"HowToSection","name":"Steak","itemListElement":[{"@type":"HowToStep","text":"Heat a large skillet over medium-high heat until very hot. Season the steaks generously with salt and pepper on both sides. Add the neutral oil to the hot skillet, then add the steaks. Sear for 3-4 minutes per side until a golden-brown crust forms and the steaks reach your desired doneness (we pull ours at 130°F for medium-rare). Transfer to a plate and let rest for at least 10 minutes.","name":"Heat a large skillet over medium-high heat until very hot. Season the steaks generously with salt and pepper on both sides. Add the neutral oil to the hot skillet, then add the steaks. Sear for 3-4 minutes per side until a golden-brown crust forms and the steaks reach your desired doneness (we pull ours at 130°F for medium-rare). Transfer to a plate and let rest for at least 10 minutes.","url":"https://afullliving.com/steak-and-seafood-garlic-parmesan-cream-sauce/#wprm-recipe-26170-step-0-0"}]},{"@type":"HowToSection","name":"Shrimp","itemListElement":[{"@type":"HowToStep","text":"While the steak rests, season the shrimp with salt, pepper, red pepper flakes, and smoked paprika. Add butter to the same skillet and let it melt. Add the shrimp in a single layer (work in batches if needed to avoid crowding) and sear for 1-2 minutes per side until pink and just cooked through. Transfer to the plate with the steak.","name":"While the steak rests, season the shrimp with salt, pepper, red pepper flakes, and smoked paprika. Add butter to the same skillet and let it melt. Add the shrimp in a single layer (work in batches if needed to avoid crowding) and sear for 1-2 minutes per side until pink and just cooked through. Transfer to the plate with the steak.","url":"https://afullliving.com/steak-and-seafood-garlic-parmesan-cream-sauce/#wprm-recipe-26170-step-1-0"}]},{"@type":"HowToSection","name":"Parmesan cream sauce","itemListElement":[{"@type":"HowToStep","text":"Add the remaining butter to the skillet along with the diced onion and a pinch of salt. Cook over medium heat until the onion is softened and lightly browned, about 5-6 minutes. Add the garlic and cook for 30 seconds until fragrant.","name":"Add the remaining butter to the skillet along with the diced onion and a pinch of salt. Cook over medium heat until the onion is softened and lightly browned, about 5-6 minutes. Add the garlic and cook for 30 seconds until fragrant.","url":"https://afullliving.com/steak-and-seafood-garlic-parmesan-cream-sauce/#wprm-recipe-26170-step-2-0"},{"@type":"HowToStep","text":"Add the chopped spinach and stir frequently until wilted. Stir in the lemon zest and broth, and let simmer for 2-3 minutes.","name":"Add the chopped spinach and stir frequently until wilted. Stir in the lemon zest and broth, and let simmer for 2-3 minutes.","url":"https://afullliving.com/steak-and-seafood-garlic-parmesan-cream-sauce/#wprm-recipe-26170-step-2-1"},{"@type":"HowToStep","text":"Stir in the heavy cream, then add the parmesan cheese in small handfuls, stirring constantly and letting each addition melt completely before adding more. Once the sauce is smooth, stir in the lemon juice. Taste and adjust seasonings as needed.","name":"Stir in the heavy cream, then add the parmesan cheese in small handfuls, stirring constantly and letting each addition melt completely before adding more. Once the sauce is smooth, stir in the lemon juice. Taste and adjust seasonings as needed.","url":"https://afullliving.com/steak-and-seafood-garlic-parmesan-cream-sauce/#wprm-recipe-26170-step-2-2"}]},{"@type":"HowToSection","name":"Assemble and serve","itemListElement":[{"@type":"HowToStep","text":"Add the steak and shrimp back to the skillet. Garnish with fresh parsley and parmesan cheese. Serve immediately and enjoy!","name":"Add the steak and shrimp back to the skillet. Garnish with fresh parsley and parmesan cheese. Serve immediately and enjoy!","url":"https://afullliving.com/steak-and-seafood-garlic-parmesan-cream-sauce/#wprm-recipe-26170-step-3-0"}]}],"aggregateRating":{"@type":"AggregateRating","ratingValue":"5","ratingCount":"76","reviewCount":"7"},"review":[{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"I made this it was so good, I did use rib eye, after searing for 1 minute I cubed it and finished it in the skillet, the added it to the sauce, This is Keto at its finest","author":{"@type":"Person","name":"Bill"},"datePublished":"2025-03-04"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"We enjoyed this over garlic rice. I think I’d leave the steak out and try with scallops next time.","author":{"@type":"Person","name":"Stephanie"},"datePublished":"2024-12-05"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"This was definitely a hit in our house, I will definitely be making it again!!","author":{"@type":"Person","name":"Sasha"},"datePublished":"2022-08-18"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Nothing like treating myself to heaven on a Monday evening! Instead of broth, I used rosé, and like you, I used rib eye, but I only had a pound. Luckily, I had 1.5 pounds of shrimp, so it all evened out perfectly! The layers of flavors - oh, yum, yum! Thanks for the amazing experience!","author":{"@type":"Person","name":"Brenna"},"datePublished":"2022-04-18"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"I just made this dish this evening, wow is all I can say. We are currently sitting in a food coma. I opted for a dry white wine and rice as the side. A-mazballs is all I can say!!!","author":{"@type":"Person","name":"Donny"},"datePublished":"2022-02-10"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"This is an absolutely awesome dinner. The sauce is unbelievable. I completely enjoyed it.","author":{"@type":"Person","name":"Yvette"},"datePublished":"2021-08-22"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"I made this for the first time this evening it was a very easy recipe to make. My family enjoyed it it was delicious. I served this with the turnip mash very good combination","author":{"@type":"Person","name":"Anita"},"datePublished":"2021-04-13"}],"recipeCategory":["Main Course"],"recipeCuisine":["American"],"suitableForDiet":["https://schema.org/GlutenFreeDiet"],"keywords":"date night, one skillet, quick","nutrition":{"@type":"NutritionInformation","calories":"640 kcal","carbohydrateContent":"10 g","proteinContent":"43 g","fatContent":"49 g","saturatedFatContent":"25 g","transFatContent":"0.3 g","cholesterolContent":"243 mg","sodiumContent":"1973 mg","fiberContent":"2 g","sugarContent":"3 g","unsaturatedFatContent":"21 g","servingSize":"1 serving"},"@id":"https://afullliving.com/steak-and-seafood-garlic-parmesan-cream-sauce/#recipe","isPartOf":{"@id":"https://afullliving.com/steak-and-seafood-garlic-parmesan-cream-sauce/#article"},"mainEntityOfPage":"https://afullliving.com/steak-and-seafood-garlic-parmesan-cream-sauce/"}]}</script>
	<!-- / Yoast SEO Premium plugin. -->



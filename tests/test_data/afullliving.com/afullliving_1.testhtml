			}
			.wp-block-media-text.is-style-polaroid-media-text .wp-block-media-text__media {
				display: flex;
				justify-content: center;
			}
			.wp-block-media-text.is-style-polaroid-media-text .wp-block-media-text__content {
				padding: 0 0 0 40px;
			}
			@media(max-width:600px) {

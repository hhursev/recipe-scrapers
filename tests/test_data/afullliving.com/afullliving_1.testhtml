	<script type="application/ld+json" class="yoast-schema-graph">{"@context":"https://schema.org","@graph":[{"@type":"Article","@id":"https://afullliving.com/chicken-butternut-squash-recipe/#article","isPartOf":{"@id":"https://afullliving.com/chicken-butternut-squash-recipe/"},"author":{"name":"Briana","@id":"https://afullliving.com/#/schema/person/56738f48c9ca57ce0ae1cd1e86acced3"},"headline":"Chicken and Butternut Squash Recipe with Parmesan Sauce","datePublished":"2020-10-20T21:44:48+00:00","dateModified":"2022-02-21T01:20:58+00:00","wordCount":2074,"commentCount":25,"publisher":{"@id":"https://afullliving.com/#organization"},"image":{"@id":"https://afullliving.com/chicken-butternut-squash-recipe/#primaryimage"},"thumbnailUrl":"https://afullliving.com/wp-content/uploads/2020/10/Chicken-and-Butternut-Squash-Recipe-1200-x-1200.png","articleSection":["Chicken &amp; Poultry","Fall Recipes","Main Courses","Winter Recipes"],"inLanguage":"en-US","potentialAction":[{"@type":"CommentAction","name":"Comment","target":["https://afullliving.com/chicken-butternut-squash-recipe/#respond"]}]},{"@type":["WebPage","FAQPage"],"@id":"https://afullliving.com/chicken-butternut-squash-recipe/","url":"https://afullliving.com/chicken-butternut-squash-recipe/","name":"Chicken and Butternut Squash Skillet Recipe — A Full Living","isPartOf":{"@id":"https://afullliving.com/#website"},"primaryImageOfPage":{"@id":"https://afullliving.com/chicken-butternut-squash-recipe/#primaryimage"},"image":{"@id":"https://afullliving.com/chicken-butternut-squash-recipe/#primaryimage"},"thumbnailUrl":"https://afullliving.com/wp-content/uploads/2020/10/Chicken-and-Butternut-Squash-Recipe-1200-x-1200.png","datePublished":"2020-10-20T21:44:48+00:00","dateModified":"2022-02-21T01:20:58+00:00","description":"This Creamy Parmesan Chicken and Butternut Squash Skillet Recipe is an easy, luscious and hearty one skillet dinnertime favorite!","breadcrumb":{"@id":"https://afullliving.com/chicken-butternut-squash-recipe/#breadcrumb"},"mainEntity":[{"@id":"https://afullliving.com/chicken-butternut-squash-recipe/#faq-question-1645227621479"},{"@id":"https://afullliving.com/chicken-butternut-squash-recipe/#faq-question-1645228733584"}],"inLanguage":"en-US","potentialAction":[{"@type":"ReadAction","target":["https://afullliving.com/chicken-butternut-squash-recipe/"]}]},{"@type":"ImageObject","inLanguage":"en-US","@id":"https://afullliving.com/chicken-butternut-squash-recipe/#primaryimage","url":"https://afullliving.com/wp-content/uploads/2020/10/Chicken-and-Butternut-Squash-Recipe-1200-x-1200.png","contentUrl":"https://afullliving.com/wp-content/uploads/2020/10/Chicken-and-Butternut-Squash-Recipe-1200-x-1200.png","width":1200,"height":1200,"caption":"chicken and butternut squash recipe"},{"@type":"BreadcrumbList","@id":"https://afullliving.com/chicken-butternut-squash-recipe/#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"A Full Living","item":"https://afullliving.com/"},{"@type":"ListItem","position":2,"name":"Recipes","item":"https://afullliving.com/recipes/"},{"@type":"ListItem","position":3,"name":"Main Courses","item":"https://afullliving.com/category/main-courses/"},{"@type":"ListItem","position":4,"name":"Chicken and Butternut Squash Recipe with Parmesan Sauce"}]},{"@type":"WebSite","@id":"https://afullliving.com/#website","url":"https://afullliving.com/","name":"A Full Living","description":"Approachable &amp; delicious wholesome recipes","publisher":{"@id":"https://afullliving.com/#organization"},"potentialAction":[{"@type":"SearchAction","target":{"@type":"EntryPoint","urlTemplate":"https://afullliving.com/?s={search_term_string}"},"query-input":{"@type":"PropertyValueSpecification","valueRequired":true,"valueName":"search_term_string"}}],"inLanguage":"en-US"},{"@type":"Organization","@id":"https://afullliving.com/#organization","name":"A Full Living","url":"https://afullliving.com/","logo":{"@type":"ImageObject","inLanguage":"en-US","@id":"https://afullliving.com/#/schema/logo/image/","url":"https://afullliving.com/wp-content/uploads/2022/01/A-Full-Living-1000x1000-1.png","contentUrl":"https://afullliving.com/wp-content/uploads/2022/01/A-Full-Living-1000x1000-1.png","width":1000,"height":1000,"caption":"A Full Living"},"image":{"@id":"https://afullliving.com/#/schema/logo/image/"},"sameAs":["https://www.facebook.com/afullliving","https://x.com/afullliving","http://www.instagram.com/afullliving","https://www.pinterest.com/afullliving/"]},{"@type":"Person","@id":"https://afullliving.com/#/schema/person/56738f48c9ca57ce0ae1cd1e86acced3","name":"Briana","sameAs":["https://afullliving.com/about/"]},{"@type":"Question","@id":"https://afullliving.com/chicken-butternut-squash-recipe/#faq-question-1645227621479","position":1,"url":"https://afullliving.com/chicken-butternut-squash-recipe/#faq-question-1645227621479","name":"What does butternut squash go well with?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Butternut squash is such a lovely winter squash with an earthy, sweet flavor. Butternut squash is the ideal fall and winter produce item, because it goes quite well with sweet ingredients, warming spices, savory herbs, and plenty of proteins and vegetables. <br/><br/>Basically, you can pair it with many different ingredients! We thought the savory flavor of thyme mixed with a creamy parmesan sauce were perfect. Chicken thighs are the perfect canvas for just about anything, so this butternut squash chicken dish is well-rounded and comforting with the flavor palate we chose. ","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https://afullliving.com/chicken-butternut-squash-recipe/#faq-question-1645228733584","position":2,"url":"https://afullliving.com/chicken-butternut-squash-recipe/#faq-question-1645228733584","name":"Should I de-bone the chicken thighs for this recipe?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"No, you don't need to de-bone the chicken thighs but this is one of those things that is truly all about your preference. For this recipe, we prefer to leave the bone-in, because it helps keep the chicken moist and juicy while cooking.<br/><br/>When it comes time to dig in, the chicken will be so tender that it falls off the bone! If you prefer not to leave the bone in, check out <a href=\"https://www.thespruceeats.com/how-to-debone-chicken-thighs-4693735\" target=\"_blank\" rel=\"noreferrer noopener\">this great guide</a>. <br/><br/><em>Just make sure you save your chicken bones for later</em>, you can turn them into a great stock! Simply throw the chicken bones into a freezer bag, and freeze them until you collect enough to make some homemade chicken stock. Here's <a href=\"https://www.thespruceeats.com/search?q=chicken%20stock&amp;searchType=recipe\" target=\"_blank\" rel=\"noreferrer noopener\">some recipes and instructions </a>for how to do that!","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Recipe","name":"Chicken and Butternut Squash Recipe with Parmesan Sauce","author":{"@id":"https://afullliving.com/#/schema/person/56738f48c9ca57ce0ae1cd1e86acced3"},"description":"This Creamy Parmesan Chicken and Butternut Squash Skillet Recipe is an easy, luscious and hearty one skillet dinner time favorite. This yummy butternut squash  chicken dinner combines a flavorful parmesan cream sauce packed with garlic, spinach, fresh thyme and roasted butternut squash and chicken thighs. This one skillet meal will become a go-to dinner recipe for the fall and winter.","datePublished":"2020-10-20T16:44:48+00:00","image":["https://afullliving.com/wp-content/uploads/2020/10/Chicken-and-Butternut-Squash-Recipe-1200-x-1200.png","https://afullliving.com/wp-content/uploads/2020/10/Chicken-and-Butternut-Squash-Recipe-1200-x-1200-500x500.png","https://afullliving.com/wp-content/uploads/2020/10/Chicken-and-Butternut-Squash-Recipe-1200-x-1200-500x375.png","https://afullliving.com/wp-content/uploads/2020/10/Chicken-and-Butternut-Squash-Recipe-1200-x-1200-480x270.png"],"video":{"name":"Creamy Parmesan Chicken and Butternut Squash Skillet","description":"This Creamy Parmesan Chicken and Butternut Squash Skillet Recipe is an easy, luscious and hearty one skillet dinner time favorite. This yummy chicken dinner combines a flavorful parmesan cream sauce packed with garlic, spinach, fresh thyme and roasted butternut squash and chicken thighs. This one skillet meal will become a go-to dinner recipe for the fall and winter.  Brought to you in partnership with Lodge Cast Iron!\n\nGet the Full Recipe: https://afullliving.com/chicken-butternut-squash-recipe/","uploadDate":"2020-10-20T21:42:44+00:00","duration":"PT1M","thumbnailUrl":"https://i.ytimg.com/vi/H27gCKxmx38/hqdefault.jpg","embedUrl":"https://www.youtube.com/embed/H27gCKxmx38?feature=oembed","contentUrl":"https://www.youtube.com/watch?v=H27gCKxmx38","@type":"VideoObject"},"recipeYield":["6","6 servings"],"prepTime":"PT20M","cookTime":"PT40M","totalTime":"PT60M","recipeIngredient":["2 tablespoons unsalted butter","2 pounds chicken thighs, bone-in and skin-on ((can also use skinless and boneless if desired))","1 tablespoon fresh thyme","2 tablespoons Italian seasoning","1.5 teaspoons kosher salt","black pepper, to taste ((start with about 1/2 a teaspoon of coarse ground black pepper))","2 tablespoons olive oil","300 grams butternut squash, peeled and cubed  ((about half of a medium butternut squash) )","8 ounces fresh spinach","4 cloves garlic, minced","1 cup chicken broth","1 cup heavy whipping cream","4 ounces parmesan cheese, shredded or grated","To garnish: thyme sprigs, grated parmesan cheese"],"recipeInstructions":[{"@type":"HowToStep","text":"Preheat your oven to 375°F. In a small bowl, combine all of your dry seasonings, salt and pepper. Sprinkle seasoning all over the chicken on both sides. Save and set aside the remaining for the squash.","name":"Preheat your oven to 375°F. In a small bowl, combine all of your dry seasonings, salt and pepper. Sprinkle seasoning all over the chicken on both sides. Save and set aside the remaining for the squash.","url":"https://afullliving.com/?p=77254#wprm-recipe-16608-step-0-0"},{"@type":"HowToStep","text":"In a hot skillet, add the butter, and then the chicken thighs skin side down. Allow to cook until golden brown, about 4 minutes. Flip, and then sear for another 4 minutes. Remove from the skillet and set aside.","name":"In a hot skillet, add the butter, and then the chicken thighs skin side down. Allow to cook until golden brown, about 4 minutes. Flip, and then sear for another 4 minutes. Remove from the skillet and set aside.","url":"https://afullliving.com/?p=77254#wprm-recipe-16608-step-0-1"},{"@type":"HowToStep","text":"Add your olive oil, butternut squash, and remaining seasonings to the skillet and mix. Cook until squash is lightly browned, about 5 minutes.","name":"Add your olive oil, butternut squash, and remaining seasonings to the skillet and mix. Cook until squash is lightly browned, about 5 minutes.","url":"https://afullliving.com/?p=77254#wprm-recipe-16608-step-0-2"},{"@type":"HowToStep","text":"Add in your fresh spinach and wilt. Once wilted, add in garlic cloves until fragrant, about 30 seconds. Reduce the heat to low. Stir in, your chicken broth, heavy whipping cream, and parmesan cheese. Stir until the cheese is melted.","name":"Add in your fresh spinach and wilt. Once wilted, add in garlic cloves until fragrant, about 30 seconds. Reduce the heat to low. Stir in, your chicken broth, heavy whipping cream, and parmesan cheese. Stir until the cheese is melted.","url":"https://afullliving.com/?p=77254#wprm-recipe-16608-step-0-3"},{"@type":"HowToStep","text":"Add the chicken thighs back into the skillet, skin side up. Bake for 20-25 minutes at 375°F, until the cheese is bubbling. Garnish with fresh parmesan and thyme sprigs.","name":"Add the chicken thighs back into the skillet, skin side up. Bake for 20-25 minutes at 375°F, until the cheese is bubbling. Garnish with fresh parmesan and thyme sprigs.","url":"https://afullliving.com/?p=77254#wprm-recipe-16608-step-0-4"},{"@type":"HowToStep","text":"Eat within 5 days and store in an airtight container in the fridge.","name":"Eat within 5 days and store in an airtight container in the fridge.","url":"https://afullliving.com/?p=77254#wprm-recipe-16608-step-0-5"}],"aggregateRating":{"@type":"AggregateRating","ratingValue":"5","ratingCount":"14"},"recipeCategory":["Main Course"],"recipeCuisine":["American"],"keywords":"chicken dinner, fall recipes, gluten free, keto, one skillet meal","nutrition":{"@type":"NutritionInformation","calories":"615 kcal","carbohydrateContent":"11 g","proteinContent":"31 g","fatContent":"50 g","saturatedFatContent":"21 g","transFatContent":"1 g","cholesterolContent":"207 mg","sodiumContent":"1161 mg","fiberContent":"3 g","sugarContent":"2 g","servingSize":"1 serving"},"@id":"https://afullliving.com/chicken-butternut-squash-recipe/#recipe","isPartOf":{"@id":"https://afullliving.com/chicken-butternut-squash-recipe/#article"},"mainEntityOfPage":"https://afullliving.com/chicken-butternut-squash-recipe/"}]}</script>
	<!-- / Yoast SEO Premium plugin. -->



            // function to populate the form
            function populateForm(form) {
                let titleInput = form.querySelector('input[name="fields[signuptitle]"]');
                let urlInput = form.querySelector('input[name="fields[signupurl]"]');
                if (titleInput) titleInput.value = "How to Bake Eggs in a Muffin Tin in the Oven"; // use the post title here
                if (urlInput) urlInput.value = window.location.href;
            }

            // count the forms
            let formsCount = 0;

            // populate any forms that are already on the page
            document.querySelectorAll('.formkit-form').forEach(populateForm);

            // create an observer instance
            let observer = new MutationObserver(function(mutations) {
                mutations.forEach(function(mutation) {
                    for (let node of mutation.addedNodes) {
                        if (!(node instanceof HTMLElement)) continue; // skip if not an HTMLElement
                        if (!node.classList.contains('formkit-form')) continue; // skip if it doesn't have the 'formkit-form' class
                        // populate the form
                        populateForm(node);
                        // disconnect the observer after the second form is found and populated
                        if (++formsCount >= 2) observer.disconnect();
                    }
                });
            });

            // start observing
            observer.observe(document.body, { childList: true, subtree: true });
        </script>

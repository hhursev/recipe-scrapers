	<script type="application/ld+json" class="yoast-schema-graph">{"@context":"https://schema.org","@graph":[{"@type":"Article","@id":"https://honest-food.net/corned-venison-recipe/#article","isPartOf":{"@id":"https://honest-food.net/corned-venison-recipe/"},"author":{"name":"Hank Shaw","@id":"https://honest-food.net/#/schema/person/edbbfc16d66a2cfd337457d4d9368b51"},"headline":"Corned Venison","datePublished":"2015-01-12T11:45:47+00:00","dateModified":"2020-04-25T22:17:34+00:00","wordCount":781,"commentCount":384,"publisher":{"@id":"https://honest-food.net/#organization"},"image":{"@id":"https://honest-food.net/corned-venison-recipe/#primaryimage"},"thumbnailUrl":"https://honest-food.net/wp-content/uploads/2015/01/corned-venison-1.jpg","articleSection":["Charcuterie","Featured","Recipe","Venison","Wild Game"],"inLanguage":"en-US","potentialAction":[{"@type":"CommentAction","name":"Comment","target":["https://honest-food.net/corned-venison-recipe/#respond"]}]},{"@type":"WebPage","@id":"https://honest-food.net/corned-venison-recipe/","url":"https://honest-food.net/corned-venison-recipe/","name":"Corned Venison Recipe - How to Make Corned Venison | Hank Shaw","isPartOf":{"@id":"https://honest-food.net/#website"},"primaryImageOfPage":{"@id":"https://honest-food.net/corned-venison-recipe/#primaryimage"},"image":{"@id":"https://honest-food.net/corned-venison-recipe/#primaryimage"},"thumbnailUrl":"https://honest-food.net/wp-content/uploads/2015/01/corned-venison-1.jpg","datePublished":"2015-01-12T11:45:47+00:00","dateModified":"2020-04-25T22:17:34+00:00","description":"A recipe for making corned venison at home. Corned venison is just like corned beef, only leaner. This recipe works with deer, elk, moose, and antelope.","breadcrumb":{"@id":"https://honest-food.net/corned-venison-recipe/#breadcrumb"},"inLanguage":"en-US","potentialAction":[{"@type":"ReadAction","target":["https://honest-food.net/corned-venison-recipe/"]}]},{"@type":"ImageObject","inLanguage":"en-US","@id":"https://honest-food.net/corned-venison-recipe/#primaryimage","url":"https://honest-food.net/wp-content/uploads/2015/01/corned-venison-1.jpg","contentUrl":"https://honest-food.net/wp-content/uploads/2015/01/corned-venison-1.jpg","width":600,"height":668,"caption":"Photo by Holly A. Heyser"},{"@type":"BreadcrumbList","@id":"https://honest-food.net/corned-venison-recipe/#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://honest-food.net/"},{"@type":"ListItem","position":2,"name":"Wild Game","item":"https://honest-food.net/category/wild-game/"},{"@type":"ListItem","position":3,"name":"Venison","item":"https://honest-food.net/category/wild-game/venison-recipes/"},{"@type":"ListItem","position":4,"name":"Corned Venison"}]},{"@type":"WebSite","@id":"https://honest-food.net/#website","url":"https://honest-food.net/","name":"Hunter Angler Gardener Cook","description":"Finding the Forgotten Feast","publisher":{"@id":"https://honest-food.net/#organization"},"potentialAction":[{"@type":"SearchAction","target":{"@type":"EntryPoint","urlTemplate":"https://honest-food.net/?s={search_term_string}"},"query-input":{"@type":"PropertyValueSpecification","valueRequired":true,"valueName":"search_term_string"}}],"inLanguage":"en-US"},{"@type":"Organization","@id":"https://honest-food.net/#organization","name":"Hunter Angler Gardener Cook","url":"https://honest-food.net/","logo":{"@type":"ImageObject","inLanguage":"en-US","@id":"https://honest-food.net/#/schema/logo/image/","url":"https://honest-food.net/wp-content/uploads/2019/05/hagc-logo-console.jpg","contentUrl":"https://honest-food.net/wp-content/uploads/2019/05/hagc-logo-console.jpg","width":200,"height":200,"caption":"Hunter Angler Gardener Cook"},"image":{"@id":"https://honest-food.net/#/schema/logo/image/"},"sameAs":["https://www.facebook.com/huntgathercook","https://instagram.com/huntgathercook/","https://www.pinterest.com/huntgathercook/","https://www.youtube.com/channel/UCsbZW7079vDEFvXtdh-gVHw","https://en.wikipedia.org/wiki/Hank_Shaw_(author)"]},{"@type":"Person","@id":"https://honest-food.net/#/schema/person/edbbfc16d66a2cfd337457d4d9368b51","name":"Hank Shaw","image":{"@type":"ImageObject","inLanguage":"en-US","@id":"https://honest-food.net/#/schema/person/image/","url":"https://secure.gravatar.com/avatar/2c2a9259ffa9316dd43eecbea8e2869cb4161e61f1b141797097e2dd7ae7a4d3?s=96&d=blank&r=pg","contentUrl":"https://secure.gravatar.com/avatar/2c2a9259ffa9316dd43eecbea8e2869cb4161e61f1b141797097e2dd7ae7a4d3?s=96&d=blank&r=pg","caption":"Hank Shaw"},"description":"Hey there. Welcome to Hunter Angler Gardener Cook, the internet's largest source of recipes and know-how for wild foods. I am a chef, author, and yes, hunter, angler, gardener, forager and cook. Follow me on Instagram and on Facebook.","sameAs":["https://honest-food.net/about/","https://www.facebook.com/huntgathercook/","https://x.com/Hank_Shaw"],"url":"https://honest-food.net/about/"},{"@type":"Recipe","name":"Corned Venison","author":{"@id":"https://honest-food.net/#/schema/person/edbbfc16d66a2cfd337457d4d9368b51"},"description":"So obviously this recipe works with all cervids, antelope, deer, moose, elk, etc. It will also work with beef and lamb, of course, but also bear and even pork -- where the effect is essentially a boiled ham.","datePublished":"2015-01-12T03:45:47+00:00","image":["https://honest-food.net/wp-content/uploads/2015/01/corned-venison-recipe-1.jpg","https://honest-food.net/wp-content/uploads/2015/01/corned-venison-recipe-1-500x500.jpg","https://honest-food.net/wp-content/uploads/2015/01/corned-venison-recipe-1-500x375.jpg","https://honest-food.net/wp-content/uploads/2015/01/corned-venison-recipe-1-480x270.jpg"],"recipeYield":["12","12 people"],"prepTime":"PT20M","cookTime":"PT180M","totalTime":"PT200M","recipeIngredient":["1/2 gallon water","1/2 cup kosher salt","1/3 cup sugar","1/2 ounce Instacure No. 1 ((sodium nitrite))","1 tablespoon cracked black pepper","1 tablespoon toasted coriander seeds","6  bay leaves, (crushed)","1 tablespoon mustard seeds","1 tablespoon dried thyme","1 teaspoon caraway seeds","1  cinnamon stick","5  chopped garlic cloves","A 3 to 5 pound venison roast"],"recipeInstructions":[{"@type":"HowToStep","text":"Add everything but the roast to a pot and bring it to a boil. Turn off the heat and cover, then let it cool to room temperature while covered. This will take a few hours. Meanwhile, trim any silverskin you find off the roast. Leave the fat. Once the brine is cool, find a container just about large enough to hold the roast, place the meat inside and cover with the brine. You might have extra, which you can discard.","name":"Add everything but the roast to a pot and bring it to a boil. Turn off the heat and cover, then let it cool to room temperature while covered. This will take a few hours. Meanwhile, trim any silverskin you find off the roast. Leave the fat. Once the brine is cool, find a container just about large enough to hold the roast, place the meat inside and cover with the brine. You might have extra, which you can discard.","url":"https://honest-food.net/corned-venison-recipe/#wprm-recipe-23145-step-0-0"},{"@type":"HowToStep","text":"Make sure the roast is completely submerged in the brine; I use a clean stone to weigh the meat down. You can also just flip the meat every day. Cover and put in the fridge for 5 to 7 days, depending on the roast's size. A 2-pound roast might only need 4 days. The longer you soak, the saltier it will get -- but you want the salt and nitrate to work its way to the center of the roast, and that takes time. Err on extra days, not fewer days.","name":"Make sure the roast is completely submerged in the brine; I use a clean stone to weigh the meat down. You can also just flip the meat every day. Cover and put in the fridge for 5 to 7 days, depending on the roast's size. A 2-pound roast might only need 4 days. The longer you soak, the saltier it will get -- but you want the salt and nitrate to work its way to the center of the roast, and that takes time. Err on extra days, not fewer days.","url":"https://honest-food.net/corned-venison-recipe/#wprm-recipe-23145-step-0-1"},{"@type":"HowToStep","text":"After the alloted time has passed, you have corned venison. To cook and eat, rinse off the meat, then put the roast in a pot just large enough to hold it and cover with fresh water. You don't want too large a pot or the fresh water will leach out too much flavor from the meat -- it's an osmosis thing. partially cover the pot and simmer gently -- don't boil -- for at least 3 hours and up to 5 hours. The meat itself will be cooked in an hour or less, but you want the sinews and connective tissue in the roast to soften and that takes time.","name":"After the alloted time has passed, you have corned venison. To cook and eat, rinse off the meat, then put the roast in a pot just large enough to hold it and cover with fresh water. You don't want too large a pot or the fresh water will leach out too much flavor from the meat -- it's an osmosis thing. partially cover the pot and simmer gently -- don't boil -- for at least 3 hours and up to 5 hours. The meat itself will be cooked in an hour or less, but you want the sinews and connective tissue in the roast to soften and that takes time.","url":"https://honest-food.net/corned-venison-recipe/#wprm-recipe-23145-step-0-2"},{"@type":"HowToStep","text":"Eat hot or cold. It is absolutely fantastic with good mustard and some sauerkraut on a sandwich.","name":"Eat hot or cold. It is absolutely fantastic with good mustard and some sauerkraut on a sandwich.","url":"https://honest-food.net/corned-venison-recipe/#wprm-recipe-23145-step-0-3"}],"aggregateRating":{"@type":"AggregateRating","ratingValue":"4.98","ratingCount":"157","reviewCount":"9"},"review":[{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Loved it! And yes, I did modify it to fit our family - no nitrate salt. To stay safe I cut the roast into 1 pound slices and brined it for 2 days - the smaller hunks of meat allowed the brine to fully penetrate it in the shorter time span. Followed the rest of the recipe exactly as written. Delicious! thank you for the excellent information and guidance on cooking wild game, we appreciate you.","author":{"@type":"Person","name":"CathyC"},"datePublished":"2026-02-02"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"thank you sir! This gave me another great way to silence the \"venison is so gamey\" critics. I had three bottom rounds (5 lbs total) from last years harvest that I usually save for jerky. I brine all 3 of them in the corned venison brine for 7 days. I finished 2 as corned beef and then coated one with the coriander and black pepper rub that you note in your pastrami recipe. I smoked it to an internal temp of 145. Both turned out wonderful. I really wish I could add pictures! I have read a lot about the difference between corned venison and pastrami is that after the brine the pastrami is smoked instead of simmered. Is this true? I noticed your pastrami recipe/brine is different. thanks again!","author":{"@type":"Person","name":"Brian W"},"datePublished":"2025-12-14"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"We made this with a 2 pound sirloin roast and it came out fantastic! We omitted the cure no.1 but otherwise followed the recipe to a T. The color is notably more grey than the pink shown in the photo above,  due to the absence of cure but the color doesn't bother us. Still tasted great. Thanks for another solid recipe!","author":{"@type":"Person","name":"NIki"},"datePublished":"2025-12-11"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Wow! I made this today with pronghorn and it is delicious.  I can’t wait to try it with some mustard on a cracker. \r\n\r\nThanks again for another delicious recipe!","author":{"@type":"Person","name":"Mary"},"datePublished":"2025-11-15"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"If I use say, five-1 lb pieces of venison vs one 5 lb roast, does that change anything? Timing? Thanks!","author":{"@type":"Person","name":"Robert"},"datePublished":"2025-11-05"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"This is so delicious! I have made this every St Patrick’s day for the past few years and we love it. My husband now makes sure he gets multiple roasts so we can enjoy it throughout the year.","author":{"@type":"Person","name":"Wendy"},"datePublished":"2025-05-31"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Hello Hank,\r\n\r\nI was wondering if you freeze the cooked corned venison in the cooking liquid?\r\nThanks!","author":{"@type":"Person","name":"Brendan Gilbreth"},"datePublished":"2025-03-18"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"I don't see PPG listed in my instacure (sodium nitrite).  At any rate, PPG is present as an additive in soup mixes, seasonings, baking mixes..... it is considered safe by the FDA.  Yes, I know that science no longer means anything, so by all means, take your chances with the most most potent toxin known to man.","author":{"@type":"Person","name":"Bob"},"datePublished":"2025-03-11"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Excellent recipe!  I was able to feed venison to folks that claim they would never like it and they LOVED it!   Thank you!","author":{"@type":"Person","name":"Courtney"},"datePublished":"2025-03-11"}],"recipeCategory":["Cured Meat","Main Course"],"recipeCuisine":["American"],"keywords":"lunch meat, pickled foods, venison","nutrition":{"@type":"NutritionInformation","calories":"32 kcal","carbohydrateContent":"7 g","proteinContent":"1 g","fatContent":"1 g","saturatedFatContent":"1 g","sodiumContent":"4725 mg","fiberContent":"1 g","sugarContent":"6 g","servingSize":"1 serving"},"@id":"https://honest-food.net/corned-venison-recipe/#recipe","isPartOf":{"@id":"https://honest-food.net/corned-venison-recipe/#article"},"mainEntityOfPage":"https://honest-food.net/corned-venison-recipe/"}]}</script>
	<!-- / Yoast SEO Premium plugin. -->



			.recipe-sidebar ul li[class*='sf-field-taxonomy'] ul li {
		position: relative;
}
.recipe-sidebar ul li[class*='sf-field-taxonomy'] ul li input {
    width: 18px;
    height: 18px;
	position: relative;
    vertical-align: middle;
    cursor: pointer;
    left: 0;
    border: 1px solid #bfbebc;
	border-radius: 0; 
	-webkit-appearance: none;
}

.recipe-sidebar ul li[class*='sf-field-taxonomy'] ul li input:checked + label:before {
		content: "x";
    color: #231f20;
    font-family: "Biko",serif;
    position: absolute;
    top: .75em;
    left: 5px;
    text-transform: none !important;
    font-size: 16px;
    line-height: 1;
    letter-spacing: 0;
}

.page-template-template_recipeindex .pagination {
	text-align: center;
	width: 100%;
}

.page-template-template_recipeindex .pagination .nav-previous, .page-template-template_recipeindex .pagination .nav-next {
		display: inline;
		margin: 0 10px;
}

.pagination.sfp a {
    letter-spacing: 0.16em;
    display: inline-block;;
    font-size: 0.65em;
    text-transform: uppercase;
    font-family: "Biko",serif;
    background: #fff;
		border-radius: 0 !important;
    background-color: #fff !important;
    color: #231f20;
    font-size: 0.65em;
    font-weight: 400;
    padding: 12px 25px 5px;
    line-height: 1 !important;
    height: 36px !important;
    border: none !important;
    cursor: pointer;
    margin: 0 auto;
}
.pagination.sfp a:hover {
		background: #231f20 !important;
		color: #fff;
}		</style>

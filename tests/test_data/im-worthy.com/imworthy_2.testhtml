d":"https:\/\/im-worthy.com\/#\/schema\/logo\/image\/"},"sameAs":["https:\/\/www.facebook.com\/ImWorthyblog\/","https:\/\/www.instagram.com\/imworthykitchen\/","https:\/\/www.pinterest.com\/ImWorthyblog\/","https:\/\/www.youtube.com\/channel\/UCLw4ED-iH6FCGli8wieZUFA?view_as=subscriber"]},{"@type":"Person","@id":"https:\/\/im-worthy.com\/#\/schema\/person\/7c80f6178df44f0bcb9df783efbd23bf","name":"Shana Thomas","image":{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/secure.gravatar.com\/avatar\/116262146f6e1f5b08ee6edc91bc2141bc469e593256951135ade9535300d0b8?s=96&d=mm&r=g","url":"https:\/\/secure.gravatar.com\/avatar\/116262146f6e1f5b08ee6edc91bc2141bc469e593256951135ade9535300d0b8?s=96&d=mm&r=g","contentUrl":"https:\/\/secure.gravatar.com\/avatar\/116262146f6e1f5b08ee6edc91bc2141bc469e593256951135ade9535300d0b8?s=96&d=mm&r=g","caption":"Shana Thomas"},"description":"Hey there, I’m Shana Thomas, food photographer, home cook, and writer behind, Im-Worthy.com. Since 2019, my goal has been to inspire you to live energetic and healthy lives with my easy vegan recipes &amp; wellness tips.","url":"https:\/\/im-worthy.com\/author\/changeyourlife14\/"},{"@type":"Recipe","name":"Watermelon & Cucumber Salad with Mango Dressing","author":{"@id":"https:\/\/im-worthy.com\/#\/schema\/person\/7c80f6178df44f0bcb9df783efbd23bf"},"description":"This watermelon and cucumber salad (without feta) with mango-lime dressing is the epitome of a refreshing summer dish. With its combination of juicy watermelon, cool cucumber, arugula, fresh mint leaves, and tropical mango dressing, every bite is bursting with flavor.","datePublished":"2023-05-17T21:09:40+00:00","image":["https:\/\/im-worthy.com\/wp-content\/uploads\/2020\/06\/Watermelon_Salad_Blog3.jpg","https:\/\/im-worthy.com\/wp-content\/uploads\/2020\/06\/Watermelon_Salad_Blog3-500x500.jpg","https:\/\/im-worthy.com\/wp-content\/uploads\/2020\/06\/Watermelon_Salad_Blog3-500x375.jpg","https:\/\/im-worthy.com\/wp-content\/uploads\/2020\/06\/Watermelon_Salad_Blog3-480x270.jpg"],"recipeYield":["4","4 people"],"prepTime":"PT10M","totalTime":"PT10M","recipeIngredient":["5 oz baby arugula (about 1 pack of store-bought arugula)","4 cups watermelon (roughly cubed )","2 lrg cucumber  (thinly sliced)","2 handfuls parsley (roughly chopped)","1\/4 cup fresh mint leaves (torn)","1  ripe mango (peeled and pitted)","3 tsp fresh or dried rosemary (can sub for thyme)","2 tbsp lime juice","sea salt &amp; black pepper (to taste)","2 tbsp extra-virgin olive oil","1 tsp maple syrup or honey (optional for added sweetness)","1\/3 cup vegan feta cheese","thinly sliced red onions (as much as desired)","1 tbsp chia seeds or hemp seeds"],"recipeInstructions":[{"@type":"HowToStep","text":"In a large bowl, combine the cubed watermelon, sliced cucumbers, parsley, and torn mint leaves. Toss gently to mix the ingredients.","name":"In a large bowl, combine the cubed watermelon, sliced cucumbers, parsley, and torn mint leaves. Toss gently to mix the ingredients.","url":"https:\/\/im-worthy.com\/best-watermelon-cucumber-salad-recipe\/#wprm-recipe-1348-step-0-0"},{"@type":"HowToStep","text":"In a blender or food processor, combine the peeled and pitted mango, lime juice, rosemary, olive oil, honey, or maple syrup (if using), salt, and pepper. Blend until smooth and creamy.","name":"In a blender or food processor, combine the peeled and pitted mango, lime juice, rosemary, olive oil, honey, or maple syrup (if using), salt, and pepper. Blend until smooth and creamy.","url":"https:\/\/im-worthy.com\/best-watermelon-cucumber-salad-recipe\/#wprm-recipe-1348-step-0-1"},{"@type":"HowToStep","text":"Pour the mango dressing over the watermelon and cucumber mixture. Gently toss to evenly coat the salad with the dressing. Serve the watermelon and cucumber salad immediately, or refrigerate for 30 minutes to allow the flavors to meld together.","name":"Pour the mango dressing over the watermelon and cucumber mixture. Gently toss to evenly coat the salad with the dressing. Serve the watermelon and cucumber salad immediately, or refrigerate for 30 minutes to allow the flavors to meld together.","url":"https:\/\/im-worthy.com\/best-watermelon-cucumber-salad-recipe\/#wprm-recipe-1348-step-0-2"},{"@type":"HowToStep","text":"Garnish with additional fresh mint leaves, if desired, and serve chilled. If desired, add crumbled vegan feta cheese, thinly sliced red onions, or chia seeds over the top of the salad for an added savory &amp; crunchy element.","name":"Garnish with additional fresh mint leaves, if desired, and serve chilled. If desired, add crumbled vegan feta cheese, thinly sliced red onions, or chia seeds over the top of the salad for an added savory &amp; crunchy element.","url":"https:\/\/im-worthy.com\/best-watermelon-cucumber-salad-recipe\/#wprm-recipe-1348-step-0-3"}],"aggregateRating":{"@type":"AggregateRating","ratingValue":"5","ratingCount":"4","reviewCount":"4"},"review":[{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"I love this salad.","author":{"@type":"Person","name":"Ladonna"},"datePublished":"2024-03-07"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"I love a simple and delicious salad.","author":{"@type":"Person","name":"Kim"},"datePublished":"2023-06-14"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Love this salad and the dressing.","author":{"@type":"Person","name":"Shayla"},"datePublished":"2023-05-20"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"This is one of the best watermelon salad's I've made in a while.","author":{"@type":"Person","name":"Emily"},"datePublished":"2023-05-17"}],"recipeCategory":["Salad","Side Dish"],"recipeCuisine":["American"],"keywords":"watermelon and cucumber salad, watermelon cucumber salad, watermelon salad without feta","nutrition":{"@type":"NutritionInformation","calories":"100 kcal","servingSize":"1 serving"},"@id":"https:\/\/im-worthy.com\/best-watermelon-cucumber-salad-recipe\/#recipe","isPartOf":{"@id":"https:\/\/im-worthy.com\/best-watermelon-cucumber-salad-recipe\/#article"},"mainEntityOfPage":"https:\/\/im-worthy.com\/best-watermelon-cucumber-salad-recipe\/"}]}</script>

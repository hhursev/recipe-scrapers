    <button class="comments-toggle-btn" id="commentsToggleBtn">Показать все комментарии</button>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const commentsBlock = document.getElementById('commentsBlock');
            const toggleBtn = document.getElementById('commentsToggleBtn');
            const maxHeight = 500; // максимальная высота блока комментариев
            let isExpanded = false;

            function setCommentsHeight() {
                const fullHeight = commentsBlock.scrollHeight;

                if (fullHeight <= maxHeight) {
                    toggleBtn.style.display = 'none';
                    commentsBlock.style.height = 'auto';
                    return;
                }

                toggleBtn.style.display = 'block';
                commentsBlock.style.height = isExpanded ? fullHeight + 'px' : maxHeight + 'px';
            }

            toggleBtn.addEventListener('click', function() {
                isExpanded = !isExpanded;
                setCommentsHeight();
                toggleBtn.textContent = isExpanded ? 'Скрыть комментарии' : 'Показать все комментарии';

                if (!isExpanded) {
                    window.scrollTo({
                        top: commentsBlock.offsetTop,
                        behavior: 'smooth'
                    });
                }
            });

            setCommentsHeight();

            window.addEventListener('resize', setCommentsHeight);
        });
    </script>

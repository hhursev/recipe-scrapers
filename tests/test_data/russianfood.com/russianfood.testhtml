\">\n        <\/a>\n        <a href=\"!!content_link4!!\" target=\"_blank\" class=\"logo-link logo-bottom-right\" \n            onclick=\"adEvent('LocalB Click', '!!local_content_id!!', JSON.stringify({'place':'!!place!!', 'link':'4'}))\">\n            <img src=\"\/images\/lb\/vk-logo.png\" alt=\"VK\">\n        <\/a>\n\n        <div class=\"b-subtitle b-subtitle-bordo\">!!content_title!!<\/div>\n    <\/div>\n<\/div>\n<script>\n    (function() {\n        var bannerId = '!!place!!_!!local_content_id!!';\n        var contentId = '!!local_content_id!!';\n        var place = '!!place!!';\n        \n        function initLocalBanner() {\n            var extInfoStr = JSON.stringify({\"place\": place});\n            adEvent('LocalB Load', contentId, extInfoStr);\n            console.log('LocalB Load', contentId, extInfoStr);\n            let lc = document.getElementById(place + '_lc_' + contentId + '_id');\n            \n            const observer = new IntersectionObserver((entries) => {\n                entries.forEach(entry => {\n                    if (entry.isIntersecting) {\n                        adEvent('LocalB Show', contentId, extInfoStr);\n                        console.log('LocalB Show', contentId, extInfoStr);\n                        observer.unobserve(entry.target); \n                    }\n                });\n            }, {\n                threshold: 0.7 \n            });\n            \n            if (lc) {\n                observer.observe(lc);\n            }\n        }\n\n        if (document.readyState === 'loading') {\n            document.addEventListener('DOMContentLoaded', initLocalBanner);\n        } else {\n            initLocalBanner();\n        }\n    })();\n<\/script>\n"},"2":{"template_id":"2","template_group_id":"1","template_max_x":"300","template_max_y":"600","template_html":"<div class=\"localb\">\n    <div id=\"!!place!!_lc_!!local_content_id!!_id\" class=\"b-container\">\n        <img src=\"\/images\/lb\/best_v_bg__300x200.png\" alt=
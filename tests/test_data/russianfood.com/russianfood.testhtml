	var ad_geo_ip_country_n = String(getCookie("geo_ip_country"));
	if(ad_geo_ip_country_n.length !== 2 ){
		ad_geo_ip_country_n = "A0";
	}
	var ad_geo_ip_city_id_n = parseInt(getCookie("geo_ip_city_id"));
	if(ad_geo_ip_city_id_n < 0 ){
		ad_geo_ip_city_id_n = 0;
	}
	var ad_geo_ip_oblast_id_n = parseInt(getCookie("geo_ip_oblast_id"));
	if(ad_geo_ip_oblast_id_n < 0 ){
		ad_geo_ip_oblast_id_n = 0;
	}
	var ad_geo_ip_okrug_id_n = parseInt(getCookie("geo_ip_okrug_id"));
	if(ad_geo_ip_okrug_id_n < 0 ){
		ad_geo_ip_okrug_id_n = 0;
	}

	function get_ad_from_n(place_name) {
		if(ad_showed_from_n[place_name] === undefined){
			//adnet not select for place, selecting adnet
			var adnets = get_ad_by_ifs_n(place_name);

			adnet='none';
			if(adnets.length === 1){
				adnet = adnets[0];
			}else if(adnets.length > 1){
				adnet = adnets[getRandomInt_n(0, adnets.length-1)];
			}
			ad_showed_from_n[place_name]=adnet;
		}

		return ad_showed_from_n[place_name];
	}

	function get_ad_showed_on_n(place_name) {
		if(ad_showed_from_n[place_name] === undefined){
			return "";
		}else{
			return ad_showed_from_n[place_name];
		}
	}

	function get_localcontent_html(lc_ids, max_x, max_y, to_block){
		let html_y_free = max_y;
		var res_html = "";
		// console.log("LocalContent ad_local_contents_n");
		// console.log(ad_local_contents_n);
		shuffleArray(lc_ids);
		for(let s = 0; s < lc_ids.length; s++){
			lc_id = lc_ids[s];
			if(ad_local_contents_n.hasOwnProperty("contents") && ad_local_contents_n.contents.hasOwnProperty(lc_id)){

				var local_content = ad_local_contents_n.contents[lc_id];
				var tmpl_g_id = local_content["content_template_group_id"];
				// res_html='a-'+local_content["content_template_group_id"];
				// console.log("LocalContent ad_local_contents_n.templates");
				// console.log(ad_local_contents_n.templates);
				if(ad_local_contents_n.hasOwnProperty("templates")
					&& ad_local_contents_n.templates.hasOwnProperty(tmpl_g_id)
				){
					// Найдем шаблон с максимальным размером, который влезет в текущее место
					var bestTemplateId = null;
					var bestTemplateHeight = 0;
					
					// Перебираем все шаблоны для данной группы шаблонов
					for (var templateId in ad_local_contents_n["templates"][tmpl_g_id]) {
						var templateHeight = parseInt(ad_local_contents_n["templates"][tmpl_g_id][templateId]["template_max_y"]);
						var templateWidth = parseInt(ad_local_contents_n["templates"][tmpl_g_id][templateId]["template_max_x"]);
						// console.log("LocalContent AAA",ad_local_contents_n["templates"][tmpl_g_id][templateId])
						// Проверяем, что шаблон влезает по высоте и ширине
						if (templateHeight <= html_y_free && 
							templateWidth <= max_x && 
							templateHeight > bestTemplateHeight) {
							bestTemplateId = templateId;
							bestTemplateHeight = templateHeight;
						}
					}
					if(bestTemplateId === null){
						// console.log("LocalContent - not found template by place size", to_block, lc_id, max_x, max_y);
						continue;
					}
					
					// console.log("html_y_free", html_y_free, ad_local_contents_n["templates"][tmpl_g_id][bestTemplateId]["template_max_y"]);

					if(html_y_free >= ad_local_contents_n["templates"][tmpl_g_id][bestTemplateId]["template_max_y"]){
						res_html += ad_local_contents_n["templates"][tmpl_g_id][bestTemplateId]["template_html"];
						local_content["place"] = to_block;
						local_content["content_ext_info"] = "";
						local_content["local_content_id"] = lc_id;
						var props = [
							"content_rubric_title", 
							"content_title", 
							"content_text", 
							"content_link", 
							"content_link2", 
							"content_link3", 
							"content_link4", 
							"content_image_url",
							"content_image_url2",
							"content_image_url3",
							"content_image_url4",
							"place",
							"local_content_id",
							"content_ext_info",
							];

						for (var i = 0; i < props.length; i++) {
							res_html = res_html.replaceAll("!!"+props[i]+"!!",local_content[props[i]]);
						}
						html_y_free -= ad_local_contents_n["templates"][tmpl_g_id][bestTemplateId]["template_max_y"];
					}
				}
			}
		}
        return res_html;
	}

	function ad_show_lc(to_block, lc_ids, max_x, max_y){
		console.log("display local "+to_block);
		if(lc_ids.length === 0){
			return false;
        }
		lc_html=get_localcontent_html(lc_ids, max_x, max_y, to_block);
		// console.log(to_block, lc_html);
        $("#"+to_block).html(lc_html);
	}


lementById(place + '_lc_' + contentId + '_id');\n            \n            const observer = new IntersectionObserver((entries) => {\n                entries.forEach(entry => {\n                    if (entry.isIntersecting) {\n                        adEvent('LocalB Show', contentId, extInfoStr);\n                        console.log('LocalB Show', contentId, extInfoStr);\n                        observer.unobserve(entry.target); \n                    }\n                });\n            }, {\n                threshold: 0.7 \n            });\n            \n            if (lc) {\n                observer.observe(lc);\n            }\n        }\n\n        if (document.readyState === 'loading') {\n            document.addEventListener('DOMContentLoaded', initLocalBanner);\n        } else {\n            initLocalBanner();\n        }\n    })();\n<\/script>\n"}},"2":{"3":{"template_id":"3","template_group_id":"2","template_max_x":"300","template_max_y":"200","template_html":"<div class=\"localb\">\n    <div id=\"!!place!!_lc_!!local_content_id!!_id\" class=\"b-container\">\n        <img src=\"\/images\/lb\/best_v_bg__300x200.png\" alt=\"\u0420\u0430\u043c\u043a\u0430\" class=\"b-frame\">\n        <div class=\"b-content b-content-full\" style=\"background-image: url('!!content_image_url!!'); background-size: cover; background-position: center;\"><\/div>\n        \n        <a href=\"!!content_link!!\" target=\"_blank\" class=\"logo-link logo-top-left\" \n            onclick=\"adEvent('LocalB Click', '!!local_content_id!!', JSON.stringify({'place':'!!place!!', 'link':'1'}))\">\n            <img src=\"\/images\/lb\/yt-logo.png\" alt=\"YouTube\">\n        <\/a>\n        <a href=\"!!content_link2!!\" target=\"_blank\" class=\"logo-link logo-bottom-left\" \n            onclick=\"adEvent('LocalB Click', '!!local_content_id!!', JSON.stringify({'place':'!!place!!', 'link':'2'}))\">\n            <img src=\"\/images\/lb\/fb-logo.png\" alt=\"Facebook\">\n        <\/a>\n       \n\n        
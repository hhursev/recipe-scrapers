	<script type="application/ld+json" class="yoast-schema-graph">{"@context":"https:\/\/schema.org","@graph":[{"@type":"Article","@id":"https:\/\/glutenfreeonashoestring.com\/gluten-free-blackberry-cobbler\/#article","isPartOf":{"@id":"https:\/\/glutenfreeonashoestring.com\/gluten-free-blackberry-cobbler\/"},"author":{"name":"Nicole Hunn","@id":"https:\/\/glutenfreeonashoestring.com\/#\/schema\/person\/6df72cd6210dac35df76154aaf38cb61"},"headline":"Gluten Free Blackberry Cobbler","datePublished":"2026-05-04T21:35:37+00:00","dateModified":"2026-05-04T21:35:38+00:00","wordCount":2092,"commentCount":4,"publisher":{"@id":"https:\/\/glutenfreeonashoestring.com\/#organization"},"image":{"@id":"https:\/\/glutenfreeonashoestring.com\/gluten-free-blackberry-cobbler\/#primaryimage"},"thumbnailUrl":"https:\/\/glutenfreeonashoestring.com\/wp-content\/uploads\/2026\/04\/Gluten-Free-Blackberry-Cobbler-1.jpg","keywords":["GF Flour"],"articleSection":["Pie"],"inLanguage":"en-US","potentialAction":[{"@type":"CommentAction","name":"Comment","target":["https:\/\/glutenfreeonashoestring.com\/gluten-free-blackberry-cobbler\/#respond"]}]},{"@type":"WebPage","@id":"https:\/\/glutenfreeonashoestring.com\/gluten-free-blackberry-cobbler\/","url":"https:\/\/glutenfreeonashoestring.com\/gluten-free-blackberry-cobbler\/","name":"Gluten Free Blackberry Cobbler Recipe","isPartOf":{"@id":"https:\/\/glutenfreeonashoestring.com\/#website"},"primaryImageOfPage":{"@id":"https:\/\/glutenfreeonashoestring.com\/gluten-free-blackberry-cobbler\/#primaryimage"},"image":{"@id":"https:\/\/glutenfreeonashoestring.com\/gluten-free-blackberry-cobbler\/#primaryimage"},"thumbnailUrl":"https:\/\/glutenfreeonashoestring.com\/wp-content\/uploads\/2026\/04\/Gluten-Free-Blackberry-Cobbler-1.jpg","datePublished":"2026-05-04T21:35:37+00:00","dateModified":"2026-05-04T21:35:38+00:00","breadcrumb":{"@id":"https:\/\/glutenfreeonashoestring.com\/gluten-free-blackberry-cobbler\/#breadcrumb"},"inLanguage":"en-US","potentialAction":[{"@type":"ReadAction","target":["https:\/\/glutenfreeonashoestring.com\/gluten-free-blackberry-cobbler\/"]}]},{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/glutenfreeonashoestring.com\/gluten-free-blackberry-cobbler\/#primaryimage","url":"https:\/\/glutenfreeonashoestring.com\/wp-content\/uploads\/2026\/04\/Gluten-Free-Blackberry-Cobbler-1.jpg","contentUrl":"https:\/\/glutenfreeonashoestring.com\/wp-content\/uploads\/2026\/04\/Gluten-Free-Blackberry-Cobbler-1.jpg","width":1200,"height":1200,"caption":"close-up of baked gluten free blackberry cobbler with a spoon in the berry filling beside golden biscuit topping"},{"@type":"BreadcrumbList","@id":"https:\/\/glutenfreeonashoestring.com\/gluten-free-blackberry-cobbler\/#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https:\/\/glutenfreeonashoestring.com\/"},{"@type":"ListItem","position":2,"name":"Recipes","item":"https:\/\/glutenfreeonashoestring.com\/gluten-free-recipes\/"},{"@type":"ListItem","position":3,"name":"Pie","item":"https:\/\/glutenfreeonashoestring.com\/category\/gluten-free-pie\/"},{"@type":"ListItem","position":4,"name":"Gluten Free Blackberry Cobbler"}]},{"@type":"WebSite","@id":"https:\/\/glutenfreeonashoestring.com\/#website","url":"https:\/\/glutenfreeonashoestring.com\/","name":"Gluten Free on a Shoestring","description":"Gluten free recipes even gluten-eaters love","publisher":{"@id":"https:\/\/glutenfreeonashoestring.com\/#organization"},"potentialAction":[{"@type":"SearchAction","target":{"@type":"EntryPoint","urlTemplate":"https:\/\/glutenfreeonashoestring.com\/?s={search_term_string}"},"query-input":{"@type":"PropertyValueSpecification","valueRequired":true,"valueName":"search_term_string"}}],"inLanguage":"en-US"},{"@type":"Organization","@id":"https:\/\/glutenfreeonashoestring.com\/#organization","name":"Gluten Free on a Shoestring","url":"https:\/\/glutenfreeonashoestring.com\/","logo":{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/glutenfreeonashoestring.com\/#\/schema\/logo\/image\/","url":"https:\/\/glutenfreeonashoestring.com\/wp-content\/uploads\/2024\/09\/Gluten-Free-on-a-Shoestring-logo.png","contentUrl":"https:\/\/glutenfreeonashoestring.com\/wp-content\/uploads\/2024\/09\/Gluten-Free-on-a-Shoestring-logo.png","width":696,"height":696,"caption":"Gluten Free on a Shoestring"},"image":{"@id":"https:\/\/glutenfreeonashoestring.com\/#\/schema\/logo\/image\/"},"sameAs":["https:\/\/www.facebook.com\/gfshoestring","https:\/\/x.com\/gfshoestring","http:\/\/www.pinterest.com\/gfshoestring\/","http:\/\/instagram.com\/gfshoestring\/","https:\/\/www.youtube.com\/channel\/UCZxUlsQcfzqLRJe5MpkLZvw"]},{"@type":"Person","@id":"https:\/\/glutenfreeonashoestring.com\/#\/schema\/person\/6df72cd6210dac35df76154aaf38cb61","name":"Nicole Hunn","image":{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/secure.gravatar.com\/avatar\/33cb3b1680f6d07da74ff65fdc2dd94d51471aec374e44cf25474ab1bb57d603?s=96&d=mm&r=g","url":"https:\/\/secure.gravatar.com\/avatar\/33cb3b1680f6d07da74ff65fdc2dd94d51471aec374e44cf25474ab1bb57d603?s=96&d=mm&r=g","contentUrl":"https:\/\/secure.gravatar.com\/avatar\/33cb3b1680f6d07da74ff65fdc2dd94d51471aec374e44cf25474ab1bb57d603?s=96&d=mm&r=g","caption":"Nicole Hunn"},"description":"Hi, I’m Nicole. I create gluten free recipes that really work and taste as good as you remember. No more making separate meals when someone is GF, or buying packaged foods that aren’t good enough to justify the price. At Gluten Free on a Shoestring, “good, for gluten free” just isn’t good enough!","sameAs":["https:\/\/glutenfreeonashoestring.com\/about\/"]},{"@type":"Recipe","name":"Gluten Free Blackberry Cobbler Recipe","author":{"@id":"https:\/\/glutenfreeonashoestring.com\/#\/schema\/person\/6df72cd6210dac35df76154aaf38cb61"},"description":"This gluten free blackberry cobbler has a jammy, sweet-tart filling and a soft biscuit topping that bakes up golden and tender. This reliable recipe works even when your berries aren’t perfect.","datePublished":"2026-05-04T17:35:37+00:00","image":["https:\/\/glutenfreeonashoestring.com\/wp-content\/uploads\/2026\/04\/Gluten-Free-Blackberry-Cobbler-1.jpg","https:\/\/glutenfreeonashoestring.com\/wp-content\/uploads\/2026\/04\/Gluten-Free-Blackberry-Cobbler-1-500x500.jpg","https:\/\/glutenfreeonashoestring.com\/wp-content\/uploads\/2026\/04\/Gluten-Free-Blackberry-Cobbler-1-500x375.jpg","https:\/\/glutenfreeonashoestring.com\/wp-content\/uploads\/2026\/04\/Gluten-Free-Blackberry-Cobbler-1-480x270.jpg"],"recipeYield":["6","6 servings"],"prepTime":"PT20M","cookTime":"PT45M","recipeIngredient":["1\/2 cup granulated sugar","3 tablespoons tapioca starch (or superfine white rice flour)","1\/2 teaspoon kosher salt","1\/2 teaspoon ground cinnamon","24 ounces fresh blackberries (about 5 1\/2 cups, rinsed and patted dry)","6 ounces fresh raspberries (about 1 1\/4 cups, rinsed and patted dry)","1 1\/2 cups all purpose gluten free flour blend (See Recipe Notes)","3\/4 teaspoon xanthan gum (omit if your blend already contains it)","2 ¼ teaspoons baking powder","¼ teaspoon baking soda","½ teaspoon kosher salt","¼ cup granulated sugar","8 tablespoons unsalted butter (thinly sliced and chilled)","1  1\/8 cups buttermilk (chilled)"],"recipeInstructions":[{"@type":"HowToStep","text":"Grease a 9-inch square stoneware baking dish, preferably in a light color, lightly with butter or neutral oil. Set it aside.","name":"Grease a 9-inch square stoneware baking dish, preferably in a light color, lightly with butter or neutral oil. Set it aside.","url":"https:\/\/glutenfreeonashoestring.com\/gluten-free-blackberry-cobbler\/#wprm-recipe-88808-step-0-0"},{"@type":"HowToSection","name":"Prepare the filling","itemListElement":[{"@type":"HowToStep","text":"In a large mixing bowl, whisk together the sugar, tapioca starch, salt and ground cinnamon.","name":"In a large mixing bowl, whisk together the sugar, tapioca starch, salt and ground cinnamon.","url":"https:\/\/glutenfreeonashoestring.com\/gluten-free-blackberry-cobbler\/#wprm-recipe-88808-step-1-0"},{"@type":"HowToStep","text":"Transfer about 3 tablespoons of this dry mixture to a small mixing bowl. Add the fresh raspberries to the dry ingredients and toss to coat them in it, then set the bowl aside.","name":"Transfer about 3 tablespoons of this dry mixture to a small mixing bowl. Add the fresh raspberries to the dry ingredients and toss to coat them in it, then set the bowl aside.","url":"https:\/\/glutenfreeonashoestring.com\/gluten-free-blackberry-cobbler\/#wprm-recipe-88808-step-1-1"},{"@type":"HowToStep","text":"Add the fresh blackberries to the large mixing bowl with the remaining dry ingredients, and toss them gently to coat all the berries well in the dry mixture.","name":"Add the fresh blackberries to the large mixing bowl with the remaining dry ingredients, and toss them gently to coat all the berries well in the dry mixture.","url":"https:\/\/glutenfreeonashoestring.com\/gluten-free-blackberry-cobbler\/#wprm-recipe-88808-step-1-2"},{"@type":"HowToStep","text":"Transfer the blackberry mixture to the prepared baking dish, and spread them gently into an even layer. Add any dry mixture that remains on the bottom of the bowl.","name":"Transfer the blackberry mixture to the prepared baking dish, and spread them gently into an even layer. Add any dry mixture that remains on the bottom of the bowl.","url":"https:\/\/glutenfreeonashoestring.com\/gluten-free-blackberry-cobbler\/#wprm-recipe-88808-step-1-3"},{"@type":"HowToStep","text":"Scatter the raspberries on top in an even layer, scattering any leftover dry ingredients on top. Set the baking dish aside.","name":"Scatter the raspberries on top in an even layer, scattering any leftover dry ingredients on top. Set the baking dish aside.","url":"https:\/\/glutenfreeonashoestring.com\/gluten-free-blackberry-cobbler\/#wprm-recipe-88808-step-1-4"}]},{"@type":"HowToSection","name":"Prepare the topping","itemListElement":[{"@type":"HowToStep","text":"In a large mixing bowl, whisk together the flour blend, xanthan gum, baking powder, baking soda, salt and sugar.","name":"In a large mixing bowl, whisk together the flour blend, xanthan gum, baking powder, baking soda, salt and sugar.","url":"https:\/\/glutenfreeonashoestring.com\/gluten-free-blackberry-cobbler\/#wprm-recipe-88808-step-2-0"},{"@type":"HowToStep","text":"Add the slices of cold butter, and toss to coat in the dry ingredients. If any slices of butter weren’t thinly sliced, flatten them with floured fingers.","name":"Add the slices of cold butter, and toss to coat in the dry ingredients. If any slices of butter weren’t thinly sliced, flatten them with floured fingers.","url":"https:\/\/glutenfreeonashoestring.com\/gluten-free-blackberry-cobbler\/#wprm-recipe-88808-step-2-1"},{"@type":"HowToStep","text":"Create a well in the center of the dry ingredients, and add the buttermilk to the center.","name":"Create a well in the center of the dry ingredients, and add the buttermilk to the center.","url":"https:\/\/glutenfreeonashoestring.com\/gluten-free-blackberry-cobbler\/#wprm-recipe-88808-step-2-2"},{"@type":"HowToStep","text":"Mix gently with a silicone spatula until you&#39;ve created a soft, relatively wet biscuit dough.","name":"Mix gently with a silicone spatula until you&#39;ve created a soft, relatively wet biscuit dough.","url":"https:\/\/glutenfreeonashoestring.com\/gluten-free-blackberry-cobbler\/#wprm-recipe-88808-step-2-3"},{"@type":"HowToStep","text":"If the topping seems like it isn’t very cold or the butter has melted at all, place the topping mixture in the refrigerator to chill briefly.","name":"If the topping seems like it isn’t very cold or the butter has melted at all, place the topping mixture in the refrigerator to chill briefly.","url":"https:\/\/glutenfreeonashoestring.com\/gluten-free-blackberry-cobbler\/#wprm-recipe-88808-step-2-4"}]},{"@type":"HowToSection","name":"Add the topping","itemListElement":[{"@type":"HowToStep","text":"Use a large ice cream scoop or two large spoons to top the berry mixture in the baking dish with 6 relatively equal scoops of the pastry topping. Concentrate them mostly toward the center as the biscuits will spread in the oven toward the edges.","name":"Use a large ice cream scoop or two large spoons to top the berry mixture in the baking dish with 6 relatively equal scoops of the pastry topping. Concentrate them mostly toward the center as the biscuits will spread in the oven toward the edges.","url":"https:\/\/glutenfreeonashoestring.com\/gluten-free-blackberry-cobbler\/#wprm-recipe-88808-step-3-0"}]},{"@type":"HowToSection","name":"Bake","itemListElement":[{"@type":"HowToStep","text":"Bake at 375°F for 20 minutes. Lower the heat to 350°F for another 20 minutes or until the filling is bubbling, the topping feels firm when pressed gently, and a toothpick inserted in the center of one of the biscuits (without entering the filling) comes out clean.","name":"Bake at 375°F for 20 minutes. Lower the heat to 350°F for another 20 minutes or until the filling is bubbling, the topping feels firm when pressed gently, and a toothpick inserted in the center of one of the biscuits (without entering the filling) comes out clean.","url":"https:\/\/glutenfreeonashoestring.com\/gluten-free-blackberry-cobbler\/#wprm-recipe-88808-step-4-0"},{"@type":"HowToStep","text":"Let cool for about 15 minutes in the pan before serving warm.","name":"Let cool for about 15 minutes in the pan before serving warm.","url":"https:\/\/glutenfreeonashoestring.com\/gluten-free-blackberry-cobbler\/#wprm-recipe-88808-step-4-1"}]}],"aggregateRating":{"@type":"AggregateRating","ratingValue":"5","ratingCount":"2","reviewCount":"2"},"review":[{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Hello!  Thank you for all your recipes.  I have been gluten free for 40 years and also refined sugar free.  I have often baked with honey or agave, which can not work well because they are liquidy, but just made your blackberry cobbler with organic maple sugar granules!  If I want powdered sugar, I put them in the blender! \r\n\r\nEveryone went overboard for the cobbler and it was gone in a flash!  Served with vanilla ice cream (coconut sugar) and it would have been great with whipped cream too.\r\nThank you again,\r\nSusan Diamond","author":{"@type":"Person","name":"Susan Diamond"},"datePublished":"2026-05-11"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"This looks so good! Have you tried it with frozen berries? I just wondered if it would throw off the liquid ratio. Thanks for sharing!","author":{"@type":"Person","name":"Jennifer Lovett"},"datePublished":"2026-05-07"}],"recipeCategory":["Dessert"],"recipeCuisine":["American"],"keywords":"gluten free blackberry cobbler","nutrition":{"@type":"NutritionInformation","servingSize":"1 serving","calories":"462 kcal","carbohydrateContent":"73 g","proteinContent":"5 g","fatContent":"17 g","saturatedFatContent":"10 g","transFatContent":"1 g","cholesterolContent":"45 mg","sodiumContent":"673 mg","fiberContent":"10 g","sugarContent":"34 g","unsaturatedFatContent":"5 g"},"@id":"https:\/\/glutenfreeonashoestring.com\/gluten-free-blackberry-cobbler\/#recipe","isPartOf":{"@id":"https:\/\/glutenfreeonashoestring.com\/gluten-free-blackberry-cobbler\/#article"},"mainEntityOfPage":"https:\/\/glutenfreeonashoestring.com\/gluten-free-blackberry-cobbler\/"}]}</script>

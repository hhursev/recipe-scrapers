["mousemove","touchstart"].forEach(function(e){window.addEventListener(e,loadIP)})</script><style type="text/css">@media only screen and (max-width: 940px) {
.wprm-container-float-right {margin:0 0 10px 0 !important;}
.wprm-recipe-image {height: 180px; overflow: hidden !important;}
.wprm-recipe-image img {width:100% !important;}
.wprm-recipe-details-container-table .wprm-recipe-block-container-table {display: inline-flex !important;}
.wprm-recipe-cook-time-container {border-width:0px solid #fff !important;}
.wprm-recipe-total-time-container {border-width:0px solid #fff !important;}
}
.wprm-unit-conversion-container {
margin-top: 30px;
    font-weight: bold;
}
.wprm-unit-conversion-container a {
color: #000 !important;
}
.recipe-intro {
background-color:#ee3e4e;
}
.recipe-intro img{
display:flex;
height:50px;
padding:10px 0px 5px 0px;
margin: 20px auto;
}
.wprm-recipe-template-linds-compact {
    margin: 0px;
    padding: 20px !important;
    border: 1px solid #000 !important;
    background-color: #fafafa; /*wprm_background type=color*/
    font-family: "Muli","Helvetica Neue",sans-serif;
    font-size: 14px; /*wprm_main_font_size type=font_size*/
    line-height: 1.5em !important; /*wprm_main_line_height type=font_size*/
    color: #464546; /*wprm_main_text type=color*/
    max-width: 650px; /*wprm_max_width type=size*/
}
.wprm-recipe-template-linds-compact h2, .wprm-recipe-template-linds-compact h3 {
    letter-spacing:3px;
}
.wprm-disclaimer {
    font-size: .8em !important;
    line-height: 1em !important;
    color: #494949;
    margin-top: 10px !important;
    font-style:oblique;
}
.wprm-call-to-action {
margin-top:20px !important;
}
.wprm-call-to-action.wprm-call-to-action-simple a {
color:#fff;
font-weight:bold;
}
.wprm-container-float-right {
margin: 0 0 10px 40px;
}
.wprm-recipe-template-linds-compact a {
    color: #222222; /*wprm_link type=color*/
}
.wprm-recipe-template-linds-compact p, .wprm-recipe-template-linds-compact li {
    font-family: "Muli","Helvetica Neue",sans-serif;
    font-size: 1em !important;
    line-height: 1.5em !important; /*wprm_main_line_height type=font_size*/
}
.wprm-recipe-template-linds-compact li {
    margin: 0 0 0 32px !important;
    padding: 0 !important;
}
.wprm-recipe-template-linds-compact ol, .wprm-recipe-template-linds-compact ul {
    margin: 0 !important;
    padding: 0 !important;
}
.wprm-recipe-template-linds-compact br {
    display: none;
}
.wprm-recipe-template-linds-compact .wprm-recipe-name,
.wprm-recipe-template-linds-compact .wprm-recipe-header {
    font-family: Helvetica, sans-serif; /*wprm_header_font_family type=font*/
    color: #464546; /*wprm_header_text type=color*/
    line-height: 1.3em; /*wprm_header_line_height type=font_size*/
}
.wprm-recipe-template-linds-compact h1,
.wprm-recipe-template-linds-compact h2,
.wprm-recipe-template-linds-compact h3,
.wprm-recipe-template-linds-compact h4,
.wprm-recipe-template-linds-compact h5,
.wprm-recipe-template-linds-compact h6 {
    font-family: Helvetica, sans-serif; /*wprm_header_font_family type=font*/
    color: #464546; /*wprm_header_text type=color*/
    line-height: 1.3em; /*wprm_header_line_height type=font_size*/
    margin: 0 !important;
    padding: 0 !important;
}
.wprm-recipe-template-linds-compact .wprm-recipe-header {
    margin-top: 2.5em !important;
}
.wprm-recipe-template-linds-compact h1 {
    font-size: 2em; /*wprm_h1_size type=font_size*/
}
.wprm-recipe-template-linds-compact h2 {
    font-size: 1.8em; /*wprm_h2_size type=font_size*/
}
.wprm-recipe-template-linds-compact h3 {
    font-size: 1.2em; /*wprm_h3_size type=font_size*/
}
.wprm-recipe-template-linds-compact h4 {
    font-size: 1em; /*wprm_h4_size type=font_size*/
}
.wprm-recipe-template-linds-compact h5 {
    font-size: 1em; /*wprm_h5_size type=font_size*/
}
.wprm-recipe-template-linds-compact h6 {
    font-size: 1em; /*wprm_h6_size type=font_size*/
}.wprm-recipe-template-linds-compact {
	border-style: solid; /*wprm_border_style type=border*/
	border-width: 0px; /*wprm_border_width type=size*/
	border-color: #464546; /*wprm_border type=color*/
	border-radius: 0px; /*wprm_border_radius type=size*/
	padding: 10px;
}
.wprm-recipe-template-linds-compact li {
		    margin: 0 0 0 18px !important;
}
.wprm-recipe-template-linds-compact .wprm-recipe-name {
font-family:oswald;
    font-weight: 500;
    letter-spacing: 1px;
    font-size: 26px;	
}
.wprm-recipe-template-linds-compact .wprm-recipe-header {
font-family:oswald;
    letter-spacing: 1px;
    font-size: 20px;
    font-weight: 500;	
}
.wprm-recipe-link.wprm-recipe-link-inline-button {
    font-size: 14px;
    }
    .wprm-recipe-link.wprm-recipe-link-inline-button {
    display: inline;
    }.wprm-recipe-template-linds-buttons {
    font-family: inherit; /*wprm_font_family type=font*/
    font-size: 12px; /*wprm_font_size type=font_size*/
    text-align: center; /*wprm_text_align type=align*/
    margin-top: 0px; /*wprm_margin_top type=size*/
    margin-bottom: 15px; /*wprm_margin_bottom type=size*/
}
.wprm-recipe-template-linds-buttons a  {
    margin: %wprm_margin_button%;
    margin: %wprm_margin_button%;
}

.wprm-recipe-template-linds-buttons a:first-child {
    margin-left: 0;

}
.wprm-recipe-template-linds-buttons a:last-child {
    margin-right: 0;
}
.wprm-recipe-template-linds-buttons .wprm-recipe-rating {
float:left;
padding-left:20px;
}
.wprm-recipe-jump {
float:left;
}
.wprm-recipe-rating .wprm-rating-star.wprm-rating-star-full svg * {
fill:#F8E71C !important;

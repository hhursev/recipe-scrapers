	#media_image-4 img {
    width: 50%;
		    margin: auto;
    display: grid;
    padding-bottom: 20px;
}
.footer-widgets-3	{
border-top: 1px solid #bfbebc;
padding-top: 20px;
	    text-align: center;
	}
.footer-widgets-3, .footer-widgets-2 {
    width: 100%;
    padding: 0px;
    margin: 0px;
	}
	.footer-widgets-2 {
    padding-right: 0px;
}
}


/*TOP OPTIN*/
.before-header {
	background-color: #e23260;
}
.before-header .enews-widget input {
    font-family: rubik;	
	opacity:1;
}
.enews .widgettitle.widget-title {
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 4px;
    font-family: rubik;
    color: #fff;	
	background:none;
	opacity: 1;
}

/*SAVE RECIPES LOGIN PAGE + SIGNUP*/
.in-text-save-recipes {
background-color: #e23260;
padding: 10px 20px 20px;
	text-align:center;
	color:#fff;
	text-transform:uppercase;
	margin-left: 5%;
}
.in-text-save-recipes strong {
    font-weight: 400;
    text-transform: none;
}
.in-text-save-recipes .wpforms-container-full .wpforms-form button[type=submit] {
	background-color: #666;
	    width: 100%;
    border: 0px;
    color: #fff;
    font-family: oswald;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 5px;
    font-size: 20px;
    font-weight: normal;
}
.in-text-save-recipes h2 {
font-family:oswald;
    font-size: 28px;
    letter-spacing: 1px;
    margin-bottom: 0px;
}
.login-page .entry-header {
margin-bottom:0px;
}
.login-page .wpforms-container-full {
    background-color: #a7c94a;
    padding: 10px 20px 20px;
}
.login-page .wpforms-container-full .wpforms-form button[type=submit] {
    width: 100%;
    background-color: #e23260;
    border: 0px;
    color: #fff;
    font-family: oswald;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 5px;
    font-size: 20px;
    font-weight: normal;
}
/*MOBILE*/
@media only screen and (max-width: 940px) {
.home-middle {
    display: block;
    width: 100%;
}
.more-from-category	{	
	    width: 100%;
    text-align: center;
}
}		</style>

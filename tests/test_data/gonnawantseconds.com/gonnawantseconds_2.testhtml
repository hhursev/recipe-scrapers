			/*TABLE OF CONTENTS
---
1 - SITE STRUCTURE - Adthrive, Fonts, Page Structure
---
2 - MENU/HEADER - Top Header, Logo and Menu
---
3 - POST TYPE - Buying Guide, Informative Post, Recipe Post
---
4 - PAGES - Homepage, Membership, Shop, Recipe Index, contact
---
5 - OPTINS
---
6 - SIDEBAR
---
7 - FOOTER
---
8 - MOBILE
*/
/*1 - SITE STRUCTURE*/
/*1A - AD THRIVE */
.pmprocm_modal_bg {
    z-index: 9999 !important;
}
@media screen and (min-width: 1200px) {
.adthrive-content {
width: 730px;
}
}

/*1B - FONTS*/
.archive-pagination a, .pagination .nav-links .page-numbers {
	color:#464546;
}
h2 {
	letter-spacing:1px;
	font-size:26px;
	font-family:oswald;
		text-transform:uppercase;
		color: #464546;
}
h3 {
	letter-spacing: 0px;
  font-size: 20px;
  font-weight: 500;
		font-family:oswald;
	color: #464546;
}
.entry-content h3 {
margin-bottom: 21px;
    margin-top: 37px;
    font-weight: 700;
    letter-spacing: 1px;
    font-size: 18px;
}
.button, .button-secondary, button, input[type="button"], input[type="reset"], input[type="submit"], a.more-link, .more-from-category a, p.more-from-category, div.wpforms-container-full .wpforms-form button[type=submit] {
	font-family: "Rubik","Helvetica Neue",sans-serif;
    font-weight: bold;
    font-size: 14px;
    background: #464546;
    color: #fff;
border:0px solid #464546;
	text-transform:uppercase;
	letter-spacing:2px;
}
.button:hover, .button-secondary:hover, button:hover, submit:hover, p.more-from-category:hover {
    background: #e32e60 !important;
	opacity:.7;
    color: #fff;
border:0px solid #e32e60;
}
p {
color: #464546;
}
article p a, article li a span, article li a, #respond a {
font-weight: bold;
background: linear-gradient(180deg, rgba(255,255,255,0) 65%, rgba(167, 201, 75,.4) 65%);
color: #464546!important;
}
article p a span {
font-weight: bold;
background: linear-gradient(180deg, rgba(255,255,255,0) 65%, rgba(167, 201, 75,.1) 65%);
color: #464546!important;
}
article p a:hover, article li a span:hover,  article li a:hover, #respond a:hover {
font-weight: bold;
background: linear-gradient(180deg, rgba(255,255,255,0) 0%, rgba(167, 201, 75,.4) 0%);
color: #464546!important;
}
article p a span:hover {
font-weight: bold;
background: linear-gradient(180deg, rgba(255,255,255,0) 0%, rgba(167, 201, 75,.1) 0%);
color: #464546!important;
}
a {
color:#222222;
}

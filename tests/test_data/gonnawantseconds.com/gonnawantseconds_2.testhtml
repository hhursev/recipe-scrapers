		jQuery(document).ready(function($){
			var lastScrollTop = 0;
			$(window).scroll(function(event){
				var st = $(this).scrollTop();
				if (st > lastScrollTop){
					$('body').addClass('down');
					$('body').removeClass('up');
				}else if(st == lastScrollTop){
				//do nothing 
				//In IE this is an important condition because there seems to be some instances where the last scrollTop is equal to the new one
				}else {
					$('body').addClass('up');
					$('body').removeClass('down');
				}
				lastScrollTop = st;
			});

			$('.button_save > a').on('click', function(e){
				e.preventDefault();
				$.ajax({
					type : "POST",
					dataType : "json",
					url : 'https://www.gonnawantseconds.com/wp-admin/admin-ajax.php',
					data : {action: "save_this_recipes", post_id : '10895'},
					success: function(response) {
						// response = JSON.parse(response);
						console.log(response);
						if(response.type == "success") {
							$('#save_this_recipes').attr('href', 'https://www.gonnawantseconds.com/my-recipe-collections/');
							$('.button_save > a').html('View Collection');
							$('.button_save > a').attr('id', 'saved_recipes');
							$('.button_save > a').attr('class', 'saved_recipes');
							$('.button_save').removeAttr('class');
						}else {
							location.assign("https://www.gonnawantseconds.com/user-registration/");
						}
					}
				});
			});
			$('.wprm-recipe-container').delegate('.saved_recipes', 'click', function(){
				location.assign("https://www.gonnawantseconds.com/my-recipe-collections/");
			});
			$('.fixed-buttons').delegate('#saved_recipes', 'click', function(){
				location.assign("https://www.gonnawantseconds.com/my-recipe-collections/");
			});
		});
	</script>

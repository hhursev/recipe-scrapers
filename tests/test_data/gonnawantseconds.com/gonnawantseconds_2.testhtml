/*.custom_header .entry-meta a{
	color: #000 !important;
    font-weight: bold;
    background: linear-gradient(180deg, rgba(255,255,255,0) 65%, rgba(245, 176, 27, 0.4) 65%);
}*/
.custom_header {
    display: -ms-grid;
    display: grid;
    -ms-grid-columns: 50% 50%;
    grid-template-columns: 50% 50%;
}
.custom_header > div {
    padding: 10px;
}
.right img {
    margin-top: 0;
}
.custom_header > div.left {
	order: 1;
}
.custom_header > div.right {
	order: 2;
}
.custom_header_container.site-inner {
    padding-bottom: 0px;
}
@media only screen and (max-width: 1023px){
	.page-template-filter-recipes .filter-wrap {
		display: block;
	}
	.page-template-filter-recipes button.filter-toggle {
	    display: none;
	}
	.page-template-filter-recipes .sidebar .recipes-facets {
		display: none;
	}
}

@media(max-width: 768px){
	.custom_header > div.right {
		order: 1;
		padding: 0;
	}
	.custom_header {
		display: -ms-grid;
		display: grid;
		-ms-grid-columns: 100%;
		grid-template-columns: 100%;
	}
	.custom_header_container.site-inner {
		padding: 0;
	}
	.custom_header > div.right img {
		width: 100%;
	}
	.custom_header > div.left {
		width: 450px;
		max-width: 100%;
		margin: -85px auto 0;
		text-align: center;
		background: #fff;
	}
	.custom_header .wprm-recipe-template-linds-buttons {
    	width: 275px;
		margin: 0 auto;
	}
}
</style>


.jump-to {
    width: 100%;
    height: 100%;
    display: inline-block;
    clear: both;
    text-align: center;
    padding-top: 20px;
    margin-bottom: 30px;
    border-top: 1px solid #b6b6b6;
    border-bottom: 1px solid #b6b6b6;
}
.jump-to-item {
    margin: 0 1.5% 22px 0;
    display: inline-block;
    vertical-align: top;
    padding: 0 5px 0;
    width: 22%;
}
.jump-to-item-text {
    padding-top: 15px;
    line-height: 16px;
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 2px;
    color: #464546;
    font-size: 10px;
    font-family: "Rubik","Helvetica Neue",sans-serif;
}
.jump-to h3 {
	letter-spacing: 1px;
    text-align: center;
    color: #464546;
    padding-top: 0px;
    margin-top: 0px;
    text-transform: uppercase;
    font-size: 20px !important;
    font-weight: bold;
}
.wprm-recipe-template-linds-buttons a {
    font-weight: 600;
    color: #fff !important;
    background-color: #464546 !important;
    border-radius: 0px;
    border: 0px !important;
    padding: 17px 20px !important;
    font-family: "Rubik","Helvetica Neue",sans-serif;
    font-size: 12px;
    letter-spacing: 2px;
}
.wprm-recipe-template-linds-buttons a:hover {
    background-color: #222222 !important;
	opacity:.7;
}
.entry-title {
    font-family: "Oswald","Helvetica Neue",sans-serif;
    font-weight: bold;
    font-size: 30px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #464546;
}
.custom_header_container .entry-meta {
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 2px;
    color: #464546;
    font-size: 10px;
    border-top: 3px solid #a6c84a;
	padding-top: 20px;
	font-family: "Rubik","Helvetica Neue",sans-serif;
}
.custom_header .excerpt p {
	    font-style: normal;
    padding-top: 5px;
}
.comment-respond h3, .entry-comments h3 {
    text-align: left;
    letter-spacing: 1px;
    color: #464546;
    padding-top: 0px;
    margin-top: 0px;
    text-transform: uppercase;
    font-size: 27px !important;
    text-align: left;
    font-weight: bold;
}
.comment-respond h3::after, .entry-comments h3::after {
	border-bottom:none;
	padding-bottom:0px;
	margin-bottom:0px;
}
.form-submit {
	    padding-top: 20px;
}
.wprm-recipe-print, .wprm-recipe-pin {
    font-weight: 600;
    font-family: "Rubik","Helvetica Neue",sans-serif;
    letter-spacing: 2px !important;
    font-size: 10px;
	padding: 10px 20px !important;
}
.button_save {
    font-weight: 600;
    font-family: "Rubik","Helvetica Neue",sans-serif;
    letter-spacing: 2px !important;
}
.wprm-recipe-template-linds-compact .wprm-recipe-name {
	font-weight:600 !important;
}
.wprm-recipe-template-linds-compact .wprm-recipe-header {
	font-weight:600 !important;
}
.entry-meta .entry-categories:before {
	content:"This recipe is part of the following collections:";
	display: block;
    padding-bottom: 10px;
    color: #464546;
    font-weight: 700;
    font-size: 22px;
    font-family: oswald;
    letter-spacing: 1px;
    text-align: left;
}
a.category, .entry-categories a, .entry-tags a {
    background: #ebf2c7;
	font-size: 14px;
	color: #464546 !important;
}
.entry-categories, .entry-tags {
    background: transparent;
	color:#464546;
}
.custom_header .wprm-recipe-template-linds-buttons {
	width: 60%;
    margin: 0 auto;
    display: grid;
}
@media only screen and (max-width: 940px) {
.wprm-recipe-pin {

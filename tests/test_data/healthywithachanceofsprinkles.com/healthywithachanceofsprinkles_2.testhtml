2021/10/oven-baked-high-protein-brownie-recipe-480x270.jpg"],"recipeYield":["1","1 brownie"],"prepTime":"PT3M","cookTime":"PT1M","recipeIngredient":["1/4 Cup Chocolate Protein Powder (30 grams (whey, casein, or plant-based))","1 Tablespoon All-Purpose Flour","1 Tablespoon Sugar (or sweetener of choice)","1 Tablespoon Cocoa Powder","1/2  Teaspoon Baking Powder","Pinch of Salt","1.5 Tablespoons Chocolate Chips ((Optional))","3 Tablespoons Plain Greek Yogurt","3 Tablespoons Milk","1 Teaspoon Olive Oil ((or Coconut Oil))","1/2 Teaspoon  Vanilla Extract"],"recipeInstructions":[{"@type":"HowToSection","name":"1-Minute Microwave Instructions","itemListElement":[{"@type":"HowToStep","text":"Mix all dry ingredients in a mug.","name":"Mix all dry ingredients in a mug.","url":"https://healthywithachanceofsprinkles.com/chocolaty-protein-brownie-mug-cake/#wprm-recipe-2576-step-0-0"},{"@type":"HowToStep","text":"Stir in wet ingredients until smooth.","name":"Stir in wet ingredients until smooth.","url":"https://healthywithachanceofsprinkles.com/chocolaty-protein-brownie-mug-cake/#wprm-recipe-2576-step-0-1"},{"@type":"HowToStep","text":"Microwave for 60 seconds. If not set, continue in 10-secondbursts (up to 90 sec).","name":"Microwave for 60 seconds. If not set, continue in 10-secondbursts (up to 90 sec).","url":"https://healthywithachanceofsprinkles.com/chocolaty-protein-brownie-mug-cake/#wprm-recipe-2576-step-0-2"},{"@type":"HowToStep","text":"Let it rest for 1–2 minutes and enjoy warm.","name":"Let it rest for 1–2 minutes and enjoy warm.","url":"https://healthywithachanceofsprinkles.com/chocolaty-protein-brownie-mug-cake/#wprm-recipe-2576-step-0-3"}]},{"@type":"HowToSection","name":"Oven-Baked Protein Brownie Instructions","itemListElement":[{"@type":"HowToStep","text":"Preheat oven to 350°F (175°C).","name":"Preheat oven to 350°F (175°C).","url":"https://healthywithachanceofsprinkles.com/chocolaty-protein-brownie-mug-cake/#wprm-recipe-2576-step-1-0"},{"@type":"HowToStep","text":"Mix all ingredients in a small oven-safe dish or ramekin.","name":"Mix all ingredients in a small oven-safe dish or ramekin.","url":"https://healthywithachanceofsprinkles.com/chocolaty-protein-brownie-mug-cake/#wprm-recipe-2576-step-1-1"},{"@type":"HowToStep","text":"Bake for 10 minutes, or until set.","name":"Bake for 10 minutes, or until set.","url":"https://healthywithachanceofsprinkles.com/chocolaty-protein-brownie-mug-cake/#wprm-recipe-2576-step-1-2"}]}],"aggregateRating":{"@type":"AggregateRating","ratingValue":"4.53","ratingCount":"40","reviewCount":"6"},"review":[{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"This brownie mug cake was so rich and yummy. Totally satisfying. I loved it.","author":{"@type":"Person","name":"Scarlet"},"datePublished":"2021-10-19"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"This looks great and I love how it's in a mug! I'm going to experiment with some of your substitution ideas. I might try it with Tigernut flour instead of oat flower and use your dairy-free suggestions.","author":{"@type":"Person","name":"Aimee Mars"},"datePublished":"2021-10-19"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"I love how quick and easy this is to make!! Everyone loved it!","author":{"@type":"Person","name":"Toni"},"datePublished":"2021-10-19"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"The microwave version has become my new to-go for a quick chocolate fix after dinner. So easy and delicious!","author":{"@type":"Person","name":"Gina"},"datePublished":"2021-10-19"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"I love mug cakes for a quick and easy chocolate fix and this protein packed version looks great.","author":{"@type":"Person","name":"Dannii"},"datePublished":"2021-10-19"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"re
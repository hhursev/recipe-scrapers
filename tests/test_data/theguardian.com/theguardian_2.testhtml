&quot;longTitle&quot;:&quot;Prize&quot;,&quot;url&quot;:&quot;/crosswords/series/prize&quot;,&quot;children&quot;:[],&quot;mobileOnly&quot;:false},{&quot;title&quot;:&quot;Genius&quot;,&quot;longTitle&quot;:&quot;Genius&quot;,&quot;url&quot;:&quot;/crosswords/series/genius&quot;,&quot;children&quot;:[],&quot;mobileOnly&quot;:false},{&quot;title&quot;:&quot;Weekend&quot;,&quot;longTitle&quot;:&quot;Weekend&quot;,&quot;url&quot;:&quot;/crosswords/series/weekend-crossword&quot;,&quot;children&quot;:[],&quot;mobileOnly&quot;:false},{&quot;title&quot;:&quot;Special&quot;,&quot;longTitle&quot;:&quot;Special&quot;,&quot;url&quot;:&quot;/crosswords/series/special&quot;,&quot;children&quot;:[],&quot;mobileOnly&quot;:false}],&quot;mobileOnly&quot;:false},{&quot;title&quot;:&quot;Wordiply&quot;,&quot;longTitle&quot;:&quot;Wordiply&quot;,&quot;url&quot;:&quot;https://www.wordiply.com&quot;,&quot;children&quot;:[],&quot;mobileOnly&quot;:false},{&quot;title&quot;:&quot;Corrections&quot;,&quot;longTitle&quot;:&quot;Corrections&quot;,&quot;url&quot;:&quot;/theguardian/series/corrections-and-clarifications&quot;,&quot;children&quot;:[],&quot;mobileOnly&quot;:false},{&quot;title&quot;:&quot;Tips&quot;,&quot;longTitle&quot;:&quot;Tips&quot;,&quot;url&quot;:&quot;https://www.theguardian.com/tips&quot;,&quot;children&quot;:[],&quot;mobileOnly&quot;:false}],&quot;brandExtensions&quot;:[{&quot;title&quot;:&quot;Search jobs&quot;,&quot;longTitle&quot;:&quot;Search jobs&quot;,&quot;url&quot;:&quot;https://jobs.theguardian.com&quot;,&quot;children&quot;:[],&quot;mobileOnly&quot;:false},{&quot;title&quot;:&quot;Digital Archive&quot;,&quot;longTitle&quot;:&quot;Digital Archive&quot;,&quot;url&quot;:&quot;https://theguardian.newspapers.com&quot;,&quot;children&quot;:[],&quot;mobileOnly&quot;:false},{&quot;title&quot;:&quot;Guardian Licensing&quot;,&quot;longTitle&quot;:&quot;Guardian Licensing&quot;,&quot;url&quot;:&quot;https://licensing.theguardian.com/&quot;,&quot;children&quot;:[],&quot;mob
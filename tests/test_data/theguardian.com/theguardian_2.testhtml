                 <script type="application/ld+json">
                    			[{"@type":"NewsArticle","@context":"https://schema.org","@id":"https://www.theguardian.com/food/2024/mar/02/vegan-chinese-takeaway-curry-recipe-tofu-vegetable-curry-meera-sodha","publisher":{"@type":"Organization","@context":"https://schema.org","@id":"https://www.theguardian.com#publisher","name":"The Guardian","url":"https://www.theguardian.com/","logo":{"@type":"ImageObject","url":"https://uploads.guim.co.uk/2018/01/31/TheGuardian_AMP.png","width":190,"height":60},"sameAs":["https://www.facebook.com/theguardian","https://twitter.com/guardian","https://www.youtube.com/user/TheGuardian"]},"isAccessibleForFree":true,"isPartOf":{"@type":["CreativeWork","Product"],"name":"The Guardian","productID":"theguardian.com:basic"},"image":["https://i.guim.co.uk/img/media/44b2223c94c81bf84df181d38163e4e5bfe2494a/0_1609_3627_2176/master/3627.jpg?width=1200&height=630&quality=85&auto=format&fit=crop&precrop=40:21,offset-x50,offset-y0&overlay-align=bottom%2Cleft&overlay-width=100p&overlay-base64=L2ltZy9zdGF0aWMvb3ZlcmxheXMvdGctZGVmYXVsdC5wbmc&enable=upscale&s=baffb2be0b4630fc57f4ce3268330e5d","https://i.guim.co.uk/img/media/44b2223c94c81bf84df181d38163e4e5bfe2494a/0_1609_3627_2176/master/3627.jpg?width=1200&height=1200&quality=85&auto=format&fit=crop&s=99e41cdb5dfbdd7b183726ab751c9341","https://i.guim.co.uk/img/media/44b2223c94c81bf84df181d38163e4e5bfe2494a/0_1609_3627_2176/master/3627.jpg?width=1200&height=900&quality=85&auto=format&fit=crop&s=004c1825f56ca07fcbc98319fa6abbc7","https://i.guim.co.uk/img/media/44b2223c94c81bf84df181d38163e4e5bfe2494a/0_1609_3627_2176/master/3627.jpg?width=1200&quality=85&auto=format&fit=max&s=065228510ff61978deee8fe921545df9"],"author":[{"@type":"Person","name":"Meera Sodha","sameAs":"https://www.theguardian.com/profile/meera-sodha"}],"datePublished":"2024-03-02T12:00:31.000Z","headline":"Meera Sodha’s vegan recipe for Chinese takeaway-style tofu and vegetable curry","dateModified":"2025-12-01T14:39:00.000Z","mainEntityOfPage":"https://www.theguardian.com/food/2024/mar/02/vegan-chinese-takeaway-curry-recipe-tofu-vegetable-curry-meera-sodha"},{"@type":"WebPage","@context":"https://schema.org","@id":"https://www.theguardian.com/food/2024/mar/02/vegan-chinese-takeaway-curry-recipe-tofu-vegetable-curry-meera-sodha","potentialAction":{"@type":"ViewAction","target":"android-app://com.guardian/https/www.theguardian.com/food/2024/mar/02/vegan-chinese-takeaway-curry-recipe-tofu-vegetable-curry-meera-sodha"}},{"@context":"http://schema.org","@type":"Recipe","name":"Chinese takeaway-style tofu and vegetable curry","description":"When I was growing up, our family treat on a Saturday night was a Chinese takeaway. We’d drive 15 minutes to our nearest town to get it and the way back was agony. Now with my own family, we still love Chinese food on Saturday night, but with no local takeaway, I make it at home","image":"https://media.guim.co.uk/44b2223c94c81bf84df181d38163e4e5bfe2494a/0_0_3627_4277/1696.jpg","datePublished":"2024-03-02T12:00:31Z","url":"https://www.theguardian.com/food/2024/mar/02/vegan-chinese-takeaway-curry-recipe-tofu-vegetable-curry-meera-sodha","recipeCategory":["Dinner"],"recipeCuisine":["Chinese"],"recipeIngredient":["450.0g extra-firm tofu drained","6.5tbsp cornflour","2.0tbsp white miso paste – I like Miso Tasty","4.0tbsp rapeseed oil","1.0 large brown onion peeled and cut into 2½cm x 2½cm pieces","4.0 garlic cloves peeled and minced","1.5tbsp mild curry powder","1.0tsp ground turmeric","0.75tsp ground ginger","2.0 carrots (about 200g), peeled and cut into ½cm-thick rounds","200.0g Tenderstem florets kept whole, stems cut into 1cm lengths","150.0g frozen petit pois defrosted","1.0tsp caster sugar","2.0tbsp light soy sauce","Cooked jasmine rice to serve"],"recipeInstructions":[{"@type":"HowToStep","text":"First, press the tofu with kitchen towel to remove any excess water, then cut it into 2cm x 2cm cubes and put in a bowl. Add five tablespoons of the cornflour, stir to coat, then set aside.","image":[]},{"@type":"HowToStep","text":"Put the remaining tablespoon and a half of cornflour in a small bowl, add two tablespoons of water, mix to combine and put to one side.","image":[]},{"@type":"HowToStep","text":"To make up the stock, put the miso in a jug, pour over 750ml just-boiled water, mix to dissolve and set aside. Put a large plate to one side of the hob, ready for when you fry the tofu.","image":[]},{"@type":"HowToStep","text":"Put a large, wide frying pan for which you have a lid on a medium heat and add the oil. Shake any excess cornflour off the tofu, then put the cubes in the pan in a single layer (depending on the size of the pan, you may need to cook the tofu in two batches) and fry for about six minutes, turning every other minute, until pale golden all over. Keeping the pan on the heat, use a slotted spoon to transfer the fried tofu to the plate by the side of the hob.","image":[]},{"@type":"HowToStep","text":"Add the onion to the hot pan and cook, stirring and separating the petals as you do so, for about six minutes, until coloured. ","image":[]},{"@type":"HowToStep","text":"Add the garlic, cook for two minutes, then stir in the spices.","image":[]},{"@type":"HowToStep","text":"Add the carrots to the pan, pour in the miso stock, pop on the lid and leave to simmer for 12 minutes, or until tender.","image":[]},{"@type":"HowToStep","text":"Stir in the Tenderstem, pop the lid back on and cook for another three minutes.","image":[]},{"@type":"HowToStep","text":"Finally, add the peas, cornflour paste, fried tofu, sugar and soy sauce, stir well to combine, then leave to simmer with the lid off for another five minutes, until the sauce has thickened and everything is hot.","image":[]},{"@type":"HowToStep","text":"Take off the heat and serve at once with rice.","image":[]}],"recipeYield":["Serves 4.0"],"prepTime":"PT10M","cookTime":"PT40M","totalTime":"PT50M","author":{"@type":"Person","name":"Meera Sodha"},"suitableForDiet":["","","https://schema.org/VegetarianDiet",""]}]
                			</script>


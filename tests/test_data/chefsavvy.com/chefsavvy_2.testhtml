y-bites\/","name":"Energy Bites (8 + Flavor Options!) - Chef Savvy","isPartOf":{"@id":"https:\/\/chefsavvy.com\/#website"},"primaryImageOfPage":{"@id":"https:\/\/chefsavvy.com\/5-ingredient-peanut-butter-energy-bites\/#primaryimage"},"image":{"@id":"https:\/\/chefsavvy.com\/5-ingredient-peanut-butter-energy-bites\/#primaryimage"},"thumbnailUrl":"https:\/\/chefsavvy.com\/wp-content\/uploads\/peanut-butter-chocolate-chip-energy-balls.jpg","datePublished":"2024-08-21T15:33:37+00:00","dateModified":"2025-04-18T16:18:18+00:00","description":"Quick and Healthy 5 Ingredient Peanut Butter Energy Bites. Takes less than 10 minutes to make with only 5 ingredients! The perfect snack!","breadcrumb":{"@id":"https:\/\/chefsavvy.com\/5-ingredient-peanut-butter-energy-bites\/#breadcrumb"},"mainEntity":[{"@id":"https:\/\/chefsavvy.com\/5-ingredient-peanut-butter-energy-bites\/#faqitem-can-you-freeze-energy-bites"},{"@id":"https:\/\/chefsavvy.com\/5-ingredient-peanut-butter-energy-bites\/#faqitem-what-can-i-use-instead-of-flax-seed"},{"@id":"https:\/\/chefsavvy.com\/5-ingredient-peanut-butter-energy-bites\/#faqitem-would-maple-syrup-work"},{"@id":"https:\/\/chefsavvy.com\/5-ingredient-peanut-butter-energy-bites\/#faqitem-what-are-the-calories-per-serving"},{"@id":"https:\/\/chefsavvy.com\/5-ingredient-peanut-butter-energy-bites\/#faqitem-what-do-i-do-if-its-too-dry"}],"inLanguage":"en-US","potentialAction":[{"@type":"ReadAction","target":["https:\/\/chefsavvy.com\/5-ingredient-peanut-butter-energy-bites\/"]}]},{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/chefsavvy.com\/5-ingredient-peanut-butter-energy-bites\/#primaryimage","url":"https:\/\/chefsavvy.com\/wp-content\/uploads\/peanut-butter-chocolate-chip-energy-balls.jpg","contentUrl":"https:\/\/chefsavvy.com\/wp-content\/uploads\/peanut-butter-chocolate-chip-energy-balls.jpg","width":665,"height":932},{"@type":"BreadcrumbList","@id":"https:\/\/chefsavvy.com\/5-ingredient-peanut-butter-energy-bites\/#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Recipe Index","item":"https:\/\/chefsavvy.com\/recipeindex\/"},{"@type":"ListItem","position":2,"name":"Breakfast","item":"https:\/\/chefsavvy.com\/category\/breakfast\/"},{"@type":"ListItem","position":3,"name":"Energy Bites (8 Flavors!)"}]},{"@type":"WebSite","@id":"https:\/\/chefsavvy.com\/#website","url":"https:\/\/chefsavvy.com\/","name":"Chef Savvy","description":"A food blog with easy to follow dinner, dessert and healthy recipes perfect for beginners!","publisher":{"@id":"https:\/\/chefsavvy.com\/#organization"},"potentialAction":[{"@type":"SearchAction","target":{"@type":"EntryPoint","urlTemplate":"https:\/\/chefsavvy.com\/?s={search_term_string}"},"query-input":{"@type":"PropertyValueSpecification","valueRequired":true,"valueName":"search_term_string"}}],"inLanguage":"en-US"},{"@type":"Organization","@id":"https:\/\/chefsavvy.com\/#organization","name":"Chef Savvy","url":"https:\/\/chefsavvy.com\/","logo":{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/chefsavvy.com\/#\/schema\/logo\/image\/","url":"https:\/\/chefsavvy.com\/wp-content\/uploads\/logo-1.png","contentUrl":"https:\/\/chefsavvy.com\/wp-content\/uploads\/logo-1.png","width":120,"height":77,"caption":"Chef Savvy"},"image":{"@id":"https:\/\/chefsavvy.com\/#\/schema\/logo\/image\/"}},{"@type":"Person","@id":"https:\/\/chefsavvy.com\/#\/schema\/person\/d317a549a2c42d44e8b4d69b487f303e","name":"Kelley Simmons","description":"With over 15 years of culinary experience, Kelley has worked in various restaurants over the years and graduated from culinary school back in 2009. Since 2014, she has been sharing her family's favorite recipes with over 1 million people every month!","sameAs":["https:\/\/chefsavvy.com\/about\/","https:\/\/www.facebook.com\/chefsavvy\/","https:\/\/www.instagram.com\/thechefsavvy\/","https:\/\/www.pinterest.com\/chefsavvy\/","https:\/\/x.com\/https:\/\/twitter.com\/ChefSavvy"]},{"@type":"Recipe","name":"Energy Bites (8 Ways!)","author":{"@id":"https:\/\/chefsavvy.com\/#\/schema\/person\/d317a549a2c42d44e8b4d69b487f303e"},"description":"Quick and Healthy 5 Ingredient Peanut Butter Energy Bites. Takes less than 10 minutes to make with only 5 ingredients! The perfect healthy snack!","datePublished":"2024-08-21T15:33:37+00:00","image":["https:\/\/chefsavvy.com\/wp-content\/uploads\/energy-bites-recipe.jpg","https:\/\/chefsavvy.com\/wp-content\/uploads\/energy-bites-recipe-500x500.jpg","https:\/\/chefsavvy.com\/wp-content\/uploads\/energy-bites-recipe-500x375.jpg","https:\/\/chefsavvy.com\/wp-content\/uploads\/energy-bites-recipe-480x270.jpg"],"video":{"name":"Energy Bites","description":"No Bake Energy Balls. Loaded with old fashioned oats, peanut butter and flax seeds. These Energy Balls are a healthy protein packed breakfast or snack!","thumbnailUrl":"https:\/\/content.jwplatform.com\/thumbs\/rfR2jmUA-720.jpg","contentUrl":"https:\/\/content.jwplatform.com\/videos\/rfR2jmUA.mp4","uploadDate":"2025-04-18T14:48:17+00:00","@type":"VideoObject"},"recipeYield":["12","12 bites"],"prepTime":"PT10M","totalTime":"PT10M","recipeIngredient":["2\/3 cup creamy peanut butter","1 cup old fashioned oats","1\/2 cup ground flax seeds","2 tbsp honey","1\/2 cup mix in&#39;s (see variations below)","1\/2 cup chocolate chips","2 tbsp cocoa powder","1\/4 cup white chocolate chips","14 cup dried cranberries","1\/2 lemon zested and juiced","2 tsp poppy seeds","1\/4 cup  mini M &amp; M&#39;s","1\/4 cup mini chocolate chips","1\/4 cup peanuts","1\/4 cup raisins","reduce oats by 1\/4 cup","1\/4 cup almonds, chopped","1\/4 cup unsweetened shredded coconut","1\/4 cup chocolate chips","1\/4 cup sprinkles","2 tbsp vanilla protein powder"],"recipeInstructions":[{"@type":"HowToStep","text":"Combine the peanut butter, oats, flax seed and honey in a large bowl. Stir in your mix ins. Place in the refrigerator for 15-30 minutes so they are easier to roll. Also slightly damp hands make it easier to roll as well!","name":"Combine ingredients","url":"https:\/\/chefsavvy.com\/5-ingredient-peanut-butter-energy-bites\/#wprm-recipe-27489-step-0-0"},{"@type":"HowToStep","text":"Roll into 12 bites and store in the fridge for up to a week.","name":"Roll","url":"https:\/\/chefsavvy.com\/5-ingredient-peanut-butter-energy-bites\/#wprm-recipe-27489-step-0-1"}],"aggregateRating":{"@type":"AggregateRating","ratingValue":"4.8","ratingCount":"257","reviewCount":"9"},"review":[{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"I added cinnamon and vanilla and used butterscotch chips to mix in. The whole family loved them. Next time I'll use a little less oats but maybe I should've reduced them anyway. All and all, the recipe was a hit.","author":{"@type":"Person","name":"Britney"},"datePublished":"2026-03-21"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"My go-to recipe every time! I usually double it :))","author":{"@type":"Person","name":"Hannah"},"datePublished":"2025-10-20"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"4"},"reviewBody":"Made 3 flavors of these today. Even after chilling and wetting my hands, they were still a bit hard to make into balls (crumbly). I tried adding a bit of water to crumbs (didn’t really work). Added a small bit of (vegan) milk into second batch—that seemed to work better. Still took a while to mold into balls, but eventually worked out. Made them for my daughter and son in-law. I’m sure they’ll love them.","author":{"@type":"Person","name":"Kathy V"},"datePublished":"2025-10-15"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Absolutely love these and they are very easy to make.","author":{"@type":"Person","name":"Sheila"},"datePublished":"2025-08-26"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Love these so easy to make.  Have made different versions over the past 40 years.\r\n\r\nLike all the variations you offer.\r\nJust made 3 batches .  1 with just chocolate chips 1 double chocolate \r\nThen made one batch with diced dried apples and raisins - so good. \r\nThese are for use to have while traveling a vacation… if I can keep my husband out of them.","author":{"@type":"Person","name":"Leslie Moss"},"datePublished":"2025-08-22"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"I need to have nutritious high protein snacks because I have dropped much more weight than is healthy. This is a wonderful addition to my efforts. I am most grateful. Thank you.\r\nMary Ann","author":{"@type":"Person","name":"Mary Ann"},"datePublished":"2025-07-22"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"One of my favorite healthy snack recipes. We I make them I add chia seeds.!","author":{"@type":"Person","name":"Sherry Hart"},"datePublished":"2025-07-02"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"My 6 year old LOVES these. They are a fantastic snack for at home (unfortunately their school is nut free). Been making these for probably over a year now. I make a double batch, freeze them on a plate, then pack into containers\/bags for the freezer, and take out 4 or 5 at a time for the fridge.\r\n\r\nI've been looking for healthier snack options too for me, with fibre and protein, and these are super delicious for adults also.\r\n\r\nThanks for the recipe!","author":{"@type":"Person","name":"Crystal"},"datePublished":"2025-05-27"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Super easy. Super delicious. Family approved!","author":{"@type":"Person","name":"Pat"},"datePublished":"2025-03-20"}],"recipeCategory":["Breakfast","Snack"],"recipeCuisine":["American"],"keywords":"Energy Bites, Fit meals, Gluten Free, Healthy, Meal Prep","nutrition":{"@type":"NutritionInformation","servingSize":"1 bite","calories":"200 kcal","carbohydrateContent":"16 g","proteinContent":"6 g","fatContent":"13 g","saturatedFatContent":"3 g","cholesterolContent":"1 mg","sodiumContent":"69 mg","fiberContent":"4 g","sugarContent":"7 g"},"@id":"https:\/\/chefsavvy.com\/5-ingredient-peanut-butter-energy-bites\/#recipe","isPartOf":{"@id":"https:\/\/chefsavvy.com\/5-ingredient-peanut-butter-energy-bites\/#article"},"mainEntityOfPage":"https:\/\/chefsavvy.com\/5-ingredient-peanut-butter-energy-bites\/"},{"@type":"Question","@id":"https:\/\/chefsavvy.com\/5-ingredient-peanut-butter-energy-bites\/#faqitem-can-you-freeze-energy-bites","position":1,"url":"https:\/\/chefsavvy.com\/5-ingredient-peanut-butter-energy-bites\/#faqitem-can-you-freeze-energy-bites","name":"Can you freeze energy bites?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"<p>Yes! These no bake energy bites can be frozen in an airtight container for up to 3 months!<\/p>","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https:\/\/chefsavvy.com\/5-ingredient-peanut-butter-energy-bites\/#faqitem-what-can-i-use-instead-of-flax-seed","position":2,"url":"https:\/\/chefsavvy.com\/5-ingredient-peanut-butter-energy-bites\/#faqitem-what-can-i-use-instead-of-flax-seed","name":"What can I use instead of flax seed?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"<p>Chia seed or hemp seed are a good alternative to ground flax seed. You can also substitute the flax for more oats or unsweetened shredded coconut!<\/p>","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https:\/\/chefsavvy.com\/5-ingredient-peanut-butter-energy-bites\/#faqitem-would-maple-syrup-work","position":3,"url":"https:\/\/chefsavvy.com\/5-ingredient-peanut-butter-energy-bites\/#faqitem-would-maple-syrup-work","name":"Would Maple syrup work?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"<p>Yes! Maple syrup can be used in place of the honey!<\/p>","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https:\/\/chefsavvy.com\/5-ingredient-peanut-butter-energy-bites\/#faqitem-what-are-the-calories-per-serving","position":4,"url":"https:\/\/chefsavvy.com\/5-ingredient-peanut-butter-energy-bites\/#faqitem-what-are-the-calories-per-serving","name":"What are the calories per serving?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"<p>This is a question that gets asked a lot. The calories are 200 for 1 serving (1 bite) I know that seems like a lot but the peanut butter in this really adds to the calories. These bites are perfect as a snack or pick me up or a quick breakfast before working out! Some readers have tried using <a href=\"https:\/\/amzn.to\/3sxGo9u\" rel=\"nofollow sponsored noopener\" target=\"_blank\">powdered peanut butter<\/a> to save on calories!<\/p>","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https:\/\/chefsavvy.com\/5-ingredient-peanut-butter-energy-bites\/#faqitem-what-do-i-do-if-its-too-dry","position":5,"url":"https:\/\/chefsavvy.com\/5-ingredient-peanut-butter-energy-bites\/#faqitem-what-do-i-do-if-its-too-dry","name":"What do I do if its too dry?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"<p>If the mixture seems too dry try adding a splash of water. I do 1 tablespoon at a time. This helps bind everything together. Alternatively you can always add a scoop more of peanut butter, honey or maple syrup to bind everything up!<\/p>","inLanguage":"en-US"},"inLanguage":"en-US"}]}</script>
	<!-- / Yoast SEO Premium plugin. -->



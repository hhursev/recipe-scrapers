					<div class="comrating"><img data-od-unknown-tag data-od-xpath="/HTML/BODY/MAIN[@id=&amp;apos;body&amp;apos;]/*[2][self::DIV]/*[1][self::DIV]/*[1][self::DIV]/*[1][self::DIV]/*[1][self::DIV]/*[3][self::DIV]/*[2][self::DIV]/*[2][self::DIV]/*[2][self::DIV]/*[1][self::UL]/*[1][self::LI]/*[1][self::ARTICLE]/*[2][self::DIV]/*[1][self::DIV]/*[3][self::DIV]/*[1][self::IMG]" class="wprm-comment-rating perfmatters-lazy" src="data:image/svg+xml,%3Csvg%20xmlns=&#039;http://www.w3.org/2000/svg&#039;%20width=&#039;80&#039;%20height=&#039;16&#039;%20viewBox=&#039;0%200%2080%2016&#039;%3E%3C/svg%3E" alt="5 stars" width="80" height="16" data-src="https://chefsavvy.com/wp-content/themes/chefsavvy2024/images/stars-5.svg" />
</div>				</div>		
				<div class="comcontent notop nobot">

<script type="application/ld+json">{"@context":"https:\/\/schema.org","@type":"Recipe","name":"The Toddler Pancake Recipe You\u2019ll Actually Want to Eat (Kaiserschmarrn)","url":"https:\/\/newdadskitchen.com\/recipe\/best-toddler-pancake-recipe-kaiserschmarrn\/","image":["https:\/\/newdadskitchen.com\/wp-content\/uploads\/2025\/09\/torn_pancake_for_toddlers_Kaiserschmarrn-500x500.png","https:\/\/newdadskitchen.com\/wp-content\/uploads\/2025\/09\/torn_pancake_for_toddlers_Kaiserschmarrn-500x375.png","https:\/\/newdadskitchen.com\/wp-content\/uploads\/2025\/09\/torn_pancake_for_toddlers_Kaiserschmarrn-480x270.png"],"author":{"@type":"Person","name":"Brad"},"datePublished":"2025-09-03","description":"This toddler pancake recipe is based on Austria\u2019s kaiserschmarrn: a fluffy, oven-baked pancake torn into bite-sized pieces. Light, golden, and perfect for dipping into jam or applesauce, it\u2019s a fun and tasty upgrade to the usual breakfast.","prepTime":"PT0H15M","cookTime":"PT0H15M","totalTime":"PT0H45M","recipeYield":"3","recipeCategory":["Breakfast"],"recipeCuisine":["Swiss"],"cookingMethod":["Baking"],"keywords":"toddler pancake recipe, fluffy pancakes for toddlers, easy breakfast for toddlers, toddler breakfast ideas, pancakes for kids, kid-friendly pancakes, healthy toddler breakfast recipe, brunch ideas for kids, how to make pancakes for toddlers, fun pancake recipe for kids, toddler breakfast ideas, pancake recipes","recipeIngredient":["4 large Eggs","2\/3 cup Milk","2 tbsp Sugar","1 tsp Vanilla Extract","1 cup All-Purpose Flour","  Powdered Sugar","  Lemon","  Jam or Jelly"],"recipeInstructions":[{"@type":"HowToStep","name":"","text":"Remove eggs and milk from fridge and allow to warm to room temperature, roughly 15 minutes.","image":""},{"@type":"HowToStep","name":"","text":"Separate egg yolks and whites into two bowls. Set yolks aside.","image":""},{"@type":"HowToStep","name":"","text":"Add a tbsp of sugar and a pinch of salt to the egg whites, then blend with a whisk or a hand mixer until egg whites are thicky and foamy, roughly two minutes. Set aside.","image":""},{"@type":"HowToStep","name":"","text":"Preheat oven to 400.","image":""},{"@type":"HowToStep","name":"","text":"Add the milk, remaining sugar, and vanilla extract to the bowl with the egg yolks. With your whisk or hand mixer, blend until mixed, then gradually add in the flour until a smooth batter forms.","image":""},{"@type":"HowToStep","name":"","text":"Add in half of the foamed egg whites into the batter; mix until blended. Add in remainder of egg whites and mix again until blended and smooth.","image":""},{"@type":"HowToStep","name":"","text":"Grease a large (at least 10\u201d) pan with enough oil to coat the base of the pan; heat stove to Medium Low. (Note: you can use butter, but make sure it does not brown or burn.) Pour batter into the hot pan and swirl around until the bottom of the pan is evenly covered. Cook for one minute.","image":""},{"@type":"HowToStep","name":"","text":"Place on middle rack of the oven and cook until bottom is browned and the insides look elastic and cheese-colored, 8-10 minutes. Return to stovetop.","image":""},{"@type":"HowToStep","name":"","text":"Set stove to Medium Low again. Cut the pancake in half lengthwise, then another halving width-wise, creating four roughly even pieces; add a bit of oil or butter to the bottom of the pan if dry. Flip the pancake pieces over.","image":""},{"@type":"HowToStep","name":"","text":"Allow the side now face-down in the pan to brown, 1-2 minutes; smash them down with a spatula as needed. With a spatula in one hand and a knife in the other, cut\/rip the pancake quarters into smaller pieces; they do not need to be even in size. Remove from pan.","image":""},{"@type":"HowToStep","name":"","text":"Sprinkle powdered sugar all over the bits.","image":""},{"@type":"HowToStep","name":"","text":"In Mitteleuropa it\u2019s common to serve this dish with jelly\/jam or applesauce, which your child will surely love and appreciate; we find a spritz of lemon is more than enough for adults. Silverware\u2013or even plates, for that matter\u2013are optional here.","image":""},{"@type":"HowToStep","name":"","text":"Add chopped up nuts or berries directly to the batter for a bit more heft; potato would work, too\u2013just par-boil half a potato and mince into small pieces, then add to the batter after whipping the eggs.","image":""}],"aggregateRating":null,"review":null,"nutrition":{"@type":"NutritionInformation","calories":"150 calories","carbohydrateContent":"40 grams","cholesterolContent":"75 milligrams","fatContent":"5 grams","fiberContent":"","proteinContent":"8 grams","saturatedFatContent":"","servingSize":"about 8 pieces","sodiumContent":"","sugarContent":"","transFatContent":""},"video":{"@type":"VideoObject","name":"The Toddler Pancake Recipe You\u2019ll Actually Want to Eat (Kaiserschmarrn)","description":"This toddler pancake recipe is based on Austria\u2019s kaiserschmarrn: a fluffy, oven-baked pancake torn into bite-sized pieces. Light, golden, and perfect for dipping into jam or applesauce, it\u2019s a fun and tasty upgrade to the usual breakfast.","thumbnailUrl":"https:\/\/i3.ytimg.com\/vi\/shorts\/maxresdefault.jpg","contentUrl":"https:\/\/www.youtube.com\/watch?v=shorts","uploadDate":"2026-06-08T22:03:46+00:00"},"@id":"https:\/\/newdadskitchen.com\/recipe\/best-toddler-pancake-recipe-kaiserschmarrn\/#recipe","isPartOf":{"@id":"https:\/\/newdadskitchen.com\/recipe\/best-toddler-pancake-recipe-kaiserschmarrn\/#webpage"},"mainEntityOfPage":{"@type":"WebPage","@id":"https:\/\/newdadskitchen.com\/recipe\/best-toddler-pancake-recipe-kaiserschmarrn\/#webpage"}}</script>
		
					</main>
			</div>
			

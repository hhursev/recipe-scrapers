</div>
<div id="fb-root"></div>
<style>

/* Recipe stuff */
.wprm-recipe-container {
	margin: 40px 0 10px;
}
.wprm-recipe-template-2019 {
	font-size: 18px;
    padding: 30px;
}
.wprm-recipe-image {
	float: right;
}
.wprm-recipe-head {
	text-align: left;
	padding: 20px;
}
.wprm-recipe-summary {
    font-size: 17px;
    line-height: 27px;
    margin: 0 0 15px;
}
.wprm-recipe h2 {
    font-size: 40px;
    margin: 0 0 10px;
}
.wprm-recipe-servings-container::after {
    content: 'Adjust number of servings to scale recipe';
    display: inline-block;
    vertical-align: middle;
    font-size: 12px;
	padding: 5px 11px;
	display: inline-block;
	border-radius: 20px;
	margin: 10px;
	color: #000;
	text-transform: capitalize;
	text-decoration: none !important;
}
.wprm-recipe-servings-container, .wprm-recipe-rating {
    margin: 0 0 20px;
    display: inline-block !important;
    vertical-align: middle;
    font-size: 22px;
}
.wprm-recipe-details-container-table.wprm-recipe-table-borders-top-bottom {
    width: auto;
    margin: 10px -20px 0;
    border-radius: 80px;
    padding: 10px;
}	
.wprm-recipe-details-container-table {
    display: flex !important;
}
input[type=number].wprm-recipe-servings {
    font-size: 22px;
    width: 80px;
}
.wprm-recipe-instruction-image img {
    margin: 10px 0 30px;
}
.wprm-recipe-print, .wprm-recipe-pin {
    display: inline-block !important;
    height: 30px;
    width: 30px;
    position: relative !important;
    top: auto !important;
    left: auto !important;
    right: auto !important;
}

.wprm-recipe-ingredient-notes {
    font-style: italic;
}
.wprm-recipe-container h3, .wprm-recipe-container h4, .wprm-recipe h3 {
    font-size: 20px;
    margin: 20px 0 !important;
}
.wprm-recipe-instructions-container .wprm-recipe-instruction-text {
    font-size: 20px;
    line-height: 30px;
}
/* Recipe Layout */
.wprm-recipe-ingredients-container {
  padding-left: 10px;
}
.wprm-recipe-instructions-container {
    padding-right: 20px;
}
.wprm-recipe-instruction-media.wprm-recipe-instruction-image {
  margin: 20px 0;
}
h4.wprm-recipe-nutrition-header, .wprm-nutrition-label-container {
  margin: 20px;
}
.recipe-tags {
  margin: 30px 20px 20px;
}
.recipe-tags .arrow-right {
  display: inline-block;
  margin-right: 10px;
  width: 0;
  height: 0;
  border-top: 5px solid transparent;
  border-bottom: 5px solid transparent;
  border-left: 5px solid #000;
}
.wprm-recipe-container {
  margin: 40px -20px 10px;
}
.wprm-recipe li {
  margin-bottom: 0 !important;
  margin-left: 20px;
  padding: 0;
}
.wprm-recipe-instruction-media.wprm-recipe-instruction-image {
	max-width: none;
}
.wprm-recipe-instruction-media.wprm-recipe-instruction-image img {
	width: 100%
}
#wprm-popup-modal-user-rating, #wprm-popup-modal-2 {
	display: none;
}
@media only screen and (max-width: 500px) {
	.wprm-recipe-image {
		display:none;
	}	
	.wprm-recipe-head {
		text-align: left;
		padding: 0;
	}
	.wprm-recipe-servings-container, .wprm-recipe-rating {
		text-align: center;
		margin: 0 auto 20px;
		display: block !important;
	}
	.wprm-recipe-details-container-table {
		font-size: 14px;
	}
	.wprm-recipe-details-container-table.wprm-recipe-table-borders-top-bottom .wprm-recipe-block-container-table {
		border: none !important;
	}
	.wprm-recipe-time-label {
		font-size: 13px;
	}
	.wprm-recipe-instruction-media.wprm-recipe-instruction-image {
		margin: 0px -45px;
	}
	.wprm-nutrition-label {
		display: block;
		margin: inherit;
	}
	.recipe-tags {
		margin: 30px 0 20px;
	}
	.sticky-sidebar {
		padding: 0;
	}
}

/* Typography */
em {
  font-style: italic;
}
.page-numbers {
    display: inline-block;
    padding: 15px 25px;
    line-height: normal;
    vertical-align: middle;
    font-size: 19px;
}
.recent-recos {
    grid-column: 3;
    padding: 50px 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: 20px;
}
.footer-reco {
	display: block;
    overflow: hidden;
    text-align: center;
    margin-bottom: 20px;
    font-size: 16px;
    letter-spacing: -0.5px;
}
.footer-reco h5 {
    margin: 10px 0;
    font-size: 25px;
}
.meow {
    margin-top: -14px;
    font-size: 17px;
}
.popular-recos {
    grid-column: 5;
    padding: 50px 0;
}
.popular-recos h4 {
    margin: 0;
    font-size: 30px;
}
.popular-reco {
	display: block;
    margin: 30px 0;
    padding-left: 45px !important;
}
.popular-reco h5 {
	font-size: 25px;
    margin: 0;
	letter-spacing: -0.5px;
}
.popular-recos.with-counter a::before {
    font-size: 60px;
    line-height: 34px;
}
.super-footer {
	text-align: center;
	font-size: 20px;
	padding: 20px;
}
.super-footer a, .super-footer .copyright {
  display: inline-block;
  position:relative
}
.footer-disclosures {
	opacity: 0.3;
    font-size: 15px;
    max-width: 600px;
    margin: 20px auto;
}
.rating {
  line-height: 16px;
  margin-top: 15px;
  font-size: 13px;
}
.star {
  background-image: url("data:image/svg+xml;base64,");
  background-size: contain;
  display: inline-block;
  vertical-align: bottom;
	--div-height: 20px;
  height: var(--div-height);
}
.rating span {
	font-weight: bold;
  margin-right: 10px;
}
.comment-pagination {
	text-align: center;
	margin: 10px auto 25px;
}
.comment-pagination .page-numbers:not(.dots) {
    display: inline-block;
    padding: 10px;
    min-width: 2.4em;
    
}


/* Layout */
#menu-overlay,
#search-overlay,
#close-sidebar {
	display:none;
	position: fixed;
	left: 0;
	top: 0;
	bottom: 0;
	right: 0;
	z-index: 10000002;
	backdrop-filter: blur(5px);
}

#sidebarMenu a, #sidebarMenu input[type=text] {
  font-size: 20px;
  display: block;
  padding: 10px 30px;
  border: 0;
  width: 100%;
  outline: none;
}
#sidebarMenu form.sidebarsearch {
  position: relative;
}
#sidebarMenu input[type=text]::placeholder {
  color: #fc6;
}
#sidebarMenu input[type=text]:focus::placeholder {
  color: rgba(0,0,0,0);
}
#sidebarMenu input[type=text]:focus {
  background: #fff;
}
#sidebarMenu .sidebarsearch button {
  position: absolute;
  top: 50%;
  right: 10px;
  width: 28px;
  height: 28px;
  padding: 0;
  border: 0;
  margin-top: -14px;
}
#sidebarMenu a:hover {
  background: rgba(50,105,70);
  color: #fff;
}
#sidebarMenu .icons {
  margin: 10px 20px;
  min-height: 40px;
}
#sidebarMenu .icons a {
  height: 20px;
  width: 20px;
  background: none;
  border: 0;
  float: left;
  padding: 0;
  margin: 10px;
}
#sidebarMenu .icon {
  height: 100%;
}
#sidebarMenu .logo {
  margin: 0;
  height: 48px;
  width: 190px;
  background-position: 30px 57%;
  background-size: 160px;
}
#sidebarMenu label.icon-close {
  float: right;
  display: block;
  height: 48px;
  width: 48px;
}
.sidebar-head {
  height: 48px;
  width: 48px;
  position: absolute;
  right: 0;
}
.sidebar-head svg {
    height: 100%;
    width: 100%;
}
.sidebar-head svg line {
  stroke: #fc6;
  stroke-width: 60;
  stroke-linecap: round;
}
.sidebar-head::after {
  content: "";
  clear: both;
  display: table;
}
#openSidebarMenu:checked ~ #sidebarMenu
 {
		transform: translateX(0);
}
#openSidebarMenu:checked ~ #menu-overlay,
#openSidebarSearch:checked ~ #search-overlay {
		display: block;
}
#openSidebarSearch:checked ~ #sidebarSearch
 {
		transform: translateX(-300px);
}
#sidebarSearch button {
  height: 50px;
  width: 50px;
  border: 0;
}
#sidebarMenu .sub-categories a {
  padding-left: 60px;
}
.main-content p.retina-image {
	padding: 0;
}
.footer-feed a {
  border-top: 1px solid #888;
  display: block;
  position: relative;
}
.sidebar-feed .by-category small {
  display: none;
}
.sidebar-feed .thumbnail-image {
  background-size: auto 100%;
  background-position: 50%;
  border-radius: 100px;
  width: 75px;
  height: 75px;
  margin-top: 5px;
}
.with-counter {
	counter-reset: section;
}
.with-counter a {
	counter-increment: section;
	padding-left: 40px;
	position: relative;
}
.with-counter a::before {
	content: counter(section);
	position: absolute;
	top: 0;
	left: 0;
	font-size: 30px;
  	line-height: 15px;
  	font-weight: normal;
  	font-family: georgia;
}
.roundup-item {
  background: rgba(128,128,128,0.1);
  padding: 20px 20px 1px;
  margin-bottom: 20px;
  counter-increment: roundup;
  position: relative;
}
.roundup-item::before {
  content: counter(roundup);
  position: absolute;
  top: 20px;
  left: 20px;
  background: #000;
  font-weight: bold;
  color: #fff;
  display: flex;
  height: 40px;
  width: 40px;
  align-items: center;
  justify-content: center;
}
.roundup-item img {
  max-width: 100%;
  height: auto;
}
.roundup-item a img {
  cursor: pointer;
}
.roundup-item h3 {
  font-size: 21px;
  margin: 20px 0;
}
.roundup-item p:first-of-type, .roundup-item p {
  font-size: 18px;
  margin: 0 0 25px;
  line-height: 23px;
  padding: 0;
}
.site-intro-image {
	margin: 0 auto 30px;
	position: relative;
	padding-top: 66%;
}
.site-intro-image img {
	position: absolute;
	top: 0;
	bottom: 0;
	left: 0;
	right: 0;
	height: 100%;
	width: 100%;
	object-fit: cover;
	object-position: center;
}
.site-intro {
	text-align: center;
}
.site-intro p {
	max-width: 280px;
	margin: 15px auto;
	font-size: 16px;
	line-height: 33px;
}
.site-intro h4 {
	font-size: 30px;
	margin: 0;
	font-weight: normal;
}

/* sidebar stuff */
.latest-posts-feed h4 {
	font-size: 30px;
	font-weight: bold;
	margin: 0 0 0 40px;
}
.sidebar-feed a {
	font-size: 20px;
	display: block;
	margin: 25px 0;
	font-weight: bold;
}
.latest-posts-feed {
	padding: 30px;
}
.recos {
	margin: 20px 0;
	padding: 20px;
}
.recos h3 {
	margin: 20px 35px;
	font-weight: bold;
	font-size: 30px;
}
.archive-tile {
	padding: 0 0 0 160px;
	position: relative;
	margin-top: 40px;
	display: flex;
	align-items: center;
	min-height: 100px;
}
.archive-tile::before {
	content: '';
	position: absolute;
	display: block;
	top: -20px;
	right: 35px;
	left: 35px;
	height: 1px;
}
.archive-tile h4 {
	margin: 0;
	font-size: 25px;
}
.archive-tile a {
	font-size: 16px;
}
.archive-image {
	position: absolute;
	height: 100px;
	top: 0;
	left: 0;
	width: 140px;
	overflow: hidden;
}

.pagination {
	text-align: center;
    font-size: 26px;
    margin: 40px auto;
}
.footer-logo {
	padding-top: 100px;
    width: 100px;
    margin: 0 auto 20px;
    opacity: 0.2;
    background-size: 60px;
    background-position: 50%;
}
.footer-logo:hover {
	opacity: 1
}
@media only screen and (max-width: 1088px) {
  .main-content p, .main-content li {
    padding: 0;
  }
  .footer-feed .feed-item {
    grid-template-columns: 1fr 100px;
    grid-column-gap: 20px;
  }
  .footer-feed .thumbnail-image {
    height: 100px;
    width: 100px;
  }
  .footer-feed .feed-text {
    font-weight: auto;
    font-size: 17px;
  }
  .footer-feed .feed-text h4 {
    font-size: 18px;
    line-height: 20px;
  }
  .with-counter a {
    padding-left: 30px;
  }
  .footer-feed.with-counter a::before {
    font-size: 60px;
    top: -10px;
  }
}
@media only screen and (max-width: 600px) {
  .roundup-section h2 {
    margin-bottom: 0;
  }
  .roundup-section:after {
    content: '\2190 \2192';
    background: #fafafa;
    display: block;
    text-align: center;
    font-size: 22px;
    line-height: 19px;
    color: #555;
  }
  .roundup-group {
    display: grid;
    grid-gap: 10px;
    grid-template-columns: repeat(20, 80%);
    will-change: transform;
    align-content: center;
    overflow-x: auto;
    scroll-snap-coordinate: 0 0;
    scroll-snap-points-x: repeat(50%);
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
  }
  .roundup-group .roundup-item {
    scroll-snap-align: start;
    padding: 10px;
    border-radius: 2px;
    margin: 0;
  }
  .roundup-group .roundup-item::before {
    top: 10px;
    left: 10px;
  }
  .roundup-group h2 a {
    font-size: 24px;
    line-height: 24px;
  }
  .roundup-group h2 {
    margin: 15px 0;
  }
  .roundup-section p:first-of-type {
    margin-top: 4px;
    font-size: 16px;
    line-height: 24px;
  }
  .roundup-item img.lazyload, .roundup-item img.lazyloading {
    height: 0;
    padding-top: 66%;
  }
  .roundup-item img.lazyloaded {
    padding: 0;
    height: auto;
  }
}
@media only screen and (max-width: 1139px) {
	.sidead {
		display: none;
	}
}
@media only screen and (max-width: 500px) {
	#commentform p {
		grid-column: 1/4;
		margin: 0 0 5px;
	}
	.jumper.header-info::before, .entry-categories.header-info::before {
		display:none;
	}
	.entry-categories.header-info {
		margin-bottom: 7px;
	}
}
@media only screen and (min-width: 501px) {
	.tile-container {
		grid-template-columns: 1fr 1fr;
	}
}
@media only screen and (min-width: 760px) and (max-width: 960px) {
	.recent-recos {
		display: block;
	}
}
@media only screen and (max-width: 760px) {
	#main-image {
		padding-top: 100%;
	}
}
@media only screen and (min-width: 760px) and (max-width: 1139px) {
	.more-recos.grid-column-container {
		grid-template-columns: 1fr 1fr;
		display: grid;
		column-gap: 30px;
	}
	.recent-recos {
		grid-column: 1;
		padding: 30px 0;
	}
	.popular-recos {
		grid-column: 2;
		padding: 30px 20px;
	}
	.recipe-head {
		display: grid;
		grid-template-columns: 1fr 1fr;
		column-gap: 30px;
	}
	.latest-posts-feed {
		display: none;
	}
	.sticky-sidebar {
		max-width: none;
	}
}
@media only screen and (min-width: 1140px) {
	.page-title {
		margin: 0 auto;
	}
	.main-content {
		grid-column: 3;
		grid-row: 1;
	}
	.grid-column-container .sticky-sidebar {
		grid-column: 5;
		grid-row: 1;
		padding: 0;
		min-height: auto !important;
	}
	.main-content p .pinit {
		display: none;
		font-size: 14px;
		top: 10px;
		left: 10px;
		background-color: #fff;
		padding: 0 10px;
	}
	.main-content p .pinit:hover {
		background-color: #d32339;
		color: #fff;
		transition: background-color 0.1s ease-in-out, color 0.1s ease-in-out;
	}
	.grid-column-container {
		display: grid;
		grid-template-columns: 1fr 1px 728px 1fr 300px 0px;
	}
	.recipe-head, .latest-posts-feed {
		display: block;
	}
	.tile-container {
		grid-template-columns: 1fr 1fr 1fr 1fr;
	}
	.searchpage-search {
		margin: 20px;
	}
}
@media only screen and (min-width: 1140px) and (max-width: 1250px) {
	.recos {
		padding: 0 0 20px;
	}
	.archive-tile a {
		font-size: 14px;
	}
	.archive-tile h4 {
		font-size: 19px;
	}
	.archive-image, .latest-posts-feed.with-counter a::before  {
		left: 10px;
	}
	.latest-posts-feed {
		padding: 20px;
	}e
}
@media only screen and (min-width: 1250px) {
	.grid-column-container {
		display: grid;
		grid-template-columns: 1fr 50px 728px 72px 400px 1fr;
	}
	.breadcrumbs {
		margin: 23px auto;
	}	
	.header-info::before, .footer-info::before {
		height: 50px;
		margin: 0 10px;
	}
	.site-intro-image {
		width: 394px;
	}
	#main-image {
		padding-top: 0%;
		margin: 40px auto;
		height: 835px;
		width: 1250px;
	}
	.hpw {
		margin: 20px auto;
	}
}


/* ad stuff */
#AdThrive_Sidebar_9_desktop {
	margin-right: 0;
  float: none !important;
  max-width: 300px;
  padding-top: 50px; 
}
.adthrive-stuck.adthrive-sticky.adthrive-sidebar {
    right: auto !important;
}
.adthrive-ad {
	clear: none !important;
}
.adthrive-device-desktop .adthrive-recipe {
  margin: 10px -10px 20px 60px !important;
}
.adthrive-comscore.adthrive-footer-message {
    margin: 0;
    padding: 10px 20px 120px;
}
.adthrive-footer-message>span {
    text-transform: none;
    color: #fff;
    font-family: inherit;
    font-weight: bold;
    border-color: #333;
}
.adthrive-footer {
  margin: 0 !important;
}
.adthrive-ccpa-link, .adthrive-ccpa-link span, .adthrive-footer-message span, .adthrive-privacy-preferences a {
    color: rgba(255, 255, 255, 0.5) !important;
}

/* comments */
.comment-cta {
  background: rgba(128,128,128,0.15);
  padding: 20px;
}
.comment-cta h4 {
  margin: 0 0 15px;
}
.article-comments p,
.article-comments p:first-of-type,
.article-comments li {
    padding: 0;
    margin: 10px 0;
}
#commentform {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  grid-template-rows: 1fr;
  grid-column-gap: 10px;
  grid-row-gap: 10px;
}
.comment-notes,
.comment-form-wprm-rating,
.comment-form-comment {
  grid-column: 1/4;
}
#commentform legend {
  display: none;
}
ol.comment-list {
  padding: 1px;
  margin-bottom: 0;
}
#respond {
    margin: 0;
    padding: 30px 60px;
}
#respond h3 {
  margin: 0;
}
#respond input[type=text],
#respond textarea {
	width: 100%;
	border-radius: 20px;
	font-size: 20px;
	padding: 10px;
	border: none;
}
#respond input[type=text] {
  height: 40px;
}
.comment-body, ol.comment-list #respond {
  background: #fff;
  margin: 20px;
  position: relative;
  padding: 10px 20px;
  word-wrap: break-word;
  position: relative;
  border-radius: 10px;
}
ol.comment-list #respond:before {
  content: '';
  border: 15px solid transparent;
  position: absolute;
  bottom: 100%;
  left: 20px;
}
#submit {
    border: 0;
    color: #fff;
    font-size: 17px;
    padding: 10px 20px;
    background: #333;
    font-weight: bold;
    border-radius: 3px;
}

/* Comments */

h3.comments-title {
  margin: 20px
}
.article-comments {
    margin-bottom: 40px;
}
ol.comment-list {

}
.comment-list li {
    list-style: none;
}
.comment-body a {
    color: #000;
}
.comment-body p {
    font-size: 17px;
    line-height: normal;
    margin-bottom: 10px;
}
.comment-author.vcard {
    font-size: 14px;
}
.comment-list {
    margin: 0;
    padding: 0;
}
.children {
	position: relative;
}
ol.children:before {
    content: '';
    border: 1px solid #666;
    position: absolute;
    top: -20px;
    left: 40px;
    height: 30px;
    width: 20px;
    border-width: 0 0 1px 1px;
}
#commentform label {
    display: block;
}
#comment {
    width: 100%;
    border: 1px solid #ccc;
    height: 150px;
    padding: 10px;
    outline: none;
}
.comment-meta.commentmetadata {
    position: absolute;
    bottom: 0;
    right: 0;
    margin: 5px 15px;
    font-size: 11px;
}
.reply {
    font-size: 11px;
    display: inline-block;
    padding: 0 6px;
    border-bottom: 2px solid #0090ff;
    line-height: 20px;
    margin-left: -6px;
}
cite.fn {
    font-style: normal;
    font-weight: 700;
}
cite.fn a {
    font-weight: 700;
    letter-spacing: normal;
    color: #000;
    border-bottom: 1px solid #f00;
}

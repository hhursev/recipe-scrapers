		<div class="light-switch-icon">
			<button type="button" class="light-switch svgicon icon-switch lightswitch" id="lightswitch" title="Toggle dark/light mode"><svg viewBox="0 0 1000 1000"><circle stroke-width="100" stroke="white" fill="none" cx="500" cy="500" r="445"/><path fill="white" d="M500,831.3C317,831.3,168.7,683,168.7,500S317,168.7,500,168.7"/></svg><span>Light/Dark mode</span></button>
			<script>
			(function() {
				const body = document.querySelector('body');
				const button = document.querySelector('.lightswitch');
				const pref = window.matchMedia('(prefers-color-scheme: dark)').matches;

				if (pref) { // your phone prefers dark mode
					if (document.cookie.match(/theme=light/i) == null) {
						body.classList.add('dark-mode');
					}
				} else if (document.cookie.match(/theme=dark/i) != null) { // you prefer dark mode
					body.classList.add('dark-mode');
				}

				button.addEventListener('click', (e) => {
				  e.preventDefault();
				  body.classList.toggle('dark-mode')
					if (body.classList.contains('dark-mode')) {
						document.cookie = 'theme=dark;domain=iamafoodblog.com;path=/';
					} else {
						document.cookie = 'theme=light;domain=iamafoodblog.com;path=/';
					}
				});
			})();
			</script>
		</div>

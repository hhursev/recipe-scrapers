	<script type="application/ld+json" class="yoast-schema-graph">{"@context":"https://schema.org","@graph":[{"@type":"WebSite","@id":"https://iamafoodblog.com/#website","url":"https://iamafoodblog.com/","name":"i am a food blog","description":"Celebrating the awesomeness of food","potentialAction":[{"@type":"SearchAction","target":"https://iamafoodblog.com/?s={search_term_string}","query-input":"required name=search_term_string"}],"inLanguage":"en-US"},{"@type":"ImageObject","@id":"https://iamafoodblog.com/chicken-pho/#primaryimage","inLanguage":"en-US","url":"https://iamafoodblog.b-cdn.net/wp-content/uploads/2026/04/chicken-pho-6294w.jpg","width":2500,"height":1668,"caption":"Chicken Pho Recipe | www.iamafoodblog.com"},{"@type":"WebPage","@id":"https://iamafoodblog.com/chicken-pho/#webpage","url":"https://iamafoodblog.com/chicken-pho/","name":"Easy Authentic Chicken Pho &middot; i am a food blog","isPartOf":{"@id":"https://iamafoodblog.com/#website"},"primaryImageOfPage":{"@id":"https://iamafoodblog.com/chicken-pho/#primaryimage"},"datePublished":"2026-05-11T16:35:14+00:00","dateModified":"2026-05-11T16:33:00+00:00","author":{"@id":"https://iamafoodblog.com/#/schema/person/e7d8bf1067379105a9ac2dac31a4c35c"},"description":"Authentic chicken pho recipe that's light, refreshing, and deeply flavorful.","inLanguage":"en-US","potentialAction":[{"@type":"ReadAction","target":["https://iamafoodblog.com/chicken-pho/"]}]},{"@type":"Person","@id":"https://iamafoodblog.com/#/schema/person/e7d8bf1067379105a9ac2dac31a4c35c","name":"Mike","image":{"@type":"ImageObject","@id":"https://iamafoodblog.com/#personlogo","inLanguage":"en-US","url":"https://secure.gravatar.com/avatar/b27016cb28215edd06a22235b500edf3?s=96&d=blank&r=g","caption":"Mike"}},{"@type":"Recipe","name":"Authentic Chicken Pho","author":{"@type":"Person","name":"Mike"},"description":"It takes 3 hours and a whole chicken and it&#039;s 100% worth it.","datePublished":"2026-05-11T09:35:14+00:00","image":["https://iamafoodblog.b-cdn.net/wp-content/uploads/2026/04/chicken-pho-6294w.jpg","https://iamafoodblog.b-cdn.net/wp-content/uploads/2026/04/chicken-pho-6294w-500x500.jpg","https://iamafoodblog.b-cdn.net/wp-content/uploads/2026/04/chicken-pho-6294w-500x375.jpg","https://iamafoodblog.b-cdn.net/wp-content/uploads/2026/04/chicken-pho-6294w-480x270.jpg"],"recipeYield":["6"],"prepTime":"PT35M","cookTime":"PT145M","totalTime":"PT180M","recipeIngredient":["1  onion (halved)","3&quot;  ginger (sliced)","5 lbs chicken (4 drumsticks, 4 thighs, 1 whole breast, bone-in, skin on)","2 lbs fresh pho noodles (or dried)","1 stick cinnamon","2-3 whole star anise","1/2 tsp coriander","1/2 tsp white pepper","1/2 tsp cloves","1/2 tsp cardamom (about 8 pods)","1/4 cup sugar","2 tbsp coarse sea salt","1 tbsp fish sauce (optional but replace with equivalent salt if omitting)","1 tbsp msg (optional)","1  lime","1 bunch Thai basil","1 bunch cilantro","2-3  Thai chilies (sliced)"],"recipeInstructions":[{"@type":"HowToStep","text":"Carefully char your aromatics with a blowtorch or over a gas hob. Set aside. In a small pan, char your spices and add to a tea bag if you have on. If you don\u2019t have a blowtorch or flame source, you can toast your aromatics in a cast iron pan as well.\u00a0","name":"Carefully char your aromatics with a blowtorch or over a gas hob. Set aside. In a small pan, char your spices and add to a tea bag if you have on. If you don\u2019t have a blowtorch or flame source, you can toast your aromatics in a cast iron pan as well.\u00a0","url":"https://iamafoodblog.com/chicken-pho/#wprm-recipe-46994-step-0-0","image":"https://iamafoodblog.b-cdn.net/wp-content/uploads/2026/04/chicken-pho-6203.jpg"},{"@type":"HowToStep","text":"Add the chicken, onion, ginger, and spices, and cover with water. Bring up to a boil on high heat. Once boiling, reduce to a low boil and set a timer for 25 minutes.","name":"Add the chicken, onion, ginger, and spices, and cover with water. Bring up to a boil on high heat. Once boiling, reduce to a low boil and set a timer for 25 minutes.","url":"https://iamafoodblog.com/chicken-pho/#wprm-recipe-46994-step-0-1","image":"https://iamafoodblog.b-cdn.net/wp-content/uploads/2026/04/chicken-pho-6214.jpg"},{"@type":"HowToStep","text":"At the end of the 25 minutes, transfer your chicken to a large bowl and let cool. Continue cooking the soup, adding water if needed. Once the chicken is cool enough to handle, roughly remove the meat from the bones, transfer to a container and refrigerate.\u00a0","name":"At the end of the 25 minutes, transfer your chicken to a large bowl and let cool. Continue cooking the soup, adding water if needed. Once the chicken is cool enough to handle, roughly remove the meat from the bones, transfer to a container and refrigerate.\u00a0","url":"https://iamafoodblog.com/chicken-pho/#wprm-recipe-46994-step-0-2","image":"https://iamafoodblog.b-cdn.net/wp-content/uploads/2026/04/chicken-pho-6226.jpg"},{"@type":"HowToStep","text":"Add the bones back to soup and continue to simmer for another 30 minutes to 2 hours. More time will make a better soup.","name":"Add the bones back to soup and continue to simmer for another 30 minutes to 2 hours. More time will make a better soup.","url":"https://iamafoodblog.com/chicken-pho/#wprm-recipe-46994-step-0-3","image":"https://iamafoodblog.b-cdn.net/wp-content/uploads/2026/04/chicken-pho-6252.jpg"},{"@type":"HowToStep","text":"Let the soup cool to a safe temperature (add 1qt water to help it cool), then strain (remember to put a container under your sieve). Ensure the soup has about 3 quarts of liquid, adding water if necessary.\u00a0","name":"Let the soup cool to a safe temperature (add 1qt water to help it cool), then strain (remember to put a container under your sieve). Ensure the soup has about 3 quarts of liquid, adding water if necessary.\u00a0","url":"https://iamafoodblog.com/chicken-pho/#wprm-recipe-46994-step-0-4","image":"https://iamafoodblog.b-cdn.net/wp-content/uploads/2026/04/chicken-pho-6260.jpg"},{"@type":"HowToStep","text":"Give the pot a quick rinse, then return the soup to the pot. Heat up the soup again, then season to your liking with sugar, fish sauce, salt, and msg as desired (my recommendations are up top).","name":"Give the pot a quick rinse, then return the soup to the pot. Heat up the soup again, then season to your liking with sugar, fish sauce, salt, and msg as desired (my recommendations are up top).","url":"https://iamafoodblog.com/chicken-pho/#wprm-recipe-46994-step-0-5","image":"https://iamafoodblog.b-cdn.net/wp-content/uploads/2026/04/chicken-pho-6271.jpg"},{"@type":"HowToStep","text":"To serve: quickly blanch your pho noodles according to the directions on the package, then transfer to large noodle soup bowls. Warm the chicken in the soup, then evenly divide the chicken between the bowls. Just before you&#39;re ready to eat, top with soup, thai basil, chilies, and cilantro, if using. Serve with ginger fish sauce to dip. (see below)","name":"To serve: quickly blanch your pho noodles according to the directions on the package, then transfer to large noodle soup bowls. Warm the chicken in the soup, then evenly divide the chicken between the bowls. Just before you&#39;re ready to eat, top with soup, thai basil, chilies, and cilantro, if using. Serve with ginger fish sauce to dip. (see below)","url":"https://iamafoodblog.com/chicken-pho/#wprm-recipe-46994-step-0-6","image":"https://iamafoodblog.b-cdn.net/wp-content/uploads/2026/04/chicken-pho-6294.jpg"}],"recipeCategory":["Main Course"],"recipeCuisine":["Vietnamese"],"keywords":"chicken, pho","nutrition":{"@type":"NutritionInformation","calories":"515 kcal","carbohydrateContent":"100.4 g","proteinContent":"19.3 g","fatContent":"2.9 g","saturatedFatContent":"0.7 g","cholesterolContent":"40 mg","sodiumContent":"789 mg","sugarContent":"8.4 g","fiberContent":"4 g","servingSize":"1 serving"},"@id":"https://iamafoodblog.com/chicken-pho/#recipe","isPartOf":{"@id":"https://iamafoodblog.com/chicken-pho/"},"mainEntityOfPage":"https://iamafoodblog.com/chicken-pho/","author_reference":{"@id":"https://iamafoodblog.com/#/schema/person/e7d8bf1067379105a9ac2dac31a4c35c"}}]}</script>

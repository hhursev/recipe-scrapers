	</div><style type="text/css">.wprm-recipe-template-2019 {
    background-color: #f8f8f8; /*wprm_background type=color*/
    font-family: inherit; /*wprm_main_font_family type=font*/
  	position: relative;
  	padding: 20px
}
.wprm-recipe-print {
    position: absolute;
    top: 20px;
    right: 20px;
}
a.wprm-recipe-pin {
    background: none !important;
    border: 0 !important;
    position: absolute;
    top: 15px;
    right: 50px;
}
.wprm-recipe-head {
 	text-align: center;	
  	padding: 40px 0
}
input[type=number].wprm-recipe-servings {
    width: 40px;
    background: #fff;
    border: 1px solid #ccc;
    border-radius: 5px;
}
.wprm-recipe-details-container-table.wprm-recipe-table-borders-top-bottom {
    border: none !important;
    background: #fff;
    width: 100%;
}
.wprm-recipe-servings-container, .wprm-recipe-rating {
    margin: 25px;
    display: inline-block !important;
    vertical-align: bottom;
}
.wprm-toggle-container {
    border: 0;
    float: right;
    margin-top: 15px;
}
.wprm-checkbox-container label::before {
    background: #fff;
    border-radius: 3px;
    border-color: #888;
}
.wprm-checkbox-container {
	top: 10px;
}
.wprm-recipe-notes-container {
    padding: 0 20px 20px;
    border-bottom: 1px solid #ddd;

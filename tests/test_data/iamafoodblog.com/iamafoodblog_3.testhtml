}
.header-info {
	display: inline-block;
	vertical-align: middle;
}
#headnotes {
	margin: 0 auto 35px;
	max-width: 500px;
	font-size: 13px;
}
.entry-categories {
	display: inline-block;
}
.breadcrumbs > span:last-of-type {
	display: none;
}

/* post typography and images */
.main-content p img, .recipe-body li img,
.wp-caption, .wp-caption img,
.wprm-recipe-instruction-media.wprm-recipe-instruction-image img {
	max-width: 100% !important;
	height: auto;
}
.recipe-body p:first-of-type strong,
.recipe-body p:first-of-type {
	font-size: 30px;
	line-height: 40px;
	font-weight: normal;
	margin: 0
}

/* main content */
.main-content {
  max-width: 728px;
  margin: 0 auto;
}
p.wp-caption-text, p.wp-caption-text:first-of-type {
    margin: -17px 80px !important;
    line-height: normal;
    text-align: center;
    font-size: 19px;
}
.cat-secret-ingredients .entry-categories .topcat a {
	height: 100px;
	width: 100px;
	border-radius: 100px;
	background: linear-gradient(rgba(255,245,230,1) 50%, #ffa478 50%);
	display: flex;
	margin: 0 auto;
	justify-content: center;
	align-items: center;
	font-size: 14px;
	color: #Fd0;
	padding: 0;
}
h3.pullquote {
	font-family: nobel, halyard-display, arial;
	text-align: center;
	border: 3px solid #eee;
	border-width: 10px 0;
	padding: 40px;
	font-size: 60px;
	line-height: 60px;
	letter-spacing: -2px;
	margin: 40px 0;
}
.main-content li {
	padding-right: 60px;
	margin-bottom: 15px;
}
.main-content .small-list li {
	margin-bottom: 0;
}
.main-content p {
  position: relative;
}
.main-content p.wp-caption-text {
    margin-top: 0;
}
.pinit {
  position: absolute;
  top: 0;
  background-color: rgba(255,255,255,0.8);
  padding: 3px 10px;
  color: #000;
  font-size: 12px;
  font-weight: bold;
  line-height: 22px;
  display: block;
}
.main-content p:hover .pinit {
  display: block;
}




		<picture class="attachment-full size-full wp-post-image sp-no-webp"><source data-lazy-srcset="https://iamafoodblog.b-cdn.net/wp-content/uploads/2026/04/chicken-pho-6294w.webp 2500w,https://iamafoodblog.b-cdn.net/wp-content/uploads/2026/04/chicken-pho-6294w-600x400.webp 600w,https://iamafoodblog.b-cdn.net/wp-content/uploads/2026/04/chicken-pho-6294w-1024x683.webp 1024w,https://iamafoodblog.b-cdn.net/wp-content/uploads/2026/04/chicken-pho-6294w-1536x1025.webp 1536w,https://iamafoodblog.b-cdn.net/wp-content/uploads/2026/04/chicken-pho-6294w-2048x1366.webp 2048w" sizes="(max-width: 2500px) 100vw, 2500px" type="image/webp"><source data-lazy-srcset="https://iamafoodblog.b-cdn.net/wp-content/uploads/2026/04/chicken-pho-6294w.jpg 2500w, https://iamafoodblog.b-cdn.net/wp-content/uploads/2026/04/chicken-pho-6294w-600x400.jpg 600w, https://iamafoodblog.b-cdn.net/wp-content/uploads/2026/04/chicken-pho-6294w-1024x683.jpg 1024w, https://iamafoodblog.b-cdn.net/wp-content/uploads/2026/04/chicken-pho-6294w-1536x1025.jpg 1536w, https://iamafoodblog.b-cdn.net/wp-content/uploads/2026/04/chicken-pho-6294w-2048x1366.jpg 2048w" sizes="(max-width: 2500px) 100vw, 2500px" type="image/jpeg"><img src="data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20viewBox='0%200%202500%201668'%3E%3C/svg%3E" class="attachment-full size-full wp-post-image sp-no-webp" alt="Chicken Pho Recipe | www.iamafoodblog.com" height="1668" width="2500" data-lazy-srcset="https://iamafoodblog.b-cdn.net/wp-content/uploads/2026/04/chicken-pho-6294w.jpg 2500w, https://iamafoodblog.b-cdn.net/wp-content/uploads/2026/04/chicken-pho-6294w-600x400.jpg 600w, https://iamafoodblog.b-cdn.net/wp-content/uploads/2026/04/chicken-pho-6294w-1024x683.jpg 1024w, https://iamafoodblog.b-cdn.net/wp-content/uploads/2026/04/chicken-pho-6294w-1536x1025.jpg 1536w, https://iamafoodblog.b-cdn.net/wp-content/uploads/2026/04/chicken-pho-6294w-2048x1366.jpg 2048w" data-lazy-sizes="(max-width: 2500px) 100vw, 2500px" data-lazy-src="https://iamafoodblog.b-cdn.net/wp-content/uploads/2026/04/chicken-pho-6294w.jpg"><noscript><img src="https://iamafoodblog.b-cdn.net/wp-content/uploads/2026/04/chicken-pho-6294w.jpg" class="attachment-full size-full wp-post-image sp-no-webp" alt="Chicken Pho Recipe | www.iamafoodblog.com" height="1668" width="2500" srcset="https://iamafoodblog.b-cdn.net/wp-content/uploads/2026/04/chicken-pho-6294w.jpg 2500w, https://iamafoodblog.b-cdn.net/wp-content/uploads/2026/04/chicken-pho-6294w-600x400.jpg 600w, https://iamafoodblog.b-cdn.net/wp-content/uploads/2026/04/chicken-pho-6294w-1024x683.jpg 1024w, https://iamafoodblog.b-cdn.net/wp-content/uploads/2026/04/chicken-pho-6294w-1536x1025.jpg 1536w, https://iamafoodblog.b-cdn.net/wp-content/uploads/2026/04/chicken-pho-6294w-2048x1366.jpg 2048w" sizes="(max-width: 2500px) 100vw, 2500px"></noscript></picture>	</picture>

	<div class="recipe-card-body">
		
<div class="recipe-ingredients">
	<h3 class="ingredients-title">Ingredients</h3>
	<ul class="ingredients-list">
		<li class="ingredient-item "> 4 whole cloves  </li><li class="ingredient-item "> 4 whole peppercorns  </li><li class="ingredient-item "> 1 bay leaf  </li><li class="ingredient-item "> 1/2 cup water  </li><li class="ingredient-item "> 1/2 cup white vinegar  </li><li class="ingredient-item "> 2 teaspoons sugar  </li><li class="ingredient-item "> 1/2 teaspoon salt  </li><li class="ingredient-item "> Dash ground ginger  </li><li class="ingredient-item "> 1 pound boneless beef top round steak, cut into 1-inch cubes  </li><li class="ingredient-item "> 3 medium carrots, cut into 1/2-inch slices  </li><li class="ingredient-item "> 2 celery ribs, cut into 1/2-inch slices  </li><li class="ingredient-item "> 1 small onion, chopped  </li><li class="ingredient-item "> 1/3 cup crushed gingersnaps  </li><li class="ingredient-item "> Hot cooked egg noodles  </li><li class="ingredient-item "> Optional: Chopped fresh parsley and coarsely ground pepper   </li>	</ul>
	<div class="text-ingredients-container">
	<a href="sms:?&amp;body=Pressure-Cooker Sauerbraten%20%0Ahttps://www.tasteofhome.com/recipes/pressure-cooker-sauerbraten/%20%0A%20%0AINGREDIENTS%20%0A%20%0A4 whole cloves%20%0A4 whole peppercorns%20%0A1 bay leaf%20%0A1/2 cup water%20%0A1/2 cup white vinegar%20%0A2 teaspoons sugar%20%0A1/2 teaspoon salt%20%0ADash ground ginger%20%0A1 pound boneless beef top round steak, cut into 1-inch cubes%20%0A3 medium carrots, cut into 1/2-inch slices%20%0A2 celery ribs, cut into 1/2-inch slices%20%0A1 small onion, chopped%20%0A1/3 cup crushed gingersnaps%20%0AHot cooked egg noodles%20%0AOptional: Chopped fresh parsley and coarsely ground pepper %20%0A" class="bumblebee-cta-button bumblebee-cta-tint-color bumblebee-cta-size--md bumblebee-cta-text-ingredients" role="button" aria-label="Text Ingredients" target="blank" data-name="Text Ingredients" data-module="content engagement" data-position="mobile text recipe"><span class="cta-icon icon-left" aria-hidden="true"><span class="bumblebee-icon bumblebee-icon-mobile-text bumblebee-icon--xs" name="icon-mobile-text" title="Text Ingredients" role="img"><svg xmlns="http://www.w3.org/2000/svg" width="15" height="20" viewBox="0 0 15 20" fill="none">

g","https:\/\/chocolatewithgrace.com\/wp-content\/uploads\/2018\/07\/CWG-No-Bake-Blueberry-Cheesecake-2-1-477x500.jpg","https:\/\/chocolatewithgrace.com\/wp-content\/uploads\/2018\/07\/CWG-No-Bake-Blueberry-Cheesecake-2-1-477x375.jpg","https:\/\/chocolatewithgrace.com\/wp-content\/uploads\/2018\/07\/CWG-No-Bake-Blueberry-Cheesecake-2-1-477x270.jpg"],"recipeYield":["15","15 servings"],"prepTime":"PT20M","totalTime":"PT380M","recipeIngredient":["½ cup butter (melted)","¼ cup granulated sugar","2 cups graham cracker crumbs (finely crushed)","1½ cup powdered sugar","11 ounces cream cheese (softened)","3 tablespoons milk","1 teaspoon vanilla","16 ounces whipped topping","2 cups blueberry pie filling ((this is one recipe&#39;s worth))"],"recipeInstructions":[{"@type":"HowToStep","text":"Stir together the melted butter, graham cracker crumbs, and sugar. Press into the bottom of a 9 x 13 baking dish.","name":"Stir together the melted butter, graham cracker crumbs, and sugar. Press into the bottom of a 9 x 13 baking dish.","url":"https:\/\/chocolatewithgrace.com\/no-bake-blueberry-cheesecake\/#wprm-recipe-3491-step-0-0"},{"@type":"HowToStep","text":"In a large bowl, beat together the powdered sugar, cream cheese, milk and vanilla until smooth. Carefully spread on top of the crust, being careful not to break it. Top with the whipped topping or homemade whipped cream.","name":"In a large bowl, beat together the powdered sugar, cream cheese, milk and vanilla until smooth. Carefully spread on top of the crust, being careful not to break it. Top with the whipped topping or homemade whipped cream.","url":"https:\/\/chocolatewithgrace.com\/no-bake-blueberry-cheesecake\/#wprm-recipe-3491-step-0-1"},{"@type":"HowToStep","text":"Carefully spread on the blueberry pie filling. Chill for at least 6 hours before serving. Store in the refrigerator. Best eaten within a few days.","name":"Carefully spread on the blueberry pie filling. Chill for at least 6 hours before serving. Store in the refrigerator. Best eaten within a few days.","url":"https:\/\/chocolatewithgrace.com\/no-bake-blueberry-cheesecake\/#wprm-recipe-3491-step-0-2"}],"aggregateRating":{"@type":"AggregateRating","ratingValue":"4.6","ratingCount":"15","reviewCount":"5"},"review":[{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"I am 71 and never ask for anything special but this year I asked for a blueberry cheesecake. My kids are in their 50's and didn't know this was my favorite.  Of course oven wasn't available so she looked up recipes and found yours. This was so delicious.  Thank you and I won't wait another 20 years to have this again.","author":{"@type":"Person","name":"Becky Cassels"},"datePublished":"2026-01-05"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"The only thing I did different i bought the ready made Philadelphia cream no bake cheese filling . Thanks I love easy I'm 85 and a cancer survivor.  Thanks","author":{"@type":"Person","name":"Nancy"},"datePublished":"2025-11-19"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Absolutely delicious!! \r\nI cut the sugar in half and added a little Truvia.","author":{"@type":"Person","name":"Angie R."},"datePublished":"2025-11-03"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"2"},"reviewBody":"Disappointed with end result and I made REAL whipped creme! Needs more creme cheese and only one can of blueberry pie filling for the top.. blueberry was overwhelming so you couldn't even taste middle creme cheese.. I baked my crust which sort of saved it.","author":{"@type":"Person","name":"Kay hawkins"},"datePublished":"2025-08-02"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Yummmmmmmmmm!!! Make it!!","author":{"@type":"Person","name":"Ellie Kostic"},"datePublished":"2025-07-05"}],"recipeCategory":["Dessert"],"recipeCuisine":["American"],"keywords":"no bake blueberry cheesecake","nutrition":{"@type":"NutritionInformation","servingSize":"1 piece","calories":"259 kcal","carbohydrateContent":"28 g","proteinContent":"2 g","fatContent":"16 g","saturatedFatContent":"9 g","cholesterolContent":"38 mg","sodiumContent":"185 mg","sugarContent":"18 g","unsaturatedFatContent":"6 g"},"@id":"https:\/\/chocolatewithgrace.com\/no-bake-blueberry-cheesecake\/#recipe","isPartOf":{"@id":"https:\/\/chocolatewithgrace.com\/no-bake-blueberry-cheesecake\/#article"},"mainEntityOfPage":"https:\/\/chocolatewithgrace.com\/no-bake-blueberry-cheesecake\/"}]}</script>

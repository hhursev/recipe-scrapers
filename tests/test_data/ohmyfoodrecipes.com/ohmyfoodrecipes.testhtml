foodrecipes.com/#/schema/logo/image/"},"sameAs":["https://www.facebook.com/ohmyfoodrecipes/","https://x.com/ohmyfoodrecipes","https://www.instagram.com/ohmyfoodrecipes/","http://www.pinterest.com/ohmyfoodrecipes","https://www.youtube.com/channel/UCh6p9czusgsrbzVPqUVyKcA"]},{"@type":"Person","@id":"https://www.ohmyfoodrecipes.com/#/schema/person/6b57ee99768de36c26a23f194e187b6c","name":"Tracy O.","sameAs":["https://www.ohmyfoodrecipes.com/about-me-ohmyfoodrecipes/","https://x.com/ohmyfoodrecipes"]},{"@type":"Recipe","name":"Braised Beef and Radish","author":{"@id":"https://www.ohmyfoodrecipes.com/#/schema/person/6b57ee99768de36c26a23f194e187b6c"},"description":"Delicious Asian Chinese flavor beef stew with radish is one of my comfort foods. This Cantonese style Chinese braised beef brisket and daikon instant pot recipe takes around 2 hours. ","datePublished":"2020-03-13T02:53:30+00:00","image":["https://www.ohmyfoodrecipes.com/wp-content/uploads/2020/03/brasied-beef-and-radish-horizontal.jpg","https://www.ohmyfoodrecipes.com/wp-content/uploads/2020/03/brasied-beef-and-radish-horizontal-500x500.jpg","https://www.ohmyfoodrecipes.com/wp-content/uploads/2020/03/brasied-beef-and-radish-horizontal-500x375.jpg","https://www.ohmyfoodrecipes.com/wp-content/uploads/2020/03/brasied-beef-and-radish-horizontal-480x270.jpg"],"video":{"name":"Braised beef and radish","description":"Delicious Asian Chinese flavor beef stew with radish instant pot is one of my comfort foods. This Cantonese style Chinese braised beef brisket and daikon instant pot recipe takes around 2 hours. Wanna know how to make this tasty dish?","thumbnailUrl":"https://content.jwplatform.com/thumbs/EIFRkyVN-720.jpg","contentUrl":"https://content.jwplatform.com/videos/EIFRkyVN.mp4","uploadDate":"2020-03-12T00:00:00.000Z","@type":"VideoObject"},"recipeYield":["8"],"prepTime":"PT5M","cookTime":"PT60M","recipeIngredient":["1  Daikon Radish  ((medium large))","2 pounds Beef chuck roast boneless","5 slices Ginger","4 cloves Garlic","5 pieces Star anise","6 pieces Clove","2 sticks Green onion","3 tablespoons Oyster sauce","3 tablespoons  Soy sauce","1/2  teaspoon Salt","2 tablespoons Brown sugar","1 cup Water"],"recipeInstructions":[{"@type":"HowToStep","text":"Wash, peel off radish skin and cut them into chunks. Then, set them aside. ","name":"Wash, peel off radish skin and cut them into chunks. Then, set them aside. ","url":"https://www.ohmyfoodrecipes.com/braised-beef-and-radish/#wprm-recipe-5858-step-0-0"},{"@type":"HowToStep","text":"Wash and cut beef roast into chunks.","name":"Wash and cut beef roast into chunks.","url":"https://www.ohmyfoodrecipes.com/braised-beef-and-radish/#wprm-recipe-5858-step-0-1"},{"@type":"HowToStep","text":"After that, put 4 cloves of garlic, 5 slices of ginger, 5 pieces of star anise, 6 pieces of clove and beef roast. Next, add 1/2 teaspoon of salt, 3 tablespoons of soy sauce, 3 tablespoons of oyster sauce, 2 tablespoons of brown sugar and 1 cup of water. Mix them well. Close the lid and vent, then push manual button adjust time to 45 minutes at high pressure and nature release pressure. ","name":"After that, put 4 cloves of garlic, 5 slices of ginger, 5 pieces of star anise, 6 pieces of clove and beef roast. Next, add 1/2 teaspoon of salt, 3 tablespoons of soy sauce, 3 tablespoons of oyster sauce, 2 tablespoons of brown sugar and 1 cup of water. Mix them well. Close the lid and vent, then push manual button adjust time to 45 minutes at high pressure and nature release pressure. ","url":"https://www.ohmyfoodrecipes.com/braised-beef-and-radish/#wprm-recipe-5858-step-0-2"},{"@type":"HowToStep","text":"After the pressure release, add radish into instant pot. Then, close the lid and vent. Push manual button and adjust time for 15 minutes at high pressure and natural release. ","name":"After the pressure release, add radish into instant pot. Then, close the lid and vent. Push manual button and adjust time for 15 minutes at high pressure and natural release. ","url":"https://www.ohmyfoodrecipes.com/braised-beef-and-radish/#wprm-recipe-5858-step-0-3"},{"@type":"HowToStep","text":"Add green onion and mix them will. You can use a strainer to remove oil or fat. (If you want the sauce thicker, you can thicken the sauce by adding corn starch and water.) ","name":"Add green onion and mix them will. You can use a strainer to remove oil or fat. (If you want the sauce thicker, you can thicken the sauce by adding corn starch and water.) ","url":"https://www.ohmyfoodrecipes.com/braised-beef-and-radish/#wprm-recipe-5858-step-0-4"}],"aggregateRating":{"@type":"AggregateRating","ratingValue":"5","ratingCount":"17","reviewCount":"1"},"review":[{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Made this tonight. It was delicious! My picky, eats only Asian food daughter, loved it! I am so happy to add this to our regular food rotation!","author":{"@type":"Person","name":"Patty"},"datePublished":"2021-08-24"}],"recipeCategory":["Main Course"],"recipeCuisine":["Asian","Chinese"],"keywords":"Braised Beef and Radish","nutrition":{"@type":"NutritionInformation","calories":"238 kcal","carbohydrateContent":"7 g","proteinContent":"23 g","fatContent":"13 g","saturatedFatContent":"6 g","cholesterolContent":"78 mg","sodiumContent":"813 mg","fiberContent":"1 g","sugarContent":"4 g","servingSize":"1 serving"},"@id":"https://www.ohmyfoodrecipes.com/braised-beef-and-radish/#recipe","isPartOf":{"@id":"https://www.ohmyfoodrecipes.com/braised-beef-and-radish/#article"},"mainEntityOfPage":"https://www.ohmyfoodrecipes.com/braised-beef-and-radish/"}]}</script>

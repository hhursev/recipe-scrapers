.is-style-book-cover img { box-shadow: 4px 4px 20px #454545; transform: rotate(3deg) scale(0.9); -webkit-backface-visibility: hidden; margin-top: 10px; margin-bottom: 10px; } .is-style-book-cover { padding: 10px; }

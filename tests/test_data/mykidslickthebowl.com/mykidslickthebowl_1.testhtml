			figure {
    margin: 0.5em 0;
}

.fs-wrap {
    width: 265px !important;
}

.browse-categories-mobile-lt .kadence-post-image-intrisic .kadence-post-image-inner-intrisic a {
    background: none;
}

.browse-categories-mobile-lt .kadence-post-image-intrisic .kadence-post-image-inner-intrisic img {
	border-radius: 0% !important;
	object-fit: contain!important;
}

.facetwp-counter {
  display: none !important;
}

.header-social-wrap .header-social-inner-wrap svg {
	border-radius: 0;
}

body .dpsp-network-list-item svg {
    border-radius: 0;
}

body #ez-toc-container .toc-toggle-lt {
    width: calc(100% + 62px);
}

body #ez-toc-container .toc-toggle-lt button:hover {
	box-shadow: none;
}

/* NP Hide Second TOC KA 7/30/25 */
.quick-start-quide-lt #ez-toc-container {
	display:none;
}
/* End hide TOC */

@media (max-width: 767px) {
	body .mobile-two-up-grid.wp-block-post-template-is-layout-grid.wp-block-post-template-is-layout-grid {
		grid-template-columns: 1fr 1fr !important;
	}
}		</style>

	<main id="inner-wrap" class="wrap kt-clear" role="main">
		<div id="primary" class="content-area">
	<div class="content-container site-container">
		<div id="main" class="site-main">
						<div class="content-wrap">
				<article id="post-28535" class="entry content-bg single-entry post-28535 post type-post status-publish format-standard has-post-thumbnail hentry category-dinner-recipes category-gluten-free-kid-friendly-recipes category-hidden-veggies category-pasta-recipes category-plant-based category-vegetarian-kid-friendly-recipes grow-content-body">
	<div class="entry-content-wrap">
		<header class="entry-header post-title title-align-inherit title-tablet-align-inherit title-mobile-align-inherit">
			<div class="share-holder-top-lt">
					<p class="dpsp-share-text " style="margin-bottom:10px">
				Sharing is caring!			</p>
					<div id="dpsp-content-" class="ltar-dpsp-content " style="min-height:32px;position:relative">

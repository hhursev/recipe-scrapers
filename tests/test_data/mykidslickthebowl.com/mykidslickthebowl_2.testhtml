liflower-alfredo-sauce\/"]}]},{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/mykidslickthebowl.com\/cauliflower-alfredo-sauce\/#primaryimage","url":"https:\/\/mykidslickthebowl.com\/wp-content\/uploads\/2025\/02\/cauliflower-alfredo-sauce-11.jpg","contentUrl":"https:\/\/mykidslickthebowl.com\/wp-content\/uploads\/2025\/02\/cauliflower-alfredo-sauce-11.jpg","width":1200,"height":1500,"caption":"Cauliflower alfredo sauce mixed through cooked pasta topped with crispy roasted cauliflower, panko bread crumbs, thyme, parsley and parmesan cheese in a ceramic dutch oven pan on benchtop with green and white checkered tea towel."},{"@type":"BreadcrumbList","@id":"https:\/\/mykidslickthebowl.com\/cauliflower-alfredo-sauce\/#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https:\/\/mykidslickthebowl.com\/"},{"@type":"ListItem","position":2,"name":"Recipes","item":"https:\/\/mykidslickthebowl.com\/kid-friendly-recipes\/"},{"@type":"ListItem","position":3,"name":"Family Dinner Ideas","item":"https:\/\/mykidslickthebowl.com\/dinner-recipes\/"},{"@type":"ListItem","position":4,"name":"Cauliflower Alfredo Sauce"}]},{"@type":"WebSite","@id":"https:\/\/mykidslickthebowl.com\/#website","url":"https:\/\/mykidslickthebowl.com\/","name":"My Kids Lick The Bowl","description":"Kid Friendly Recipes","publisher":{"@id":"https:\/\/mykidslickthebowl.com\/#organization"},"potentialAction":[{"@type":"SearchAction","target":{"@type":"EntryPoint","urlTemplate":"https:\/\/mykidslickthebowl.com\/?s={search_term_string}"},"query-input":{"@type":"PropertyValueSpecification","valueRequired":true,"valueName":"search_term_string"}}],"inLanguage":"en-US"},{"@type":"Organization","@id":"https:\/\/mykidslickthebowl.com\/#organization","name":"My Kids Lick The Bowl","url":"https:\/\/mykidslickthebowl.com\/","logo":{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/mykidslickthebowl.com\/#\/schema\/logo\/image\/","url":"https:\/\/mykidslickthebowl.com\/wp-content\/uploads\/2017\/03\/My-Kids-Lick-The-Bowl-Website-Header.jpg","contentUrl":"https:\/\/mykidslickthebowl.com\/wp-content\/uploads\/2017\/03\/My-Kids-Lick-The-Bowl-Website-Header.jpg","width":640,"height":300,"caption":"My Kids Lick The Bowl"},"image":{"@id":"https:\/\/mykidslickthebowl.com\/#\/schema\/logo\/image\/"},"sameAs":["http:\/\/www.facebook.com\/mykidslickthebowl","https:\/\/x.com\/staceymklb","http:\/\/www.instagram.com\/my_kids_lick_the_bowl","http:\/\/www.linkedin.com\/in\/stacey-kemeys","https:\/\/nz.pinterest.com\/KidFoodExpert\/"]},{"@type":"Person","@id":"https:\/\/mykidslickthebowl.com\/#\/schema\/person\/811751076c89b7aa27269ee6bdc8c237","name":"Stacey","image":{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/secure.gravatar.com\/avatar\/c8842d5a0b48c0f2b56f048b9ab1301d8288b7254746a260921919071d3f3b8d?s=96&d=mm&r=g","url":"https:\/\/secure.gravatar.com\/avatar\/c8842d5a0b48c0f2b56f048b9ab1301d8288b7254746a260921919071d3f3b8d?s=96&d=mm&r=g","contentUrl":"https:\/\/secure.gravatar.com\/avatar\/c8842d5a0b48c0f2b56f048b9ab1301d8288b7254746a260921919071d3f3b8d?s=96&d=mm&r=g","caption":"Stacey"},"sameAs":["https:\/\/mykidslickthebowl.com\/start-here\/","https:\/\/facebook.com\/mykidslickthebowl"],"url":"https:\/\/mykidslickthebowl.com\/author\/stacey\/"},{"@type":"Recipe","name":"Cauliflower Alfredo Sauce","author":{"@id":"https:\/\/mykidslickthebowl.com\/#\/schema\/person\/811751076c89b7aa27269ee6bdc8c237"},"description":"A creamy, veggie-loaded cauliflower Alfredo sauce made with roasted garlic and parmesan—perfect for pasta, mac and cheese, or lasagna.","datePublished":"2025-06-08T17:36:24+00:00","image":["https:\/\/mykidslickthebowl.com\/wp-content\/uploads\/2025\/02\/cauliflower-alfredo-sauce-6.jpg","https:\/\/mykidslickthebowl.com\/wp-content\/uploads\/2025\/02\/cauliflower-alfredo-sauce-6-500x500.jpg","https:\/\/mykidslickthebowl.com\/wp-content\/uploads\/2025\/02\/cauliflower-alfredo-sauce-6-500x375.jpg","https:\/\/mykidslickthebowl.com\/wp-content\/uploads\/2025\/02\/cauliflower-alfredo-sauce-6-480x270.jpg"],"video":{"name":"Cauliflower Alfredo 1080 LS.mov","description":"This Cauliflower Alfredo Sauce is healthy, creamy, and packed with flavour! Roasted garlic, parmesan, and cauliflower blend into a smooth, velvety sauce the whole family will love. Whether you're tossing it through pasta, layering it into mac and cheese, or using it as a base for a vegetable-loaded lasagna, this creamy cauliflower sauce is a delicious way to add extra veggies to any meal. Try this Cauliflower Alfredo Sauce Healthy option for an easy dinner upgrade.","thumbnailUrl":"https:\/\/content.jwplatform.com\/thumbs\/UkMybd2E-720.jpg","contentUrl":"https:\/\/content.jwplatform.com\/videos\/UkMybd2E.mp4","uploadDate":"2025-05-29T02:45:43+00:00","@type":"VideoObject"},"recipeYield":["4","4 servings"],"prepTime":"PT5M","cookTime":"PT40M","totalTime":"PT45M","recipeIngredient":["300 grams pasta  ((10 oz) )","1 head cauliflower ((approx. 500g))","6 cloves garlic","3 Tbsp olive oil","3  Tbsp parmesan cheese ((30g))","1\/2 cup milk","salt and pepper to taste","¼  cup panko bread crumbs","1 teaspoon fresh thyme","1 Tablespoon parmesan cheese"],"recipeInstructions":[{"@type":"HowToStep","text":"Slice the cauliflower into even-sized florets approximately 1cm thick (It doesn&#039;t have to be absolutely perfect).","name":"Slice the cauliflower into even-sized florets approximately 1cm thick (It doesn&#039;t have to be absolutely perfect).","url":"https:\/\/mykidslickthebowl.com\/cauliflower-alfredo-sauce\/#wprm-recipe-28536-step-0-0"},{"@type":"HowToStep","text":"Toss the cauliflower and garlic cloves in the oil. Spread the oiled florets and garlic out on a baking tray.","name":"Toss the cauliflower and garlic cloves in the oil. Spread the oiled florets and garlic out on a baking tray.","url":"https:\/\/mykidslickthebowl.com\/cauliflower-alfredo-sauce\/#wprm-recipe-28536-step-0-1"},{"@type":"HowToStep","text":"Bake in a moderate oven 160 degrees Celsius (320 F) for 30 mins (the cauliflower should be tender at this point.) Remove three quarters of the cauliflower and the garlic from the oven at this point, and transfer to a food processor or blender.","name":"Bake in a moderate oven 160 degrees Celsius (320 F) for 30 mins (the cauliflower should be tender at this point.) Remove three quarters of the cauliflower and the garlic from the oven at this point, and transfer to a food processor or blender.","url":"https:\/\/mykidslickthebowl.com\/cauliflower-alfredo-sauce\/#wprm-recipe-28536-step-0-2"},{"@type":"HowToStep","text":"(Optional Topping) Increase the temperature of your oven to 200 degrees celsius (400 F) and bake  the remaining cauliflower for for a further 5-10 minutes or until brown and crispy.","name":"(Optional Topping) Increase the temperature of your oven to 200 degrees celsius (400 F) and bake  the remaining cauliflower for for a further 5-10 minutes or until brown and crispy.","url":"https:\/\/mykidslickthebowl.com\/cauliflower-alfredo-sauce\/#wprm-recipe-28536-step-0-3"},{"@type":"HowToStep","text":"Cook your pasta in boiling salted water as per the packet instructions.","name":"Cook your pasta in boiling salted water as per the packet instructions.","url":"https:\/\/mykidslickthebowl.com\/cauliflower-alfredo-sauce\/#wprm-recipe-28536-step-0-4"},{"@type":"HowToStep","text":"Add the parmesan cheese and milk to the food processor or blender and blitz the cauliflower and garlic until smooth.Season to taste with salt and pepper.","name":"Add the parmesan cheese and milk to the food processor or blender and blitz the cauliflower and garlic until smooth.Season to taste with salt and pepper.","url":"https:\/\/mykidslickthebowl.com\/cauliflower-alfredo-sauce\/#wprm-recipe-28536-step-0-5"},{"@type":"HowToStep","text":"Drain your pasta reserving 1 cup of the pasta cooking water.","name":"Drain your pasta reserving 1 cup of the pasta cooking water.","url":"https:\/\/mykidslickthebowl.com\/cauliflower-alfredo-sauce\/#wprm-recipe-28536-step-0-6"},{"@type":"HowToStep","text":"If your cauliflower alfredo sauce is very thick use a little of the pasta cooking water to thin it out.","name":"If your cauliflower alfredo sauce is very thick use a little of the pasta cooking water to thin it out.","url":"https:\/\/mykidslickthebowl.com\/cauliflower-alfredo-sauce\/#wprm-recipe-28536-step-0-7"},{"@type":"HowToStep","text":"Toss your pasta in the cauliflower alfredo sauce","name":"Toss your pasta in the cauliflower alfredo sauce","url":"https:\/\/mykidslickthebowl.com\/cauliflower-alfredo-sauce\/#wprm-recipe-28536-step-0-8"},{"@type":"HowToStep","text":"Optional Topping: Roughly chop the now crispy roasted cauliflower and combine it with the pink bread crumbs, thyme and second measure of parmesan cheese, sprinkle this crumb topping on to your creamy cauliflower alfredo pasta.","name":"Optional Topping: Roughly chop the now crispy roasted cauliflower and combine it with the pink bread crumbs, thyme and second measure of parmesan cheese, sprinkle this crumb topping on to your creamy cauliflower alfredo pasta.","url":"https:\/\/mykidslickthebowl.com\/cauliflower-alfredo-sauce\/#wprm-recipe-28536-step-0-9"}],"recipeCategory":["Dinner, Sauce"],"recipeCuisine":["Italian Inspired"],"keywords":"Cauliflower Alfredo Sauce, Healthy Alfredo Sauce","nutrition":{"@type":"NutritionInformation","calories":"461 kcal","carbohydrateContent":"69 g","proteinContent":"16 g","fatContent":"14 g","saturatedFatContent":"3 g","cholesterolContent":"5 mg","sodiumContent":"168 mg","fiberContent":"6 g","sugarContent":"7 g","servingSize":"1 serving","unsaturatedFatContent":"10 g"},"@id":"https:\/\/mykidslickthebowl.com\/cauliflower-alfredo-sauce\/#recipe","isPartOf":{"@id":"https:\/\/mykidslickthebowl.com\/cauliflower-alfredo-sauce\/#article"},"mainEntityOfPage":"https:\/\/mykidslickthebowl.com\/cauliflower-alfredo-sauce\/"}]}</script>

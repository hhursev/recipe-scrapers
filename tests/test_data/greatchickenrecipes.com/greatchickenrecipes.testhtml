    <div class="wprm-recipe-image wprm-block-image-rounded"><noscript><img loading="lazy" decoding="async" style="border-width: 0px;border-style: solid;border-color: #666666;border-radius: 3px;" width="250" height="250" src="https://greatchickenrecipes.com/wp-content/uploads/2023/03/BBQ-Chicken-Dry-Rub-500x500.jpg" class="attachment-250x250 size-250x250" alt="a scoop of BBQ Chicken Dry Rub from a jar" srcset="https://greatchickenrecipes.com/wp-content/uploads/2023/03/BBQ-Chicken-Dry-Rub-500x500.jpg 500w, https://greatchickenrecipes.com/wp-content/uploads/2023/03/BBQ-Chicken-Dry-Rub-150x150.jpg 150w, https://greatchickenrecipes.com/wp-content/uploads/2023/03/BBQ-Chicken-Dry-Rub-728x728.jpg 728w" sizes="auto, (max-width: 760px) calc(100vw - 48px), 720px"></noscript><img loading="lazy" decoding="async" style="border-width: 0px;border-style: solid;border-color: #666666;border-radius: 3px;" width="250" height="250" src="https://greatchickenrecipes.com/wp-content/uploads/2023/03/BBQ-Chicken-Dry-Rub-500x500.jpg" class="attachment-250x250 size-250x250 lazyload" alt="a scoop of BBQ Chicken Dry Rub from a jar" srcset="https://greatchickenrecipes.com/wp-content/uploads/2023/03/BBQ-Chicken-Dry-Rub-500x500.jpg 500w, https://greatchickenrecipes.com/wp-content/uploads/2023/03/BBQ-Chicken-Dry-Rub-150x150.jpg 150w, https://greatchickenrecipes.com/wp-content/uploads/2023/03/BBQ-Chicken-Dry-Rub-728x728.jpg 728w" sizes="auto, (max-width: 760px) calc(100vw - 48px), 720px" id="mv-trellis-img-6" data-trellis-processed="1"></div>

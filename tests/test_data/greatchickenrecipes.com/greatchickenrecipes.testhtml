aption":"Great Chicken Recipes"},"image":{"@id":"https://greatchickenrecipes.com/#/schema/logo/image/"}},{"@type":"Person","@id":"https://greatchickenrecipes.com/#/schema/person/0c1474e659892d314683c2a75f39c57c","name":"Davinah Cenou Montezuma","image":{"@type":"ImageObject","inLanguage":"en-US","@id":"https://greatchickenrecipes.com/#/schema/person/image/","url":"https://secure.gravatar.com/avatar/f52c79dfc63a44238c33903aa104205c8d1fe71099080aa68d4c7b52193a1d7c?s=96&d=mm&r=g","contentUrl":"https://secure.gravatar.com/avatar/f52c79dfc63a44238c33903aa104205c8d1fe71099080aa68d4c7b52193a1d7c?s=96&d=mm&r=g","caption":"Davinah Cenou Montezuma"},"sameAs":["https://greatchickenrecipes.com/about-us/","https://www.facebook.com/greatchickenrecipes/","https://www.instagram.com/greatchickenrecipes/","https://www.pinterest.com/greatchickenrecipes/"],"url":"https://greatchickenrecipes.com/author/hello/"},{"@type":"Question","@id":"https://greatchickenrecipes.com/bbq-chicken-rub/#faq-question-1678789676768","position":1,"url":"https://greatchickenrecipes.com/bbq-chicken-rub/#faq-question-1678789676768","name":"How long should dry rub sit on chicken?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"When I make things like my bbq wings or baked bbq chicken thighs, I sit the dry rub on the meat overnight (or at least 4 hours).","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https://greatchickenrecipes.com/bbq-chicken-rub/#faq-question-1679020462504","position":2,"url":"https://greatchickenrecipes.com/bbq-chicken-rub/#faq-question-1679020462504","name":"How do you use BBQ Rub on chicken?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Use the rub as a dry brine. I personally prefer to use about two tablespoons of bbq rub for every pound of chicken that I am cooking. For best flavor, you should allow the rub to sit on the chicken for at least 4 hours. But, I have cooked bbq chicken immediately. ","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Recipe","name":"BBQ Chicken Dry Rub","author":{"@id":"https://greatchickenrecipes.com/#/schema/person/0c1474e659892d314683c2a75f39c57c"},"description":"This homemade bbq chicken rub adds sweet and smoky flavor to chicken. Use it as a dry brine or with your favorite bbq sauce.","datePublished":"2023-03-17T02:50:55+00:00","image":["https://greatchickenrecipes.com/wp-content/uploads/2023/03/BBQ-Chicken-Dry-Rub.jpg","https://greatchickenrecipes.com/wp-content/uploads/2023/03/BBQ-Chicken-Dry-Rub-500x500.jpg","https://greatchickenrecipes.com/wp-content/uploads/2023/03/BBQ-Chicken-Dry-Rub-500x375.jpg","https://greatchickenrecipes.com/wp-content/uploads/2023/03/BBQ-Chicken-Dry-Rub-480x270.jpg"],"recipeYield":["16"],"prepTime":"PT5M","totalTime":"PT5M","recipeIngredient":["1 tbsp Smoked Paprika","½ tbsp Cayenne Pepper","1 tsp Chili Powder","½ tbsp Black Pepper","2.5 tsp Garlic Powder","1 tsp Onion Powder","3 tsp Natural Ancient Sea Salt (fine)","¾ tsp Italian Seasoning","2.5 tsp dried thyme","¼ cup brown sugar (or brown sugar substitute)"],"recipeInstructions":[{"@type":"HowToStep","text":"Add all of the spices to a glass jar.","name":"Add all of the spices to a glass jar.","url":"https://greatchickenrecipes.com/bbq-chicken-rub/#wprm-recipe-161-step-0-0"},{"@type":"HowToStep","text":"Shake or whisk until incorporated.","name":"Shake or whisk until incorporated.","url":"https://greatchickenrecipes.com/bbq-chicken-rub/#wprm-recipe-161-step-0-1"}],"aggregateRating":{"@type":"AggregateRating","ratingValue":"5","ratingCount":"22"},"recipeCategory":["Main Course"],"recipeCuisine":["American"],"keywords":"barbecue chicken rub, BBQ Chicken Dry Rub, bbq chicken rub","nutrition":{"@type":"NutritionInformation","calories":"18 kcal","carbohydrateContent":"4 g","proteinContent":"0.2 g","fatContent":"0.1 g","saturatedFatContent":"0.02 g","sodiumContent":"658 mg","fiberContent":"0.4 g","sugarContent":"3 g","unsaturatedFatContent":"0.12 g","servingSize":"1 serving"},"@id":"https://greatchickenrecipes.com/bbq-chicken-rub/#recipe","isPartOf":{"@id":"https://greatchickenrecipes.com/bbq-chicken-rub/#article"},"mainEntityOfPage":"https://greatchickenrecipes.com/bbq-chicken-rub/"}]}</script>

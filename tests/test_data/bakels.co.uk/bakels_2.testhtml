                                            <div class="col-lg-4 col-md-4 col-sm-4 col-4 text-xs-right">-</div>
                    
                                </div>
            <div class="row row-group">
                                    <div class="col-12 text-xs-right">
                        <strong>Total Weight</strong>: 1.210                    </div>
                
                            </div>
                                <div class="row row-group">
                <div class="col-12 text-xs-left"><span class="group-label">Group Assembly</span></div>
                <div class="col-lg-8 col-md-8 col-sm-8 col-8 text-xs-left">
                    <span class="sr-only ingredient-label">Ingredient</span>
                </div>

                                    <div class="col-lg-4 col-md-4 col-sm-4 col-4 text-xs-right">
                        <span class="ingredient-label">KG</span>
                    </div>
                
                                        <div class="col-lg-8 col-md-8 col-sm-8 col-8 text-xs-left"><a href="https://www.britishbakels.co.uk/products/ready-to-use-mallow/">Ready-to-Use Mallow</a></div>
                    
                                            <div class="col-lg-4 col-md-4 col-sm-4 col-4 text-xs-right">0.360</div>
                    
                                            <div class="col-lg-8 col-md-8 col-sm-8 col-8 text-xs-left">Pumpkin Spice (Powder)</div>
                    
                                            <div class="col-lg-4 col-md-4 col-sm-4 col-4 text-xs-right">0.005</div>
                    
                                            <div class="col-lg-8 col-md-8 col-sm-8 col-8 text-xs-left">Dark chocolate</div>
                    
                                            <div class="col-lg-4 col-md-4 col-sm-4 col-4 text-xs-right">0.200</div>
                    
                                </div>
            <div class="row row-group">
                                    <div class="col-12 text-xs-right">
                        <strong>Total Weight</strong>: 0.565                    </div>
                

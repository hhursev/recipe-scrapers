                        <span class="ingredient-label">KG</span>
                    </div>
                
                                        <div class="col-lg-8 col-md-8 col-sm-8 col-8 text-xs-left"><a href="https://www.britishbakels.co.uk/products/vanilla-cookie-mix-complete/">Vanilla Cookie Mix Complete</a></div>
                    
                                            <div class="col-lg-4 col-md-4 col-sm-4 col-4 text-xs-right">1.000</div>
                    
                                            <div class="col-lg-8 col-md-8 col-sm-8 col-8 text-xs-left">Butter/margarine</div>
                    
                                            <div class="col-lg-4 col-md-4 col-sm-4 col-4 text-xs-right">0.150</div>
                    
                                            <div class="col-lg-8 col-md-8 col-sm-8 col-8 text-xs-left">Water</div>
                    

  <script id="jumptolink" defer data-src="data:text/javascript,%2F%2A%2A%0A%20%20%20%2A%20Modern%20scroll-to-anchor%20function%20using%20ResizeObserver.%0A%20%20%20%2A%20It%20performs%20an%20initial%20scroll%2C%20then%20watches%20for%20layout%20shifts%0A%20%20%20%2A%20and%20corrects%20the%20scroll%20position%20if%20necessary.%0A%20%20%20%2A%20%2A%20%40param%20%7Bstring%7D%20targetId%20The%20ID%20of%20the%20element%20to%20scroll%20to.%0A%20%20%20%2A%20%40param%20%7Bnumber%7D%20offset%20Adjust%20for%20sticky%20headers.%0A%20%20%20%2A%2F%0A%20%20function%20modernScrollTo%28targetId%2C%20offset%20%3D%2080%29%20%7B%0A%20%20%20%20const%20targetElement%20%3D%20document.getElementById%28targetId%29%3B%0A%20%20%20%20if%20%28%21targetElement%29%20return%3B%0A%20%20%0A%20%20%20%20%2F%2F%20---%201.%20Perform%20the%20initial%20smooth%20scroll%20---%0A%20%20%20%20const%20initialY%20%3D%20window.scrollY%20%2B%20targetElement.getBoundingClientRect%28%29.top%20-%20offset%3B%0A%20%20%20%20window.scrollTo%28%7B%0A%20%20%20%20%20%20top%3A%20initialY%2C%0A%20%20%20%20%20%20behavior%3A%20%27smooth%27%0A%20%20%20%20%7D%29%3B%0A%20%20%0A%20%20%20%20%2F%2F%20---%202.%20Update%20URL%20and%20manage%20focus%20for%20accessibility%20---%0A%20%20%20%20if%20%28history.pushState%29%20%7B%0A%20%20%20%20%20%20history.pushState%28null%2C%20null%2C%20%60%23%24%7BtargetId%7D%60%29%3B%0A%20%20%20%20%7D%0A%20%20%20%20if%20%28targetElement.tabIndex%20%3D%3D%3D%20-1%29%20%7B%0A%20%20%20%20%20%20targetElement.setAttribute%28%27tabindex%27%2C%20%27-1%27%29%3B%0A%20%20%20%20%7D%0A%20%20%20%20targetElement.focus%28%7B%20preventScroll%3A%20true%20%7D%29%3B%0A%20%20%0A%20%20%0A%20%20%20%20%2F%2F%20---%203.%20Observe%20for%20layout%20shifts%20and%20correct%20the%20scroll%20position%20---%0A%20%20%20%20const%20observer%20%3D%20new%20ResizeObserver%28%28%29%20%3D%3E%20%7B%0A%20%20%20%20%20%20const%20correctedY%20%3D%20window.scrollY%20%2B%20targetElement.getBoundingClientRect%28%29.top%20-%20offset%3B%0A%20%20%20%20%20%20%0A%20%20%20%20%20%20%2F%2F%20Only%20re-scroll%20if%20the%20position%20is%20off%20by%20more%20than%20a%20few%20pixels%0A%20%20%20%20%20%20if%20%28Math.abs%28window.scrollY%20-%20correctedY%29%20%3E%205%29%20%7B%0A%20%20%20%20%20%20%20%20window.scrollTo%28%7B%0A%20%20%20%20%20%20%20%20%20%20top%3A%20correctedY%2C%0A%20%20%20%20%20%20%20%20%20%20behavior%3A%20%27auto%27%20%2F%2F%20Use%20%27auto%27%20for%20instant%20correction%0A%20%20%20%20%20%20%20%20%7D%29%3B%0A%20%20%20%20%20%20%7D%0A%20%20%20%20%7D%29%3B%0A%20%20%0A%20%20%20%20%2F%2F%20Observe%20the%20main%20content%20area%20or%20the%20whole%20body%20for%20size%20changes.%0A%20%20%20%20%2F%2F%20This%20is%20more%20efficient%20than%20observing%20hundreds%20of%20individual%20images.%0A%20%20%20%20observer.observe%28document.body%29%3B%0A%20%20%0A%20%20%20%20%2F%2F%20---%204.%20Stop%20observing%20after%20a%20while%20to%20save%20resources%20---%0A%20%20%20%20%2F%2F%20Layouts%20should%20stabilize%20within%20a%20few%20seconds.%0A%20%20%20%20setTimeout%28%28%29%20%3D%3E%20%7B%0A%20%20%20%20%20%20observer.disconnect%28%29%3B%0A%20%20%20%20%7D%2C%203000%29%3B%20%2F%2F%20Stop%20checking%20after%203%20seconds%0A%20%20%7D%0A%20%20%0A%20%20%0A%20%20%2F%2F%20Attach%20to%20your%20links%0A%20%20document.querySelectorAll%28%22a.jumprecipe%22%29.forEach%28link%20%3D%3E%20%7B%0A%20%20%20%20link.addEventListener%28%22click%22%2C%20function%20%28e%29%20%7B%0A%20%20%20%20%20%20e.preventDefault%28%29%3B%0A%20%20%20%20%20%20const%20targetId%20%3D%20this.getAttribute%28%22href%22%29.substring%281%29%3B%0A%20%20%20%20%20%20if%20%28targetId%29%20%7B%0A%20%20%20%20%20%20%20%20modernScrollTo%28targetId%2C%2080%29%3B%20%2F%2F%20Pass%20offset%20here%0A%20%20%20%20%20%20%7D%0A%20%20%20%20%7D%29%3B%0A%20%20%7D%29%3B"></script>


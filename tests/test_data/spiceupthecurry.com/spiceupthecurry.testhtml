on":[{"@type":"ReadAction","target":["https://www.spiceupthecurry.com/sandesh-recipe/"]}]},{"@type":"ImageObject","inLanguage":"en-US","@id":"https://www.spiceupthecurry.com/sandesh-recipe/#primaryimage","url":"https://www.spiceupthecurry.com/wp-content/uploads/2019/10/sandesh-recipe-1.jpg","contentUrl":"https://www.spiceupthecurry.com/wp-content/uploads/2019/10/sandesh-recipe-1.jpg","width":667,"height":1000,"caption":"Sandesh Recipe (Bengali Sweet Sondesh)"},{"@type":"BreadcrumbList","@id":"https://www.spiceupthecurry.com/sandesh-recipe/#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://www.spiceupthecurry.com/"},{"@type":"ListItem","position":2,"name":"Indian Sweets","item":"https://www.spiceupthecurry.com/category/indian-sweets/"},{"@type":"ListItem","position":3,"name":"Sandesh Recipe (Bengali Sweet Sondesh)"}]},{"@type":"WebSite","@id":"https://www.spiceupthecurry.com/#website","url":"https://www.spiceupthecurry.com/","name":"Spice Up The Curry","description":"Vegetarian Recipes","publisher":{"@id":"https://www.spiceupthecurry.com/#organization"},"potentialAction":[{"@type":"SearchAction","target":{"@type":"EntryPoint","urlTemplate":"https://www.spiceupthecurry.com/?s={search_term_string}"},"query-input":{"@type":"PropertyValueSpecification","valueRequired":true,"valueName":"search_term_string"}}],"inLanguage":"en-US"},{"@type":"Organization","@id":"https://www.spiceupthecurry.com/#organization","name":"Spice Up The Curry","url":"https://www.spiceupthecurry.com/","logo":{"@type":"ImageObject","inLanguage":"en-US","@id":"https://www.spiceupthecurry.com/#/schema/logo/image/","url":"https://www.spiceupthecurry.com/wp-content/uploads/2020/06/Spice-Up-The-Curry-300x300-1.png","contentUrl":"https://www.spiceupthecurry.com/wp-content/uploads/2020/06/Spice-Up-The-Curry-300x300-1.png","width":300,"height":300,"caption":"Spice Up The Curry"},"image":{"@id":"https://www.spiceupthecurry.com/#/schema/logo/image/"},"sameAs":["https://www.facebook.com/spiceupthecurry","https://x.com/spiceupthecurry","https://www.instagram.com/spice.up.the.curry/","https://www.pinterest.com/spiceupthecurry/"]},{"@type":"Person","@id":"https://www.spiceupthecurry.com/#/schema/person/7176dac20eedfa98c91ae21b173f4575","name":"Kanan Patel","image":{"@type":"ImageObject","inLanguage":"en-US","@id":"https://www.spiceupthecurry.com/#/schema/person/image/","url":"https://secure.gravatar.com/avatar/8101c56fddf31a6ea42894bad5db9aef4dc4e030e989ae3fc95bba213f7acf0a?s=96&d=blank&r=g","contentUrl":"https://secure.gravatar.com/avatar/8101c56fddf31a6ea42894bad5db9aef4dc4e030e989ae3fc95bba213f7acf0a?s=96&d=blank&r=g","caption":"Kanan Patel"},"description":"To understand the art and science of cooking, I’ve read many cookbooks and culinary books—and now I’m sharing all that experience with you. I started this blog in 2012 to share reliable vegetarian, Indian, and eggless baking recipes (with step-by-step photos and videos) that you can count on.","sameAs":["https://www.spiceupthecurry.com/about/"]},{"@type":"Recipe","name":"Sandesh Recipe (Bengali Sweet Sondesh)","author":{"@id":"https://www.spiceupthecurry.com/#/schema/person/7176dac20eedfa98c91ae21b173f4575"},"description":"Sandesh (Sondesh) sweet is the traditional Bengali dessert that is made from chenna and sugar only. A must-try dessert for the Diwali festival.","datePublished":"2019-10-09T14:20:29+00:00","image":["https://www.spiceupthecurry.com/wp-content/uploads/2019/10/sandesh-recipe-1.jpg","https://www.spiceupthecurry.com/wp-content/uploads/2019/10/sandesh-recipe-1-500x500.jpg","https://www.spiceupthecurry.com/wp-content/uploads/2019/10/sandesh-recipe-1-500x375.jpg","https://www.spiceupthecurry.com/wp-content/uploads/2019/10/sandesh-recipe-1-480x270.jpg"],"recipeYield":["20","20 pieces"],"prepTime":"PT20M","cookTime":"PT20M","totalTime":"PT40M","recipeIngredient":["2 liters or 8 ½ cups Milk (Full-fat whole milk (preferably cow’s milk))","2-3 tablespoons Lemon juice (Or vinegar)","½ cup Sugar (*see notes)","Pistachios (chopped for garnishing)"],"recipeInstructions":[{"@type":"HowToSection","name":"Making chenna:","itemListElement":[{"@type":"HowToStep","text":"Prepare a sieve for straining: line a large fine-mesh sieve with several layers of cheese cheesecloth or use man’s handkerchief or thin cotton cloth. Set over a large bowl.","name":"Prepare a sieve for straining: line a large fine-mesh sieve with several layers of cheese cheesecloth or use man’s handkerchief or thin cotton cloth. Set over a large bowl.","url":"https://www.spiceupthecurry.com/sandesh-recipe/#wprm-recipe-39022-step-0-0"},{"@type":"HowToStep","text":"Pour the milk in a heavy bottom pan or patila. Heat the milk over medium heat and let it come to a full boil, stirring frequently.","name":"Pour the milk in a heavy bottom pan or patila. Heat the milk over medium heat and let it come to a full boil, stirring frequently.","url":"https://www.spiceupthecurry.com/sandesh-recipe/#wprm-recipe-39022-step-0-1"},{"@type":"HowToStep","text":"Once it starts boiling, turn off the heat and remove it from the heat. Add lemon juice and keep stirring.","name":"Once it starts boiling, turn off the heat and remove it from the heat. Add lemon juice and keep stirring.","url":"https://www.spiceupthecurry.com/sandesh-recipe/#wprm-recipe-39022-step-0-2"},{"@type":"HowToStep","text":"As you stir, you will notice that milk has starts to curdle. If it does not curdle, then you can add more lemon juice. But do not add too much at the beginning.","name":"As you stir, you will notice that milk has starts to curdle. If it does not curdle, then you can add more lemon juice. But do not add too much at the beginning.","url":"https://www.spiceupthecurry.com/sandesh-recipe/#wprm-recipe-39022-step-0-3"},{"@type":"HowToStep","text":"You will see the greenish whey and milk solids(chenna) are separated. Drain and separate them using a prepared strainer.","name":"You will see the greenish whey and milk solids(chenna) are separated. Drain and separate them using a prepared strainer.","url":"https://www.spiceupthecurry.com/sandesh-recipe/#wprm-recipe-39022-step-0-4"},{"@type":"HowToStep","text":"Then wash the chenna under running cold water, so all the sourness from lemon juice/vinegar will wash away. Also, as it cools down, it stops further cooking and prevents it from becoming chewy.","name":"Then wash the chenna under running cold water, so all the sourness from lemon juice/vinegar will wash away. Also, as it cools down, it stops further cooking and prevents it from becoming chewy.","url":"https://www.spiceupthecurry.com/sandesh-recipe/#wprm-recipe-39022-step-0-5"},{"@type":"HowToStep","text":"Now gather the edges of the cloth, tie and twist, press lightly to remove all the moisture.","name":"Now gather the edges of the cloth, tie and twist, press lightly to remove all the moisture.","url":"https://www.spiceupthecurry.com/sandesh-recipe/#wprm-recipe-39022-step-0-6"},{"@type":"HowToStep","text":"Chenna is ready","name":"Chenna is ready","url":"https://www.spiceupthecurry.com/sandesh-recipe/#wprm-recipe-39022-step-0-7"}]},{"@type":"HowToSection","name":"Making sandesh sweet:","itemListElement":[{"@type":"HowToStep","text":"Take prepared chenna to a plate.","name":"Take prepared chenna to a plate.","url":"https://www.spiceupthecurry.com/sandesh-recipe/#wprm-recipe-39022-step-1-0"},{"@type":"HowToStep","text":"Start kneading with the help of your palm and keep kneading till it gets smooth and comes together like a dough. It took me about 4-5 minutes.","name":"Start kneading with the help of your palm and keep kneading till it gets smooth and comes together like a dough. It took me about 4-5 minutes.","url":"https://www.spiceupthecurry.com/sandesh-recipe/#wprm-recipe-39022-step-1-1"},{"@type":"HowToStep","text":"Now add sugar to the smooth, kneaded chenna.","name":"Now add sugar to the smooth, kneaded chenna.","url":"https://www.spiceupthecurry.com/sandesh-recipe/#wprm-recipe-39022-step-1-2"},{"@type":"HowToStep","text":"Again knead it well to incorporate the sugar. It will become sticky yet smooth. No more bigger sized milk granules left. Alternately you can do this kneading step in a food processor.","name":"Again knead it well to incorporate the sugar. It will become sticky yet smooth. No more bigger sized milk granules left. Alternately you can do this kneading step in a food processor.","url":"https://www.spiceupthecurry.com/sandesh-recipe/#wprm-recipe-39022-step-1-3"},{"@type":"HowToStep","text":"Take the chenna sugar mixture into the pan and turn the heat on medium-low.","name":"Take the chenna sugar mixture into the pan and turn the heat on medium-low.","url":"https://www.spiceupthecurry.com/sandesh-recipe/#wprm-recipe-39022-step-1-4"},{"@type":"HowToStep","text":"Continue cooking with stirring constantly. This step is crucial, cook for only 4-5 minutes no more than that. Do not overcook it otherwise it becomes crumbly.","name":"Continue cooking with stirring constantly. This step is crucial, cook for only 4-5 minutes no more than that. Do not overcook it otherwise it becomes crumbly.","url":"https://www.spiceupthecurry.com/sandesh-recipe/#wprm-recipe-39022-step-1-5"},{"@type":"HowToStep","text":"Remove the cooked mixture to a plate, spread it for quicker cooling. Let it cool down till it becomes warm.","name":"Remove the cooked mixture to a plate, spread it for quicker cooling. Let it cool down till it becomes warm.","url":"https://www.spiceupthecurry.com/sandesh-recipe/#wprm-recipe-39022-step-1-6"},{"@type":"HowToStep","text":"While it is still warm, start kneading it till it becomes smooth and comes together like a dough ball.","name":"While it is still warm, start kneading it till it becomes smooth and comes together like a dough ball.","url":"https://www.spiceupthecurry.com/sandesh-recipe/#wprm-recipe-39022-step-1-7"},{"@type":"HowToStep","text":"Now take a small portion and start shaping into a patty or peda like. You can use store-bought moulds to shape them.","name":"Now take a small portion and start shaping into a patty or peda like. You can use store-bought moulds to shape them.","url":"https://www.spiceupthecurry.com/sandesh-recipe/#wprm-recipe-39022-step-1-8"},{"@type":"HowToStep","text":"Garnish with chopped pistachios.","name":"Garnish with chopped pistachios.","url":"https://www.spiceupthecurry.com/sandesh-recipe/#wprm-recipe-39022-step-1-9"}]}],"aggregateRating":{"@type":"AggregateRating","ratingValue":"4.62","ratingCount":"13","reviewCount":"2"},"review":[{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"I am nearly in tears.  I have been looking for this recipe for (aging myself here) 38 years; ever since a classmate in college shared it with us.  I did not know what it was called, and my half-hearted efforts to find it were stymied because all I could remember was 'curdled milk and sugar'; try explaining THAT to people.  By chance I clicked and THANK YOU THANK YOU THANK YOU!  Am going to get diabetes now...  😁","author":{"@type":"Person","name":"Auntie K"},"datePublished":"2021-08-20"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"sondesh receipe is step by step with detailed tips and photos made easy and simple with begginers. sondesh is very delicious even my kids like it very much.thanks for proper guidance.","author":{"@type":"Person","name":"sheela varia"},"datePublished":"2020-04-01"}],"recipeCategory":["Dessert"],"recipeCuisine":["Bengali","Indian"],"keywords":"bengali sondesh, sandesh sweet recipe","nutrition":{"@type":"NutritionInformation","servingSize":"2 pieces","calories":"162 kcal","carbohydrateContent":"20.1 g","proteinContent":"6.6 g","fatContent":"6.6 g","sodiumContent":"1 mg","sugarContent":"10.1 g"},"@id":"https://www.spiceupthecurry.com/sandesh-recipe/#recipe","isPartOf":{"@id":"https://www.spiceupthecurry.com/sandesh-recipe/#article"},"mainEntityOfPage":"https://www.spiceupthecurry.com/sandesh-recipe/"}]}</script>

n-US","potentialAction":[{"@type":"ReadAction","target":["https://www.theppk.com/2008/08/berry-week-day-1-marionberry-lavender-scones/"]}]},{"@type":"ImageObject","inLanguage":"en-US","@id":"https://www.theppk.com/2008/08/berry-week-day-1-marionberry-lavender-scones/#primaryimage","url":"https://www.theppk.com/wp-content/uploads/2014/02/MarionberryLavenderScones.jpg","contentUrl":"https://www.theppk.com/wp-content/uploads/2014/02/MarionberryLavenderScones.jpg","width":670,"height":910},{"@type":"BreadcrumbList","@id":"https://www.theppk.com/2008/08/berry-week-day-1-marionberry-lavender-scones/#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://www.theppk.com/"},{"@type":"ListItem","position":2,"name":"Marionberry Lavender Scones"}]},{"@type":"WebSite","@id":"https://www.theppk.com/#website","url":"https://www.theppk.com/","name":"Post Punk Kitchen","description":"By Isa Chandra Moskowitz","publisher":{"@id":"https://www.theppk.com/#organization"},"potentialAction":[{"@type":"SearchAction","target":{"@type":"EntryPoint","urlTemplate":"https://www.theppk.com/?s={search_term_string}"},"query-input":{"@type":"PropertyValueSpecification","valueRequired":true,"valueName":"search_term_string"}}],"inLanguage":"en-US"},{"@type":"Organization","@id":"https://www.theppk.com/#organization","name":"Post Punk Kitchen","url":"https://www.theppk.com/","logo":{"@type":"ImageObject","inLanguage":"en-US","@id":"https://www.theppk.com/#/schema/logo/image/","url":"https://www.theppk.com/wp-content/uploads/2019/09/cropped-PPK-Logo.png","contentUrl":"https://www.theppk.com/wp-content/uploads/2019/09/cropped-PPK-Logo.png","width":512,"height":512,"caption":"Post Punk Kitchen"},"image":{"@id":"https://www.theppk.com/#/schema/logo/image/"},"sameAs":["https://www.facebook.com/IsaChandraMoskowitz/","https://www.instagram.com/postpunkkitchen/?hl=en"],"email":"hello@theppk.com","legalName":"The Post Punk Kitchen","numberOfEmployees":{"@type":"QuantitativeValue","minValue":"1","maxValue":"10"}},{"@type":"Person","@id":"https://www.theppk.com/#/schema/person/67125ec1f692d6457752b379398a7890","name":"Isa Chandra","image":{"@type":"ImageObject","inLanguage":"en-US","@id":"https://www.theppk.com/#/schema/person/image/","url":"https://secure.gravatar.com/avatar/15562381f81266a8a2347eebcd35e69a842aa410a379aa5f94b6be24459426fc?s=96&d=mm&r=g","contentUrl":"https://secure.gravatar.com/avatar/15562381f81266a8a2347eebcd35e69a842aa410a379aa5f94b6be24459426fc?s=96&d=mm&r=g","caption":"Isa Chandra"},"url":"https://www.theppk.com/author/admin/"},{"@type":"Recipe","name":"Marionberry Lavender Scones","author":{"@id":"https://www.theppk.com/#/schema/person/67125ec1f692d6457752b379398a7890"},"description":"","datePublished":"2008-08-21T15:43:16+00:00","image":["https://www.theppk.com/wp-content/uploads/2014/02/MarionberryLavenderScones.jpg","https://www.theppk.com/wp-content/uploads/2014/02/MarionberryLavenderScones-500x500.jpg","https://www.theppk.com/wp-content/uploads/2014/02/MarionberryLavenderScones-500x375.jpg","https://www.theppk.com/wp-content/uploads/2014/02/MarionberryLavenderScones-480x270.jpg"],"recipeYield":["12","12 scones"],"recipeIngredient":["1 1/4 cups almond milk ((or your non-dairy milk of choice))","2 teaspoons apple cider vinegar","3 cups flour","2 tablespoons baking powder","1/2 cup sugar (plus extra for sprinkling)","1/2 teaspoon salt","1/4 cup fresh culinary lavender (chopped)","1/2 cup non hydrogenated shortening","2 tablespoons canola oil","1 teaspoon pure vanilla extract","2 cups marionberries, or berries of your choice"],"recipeInstructions":[{"@type":"HowToStep","text":"Preheat the oven to 375 F. Lightly grease a baking sheet or line with parchment paper. Measure out the milk and add the vinegar to it. Set aside to curdle.","name":"Preheat the oven to 375 F. Lightly grease a baking sheet or line with parchment paper. Measure out the milk and add the vinegar to it. Set aside to curdle.","url":"https://www.theppk.com/2008/08/berry-week-day-1-marionberry-lavender-scones/#wprm-recipe-11841-step-0-0"},{"@type":"HowToStep","text":"Mix together the flour, baking powder, salt and sugar in a large mixing bowl. Add the shortening in small clumps, then use your fingers to cut it into the flour until it appears like small pebbles. (You an also use a food processor for this, but I prefer to use my hands.) Mix in the lavender.","name":"Mix together the flour, baking powder, salt and sugar in a large mixing bowl. Add the shortening in small clumps, then use your fingers to cut it into the flour until it appears like small pebbles. (You an also use a food processor for this, but I prefer to use my hands.) Mix in the lavender.","url":"https://www.theppk.com/2008/08/berry-week-day-1-marionberry-lavender-scones/#wprm-recipe-11841-step-0-1"},{"@type":"HowToStep","text":"Create a well in the center and add the soy milk, oil and vanilla. Mix with a wooden spoon just a bit, then add in the berries. Mix again until everything is moistened, but don’t overmix. A couple of dry looking spots are just fine.","name":"Create a well in the center and add the soy milk, oil and vanilla. Mix with a wooden spoon just a bit, then add in the berries. Mix again until everything is moistened, but don’t overmix. A couple of dry looking spots are just fine.","url":"https://www.theppk.com/2008/08/berry-week-day-1-marionberry-lavender-scones/#wprm-recipe-11841-step-0-2"},{"@type":"HowToStep","text":"Use a 1/4 cup measuring up to scoop the scones out on to the baking sheet. Spray it wth cooking spray first so that the batter comes out easier.","name":"Use a 1/4 cup measuring up to scoop the scones out on to the baking sheet. Spray it wth cooking spray first so that the batter comes out easier.","url":"https://www.theppk.com/2008/08/berry-week-day-1-marionberry-lavender-scones/#wprm-recipe-11841-step-0-3"},{"@type":"HowToStep","text":"Sprinkle tops with a bit more sugar, then bake for 18 to 22 minutes, until tops are firm to the touch and lightly browned. Serve warm!","name":"Sprinkle tops with a bit more sugar, then bake for 18 to 22 minutes, until tops are firm to the touch and lightly browned. Serve warm!","url":"https://www.theppk.com/2008/08/berry-week-day-1-marionberry-lavender-scones/#wprm-recipe-11841-step-0-4"}],"@id":"https://www.theppk.com/2008/08/berry-week-day-1-marionberry-lavender-scones/#recipe","isPartOf":{"@id":"https://www.theppk.com/2008/08/berry-week-day-1-marionberry-lavender-scones/#article"},"mainEntityOfPage":"https://www.theppk.com/2008/08/berry-week-day-1-marionberry-lavender-scones/"}]}</script>

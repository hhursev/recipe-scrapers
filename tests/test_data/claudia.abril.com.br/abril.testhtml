            function abril_scripts_add_click(clallback, param) {
        if (abril_scripts_dinamicos_carregados !== true) {
          abril_scripts_add();
          abril_scripts_dinamicos_carregados = true;
        }
        pcallback = eval("(" + clallback + ")");
        return pcallback(param);
      }


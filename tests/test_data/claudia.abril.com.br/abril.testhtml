$("#user-exp-ctrl").on("click", function () {
    $("#user-exp-login-spinner").addClass("loadExpLoggedSpinner");
    $('#user-exp-ctrl').css("pointerEvents", "none");
    $("#header-user-exp-ctrl").css("pointerEvents", "none");
    $("#user-exp-login-spinner").toggleClass("show");
    $("html").toggleClass("user-exp-overflow");
    // refatora
    $('#user-exp-ctrl').css("pointerEvents", "none");
    $("#header-user-exp-ctrl").css("pointerEvents", "none");
    $("#user-exp-menu").toggleClass("show");
    $("#user-exp-menu-fade").toggleClass("show");
    $("#user-exp-login-spinner").removeClass("loadExpLoggedSpinner");
    if( scripts_dinamicos_carregados !== true){
        scripts_add();
        scripts_dinamicos_carregados = true;
    }
    AbrilNotificacoes.ler(1);
    return;
} );

$(".user-alert-close img").on("click", function () {
  $('#user-exp-ctrl').css("pointerEvents", "auto")
  $("#header-user-exp-ctrl").css("pointerEvents", "auto");
  $("#user-exp-menu").removeClass("show");
  $("#user-exp-menu-fade").removeClass("show");
  $("html").toggleClass("user-exp-overflow");
  $("#user-exp-login-spinner").toggleClass("show");
  if($(".user-alert-icon img").length > 0){
    $(".user-alert-icon img").css("display", "none");
  }
  if($(".user-alert-icon").length > 0){
    $(".user-alert-icon").css("display", "none");
  }
});

var AbrilNotificacoes = (function () {
    var cokieName = "notificationsControl";
    var storageName = "abrilNotificacoes";
    function init(){
        const data_info = JSON.parse(localStorage.getItem('abrilNotificacoes'));
        console.log('AbrilNotificacoes.init()');

        if(data_info===null){
            $('#user-exp-ctrl .user-avatar').css('display', 'none');
            $('.user-avatar-name').css('display','block')
            $('#user-exp-ctrl .user-avatar').css('display','none');
            $('.user-avatar.user-avatar-notification').css('display', 'none');
            $("#user-exp-alerts-wrapper").css('visibility','hidden');
            $(".user-exp-detail").css('border-radius','0 0 4px 4px');
            return;
        }

        $("#user-exp-login-spinner").removeClass("loadExpLoggedSpinner");
        if (data_info.avatar) {
            $('.user-avatar-name').css('display','none');
            $('#user-exp-ctrl .user-avatar').attr('src', data_info.avatar).css('display', 'block');
            $('.user-avatar.user-avatar-notification').attr('src', data_info.avatar).css('display', 'block');
            $(".user-alert-icon").addClass("user-alert-foto");
        } else {
            $('.user-avatar-name').css('display','block')
            $('#user-exp-ctrl .user-avatar').css('display','none');
            $('.user-avatar.user-avatar-notification').css('display', 'none');
            $(".user-alert-icon").removeClass("user-alert-foto");
        }

        if(typeof data_info.visualizado !=="undefined"){
            if(data_info.visualizado === true){
                $("#user-exp-ctrl").attr("data-visualizado", true);
                $(".user-alert-icon").css("display", "none");
            }else{
                $("#user-exp-ctrl").attr("data-visualizado", false);
                $(".user-alert-icon").css("display", "inline-block");
            }
        }

        let perfilUrl = 'https://minha.abril.com.br';
        if(assine_environment[0]==='sandbox'){
            perfilUrl = 'https://homolog-minha.abril.com.br';
        }

        $('.user-exp-account a').attr('href', perfilUrl);

        if(typeof data_info.notifications === 'undefined'){
            $("#user-exp-alerts-wrapper").css('visibility','hidden');
            $(".user-exp-detail").css('border-radius','0 0 4px 4px');
            return;
        }

        if(data_info.notifications === null){
            $("#user-exp-alerts-wrapper").css({'visibility':'hidden'});
            $(".user-exp-detail").css({'border-radius':'0 0 4px 4px'});
            return;
        }

        return AbrilNotificacoes.montar(data_info.notifications, perfilUrl)
    }

    function montar(notifications, perfilUrl){
        let htmlMsg = '';
        let temCritico = '';
        if(notifications.length >= 1){
            $("#user-exp-alerts-wrapper").css("visibility", "visible");
            $("#user-exp-notification-red").css("visibility", "visible");
            let total = notifications.length;

            const unicNotifications = Object.values(
            notifications.reduce((acc, obj) => ({ ...acc, [obj.dscTituloNotificacao]: obj }), {})
            );
            
            unicNotifications.forEach((msg, i) => {
                console.log(msg);
                let titulo = msg.dscTituloNotificacao? msg.dscTituloNotificacao : msg.codTipoNotificacao;
                let critico = msg.critico;
                if ('sim' === critico) {
                    temCritico = 'sim';
                }

                let bg = msg.codCorTextoNotificacao? ' style="background-color: '+msg.codCorTextoNotificacao+'"': '';
                if(i<=1){
                    if ('sim' === critico) {
                        htmlMsg += '<div class="user-exp-row user-alert-critico">';
                    }
                    else {
                        htmlMsg += '<div class="user-exp-row">';
                    }
                        htmlMsg += '<div class="info">';
                            htmlMsg += '<p class="user-alert-title"><mark'+bg+'>'+titulo+'</mark></p>';
                        htmlMsg += '</div>';
                        if(msg.txtNotificacao != null){
                            htmlMsg += '<div class="textlink"><a href="'+msg.dscUrlMinhaAbril+'">';
                            htmlMsg += convertHtml(msg.txtNotificacao) + '</a></div>';
                        }
                    htmlMsg += '</div>';
                }
                if(i==2){
                    htmlMsg += '<div class="user-exp-row"><div class="info-more">';
                    htmlMsg += '<p class="user-alert-title">Você tem <span class="user-alert-qt">+ alertas</span>. ';
                    htmlMsg += '<a href="'+perfilUrl+'/mural/" target="blank">Saiba mais...</a></p></div></div>';
                }
            });
        }
        $("#user-exp-alerts-wrapper").html('<div class="user-exp-menu-fade-alerts"></div>' +htmlMsg);
        return;
    }

    function criar(userID, mostrar=false) {
        console.log("AbrilNotificacoes.cria notificações storage", mostrar);
        if (Number.isInteger(userID) !== true) {
            console.log("AbrilNotificacoes.cria userID invalido");
            return;
        }
        
        sendAjax(userID, false);
        if(mostrar === true){
            AbrilNotificacoes.init();
        }
    }

    async function sendAjax(userID, visualizar=false){
        console.log("AbrilNotificacoes: sendAjax");
        if( checkCokieNotifications() && checkStorageNotifications() ){
            console.log("AbrilNotificacoes: ja existe storage não criar");
            init();
            return;
        }
        
        const myHeaders = new Headers();
        myHeaders.append("Content-Type", "application/x-www-form-urlencoded");
        
        const data = new URLSearchParams();
        data.append("action", "get_notification_user");
        data.append("_token", document.getElementById("notification_user_ajax_nonce").value);
        data.append("crm", userID);
        
        const requestOptions = {
            method: "POST",
            headers: myHeaders,
            body: data
        }
        
        const response = await fetch(ajaxurl, requestOptions)
        .then((response) => response.json())
        .then((result) => {
            console.log(result)
            salvar(result);
            createCokieNotifications();
            console.log("AbrilNotificacoes: notificações criadas");
        })
        .catch((error) => {
            console.error(error)
            console.log("AbrilNotificacoes: Erro Notifications 1");
        });
        init();
    }

    function ler(userID){
        console.log("AbrilNotificacoes.ler notificações storage");
        if (Number.isInteger(userID) !== true) {
            console.log("AbrilNotificacoes.ler userID invalido");
            return;
        }

        $("#user-exp-ctrl").attr("data-visualizado", true);
        $(".user-alert-icon").css("display", "none");

        console.log("AbrilNotificacoes: sava 3");
        changeStorageStatusLida();
        //sendAjax(userID, true);
    }

    function salvar(data){
        if (!data) {
            return;
        }
        localStorage.setItem("abrilNotificacoes", JSON.stringify(data));
    }

    function excluir(){
        localStorage.removeItem('abrilNotificacoes');
        deleteCokieNotifications();
        $("#user-exp-ctrl").attr("data-visualizado", true);
        $(".user-alert-icon").css("display", "none");
        console.log('AbrilNotificacoes.excluir');
        return init();
    }

    function convertHtml(text){
        text = text.replaceAll(/&lt;/g,'<');
        text = text.replaceAll(/&gt;/g,'>');
        text = text.replaceAll(/&amp;/g,'&');
        text = text.replaceAll(/&quot;/g,'"');
        return text;
    }

    function createCokieNotifications(){
        var d = '';
        var value = true;
        d = new Date();
        d.setTime( d.getTime() + (1000*60*60*24)) ;
        expires = "expires="+ d.toUTCString();
        return document.cookie = cokieName+"="+value+";" + expires + ";domain=.abril.com.br;path=/";
    } 

    function checkCokieNotifications(){
          var nameEQ = cokieName + "=";
          var ca = document.cookie.split(";");
          for (var i = 0; i < ca.length; i++) {
            var c = ca[i];
            while (c.charAt(0) == " ") c = c.substring(1, c.length);
            if (c.indexOf(nameEQ) == 0) {
              return true;
            }
          }
       
        return false;
    }
    
    function deleteCokieNotifications() {
        let cookie_params = cokieName +"=" +
           ";domain=.abril.com.br" + 
           "expires=Thu, 01 Jan 1970 00:00:01 GMT";
        document.cookie = cookie_params;
    }

    function checkStorageNotifications(){
        if( localStorage.getItem(storageName) ){
          return true;
        }
        return false;
    }  

    function changeStorageStatusLida(){
        if( data = localStorage.getItem(storageName) ){
            data = JSON.parse(localStorage.getItem(storageName));
            data.visualizado =true;
            localStorage.setItem(storageName, JSON.stringify(data));
        }
        return ;
    }
    
    function checkNotificationsExists(){
        return checkCokieNotifications() && checkStorageNotifications();
    }
    
    return {
        init: init,
        montar, montar,
        criar: criar,
        excluir: excluir,
        ler: ler,
        changeStorageStatusLida: changeStorageStatusLida,
        check: checkNotificationsExists
    };
})();
</script>

    <script>
        var AbrilUserHeader = (function() {
            const storageUser = "abrilAssetsUser";

            function setMessage(mensagem, name, line, tipo) {
                cor = "#000000";
                if (tipo !== undefined) {
                    cor = "#FFFFFF";
                }
                console.log("%c" + name + " | linha: " + line + "\n" + mensagem,
                    "color:" + cor + "; background-color: " + corTipo(tipo) + "; padding:3px 10px;");
                return;
            }

            function corTipo(tipo) {
                switch (tipo) {
                    case "alert":
                        cor = '#FF8000'
                        break;
                    case "alert":
                        cor = '#D90000'
                        break;
                    case "success":
                        cor = '#00B200'
                        break;
                    default:
                        cor = "#FFFFFF";
                }
                return cor;
            }

            function montarHeaderLogged(userBundle) {
                const dataUser = JSON.parse(localStorage.getItem(storageUser));
                console.log("montarHeaderLogged", userBundle);

                const ofertaDiv = document.querySelector('.menu-oferta-aovivo');
                if (ofertaDiv && userBundle == true) {
                    ofertaDiv.style.display = 'none';
                }

                objHideShow(".user-alert-icon", "none");
                if (dataUser.nome.length > 0) {
                    objPointerEvents(".sub-header .search-area a");
                    if (document.querySelectorAll(".user-Name").length > 0) {
                        let inicialNome = dataUser.nome.substr(0, 2);
                        let nomeSobrenome = dataUser.nome.substr(0, 2);
                        let qtdNomes = dataUser.nome.split(' ').length;
                        let nomPessoaFirstName = dataUser.nome;
                        if (dataUser.nome.split(' ')[0] !== undefined) {
                            nomPessoaFirstName = dataUser.nome.split(' ')[0];
                            nomeSobrenome = nomPessoaFirstName;
                        }
                        if (qtdNomes > 1) {
                            inicialNome = dataUser.nome.split(' ')[0].substr(0, 1) + dataUser.nome.split(' ')[qtdNomes-1].substr(0, 1);
                            nomeSobrenome = dataUser.nome.split(' ')[0] + ' ' + dataUser.nome.split(' ')[qtdNomes-1];
                        }
                        objValue(".user-Name", inicialNome, "text");
                        
                        objHideShow("#user-exp-ctrl .user-avatar", "none");
                        objHideShow("#user-exp-ctrl .user-avatar-name", "inline");
                        objValue("#userName", "OLÁ, " + nomeSobrenome, "text");
                        objValue(".userNameExp", nomPessoaFirstName, "text");
                        objValue("#userNameExpToggled", dataUser.nome.toLowerCase().replace(/\b\w/g, c => c.toUpperCase()), "text");
                        objValue("#userExpEmail", dataUser.email, "text");
                    }
                }
                if(document.getElementById("header-user-exp-ctrl") !== null) {
                    objHideShow(".hot-topics-user-exp", "block");
                }
                objAddRemoveClass('body', 'add', 'logged-block');
                objHideShow("#login", "none");
                objHideShow("#assinemenu", "none");
                objHideShow("#logintop", "none");
                objHideShow(".sidebarMenu .assine-btn", "none");
                objHideShow(".assinante", "none");
                objHideShow("#user-exp-login", "none");
                objHideShow("#logout", "inline");
                objHideShow("#logout2", "inline");
                objAddRemoveClass('body', 'add', 'logged');
                objHideShow(".search-area a:not(.btn-assine-abril)", "none");
                $('body').addClass('logged');
                if(window.innerWidth < 766){
                    objHideShow(".assinetop", "none");
                }
                if($("#header-user-exp-ctrl").length) {
                    $("#header-user-exp-ctrl").show();
                    $(".assinante").hide();
                }
                
                if(userBundle === true) {
                    if(AbrilNotificacoes.check()){
                        AbrilNotificacoes.init();
                    }else{
                        AbrilNotificacoes.criar(dataUser.crm, true);
                    }
                }
                return;
            }

            function montarHeaderNotLogged() {
                objPointerEvents(".sub-header .search-area a");
                objHideShow("#login", "block");
                objHideShow(".assinetop", "flex");
                objHideShow("#assinemenu", "block");
                objHideShow("#logintop", "block");
                objHideShow("#logout", "block");
                objHideShow(".buscaVivo", "class", "block");
                objHideShow("#logout2", "none");
                objHideShow("#assine_top", "block");
                objHideShow("#logout", "none");
                objHideShow("#logout", "none");
                objHideShow(".sub-header .search-area a", "block");
                objAddRemoveClass(".sub-header .search-area a", "remove", "hide-s");
                objAddRemoveClass("body", "remove", "logged");
                objValue(".userNameExp", "Usuário", "text");
                objValue("#userName", "Usuário", "text");
                if(window.innerWidth < 766){
                    objHideShow(".assinetop", "none");
                    objAddRemoveClass(".mobile-assine", "add", "on");
                }
                return;
            }

            function objHideShow(name, value) {
                const objs = document.querySelectorAll(name);
                objs.forEach(obj => {
                    obj.style.display = value;
                });
            }

            function objAddRemoveClass(name, action, value) {
                const objs = document.querySelectorAll(name);
                objs.forEach(obj => {
                    if (action === 'add') {
                        obj.classList.add(value);
                    }
                    if (action === 'remove') {
                        obj.classList.remove(value);
                    }
                });
            }

            function objPointerEvents(name) {
                const objs = document.querySelectorAll(name);
                objs.forEach(obj => {
                    obj.style.pointerEvents = 'initial';
                });
            }

            function objValue(name, value, type = 'text') {
                const objs = document.querySelectorAll(name);
                objs.forEach(obj => {
                    if (type === 'text') {
                        obj.innerText = value;
                    }
                    if (type === 'value') {
                        obj.value = value;
                    }
                });
            }

            function getUser(userBundle = false) {
                let userStorage = localStorage.getItem(storageUser);
                let dateNow = new Date().toLocaleString("pt-BR");
                if(userStorage !== null) {
                    userBundle = true;
                }
                if (userBundle === true) {
                    return AbrilUserHeader.montarHeaderLogged(true);
                } else if (userStorage !== null) {
                    return AbrilUserHeader.montarHeaderLogged(false);
                }
                const ofertaDiv = document.querySelector('.menu-oferta-aovivo');
                if (ofertaDiv) {
                    ofertaDiv.style.display = 'block';
                }
                return AbrilUserHeader.montarHeaderNotLogged();
            }

            return {
                setMessage,
                getUser,
                montarHeaderLogged,
                montarHeaderNotLogged,
                objAddRemoveClass
            }
        })();
        AbrilUserHeader.getUser(false);
    </script>
    <script>
      function loadPushNewsFile() {

      	let userStorage = JSON.parse(localStorage.getItem('abrilAssetsUser'));
		if(typeof userStorage === "object" && userStorage !== null){
			if(typeof userStorage.crm === "number" ){
				console.log('PUSH NEWS CANCELADA - USER LOGADO');
				return;
			}
		}

      	AbrilScriptsExec.createCookieListControl("abril_exec_pushNews");

        let filePushNews = "https://cdn.pn.vg/push/pushnews-launcher.js?appId=4e0075b6-fba8-47c0-98c9-bb98d78b6b27";
        var page = window.location.href;

        console.log('CHAMA PUSH NEWS');

        if(page.indexOf("abril.com.br/ofertas") !== -1){ return console.log("local pushnew bloqueou ofertas"); }
        if(page.indexOf("abril.com.br/assinar") !== -1){ return console.log("local pushnew bloqueou assinar"); }
        if(page.indexOf("abril.com.br/login") !== -1){ return console.log("local pushnew bloqueou login"); }


            jQuery(window).one('scroll', function() {
                if(false === jQuery('#user-exp-menu-fade.show').length > 0) {
                	console.log('EXECUTA PUSH NEWS GERAL')
                    var pushNewsScript = document.createElement("script");
                    pushNewsScript.src = filePushNews;
                    pushNewsScript.async = true;
                    document.body.appendChild(pushNewsScript);
                }
            });
      }
/* Remove regra de 1 pushnews oor dia */

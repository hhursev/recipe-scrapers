          scriptElement.src = 'https://claudia.abril.com.br/wp-content/themes/abril-master2/js/abrad.min.js?ver=3.3.2';
          document.body.appendChild(scriptElement);
        }

        function handleScroll() {
          if (window.scriptAdded === true) return true;
          window.scriptAdded = true;

          eventos.forEach(function (evento) {
            window.removeEventListener(evento, handleScroll);
          });

          addScriptToHead();
        }

        if (/Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent)) {
            var eventos = ["scroll"];
        } else {
            var eventos = ["keydown", "mousemove", "touchmove", "touchstart", "touchend", "wheel", "scroll", "click"];
        }

        eventos.forEach(function(evento) {
            window.addEventListener(evento, handleScroll);
        });
      }

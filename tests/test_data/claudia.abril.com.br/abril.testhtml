<body class="wp-singular receitas_portal-template-default single single-receitas_portal postid-1536110 wp-theme-abril-master2 wp-child-theme-abril-claudia paywall-theme-light breaking-news-first breaking-news-image new-exp-logada">
  <style>.searchOpener .hide-s {display: none !important;}

@media (max-width: 991px) and (orientation: landscape) {
  .sidebar-sign-search .assinetop {
    display: none !important;
  }
}



@media (max-width: 991px) {
  html {overflow-x: hidden !important;}
  body, html {padding-bottom:30px;}
  main > .breaking-news:first-child:first-of-type { padding-top: 32px; }
}
body, html { font-size: 10px; font-family: "Roboto", sans-serif; }
body.no-scroll { overflow: hidden; }
a, button, .btn { text-decoration: none; border: none; background: transparent; cursor: pointer; }
button { font-family: "Roboto", sans-serif; font-size: 1.4rem; }
a { color: #AE0F09; }
p del {text-decoration: line-through;}
.dark .title a, .darklight .title a { color: inherit; }
.block-title a { color: #2f2f2f; }
.dark .block-title a, .darklight .block-title a { color: inherit; }
 
/* ASSUNTOS EM DESTAQUE */
.hot-topics { font-size: 1.3rem; color: #fff; background: #313131; padding: 10px 0; }
.hot-topics a { color: inherit; }
.hot-topics a:not(.btn) { text-decoration: underline; }
.hot-topics li { display: inline; padding: 0 4.5px; }
.hot-topics li:first-child, .hot-topics li:last-child { padding: 0; }
.hot-topics .btn { padding: 4px 8px; border: 1px solid #fff; float: right;margin-top: -5px; }

/* SIDEBAR SOCIAL */
.sidebar-social .menu a{width: 30px;height: 30px;display: block;font-size: 0px;background-size: cover;background-repeat: no-repeat;border:none;}
.sidebar-social .menu a:before{font-family: 'icons' !important;speak: never;font-style: normal;font-weight: 400;font-variant: normal;text-transform: none;line-height: 1;-webkit-font-smoothing: antialiased;-moz-osx-font-smoothing: grayscale;color: #000;font-size: 18px;line-height: 26px;}
.sidebar-social .menu a[href*="twitter"]:before, .sidebar-social .menu a[href*="x.com"]:before { content: "\e917"; }
.sidebar-social .menu a[href*="youtube"]:before { content: "\ea9d"; }
.sidebar-social .menu a[href*="facebook"]:before { content: "\e914";  }
.sidebar-social .menu a[href*="instagram"]:before { content: "\ea92"; }
.sidebar-social .menu a[href*="spotify"]:before { content: "\e916"; }
.sidebar-social .menu a[href*="linkedin"]:before { content: "\e91b"; }
.sidebar-social .menu a[href*="pinterest"]:before, .sidebar-social a[href*="pin.it"]:before { content: "\e907" }
.sidebar-social .menu a[href*="tiktok"]:before { content: "\e906"; }
.sidebar-social .menu a[href*="t.me"]:before { content: "\e90a"; font-size: 14px; }
.sidebar-social .menu a[href*=main]:before{
    content: url("data:image/svg+xml;base64,");
    
}
.sidebar-social .menu-social-container .menu li a {padding-left: 0 !important; margin: 0;border-left: 0}
.sidebar-social .menu {float: left;display: flex;z-index: 99;align-items: center;justify-content: left;flex-wrap: wrap;width:100%;margin-top: 0;}
.sidebar-social .menu li {float:left;}
.sidebar-social .menu li a {padding: 0 !important; padding-left: 0!important;text-decoration: none;width: 30px;height: 30px;display: block;font-size: 0px;background-size: cover;background-repeat: no-repeat;}
.sidebar-social .menu li a:hover{background: transparent;}
.sidebar-social .menu-image-title {font-size: 0;}

.sidebarMenu .sidebar-social .menu { justify-content: center;margin-top: 0;}
.sidebarMenu .sidebar-social .menu li {text-align:center;}
.sidebarMenu .sidebar-social {margin-bottom: 0;height: 40px;padding-bottom: 12px;margin-top: 8px;display: flex;align-items: center;justify-content: center;width: 100%;}
.sidebarMenu ul:not(.container, .menu) > .menu-item {border-top: 1px solid #cecece;}
.sidebarMenu ul:not(.container, .menu) > .menu-item ~.menu-item{border-top: none;}
.sidebarMenu .assine-btn a{margin-bottom: 10px;}
.sidebarMenu .userName:not(:empty) {margin-top: 15px;}
.sidebarMenu > ul > li #logout2 {padding-bottom: 15px !important;}
.sub-header .sidebar-social {margin-bottom: 0;}

body.fixed .sub-header .sidebar-social-wrapper {display:none;}

@media (max-width: 991px) {
  .hot-topics-user-exp {padding: 0;margin:0;display:none;}

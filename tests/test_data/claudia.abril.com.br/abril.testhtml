}

/* HEADER PRINCIPAL */
body > header { border-bottom: 1.5px solid rgba(0, 0, 0, 0.17); font-size: 1.5rem; background-color: #FAFAFA; }
header .main-menu { padding: 12px 0; margin: 12px 0 0; flex-grow: 4; position: relative; text-align: center; font-family: "Source Serif Pro", serif; font-size: 1.5rem; }
.main-menu a { color: #000; text-transform: uppercase; }
.main-menu::before { content: ""; position: absolute; top: -1px; left: -100%; right: -100%; height: 1px; background: rgba(0, 0, 0, 0.17); }
.main-menu li { display: inline; padding: 0 5px; }

.mobile-assine.on {display: none;position: sticky !important;top: 0px;z-index: 99;height: 48px;opacity: 1;}

.mobile-assine {padding: 0;margin-top: 0;opacity: 0;overflow: hidden;height: 0;position: absolute;width: 100%;}
.single .mobile-assine{margin-bottom: -40px;}
.mobile-assine span {height: 35px;margin-top: 0;padding: 9px 0;display:block;text-align: center;background: #ffce00;color: #a0251a;font-size: 13px;font-size: 13px;width: 100%;max-width:100vw;font-weight: bold;}
.fixed .mobile-assine {z-index: 99999;}

.heading-tag { font-size: 0; width: 1px; height: 1px; position: absolute; }

@media (min-width: 992px) {
  body > header { overflow-x: hidden; }
}

@media (max-width: 991px) {
  body section .cards:first-of-type { padding-top: 0; }
  body section:first-child {padding-top: 40px;}
  body.tag section:first-child {padding-top: 0;}
  body section.block:first-of-type {padding-top: 20px;}
  .sub-header.container:before{ left: 0 !important; right: 0 !important; max-width: 100%;}
}

/* HEADER PRINCIPAL - FIXADO */
.fixed .hot-topics { display: none; }
.fixed .sub-header { position: fixed;z-index: 999990 !important; top: 0; right: 0; left: 0; }
.fixed .sub-header::before { content: ""; position: absolute; top: 0; bottom: 0; left: -100%; right: -100%; background: #fafafa; z-index: -1; border-bottom: 1.5px solid rgba(0, 0, 0, 0.17); }
.fixed .brand-logo img, .fixed .brand-logo svg { height: 36px; width:auto; }

.fixed .menu-button { order: 1; }
.fixed .brand-logo { order: 2; }
.fixed .main-menu { order: 3; margin: 0; padding: 0; position: static; }
.fixed .search-area { order: 4; }

@media (min-width: 992px) {
  .fixed .menu-button { width: 3% }
  .fixed .brand-logo { width: 101px }
  .fixed .main-menu { width: calc(60% - 120px); }
  .fixed .search-area { width: 20% }
  .fixed .sub-header .icon + span { display: none; }
  body:not(.fixed) header .sub-header {padding-top: 10px;}
}


/* SUB-HEADER */ 
header .sub-header {text-transform: uppercase; font-size: 1.4rem; position: relative; background-color: #FAFAFA; }
body:not(.new-exp-logada) header .sub-header { padding-top: 6px; padding-bottom: 6px;}
.sub-header .row { align-items: center;justify-content: space-between;}
.sub-header .icon { vertical-align: middle; font-size: 2rem; position: relative;}
.sub-header .icon:first-child { padding-right: 5px; }
.menuOpener { font-size: 1.4rem; text-transform: uppercase;display: flex;align-items: center; }
.brand-logo { text-align: center; }
.brand-logo img, .brand-logo svg { max-width: 105px; }
.menu-button {height: 23px;    text-align: left;
  position: static;
  z-index: 9999;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: left;
  align-items: center;}

@media (max-width: 991px) {
  .sub-header img { max-width: 85px; }
}

@media (min-width: 992px) and  (max-width: 1200px) {
  .fixed .search-area { width: 25% !important }
  .fixed .main-menu, .fixed .brand-logo {width: 50% !important;margin-left: 21%;}
  .fixed .sub-header .icon + span { display: none; }
  .hide-s {display: none !important;}
}

/* PESQUISA NO HEADER */
.sub-header .search-area { text-align: right; position: static;z-index:9999;display: flex;flex-direction: row;flex-wrap: wrap;justify-content: right;align-items: center; }
.sub-header .search-area a { margin-right: 15px; display: none; pointer-events:none;}
.exp-logado.fixed .sub-header .search-area {margin-top: 0 !important; top: 0;}
.sub-header .search-area button { text-transform: uppercase; }
.sub-header .search-area input { width: 100%; height: 35px; padding: 0 35px 0 15px; border: 1px solid rgba(0, 0, 0, 0.17); font-size: 16px!important; -webkit-transition: font-size .25s ease; }
.sub-header .search-area input:focus { font-size: 16px !important; }
.sub-header .search-area form button { border: 0; padding: 0; position: absolute; top: 11px; right: 0; background: #ae0f09; color: white; padding: 0 12px; font-weight: 300;text-transform: capitalize; top: 10px; right: 20px; bottom: 10px;}
.sub-header .search-area form { z-index: 9; position: absolute; overflow-x: hidden; height: 0; width: 100%; padding: 0 20px; background: white; border: 0px solid transparent; top: 100%; left: 0; right: 0; transition: .3s ease;}
.searchOpen .sub-header .search-area form { height: 57px; padding: 10px 20px; border: 1px solid #ccc; }
.searchOpen .sub-header .search-area {z-index: 9999999;}
.fixed .sub-header .search-area form {margin: -10px 0;}

@media (min-width: 992px) {
  .sub-header .search-area form { opacity: 0; top: 19px;left:5px; }
  .sub-header .search-area form button { color: #000; padding: 0; background: transparent; top: 7px; right: 7px; }
  .sub-header .search-area form, .searchOpen .sub-header .search-area form { left: auto; padding: 0; border: 0; height: auto; width: 0; }
  .searchOpen .sub-header .search-area form { width: 220px; opacity: 1;top:17px;right: -10px;}
  .fixed .searchOpen .sub-header .search-area form {top:6px;right:3px;}
}

body.paywall-theme-dark .mobile-assine span{background: #000;color: #FFF;font-weight: bold;text-decoration: underline; line-height:17px;}

@media ( min-width: 992px) {
  body:not(.fixed) > header .hot-topics-user-exp  .hot-topics.hide-s {min-width: 900px;min-height: 15px;}
  body:not(.fixed) header .sub-header{min-height:115px;min-width:115px; padding-bottom: 0}
  body:not(.fixed).new-exp-logada .search-area {min-height: 5px;}
  body:not(.fixed) .hot-topics, .sub-header {min-width: 835px;}
}</style><style>/* GERAL */
body, html { font-family: "Quicksand", sans-serif; }
a { color: #B30020; }
/* HEADER TOP MENU */
header .sub-header .menu-sociais-container .menu-image-title{display: none;}
header .sub-header .f-social .btn-media-top li:first-child{display: none;}
body.home .sub-header .search-area form .icon { color: #000; }
body:not(.home).fixed .sub-header .search-area form {z-index: 99;}


/* HEADER */
header .sub-header{background:#FAFAFA;padding-top:0;}
header .sub-header .main-menu li{margin-left: -4px;padding: 0 25px 0;border-left: solid 1px;background: #FAFAFA;}
header .sub-header .main-menu li:first-child{border-left:none}
header .sub-header .main-menu li a{font: Italic 20px/16px "Playfair Display",sans-serif;text-transform: none;}
header .sub-header .main-menu::after {z-index: 1;position: absolute;content: "";top: 50%;left: 10px;right: 10px;height: 2px;background: #000;}
header .main-menu::before{display:none; }
.sub-header .search-area form{margin-top: 35px;}
.sub-header .search-area button{color: #000;font: 400 16px 'Quicksand',sans-serif;}
.sub-header .search-area a {color: #fff;background: #B30020;padding: 3px 15px;font: 700 15px/16px "Quicksand",sans-serif,sans-serif;}
header ul.menu {position: relative;z-index: 90;}
header .sidebarMenu > ul li a:hover {border-left-color:#D1204E;}
header .sidebarMenu > ul > li:first-child a svg {max-width: 137px;}
header .sidebarMenu > ul > li:nth-child(3) { display: block;}
header .sidebarMenu > ul > li.assine-btn a:hover {  opacity: 1;  }
header .sidebarMenu > ul a {font: 500 15px/24px "Quicksand",sans-serif;}
.hot-topics {background: #000;}
.hot-topics li {font: 500 15px/18px "Quicksand",sans-serif}
.hot-topics a:not(.btn) {text-decoration: none;}
@media (max-width: 991px){
  .breaking-news-image.home .sub-header .search-area form { margin-top: 0;}
}
@media (min-width: 992px){
  .breaking-news-image.home .sub-header .search-area form {
    margin-top: -114px;
  }
  .fixed.breaking-news-image.home .sub-header .search-area form {
    margin-top: -31px;
  }
  body:not(.home).searchOpen .sub-header .search-area form {
		margin-top: 0;
		top: 0;
	}
  body > header { overflow-y: hidden;}
}

/* HEADER FIX */
.fixed .sub-header{padding: 8px 16px;}
.fixed .sub-header .icon:first-child,.fixed .sub-header .searchOpener .icon{color: #FFF}
.fixed .brand-logo img, .fixed .brand-logo svg .logo_claudia {fill: #FFF;}
.fixed .main-menu,.fixed .brand-logo,.fixed .search-area{width: auto;}
.fixed .brand-logo{order: 2;padding:0 0 0 0;z-index:9;}
.fixed .search-area{order: 4;}
.fixed .sub-header .search-area form{margin-top: -8px;}
.fixed .menu-menu-header-container{background: #000;}
.fixed .main-menu{border:none;text-align: left;}
.fixed .main-menu li , .fixed .main-menu li > a > span {color: #FFF;}
.fixed .sub-header .main-menu li {padding: 0 10px 0 10px;}
.fixed .main-menu a:hover:after{background: #FFF;bottom:-5px;}
.fixed header .main-menu:before{background: #DD2739;border: none; }
.fixed .menu-button{z-index:9;}
.fixed .sub-header::before{background: #000;}
.fixed .sub-header .search-area a {padding:2px 9px; }
.fixed .sub-header .main-menu::after {display: none;}
.fixed .sub-header .main-menu li{background: transparent;}
.fixed .sub-header .main-menu li:first-child{border-left: none;}
.fixed .sub-header .main-menu li a{font: 500 18px/16px "Quicksand",sans-serif;text-transform: none;}
.mobile-assine span { background: #B30020; color: #fff;}
.breaking-news-image.home>header .menuOpener span { font: 400 16px 'Quicksand',sans-serif;  }
.fixed .sub-header .search-area form button span {display: block;}
.fixed .sub-header .search-area button { color: #FFF; }

/* CSS adicional */
.share li a .icon:before {color: #FFF;}
#piano-modal-pay-wall-multiple #outrosPlanosAmp:nth-child(2) {display:none;}
.block.most-read .our-carousel .card .title strong {height:50px;}
.post .content blockquote { width:100%; margin:0; }
.block.esporte .row+.row { display: flex !important; }
.breaking-news-image.home .block.breaking-news {padding-top:0;}
.single-receitas .content #mais_lidas, .single-receitas .content #leia_mais {display:none;}
#ip_abril.injected-paywall {height: 823px;}

@media (max-width: 991px) {
  body > header {border-bottom:0;}
  .container:has(nav.brands-menu) {overflow: hidden;}
  .fixed .brand-logo {margin: 0 auto;}
  .fixed .brand-logo img, .fixed .brand-logo svg .logo_claudia {fill: #AE0F09;}
  .fixed .brand-logo img, .fixed .brand-logo svg {margin-left: 0;margin-top: -3px !important;}
  .fixed .sub-header::before{background: #FFF;}
  .article-video-content>.fit-video>iframe{width: 100%;height: 200px;}
  .sub-header.container {border:none;}
  .sub-header .search-area form, .searchOpen .sub-header .search-area form {margin-top: 0;}
  .block-sub-title {margin: 10px 0;color: #DD2739 !important;font-size: 14px;}
  .brand-logo {padding: 10px 0 5px;}
  .fixed .sub-header .icon:first-child, .fixed .sub-header .searchOpener .icon {color: #000;}
  .fixed .main-menu, .fixed .brand-logo { margin: 0; padding: 0; width: 50%; }
  .fixed .search-area { position: static; width: 25%; }
  .single-post.fixed .sub-header .searchOpener .icon::before, .single-post.fixed.sub-header .icon.menu::before, .fixed .sub-header .icon.menu::before, .home.fixed .sub-header .searchOpener .icon::before { color: #000; }
  .fixed.searchOpen .sub-header .search-area button span { color: #FFF; }
  body.home .sub-header .search-area form, body.home .searchOpen .sub-header .search-area form { margin-top: 0;z-index:999999;}
  .single-post .post .media-open, .post .featured-media, .post .wp-caption {margin-left:0;}
  body:not(.fixed) #sponsored-fixed { margin-bottom: 0 !important; }
}

@media (min-width: 991px) {
  .fixed .sub-header .search-area { position: relative; overflow: visible; }
  .fixed.searchOpen .sub-header .icon:first-child { display: block; color: #000000; }
  .fixed.searchOpen .sub-header .search-area form { margin-top: -31px; }
  .fixed .searchOpener .icon { color: #FFFFFF; }
  .sub-header .search-area { z-index: 999999; }
  .fixed .menu-button, .fixed .sub-header .search-area { width: 19%; }
  .fixed .brand-logo { width: 60%; }
  .fixed .main-menu { text-align: center; margin-top: 15px;}
  .fixed .sub-header { padding: 10px 24px; }
  .fixed .search-area{order: 3;}
  .fixed .main-menu { order: 4; }
  .fixed .sub-header .icon.menu::before { color: #FFF; }
  .fixed .menuOpener .icon::before,.fixed .sub-header .searchOpener .icon::before { color: #FFF; }
  .sub-header .search-area form { top: 99% !important; }
  body.fixed #sponsored-fixed { margin-top: 15px; }
  body:not(.home):not(.fixed) .brand-logo{padding-top: 10px;}
}</style><style>/* BLOCK NEWSLETTER */
.block.newsletter {
    padding: 0;
    border: none;
}
.block.newsletter .container {
    border: 1px solid #d5beac;
    margin: 2px auto;
    margin-top: 0px;
    padding: 0 12px;
}
.block.newsletter .block-title, .block.newsletter .block-title strong {
    background: #d5beac;
    padding: 20px 40px;
    color: #000;
    font-size: 36px;
    text-align: left;
    font-weight: 500;
}

.block.newsletter .block-title strong {
    padding: 0;
    text-align: left;
    font-weight: 500;
}

.block.newsletter .description {
    width: 60%;
    font-size: 18px;
    font-family: "Quicksand", sans-serif;
    padding: 0 40px;
    padding-top: 10px;
}

.block.newsletter .description strong {
    color: #ae0f09;
}

.block.newsletter form .form-group label {
    flex-direction: row;
}

.block.newsletter form {
    padding: 0 40px;
    margin-bottom: 30px;
}

.block.newsletter.light form .form-group label .description {
    padding: 0 0 0 28px;
    margin-top: 10px;
    width: 100%;
    font: normal normal normal 18px/24px Quicksand;
}

.block.newsletter form .form-group input[type=checkbox]:checked+label:before {
    width: 20px;
    height: 20px;
    content: url(/wp-content/themes/abril-claudia/inc/images/check-input.svg);
    background-color: transparent;
    margin-top: -10px;
    position: relative;
    z-index: 1;
}

.block.newsletter form .form-group input[type=checkbox]+label:before {
    width: 20px;
    height: 20px;
    border: 2px solid #d5beac;
    margin: 0px;
    padding: 8px 0;
}
.block.newsletter form .form-group input[type=checkbox]:checked+label:after{
    content: '';
    display: block;
    width: 18px;
    height: 18px;
    background: #000;
    position: absolute;
    z-index: 0;
    border-radius: 50%;
    left: 15px;
    top: 8px;
}

.block.newsletter form .form-group label .title {
    width: 100%;
    margin: 0;
    margin-top: 0px;
}

.block.newsletter .sib_embed_signup .row div.col-s-12.col-l-4:last-child, .block.newsletter .msg-return {
    margin-top: 5px;
    margin-bottom: 0;
    margin-left: 15px;
    width: 38.5%;
    height: calc(100% - 120px);
    position: absolute;
    top: 90px;
}

.block.newsletter .sib_embed_signup {
    margin: 0;
}

.newsletter-num-0 .sib_embed_signup .theform {
    margin-top: 0;
    padding: 0;
}

.block.newsletter.light form label {
    text-align: left;
    font-family: "Quicksand", sans-serif;
    font-size: 11px;
}

.block.newsletter form input[type=submit] {
    font-size: 14px;
    font-family: "Quicksand", sans-serif;
    background: #000;
    font-weight: bold;
}
.block.newsletter .msg-return{
    align-items: initial;
}

.newsletter-num-0 .sib_embed_signup .theform .row .col-l-7 {
    width: 100%;
}

.newsletter-num-0 .sib_embed_signup .theform .row .col-l-5 {
    position: absolute;
    right: 0;
    top: 47%;
    border-left: 1px solid #ccc;
    padding-left: 50px;
    padding-right: 40px;
}

.block.newsletter form input[type=email] {
    font-family: "Playfair Display", serif;
    font-style: italic;
}

.block.newsletter form .form-group label .title {
    margin-top: -1px;
    font-size: 20px;
    font-family: "Quicksand", sans-serif;
    color: #000;
}

.newsletter-num-0 .sib_embed_signup .theform .row .msg-return {
    top: 45%;
    height: 8vh;
    bottom: 0;
}

.msg-return.col-s-12.col-l-4 {
    width: 38%;
    right: 0;
}

.block.newsletter .msg-return span h2 {
    font: normal normal normal 20px/24px Playfair Display;
}
.block.newsletter.light.newsletter-num-3 .form-group{
  width: 20%;
}
.block.newsletter.light.newsletter-num-2 .form-group{
  width: 30%;
}

.block.newsletter.single-newsletter .container{
    border: none;
}

.block.newsletter.single-newsletter .container .newsletter-single-desc .description {
    width: 100%;
    padding: 0 10px;
}

.block.newsletter.single-newsletter .msg-return{
    margin-top: 0;
    width: 100% !important;
    padding: 0 10px;
    position: relative;
    top: initial;
    border: none;
    padding-left: 0;
}
.block.newsletter.single-newsletter form .icon{
    top: 30px;
    right: 160px;
}
.block.newsletter.single-newsletter .content-newsletter form {
    padding: 0 10px;
    margin-bottom: 0;
    margin-top: 20px;
}

.block.newsletter form.theform .col-s-12.col-l-4:last-child {
    position: absolute;
    right: 0;
    top: 37%;
    padding-left: 50px;
    padding-right: 40px;
}

.block.newsletter.newsletter-num-1 form.theform {
    padding: 0;
    margin: 0;
    padding-bottom: 40px;
}

.block.newsletter.newsletter-num-1 .row .col-l-7.col-s-12 {
    width: 100%;
}

.block.newsletter.newsletter-num-1 .row .col-s-12.col-l-5 {
    position: absolute;
    right: 0;
    top: 47%;
    border-left: 1px solid #ccc;
    padding-left: 35px;
    padding-right: 50px;
}

.block.newsletter.newsletter-num-1 .description {
    padding-top: 20px;
}

.block.newsletter.newsletter-num-1 .msg-return.col-s-12.col-l-5 {
    top: 45%;
    height: 8vh;
}
.block.newsletter form .icon{
    top: 10px;
    right: 195px;
}

@media(max-width: 1072px) {
    .block.newsletter form.theform .col-s-12.col-l-4:last-child,
    .block.newsletter form.theform .col-s-12.col-l-5:last-child {
        top: 45%;
    }
    .newsletter-num-0 .sib_embed_signup .theform .row .msg-return {
        bottom: 21px;
    }
}

@media(max-width: 992px) {
    .block.newsletter.newsletter-num-1 .msg-return.col-s-12.col-l-5 {
        margin-left: 55px !important;
        margin-right: 55px !important;
        padding-top: 0 !important;
    }
    .block.newsletter.newsletter-num-1 .row .col-s-12.col-l-5 {
        position: relative;
        border-top: 1px solid #ccc;
        padding-top: 25px;
        width: calc(100% - 60px);
        margin: 0 auto;
        border-left: 0;
        margin-top: 25px;
        padding-left: 0;
        padding-right: 0;
    }
    .block.newsletter.newsletter-num-1 form.theform{
        padding-bottom: 20px;
    }
    .block.newsletter.newsletter-num-1 .description{
        padding-top: 0;
    }
    .block.newsletter form.theform .col-s-12.col-l-4:last-child {
        position: initial;
    }
    .newsletter-num-0 .sib_embed_signup .theform .row .msg-return {
        padding: 5px 50px !important;
    }
    .block.newsletter.single-newsletter .msg-return {
        padding: 0 20px;
        margin-top: -10px;
    }
    .block.newsletter .block-title {
        margin-top: 0;
        font: normal normal normal 32px/42px Playfair Display;
        padding: 10px 20px;
    }
    .block.newsletter .container {
        padding: 0;
    }
    .block.newsletter .description, .block.newsletter.light form .form-group label .description {
        width: 100%;
        padding: 0 20px;
    }
    .block.newsletter .sib_embed_signup .row div.col-s-12.col-l-4:last-child, .block.newsletter .msg-return {
        margin: 0 auto;
        width: calc(100% - 20px);
        position: relative;
        padding-left: 0;
        padding-right: 0;
        top: 0;
    }
    .block.newsletter form .icon {
        top: 35px;
        right: 145px;
    }
    .block.newsletter form input[type=email] {
        font-family: "Playfair Display", serif !important;
        font-style: italic !important;
    }
    .block.newsletter.light.newsletter-num-2 .form-group,
    .block.newsletter.light.newsletter-num-3 .form-group {
        width: 100%;
        padding: 0 5px;
    }
    .block.newsletter form {
        padding: 0 20px;
    }
    .block.newsletter form .form-group input[type=checkbox]:checked+label:after{
        top: 9px;
        left: 11px;
    }
    .block.newsletter form .form-group input[type=checkbox]:checked+label:before{
        margin-top: -8px;
    }
    .block.newsletter .block-title, .block.newsletter .block-title strong{
        font-size: 32px;
    }
    .block.newsletter form input[type=email],
    .block.newsletter form input[type=submit]{
        border-radius: 0;
    }
    .newsletter-num-0 .sib_embed_signup .theform .row .col-l-5 {
        width: 90%;
        position: initial;
        right: 0;
        bottom: 17px;
        border-top: 1px solid #ccc;
        padding: 0;
        padding-top: 30px;
        margin: 0 auto;
        margin-top: 30px;
        border-left: 0;
    }
    .newsletter-num-0 .sib_embed_signup .theform .row .msg-return {
        padding-top: 5px;
    }
}

@media(max-width: 900px) {
    .newsletter-num-0 .sib_embed_signup .theform .row .col-l-5 {
        width: 80%;
    }
}</style>
  

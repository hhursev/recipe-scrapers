    var execPushNews = AbrilScriptsExec.checkCookieListControl("abril_exec_pushNews");
    if ( execPushNews ) {
        AbrilScriptsExec.removeFunctionList("loadPushNewsFile");
        console.log('Removeu PushNews File');
    }
*/
    AbrilScriptsExec.setLoadStatus("loadPushNewsFile");

    if( AbrilScriptsExec.checkDirectExec("loadPushNewsFile") ){
        loadPushNewsFile();
    }
    </script>
  

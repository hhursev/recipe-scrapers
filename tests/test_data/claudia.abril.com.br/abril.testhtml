});


function scripts_add_click(clallback, param){
    if( scripts_dinamicos_carregados !== true){
        scripts_add();
        scripts_dinamicos_carregados = true;
    }
    if( typeof AbrilLogin === 'undefined' ){
        return setTimeout(() => {
         scripts_add_click(clallback, param);
        }, "1000");
    }
    pcallback = eval("(" + clallback + ")");
    return pcallback(param);
}


      // Otimização INP: Melhor gerenciamento de carregamento de scripts
      function abril_scripts_add() {
        if (abril_scripts_dinamicos_carregados === true) {
          return;
        }
        
        // Usa requestIdleCallback para carregar scripts quando o navegador estiver ocioso
        if ('requestIdleCallback' in window) {
          requestIdleCallback(() => {
            loadScriptsDynamically();
          }, { timeout: 2000 });
        } else {
          // Fallback para navegadores que não suportam requestIdleCallback
          setTimeout(loadScriptsDynamically, 100);
        }
      }


    "Tortilla pšeničná 2 ks",
    "Philadephia 125 g",
    "Salátová okurka 1 ks",
    "Krůtí šunka 3 plát.",
    "Sýr tvrdý 3 plát.",
    "Hroznové víno bílé  ",
    "Jablečná kapsička  "
  ],
  "recipeInstructions": [
    {
      "@type": "HowToStep",
      "position": 1,
      "name": "1.",
      "text": "Z tortil odkrojte okraje tak, abyste místo kruhu získali obdélník. Pomažte je sýrem. První obdélník vyskládejte tenkými kolečky okurky. Zarolujte a dvakrát přepulte."
    },
    {
      "@type": "HowToStep",
      "position": 2,
      "name": "2.",
      "text": "Druhou tortilu vyskládejte šunkou, sýrem a postupujte stejně jako u první rolky."
    },
    {
      "@type": "HowToStep",
      "position": 3,
      "name": "3.",
      "text": "Svačinu doplňte o minibalení bezpeckového hroznového vína a jablečnou kapsičku Hello 100 %."
    }
  ],

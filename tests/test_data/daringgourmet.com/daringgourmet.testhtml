.dropdown {
  position: relative;
  display: inline-block;
  background: #990033;
  width: 100%;
  color: #FFF;
  font-weight: 500;
  padding: 5px 0;
	text-align: center;
}

.dropdown span {
  padding: 5px 20px;
}

.dropdown-content {
  display: none;
  position: absolute;
  width: 100%;
  box-shadow: 0 8px 16px 0 rgba(0, 0, 0, .2);
  padding: 10px 0;
  z-index: 1;
  background: #fafafa;
  margin-top: 5px;
  line-height: 10px;
  max-height: 300px;
  overflow-y: scroll;
	text-align: center;
}

.dropdown.widen .dropdown-content {
	width: 200%
}

.dropdown:after {
  content: "\2304";
  font-weight: 700;
  right: 10px;
  bottom: 8px;
  position: absolute;
}

.dropdown:hover .dropdown-content {
    display: block;
}

.dropdown-content a {
	color: #000;
	text-decoration: none;
}

.dropdown.widen .dropdown-content {
	column-count: 3;
}

.dropdown-content a:hover {
	color: #990033;
}


span class="wprm-recipe-ingredient-notes wprm-recipe-ingredient-notes-faded">divided</span></li><li class="wprm-recipe-ingredient" style="list-style-type: none;" data-uid="14"><span class="wprm-checkbox-container"><input type="checkbox" id="wprm-checkbox-6" class="wprm-checkbox" aria-label="&nbsp;1/4 teaspoon Salt , (optional)"><label for="wprm-checkbox-6" class="wprm-checkbox-label"><span class="sr-only screen-reader-text wprm-screen-reader-text">&#9634; </span></label></span><span class="wprm-recipe-ingredient-amount">1/4</span> <span class="wprm-recipe-ingredient-unit">teaspoon</span> <span class="wprm-recipe-ingredient-name"><a href="http://amzn.to/2DEOIsV" class="wprm-recipe-ingredient-link" target="_blank" rel="nofollow">Salt </a></span>, <span class="wprm-recipe-ingredient-notes wprm-recipe-ingredient-notes-faded">(optional)</span></li><li class="wprm-recipe-ingredient" style="list-style-type: none;" data-uid="16"><span class="wprm-checkbox-container"><input type="checkbox" id="wprm-checkbox-7" class="wprm-checkbox" aria-label="&nbsp;1 cup  Rice flour, very fine (see notes)"><label for="wprm-checkbox-7" class="wprm-checkbox-label"><span class="sr-only screen-reader-text wprm-screen-reader-text">&#9634; </span></label></span><span class="wprm-recipe-ingredient-amount">1</span> <span class="wprm-recipe-ingredient-unit">cup </span> <span class="wprm-recipe-ingredient-name"><a href="https://amzn.to/2E27Eqh" class="wprm-recipe-ingredient-link" target="_blank" rel="nofollow">Rice flour</a></span>, <span class="wprm-recipe-ingredient-notes wprm-recipe-ingredient-notes-faded">very fine (see notes)</span></li><li class="wprm-recipe-ingredient" style="list-style-type: none;" data-uid="18"><span class="wprm-checkbox-container"><input type="checkbox" id="wprm-checkbox-8" class="wprm-checkbox" aria-label="&nbsp;Saffron, (optional)"><label for="wprm-checkbox-8" class="wprm-checkbox-label"><span class="sr-only screen-reader-text wprm-screen-reader-text">&#9634; </span></label></span><span class="wprm-recipe-ingredient-name">Saffron</span>, <span class="wprm-recipe-ingredient-notes wprm-recipe-ingredient-notes-faded">(optional)</span></li></ul></div></div>
<div id="recipe-10740-instructions" class="wprm-recipe-instructions-container wprm-recipe-10740-instructions-container wprm-block-text-normal" data-recipe="10740"><h3 class="wprm-recipe-header wprm-recipe-instructions-header wprm-block-text-none wprm-align-left wprm-header-decoration-none wprm-header-has-actions" style="">Instructions&nbsp;<div class="wprm-recipe-media-toggle-container wprm-toggle-container wprm-toggle-buttons-container wprm-block-text-normal" style="background-color: #ffffff;border-color: var(--wp--preset--color--foreground);color: var(--wp--preset--color--foreground);border-radius: 3px;"><button class="wprm-recipe-media-toggle wprm-toggle wprm-toggle-active" data-state="on" data-recipe="10740" style="background-color: var(--wp--preset--color--foreground);color: #ffffff;" aria-label="Show instruction media"><span class="wprm-recipe-icon wprm-toggle-icon wprm-toggle-icon-active"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewbox="0 0 24 24"><g class="nc-icon-wrapper" stroke-linecap="square" stroke-linejoin="miter" stroke-width="1" transform="translate(0.5 0.5)" fill="#ffffff" stroke="#ffffff"><circle data-color="color-2" cx="12" cy="13" r="5" fill="none" stroke-miterlimit="10"></circle><path d="M21,22H3a2,2,0,0,1-2-2V7A2,2,0,0,1,3,5H7L9,2h6l2,3h4a2,2,0,0,1,2,2V20A2,2,0,0,1,21,22Z" fill="none" stroke="#ffffff" stroke-miterlimit="10"></path><circle data-color="color-2" data-stroke="none" cx="4" cy="8" r="1" stroke="none"></circle></g></svg></span><span class="wprm-recipe-icon wprm-toggle-icon wprm-toggle-icon-inactive"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewbox="0 0 24 24"><g class="nc-icon-wrapper" stroke-linecap="square" stroke-linejoin="miter" stroke-width="1" transform="translate(0.5 0.5)" fill="var(--wp--preset--color--foreground)" stroke="var(--wp--preset--color--foreground)"><circle data-color="color-2" cx="12" cy="13" r="5" fill="none" stroke-miterlimit="10"></circle><path d="M21,22H3a2,2,0,0,1-2-2V7A2,2,0,0,1,3,5H7L9,2h6l2,3h4a2,2,0,0,1,2,2V20A2,2,0,0,1,21,22Z" fill="none" stroke="var(--wp--preset--color--foreground)" stroke-miterlimit="10"></path><circle data-color="color-2" data-stroke="none" cx="4" cy="8" r="1" stroke="none"></circle></g></svg></span></button><button class="wprm-recipe-media-toggle wprm-toggle" data-state="off" data-recipe="10740" style="background-color: var(--wp--preset--color--foreground);color: #ffffff;border-left: 1px solid var(--wp--preset--color--foreground);" aria-label="Hide instruction media"><span class="wprm-recipe-icon wprm-toggle-icon wprm-toggle-icon-active"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewbox="0 0 24 24"><g class="nc-icon-wrapper" stroke-linecap="square" stroke-linejoin="miter" stroke-width="1" transform="translate(0.5 0.5)" fill="#ffffff" stroke="#ffffff"><circle data-color="color-2" cx="12" cy="12" r="4" fill="none" stroke-miterlimit="10"></circle><path d="M22,8v9a2,2,0,0,1-2,2H10" fill="none" stroke="#ffffff" stroke-miterlimit="10"></path><path data-cap="butt" d="M2,17V8A2,2,0,0,1,4,6H7L9,3h6l2.4,3.6" fill="none" stroke="#ffffff" stroke-miterlimit="10" stroke-linecap="butt"></path><line data-cap="butt" data-color="color-2" x1="23" y1="1" x2="1" y2="23" fill="none" stroke-miterlimit="10" stroke-linecap="butt"></line></g></svg></span><span class="wprm-recipe-icon wprm-toggle-icon wprm-toggle-icon-inactive"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewbox="0 0 24 24"><g class="nc-icon-wrapper" stroke-linecap="square" stroke-linejoin="miter" stroke-width="1" transform="translate(0.5 0.5)" fill="var(--wp--preset--color--foreground)" stroke="var(--wp--preset--color--foreground)"><circle data-color="color-2" cx="12" cy="12" r="4" fill="none" stroke-miterlimit="10"></circle><path d="M22,8v9a2,2,0,0,1-2,2H10" fill="none" stroke="var(--wp--preset--color--foreground)" stroke-miterlimit="10"></path><path data-cap="butt" d="M2,17V8A2,2,0,0,1,4,6H7L9,3h6l2.4,3.6" fill="none" stroke="var(--wp--preset--color--foreground)" stroke-miterlimit="10" stroke-linecap="butt"></path><line data-cap="butt" data-color="color-2" x1="23" y1="1" x2="1" y2="23" fill="none" stroke-miterlimit="10" stroke-linecap="butt"></line></g></svg></span></button></div></h3><div class="wprm-recipe-instruction-group"><h4 class="wprm-recipe-group-name wprm-recipe-instruction-group-name wprm-block-text-none">Prepare the filling:</h4><ul class="wprm-recipe-instructions"><li id="wprm-recipe-10740-step-0-0" class="wprm-recipe-instruction" style="list-style-type: decimal;"><div class="wprm-recipe-instruction-text"><span style="display: block;">Heat a heavy bottom pan on medium flame. Add the grated coconut and roast it for 2-3 minutes. </span></div><div class="wprm-recipe-instruction-media wprm-recipe-instruction-image"><img decoding="async" data-pin-nopin="true" width="300" height="300" src="data:image/svg+xml,%3Csvg%20xmlns=&#039;http://www.w3.org/2000/svg&#039;%20width=&#039;300&#039;%20height=&#039;300&#039;%20viewBox=&#039;0%200%20300%20300&#039;%3E%3C/svg%3E" class="attachment-medium size-medium perfmatters-lazy" alt="grated coconut in a pan" data-pin-media="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-1.jpg" data-src="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-1-300x300.jpg" data-srcset="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-1-300x300.jpg 300w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-1-378x378.jpg 378w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-1-276x276.jpg 276w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-1-600x600.jpg 600w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-1-400x400.jpg 400w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-1-150x150.jpg 150w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-1-360x361.jpg 360w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-1-500x500.jpg 500w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-1.jpg 720w" data-sizes="auto, (max-width: 300px) 100vw, 300px" /></div> </li><li id="wprm-recipe-10740-step-0-1" class="wprm-recipe-instruction" style="list-style-type: decimal;"><div class="wprm-recipe-instruction-text"><span style="display: block;">Add jaggery, cardamom and poppy seeds. Cook until they blend together and ooze out a little liquid, about 2-3 minutes. Do not overcook. </span></div><div class="wprm-recipe-instruction-media wprm-recipe-instruction-image"><img decoding="async" data-pin-nopin="true" width="300" height="300" src="data:image/svg+xml,%3Csvg%20xmlns=&#039;http://www.w3.org/2000/svg&#039;%20width=&#039;300&#039;%20height=&#039;300&#039;%20viewBox=&#039;0%200%20300%20300&#039;%3E%3C/svg%3E" class="attachment-medium size-medium perfmatters-lazy" alt="grated coconut with poppy seeds and grated jaggery in a pan" data-pin-media="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-2.jpg" data-src="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-2-300x300.jpg" data-srcset="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-2-300x300.jpg 300w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-2-378x378.jpg 378w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-2-276x276.jpg 276w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-2-600x600.jpg 600w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-2-400x400.jpg 400w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-2-150x150.jpg 150w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-2-360x361.jpg 360w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-2-500x500.jpg 500w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-2.jpg 720w" data-sizes="auto, (max-width: 300px) 100vw, 300px" /></div> </li><li id="wprm-recipe-10740-step-0-2" class="wprm-recipe-instruction" style="list-style-type: decimal;"><div class="wprm-recipe-instruction-text"><span style="display: block;">Take the pan off the flame and let it cool. It is important that the mixture completely cools. </span></div><div class="wprm-recipe-instruction-media wprm-recipe-instruction-image"><img decoding="async" data-pin-nopin="true" width="225" height="300" src="data:image/svg+xml,%3Csvg%20xmlns=&#039;http://www.w3.org/2000/svg&#039;%20width=&#039;225&#039;%20height=&#039;300&#039;%20viewBox=&#039;0%200%20225%20300&#039;%3E%3C/svg%3E" class="attachment-medium size-medium perfmatters-lazy" alt="coconut and jaggery filling for modak" data-pin-media="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-3.jpg" data-src="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-3-225x300.jpg" data-srcset="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-3-225x300.jpg 225w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-3-400x533.jpg 400w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-3.jpg 720w" data-sizes="auto, (max-width: 225px) 100vw, 225px" /></div> </li></ul></div><div class="wprm-recipe-instruction-group"><h4 class="wprm-recipe-group-name wprm-recipe-instruction-group-name wprm-block-text-none">Prepare the covering: </h4><ul class="wprm-recipe-instructions"><li id="wprm-recipe-10740-step-1-0" class="wprm-recipe-instruction" style="list-style-type: decimal;"><div class="wprm-recipe-instruction-text"><span style="display: block;">In a pot, bring 1 cup of water to a rolling boil. Add 1 tsp ghee and salt (optional). </span></div><div class="wprm-recipe-instruction-media wprm-recipe-instruction-image"><img decoding="async" data-pin-nopin="true" width="300" height="300" src="data:image/svg+xml,%3Csvg%20xmlns=&#039;http://www.w3.org/2000/svg&#039;%20width=&#039;300&#039;%20height=&#039;300&#039;%20viewBox=&#039;0%200%20300%20300&#039;%3E%3C/svg%3E" class="attachment-medium size-medium perfmatters-lazy" alt="water boiling in a pan" data-pin-media="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-4.jpg" data-src="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-4-300x300.jpg" data-srcset="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-4-300x300.jpg 300w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-4-378x378.jpg 378w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-4-276x276.jpg 276w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-4-600x600.jpg 600w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-4-400x400.jpg 400w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-4-150x150.jpg 150w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-4-360x361.jpg 360w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-4-500x500.jpg 500w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-4.jpg 720w" data-sizes="auto, (max-width: 300px) 100vw, 300px" /></div> </li><li id="wprm-recipe-10740-step-1-1" class="wprm-recipe-instruction" style="list-style-type: decimal;"><div class="wprm-recipe-instruction-text"><span style="display: block;">Add the rice flour, mix it well with a spoon. This will make a lumpy dough. Turn off the flame. Cover the pot and leave it for 3-5 minutes. </span></div><div class="wprm-recipe-instruction-media wprm-recipe-instruction-image"><img decoding="async" data-pin-nopin="true" width="300" height="300" src="data:image/svg+xml,%3Csvg%20xmlns=&#039;http://www.w3.org/2000/svg&#039;%20width=&#039;300&#039;%20height=&#039;300&#039;%20viewBox=&#039;0%200%20300%20300&#039;%3E%3C/svg%3E" class="attachment-medium size-medium perfmatters-lazy" alt="rice flour added to boiling water" data-pin-media="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-5.jpg" data-src="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-5-300x300.jpg" data-srcset="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-5-300x300.jpg 300w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-5-378x378.jpg 378w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-5-276x276.jpg 276w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-5-600x600.jpg 600w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-5-400x400.jpg 400w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-5-150x150.jpg 150w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-5-360x361.jpg 360w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-5-500x500.jpg 500w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-5.jpg 720w" data-sizes="auto, (max-width: 300px) 100vw, 300px" /></div> </li><li id="wprm-recipe-10740-step-1-2" class="wprm-recipe-instruction" style="list-style-type: decimal;"><div class="wprm-recipe-instruction-text"><span style="display: block;">Remove this to a large bowl and let it cool a bit. You want this mixture to be still warm while you make a dough from it. </span></div></li><li id="wprm-recipe-10740-step-1-3" class="wprm-recipe-instruction" style="list-style-type: decimal;"><div class="wprm-recipe-instruction-text"><span style="display: block;">While the mixture is still warm, apply some ghee and warm water to your hands and knead it until it is soft, about 5-7 minutes. The dough should not look patchy or crumble. You will need to add about 2 tablespoons of warm water while kneading to make a smooth dough. Optionally, you can also add couple of teaspoons of warm milk while kneading the dough which will make it extra soft. </span></div><div class="wprm-recipe-instruction-media wprm-recipe-instruction-image"><img decoding="async" data-pin-nopin="true" width="300" height="300" src="data:image/svg+xml,%3Csvg%20xmlns=&#039;http://www.w3.org/2000/svg&#039;%20width=&#039;300&#039;%20height=&#039;300&#039;%20viewBox=&#039;0%200%20300%20300&#039;%3E%3C/svg%3E" class="attachment-medium size-medium perfmatters-lazy" alt="rice flour dough" data-pin-media="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-1-2.jpg" data-src="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-1-2-300x300.jpg" data-srcset="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-1-2-300x300.jpg 300w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-1-2-378x378.jpg 378w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-1-2-276x276.jpg 276w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-1-2-600x600.jpg 600w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-1-2-400x400.jpg 400w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-1-2-150x150.jpg 150w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-1-2-360x361.jpg 360w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-1-2-500x500.jpg 500w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-1-2.jpg 720w" data-sizes="auto, (max-width: 300px) 100vw, 300px" /></div> </li><li id="wprm-recipe-10740-step-1-4" class="wprm-recipe-instruction" style="list-style-type: decimal;"><div class="wprm-recipe-instruction-text"><span style="display: block;">Wrap the dough with a damp cloth. It is important to keep the dough damp and soft. Now make 12 lemon size balls. Note: The size of the balls will also depend on the size of the modak mold you have. Also keep the balls covered with the damp cloth.   </span></div><div class="wprm-recipe-instruction-media wprm-recipe-instruction-image"><img decoding="async" data-pin-nopin="true" width="300" height="300" src="data:image/svg+xml,%3Csvg%20xmlns=&#039;http://www.w3.org/2000/svg&#039;%20width=&#039;300&#039;%20height=&#039;300&#039;%20viewBox=&#039;0%200%20300%20300&#039;%3E%3C/svg%3E" class="attachment-medium size-medium perfmatters-lazy" alt="Rice flour balls along with applying ghee to Modak Mold" data-pin-media="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-8.jpg" data-src="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-8-300x300.jpg" data-srcset="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-8-300x300.jpg 300w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-8-378x378.jpg 378w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-8-276x276.jpg 276w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-8-600x600.jpg 600w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-8-400x400.jpg 400w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-8-150x150.jpg 150w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-8-360x361.jpg 360w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-8-500x500.jpg 500w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-8.jpg 720w" data-sizes="auto, (max-width: 300px) 100vw, 300px" /></div> </li></ul></div><div class="wprm-recipe-instruction-group"><h4 class="wprm-recipe-group-name wprm-recipe-instruction-group-name wprm-block-text-none">Assembling Modak: </h4><ul class="wprm-recipe-instructions"><li id="wprm-recipe-10740-step-2-0" class="wprm-recipe-instruction" style="list-style-type: decimal;"><div class="wprm-recipe-instruction-text"><span style="display: block;">Apply some ghee or oil to the base of a steamer basket. </span></div></li><li id="wprm-recipe-10740-step-2-1" class="wprm-recipe-instruction" style="list-style-type: decimal;"><div class="wprm-recipe-instruction-text"><span style="display: block;">Open the mold and apply ghee with your fingers to the inside of the mold. Close the mold, and place one lemon size dough ball inside the mold. </span></div><div class="wprm-recipe-instruction-media wprm-recipe-instruction-image"><img decoding="async" data-pin-nopin="true" width="300" height="300" src="data:image/svg+xml,%3Csvg%20xmlns=&#039;http://www.w3.org/2000/svg&#039;%20width=&#039;300&#039;%20height=&#039;300&#039;%20viewBox=&#039;0%200%20300%20300&#039;%3E%3C/svg%3E" class="attachment-medium size-medium perfmatters-lazy" alt="rice flour dough inside Modak Mold" data-pin-media="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-9.jpg" data-src="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-9-300x300.jpg" data-srcset="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-9-300x300.jpg 300w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-9-378x378.jpg 378w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-9-276x276.jpg 276w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-9-600x600.jpg 600w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-9-400x400.jpg 400w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-9-150x150.jpg 150w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-9-360x361.jpg 360w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-9-500x500.jpg 500w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-9.jpg 720w" data-sizes="auto, (max-width: 300px) 100vw, 300px" /></div> </li><li id="wprm-recipe-10740-step-2-2" class="wprm-recipe-instruction" style="list-style-type: decimal;"><div class="wprm-recipe-instruction-text"><span style="display: block;">Now with your finger start spreading the dough to the sides of the mold so it gets the shape. Allow some dough to come out of the mold which will be used to seal after adding the stuffing. </span></div><div class="wprm-recipe-instruction-media wprm-recipe-instruction-image"><img decoding="async" data-pin-nopin="true" width="300" height="300" src="data:image/svg+xml,%3Csvg%20xmlns=&#039;http://www.w3.org/2000/svg&#039;%20width=&#039;300&#039;%20height=&#039;300&#039;%20viewBox=&#039;0%200%20300%20300&#039;%3E%3C/svg%3E" class="attachment-medium size-medium perfmatters-lazy" alt="shaping modak using a mold" data-pin-media="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-10.jpg" data-src="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-10-300x300.jpg" data-srcset="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-10-300x300.jpg 300w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-10-378x378.jpg 378w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-10-276x276.jpg 276w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-10-600x600.jpg 600w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-10-400x400.jpg 400w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-10-150x150.jpg 150w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-10-360x361.jpg 360w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-10-500x500.jpg 500w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-10.jpg 720w" data-sizes="auto, (max-width: 300px) 100vw, 300px" /></div> </li><li id="wprm-recipe-10740-step-2-3" class="wprm-recipe-instruction" style="list-style-type: decimal;"><div class="wprm-recipe-instruction-text"><span style="display: block;">Scoop in a spoonful of the filling and gently seal the bottom with the dough that came out of the mold. </span></div><div class="wprm-recipe-instruction-media wprm-recipe-instruction-image"><img decoding="async" data-pin-nopin="true" width="300" height="300" src="data:image/svg+xml,%3Csvg%20xmlns=&#039;http://www.w3.org/2000/svg&#039;%20width=&#039;300&#039;%20height=&#039;300&#039;%20viewBox=&#039;0%200%20300%20300&#039;%3E%3C/svg%3E" class="attachment-medium size-medium perfmatters-lazy" alt="filling added to modak" data-pin-media="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-11.jpg" data-src="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-11-300x300.jpg" data-srcset="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-11-300x300.jpg 300w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-11-378x378.jpg 378w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-11-276x276.jpg 276w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-11-600x600.jpg 600w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-11-400x400.jpg 400w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-11-150x150.jpg 150w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-11-360x361.jpg 360w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-11-500x500.jpg 500w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-11.jpg 720w" data-sizes="auto, (max-width: 300px) 100vw, 300px" /></div> </li><li id="wprm-recipe-10740-step-2-4" class="wprm-recipe-instruction" style="list-style-type: decimal;"><div class="wprm-recipe-instruction-text"><span style="display: block;">Open the mold and remove the modak gently. Place it in a steamer basket. Make remaining modak's in the same way. Between making modak's, apply ghee again to the mold. </span></div><div class="wprm-recipe-instruction-media wprm-recipe-instruction-image"><img decoding="async" data-pin-nopin="true" width="300" height="300" src="data:image/svg+xml,%3Csvg%20xmlns=&#039;http://www.w3.org/2000/svg&#039;%20width=&#039;300&#039;%20height=&#039;300&#039;%20viewBox=&#039;0%200%20300%20300&#039;%3E%3C/svg%3E" class="attachment-medium size-medium perfmatters-lazy" alt="modak shaped using a mold" data-pin-media="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-13.jpg" data-src="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-13-300x300.jpg" data-srcset="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-13-300x300.jpg 300w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-13-378x378.jpg 378w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-13-276x276.jpg 276w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-13-600x600.jpg 600w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-13-400x400.jpg 400w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-13-150x150.jpg 150w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-13-360x361.jpg 360w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-13-500x500.jpg 500w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-13.jpg 720w" data-sizes="auto, (max-width: 300px) 100vw, 300px" /></div> </li><li id="wprm-recipe-10740-step-2-5" class="wprm-recipe-instruction" style="list-style-type: decimal;"><div class="wprm-recipe-instruction-text"><span style="display: block;">Optionally, place a strand of saffron on top of each modak and press it into the rice flour covering. </span></div><div class="wprm-recipe-instruction-media wprm-recipe-instruction-image"><img decoding="async" data-pin-nopin="true" width="300" height="300" src="data:image/svg+xml,%3Csvg%20xmlns=&#039;http://www.w3.org/2000/svg&#039;%20width=&#039;300&#039;%20height=&#039;300&#039;%20viewBox=&#039;0%200%20300%20300&#039;%3E%3C/svg%3E" class="attachment-medium size-medium perfmatters-lazy" alt="closeup shot of Ukadiche Modak on hand" data-pin-media="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-14.jpg" data-src="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-14-300x300.jpg" data-srcset="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-14-300x300.jpg 300w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-14-378x378.jpg 378w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-14-276x276.jpg 276w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-14-600x600.jpg 600w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-14-400x400.jpg 400w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-14-150x150.jpg 150w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-14-360x361.jpg 360w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-14-500x500.jpg 500w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-Steps-Piping-Pot-Curry-14.jpg 720w" data-sizes="auto, (max-width: 300px) 100vw, 300px" /></div> </li><li id="wprm-recipe-10740-step-2-6" class="wprm-recipe-instruction" style="list-style-type: decimal;"><div class="wprm-recipe-instruction-text"><span style="display: block;">Depending on the size of your steamer basket, you might want to steam modak in multiple batches. You want to make sure the modak are not placed too close to each other.   </span></div></li></ul></div><div class="wprm-recipe-instruction-group"><h4 class="wprm-recipe-group-name wprm-recipe-instruction-group-name wprm-block-text-none">Steaming Modak in the stovetop steamer:</h4><ul class="wprm-recipe-instructions"><li id="wprm-recipe-10740-step-3-0" class="wprm-recipe-instruction" style="list-style-type: decimal;"><div class="wprm-recipe-instruction-text"><span style="display: block;">In a pot where the steamer basket fits, bring water to a rolling boil. Set the boiling water on medium heat. Place the steamer basket and steam the modak covered for 8-10 minutes. You should see a shine appear on the modak. </span></div><div class="wprm-recipe-instruction-media wprm-recipe-instruction-image"><img decoding="async" data-pin-nopin="true" width="225" height="300" src="data:image/svg+xml,%3Csvg%20xmlns=&#039;http://www.w3.org/2000/svg&#039;%20width=&#039;225&#039;%20height=&#039;300&#039;%20viewBox=&#039;0%200%20225%20300&#039;%3E%3C/svg%3E" class="attachment-medium size-medium perfmatters-lazy" alt="Rice dumplings, called Ukadiche modak steamed in instant pot" data-pin-media="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-ready-to-be-steamed-Piping-Pot-Curry.jpg" data-src="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-ready-to-be-steamed-Piping-Pot-Curry-225x300.jpg" data-srcset="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-ready-to-be-steamed-Piping-Pot-Curry-225x300.jpg 225w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-ready-to-be-steamed-Piping-Pot-Curry-400x533.jpg 400w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-ready-to-be-steamed-Piping-Pot-Curry.jpg 720w" data-sizes="auto, (max-width: 225px) 100vw, 225px" /></div> </li><li id="wprm-recipe-10740-step-3-1" class="wprm-recipe-instruction" style="list-style-type: decimal;"><div class="wprm-recipe-instruction-text"><span style="display: block;">Take the steamer basket out and let it cool for about 5 minutes. This will help make sure the base does not break when you pick up the modak. </span></div></li></ul></div><div class="wprm-recipe-instruction-group"><h4 class="wprm-recipe-group-name wprm-recipe-instruction-group-name wprm-block-text-none">Steaming Modak in the Instant Pot:</h4><ul class="wprm-recipe-instructions"><li id="wprm-recipe-10740-step-4-0" class="wprm-recipe-instruction" style="list-style-type: decimal;"><div class="wprm-recipe-instruction-text"><span style="display: block;">Add 1 cup of water to the Instant Pot insert and place the trivet. Let the water boil on saute mode while you are preparing the modak. </span></div></li><li id="wprm-recipe-10740-step-4-1" class="wprm-recipe-instruction" style="list-style-type: decimal;"><div class="wprm-recipe-instruction-text"><span style="display: block;">Place the steamer basket with modak on the trivet. Close lid with valve in venting position. Set on steam mode and steam for 10 minutes. You will need an external timer to keeo the time. </span></div><div class="wprm-recipe-instruction-media wprm-recipe-instruction-image"><img decoding="async" data-pin-nopin="true" width="225" height="300" src="data:image/svg+xml,%3Csvg%20xmlns=&#039;http://www.w3.org/2000/svg&#039;%20width=&#039;225&#039;%20height=&#039;300&#039;%20viewBox=&#039;0%200%20225%20300&#039;%3E%3C/svg%3E" class="attachment-medium size-medium perfmatters-lazy" alt="Sweet Rice dumplings (modak) ready to be steamed in instant pot" data-pin-media="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-steaming-in-instant-pot-Piping-Pot-Curry.jpg" data-src="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-steaming-in-instant-pot-Piping-Pot-Curry-225x300.jpg" data-srcset="https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-steaming-in-instant-pot-Piping-Pot-Curry-225x300.jpg 225w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-steaming-in-instant-pot-Piping-Pot-Curry-400x533.jpg 400w, https://pipingpotcurry.com/wp-content/uploads/2019/09/Ukadiche-Modak-steaming-in-instant-pot-Piping-Pot-Curry.jpg 720w" data-sizes="auto, (max-width: 225px) 100vw, 225px" /></div> </li><li id="wprm-recipe-10740-step-4-2" class="wprm-recipe-instruction" style="list-style-type: decimal;"><div class="wprm-recipe-instruction-text"><span style="display: block;">After 10 minutes, remove the lid after the pin has dropped. Carefully remove the steamer basket and let the modak cool for about 5 minutes. This will help make sure the base does not break when you pick up the modak. </span></div></li><li id="wprm-recipe-10740-step-4-3" class="wprm-recipe-instruction" style="list-style-type: decimal;"><div class="wprm-recipe-instruction-text"><span style="display: block;">Ukadiche Modak is ready to be enjoyed! </span></div></li></ul></div></div>
	
	<div id="recipe-10740-notes" class="wprm-recipe-notes-container wprm-block-text-normal"><h3 class="wprm-recipe-header wprm-recipe-notes-header wprm-block-text-none wprm-align-left wprm-header-decoration-none" style="">Notes</h3><div class="wprm-recipe-notes"><span style="display: block;"><strong>Preparing the day before:</strong> This stuffing can be made a couple of days in advance and refrigerated until ready to be used.</span><div class="wprm-spacer"></div>
<span style="display: block;"><strong>Frozen coconut:</strong> If fresh coconut is not available, you can use frozen coconut. I used frozen, and the mixture looks like long strands of coconut, but it works well. The ideal is fresh coconut; however, this works if fresh is not available.&nbsp;</span><div class="wprm-spacer"></div>
<span style="display: block;"><strong>Rice flour:</strong> It is important the flour is very fine. You can buy Modak rice flour or stone ground rice flour. Another option is to sieve store-bought rice flour through a fine sieve before using.</span><div class="wprm-spacer"></div>
<span style="display: block;"><strong>Modak Mold:</strong> I got the aluminum modak mold from the Indian grocery store. They are available on <a href="https://amzn.to/2Ya2QYb" data-eafl-id="14657" data-eafl-parsed="1" class="eafl-link eafl-link-text eafl-link-direct" target="_blank" rel="nofollow">Amazon</a>. If you don&rsquo;t have the mold, then you can still make the modak.</span><div class="wprm-spacer"></div>
<span style="display: block;"><strong>Preparing Modak without a mold:</strong> Using your hand, flatten the lemon-sized dough ball by applying pressure at the center but keeping one finger at the edges to seal any broken sides. Scoop in the mixture and slowly, with the base of your hands, wrap it up. Using a toothpick, make an impression all around the modak for an easy pattern.&nbsp;&nbsp;</span></div></div>
	<div class="cwp-food-nutrition">
		<div id="recipe-10740-nutrition" class="wprm-nutrition-label-shortcode-container"><h3 class="wprm-recipe-header wprm-recipe-nutrition-header wprm-block-text-uppercase wprm-align-left wprm-header-decoration-none" style="">Nutrition</h3><div class="wprm-nutrition-label-container wprm-nutrition-label-container-grouped wprm-block-text-normal wprm-nutrition-label-container-grouped-text" style="text-align: left;column-gap: 10px;"><span class="wprm-nutrition-label-text-nutrition-container wprm-nutrition-label-text-nutrition-container-calories" style="flex-basis: 150px;"><span class="wprm-nutrition-label-text-nutrition-label  wprm-block-text-faded" style="color: #333333">Calories: </span><span class="wprm-nutrition-label-text-nutrition-value" style="color: #333333">160</span><span class="wprm-nutrition-label-text-nutrition-unit" style="color: #333333">kcal</span></span><span class="wprm-nutrition-label-text-nutrition-container wprm-nutrition-label-text-nutrition-container-carbohydrates" style="flex-basis: 150px;"><span class="wprm-nutrition-label-text-nutrition-label  wprm-block-text-faded" style="color: #333333">Carbohydrates: </span><span class="wprm-nutrition-label-text-nutrition-value" style="color: #333333">25</span><span class="wprm-nutrition-label-text-nutrition-unit" style="color: #333333">g</span></span><span class="wprm-nutrition-label-text-nutrition-container wprm-nutrition-label-text-nutrition-container-protein" style="flex-basis: 150px;"><span class="wprm-nutrition-label-text-nutrition-label  wprm-block-text-faded" style="color: #333333">Protein: </span><span class="wprm-nutrition-label-text-nutrition-value" style="color: #333333">1</span><span class="wprm-nutrition-label-text-nutrition-unit" style="color: #333333">g</span></span><span class="wprm-nutrition-label-text-nutrition-container wprm-nutrition-label-text-nutrition-container-fat" style="flex-basis: 150px;"><span class="wprm-nutrition-label-text-nutrition-label  wprm-block-text-faded" style="color: #33
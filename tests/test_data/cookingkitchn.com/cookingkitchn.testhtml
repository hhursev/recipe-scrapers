  <title>Crispy Cabbage Pie with Dill Cream Sauce | Savory Comfort Dish - Cooking Kitchn</title>
  <meta name="description" content="Golden cabbage pie paired with dill-infused cream sauce for a flavorful and comforting bite."/>
  <script type="application/ld+json">[{"@context":"http://schema.org","@type":"Recipe","publisher":{"@type":"Organization","url":"https://cookingkitchn.com/","name":"Cooking Kitchn","logo":{"@type":"ImageObject","url":"https://cookingkitchn.com/assets/drawable/banner.png","width":600,"height":60}},"author":{"@type":"Person","name":"Sophia","jobTitle":"Food Writer & Recipe Developer","url":"https://cookingkitchn.com/authors/sophia","image":["https://cookingkitchn.com/assets/images/1744135605785-rev2ti8a.webp","https://cookingkitchn.com/cdn-cgi/image/fit=cover,width=1280,height=720,format=auto/assets/images/1744135605785-rev2ti8a.webp","https://cookingkitchn.com/cdn-cgi/image/fit=cover,width=1280,height=1280,format=auto/assets/images/1744135605785-rev2ti8a.webp","https://cookingkitchn.com/cdn-cgi/image/fit=cover,width=1280,height=960,format=auto/assets/images/1744135605785-rev2ti8a.webp"]},"url":"https://cookingkitchn.com/recipes/crispy-cabbage-dill-cream","name":"Crispy Cabbage Dill Cream","datePublished":"2025-07-07T10:48:41.518Z","description":"Golden cabbage pie meets zesty dill cream for a fresh, savory dish perfect for sharing.","recipeCategory":"Nourishing Salads","recipeCuisine":"Central European","keywords":"cabbage pie, dill sauce, savory pie, crispy cabbage, vegetarian, comfort food, easy skillet meal","prepTime":"PT15M","cookTime":"PT30M","totalTime":"PT45M","nutrition":{"@type":"NutritionInformation","calories":"260 calories"},"recipeYield":[4,"1 large pie (approximately 4 slices)"],"image":["https://cookingkitchn.com/assets/images/1751879523571-feiqjwzu.webp","https://cookingkitchn.com/cdn-cgi/image/fit=cover,width=1280,height=720,format=auto/assets/images/1751879523571-feiqjwzu.webp","https://cookingkitchn.com/cdn-cgi/image/fit=cover,width=1280,height=1280,format=auto/assets/images/1751879523571-feiqjwzu.webp","https://cookingkitchn.com/cdn-cgi/image/fit=cover,width=1280,height=960,format=auto/assets/images/1751879523571-feiqjwzu.webp"],"aggregateRating":{"@type":"AggregateRating","ratingValue":4.5,"ratingCount":41,"bestRating":5,"worstRating":3},"recipeIngredient":["0.5 medium cabbage, finely shredded (approximately 450 grams)","3 green onions, chopped (including greens and whites)","3 large eggs","1 tablespoon Dijon mustard","1 teaspoon salt","0.5 teaspoon ground black pepper","70 grams flour (standard or gluten-free blend)","1 teaspoon baking powder","3 to 4 tablespoons olive oil, for frying","0.5 cup grated cheese, such as Cheddar or Mozzarella (optional)","80 millilitres light sour cream","2 tablespoons mayonnaise","2 tablespoons fresh dill, finely chopped","Pinch of salt","Pinch of ground black pepper"],"recipeInstructions":[{"@type":"HowToStep","name":"Prepare Vegetable Base","text":"Finely shred the cabbage and chop the green onions, then place both into a large mixing bowl. For ease of serving, cut any extra-long cabbage strips in half.","url":"https://cookingkitchn.com/recipes/crispy-cabbage-dill-cream#instruction-1"},{"@type":"HowToStep","name":"Combine Eggs and Seasoning","text":"In a separate bowl, whisk eggs with Dijon mustard, salt, and pepper. Pour the egg mixture over the shredded cabbage and onions, tossing to thoroughly coat.","url":"https://cookingkitchn.com/recipes/crispy-cabbage-dill-cream#instruction-2"},{"@type":"HowToStep","name":"Incorporate Dry Ingredients","text":"Sprinkle flour and baking powder over the cabbage mixture. Gently fold until all elements are combined and coated evenly.","url":"https://cookingkitchn.com/recipes/crispy-cabbage-dill-cream#instruction-3"},{"@type":"HowToStep","name":"Cook on Stovetop","text":"Heat 2 tablespoons olive oil in a large nonstick skillet (23–25 centimetres) over medium heat. Add the prepared mixture, spread into an even layer, and press down with a spatula. Lower heat to medium-low, cover with a lid or foil, and cook for approximately 15 minutes until the base is golden and crisp.","url":"https://cookingkitchn.com/recipes/crispy-cabbage-dill-cream#instruction-4"},{"@type":"HowToStep","name":"Invert and Brown Opposite Side","text":"Using a spatula, loosen the pie from the pan edges. Invert onto a large plate or cutting board. Add another tablespoon of olive oil to the pan, then carefully slide the pie back into the skillet, uncooked side down. Cook uncovered for 10–15 minutes more, until the second side is golden. If using cheese, sprinkle over the top after flipping and allow to melt.","url":"https://cookingkitchn.com/recipes/crispy-cabbage-dill-cream#instruction-5"},{"@type":"HowToStep","name":"Prepare Dill Cream Sauce","text":"In a small bowl, combine light sour cream, mayonnaise, chopped dill, and a pinch each of salt and pepper. Stir until smooth and blended.","url":"https://cookingkitchn.com/recipes/crispy-cabbage-dill-cream#instruction-6"},{"@type":"HowToStep","name":"Slice and Serve","text":"Allow the cabbage pie to cool for several minutes before slicing. Serve with dill cream sauce on the side or drizzled over individual portions. Garnish with additional dill or green onions as desired.","url":"https://cookingkitchn.com/recipes/crispy-cabbage-dill-cream#instruction-7"}]},{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://cookingkitchn.com/"},{"@type":"ListItem","position":2,"name":"Recipes","item":"https://cookingkitchn.com/recipes"},{"@type":"ListItem","position":3,"name":"Crispy Cabbage Dill Cream"}]}]</script>

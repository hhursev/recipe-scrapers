                  width="1024" height="1024"
                  src="/assets/images/1751879523571-feiqjwzu.webp" 
                  srcset="/cdn-cgi/image/fit=contain,width=1024,format=auto/assets/images/1751879523571-feiqjwzu.webp 1024w,
                            /cdn-cgi/image/fit=contain,width=768,format=auto/assets/images/1751879523571-feiqjwzu.webp 768w,

                    <li>
                      <strong>Calories:</strong>
                      <span>260</span>
                    </li>
                    <li>
                      <strong>Total Fat:</strong>
                      <span>15 g</span>
                    </li>
                    <li>
                      <strong>Total Carbohydrate:</strong>
                      <span>21 g</span>
                    </li>
                    <li>
                      <strong>Protein:</strong>
                      <span>9 g</span>
                    </li>
                  </ul>
                </details>
                <!-- end RecipeNutrition -->
                
              </div>

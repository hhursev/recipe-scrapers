<!-- ============================================================
  Geo Detection — Currency & Country
  Single call to Cloudflare worker, shared by Currency and Shopify
============================================================ -->
<script>
  const GEO_CURRENCY_KEY = "currency";
  const GEO_COUNTRY_KEY = "shopify_country";
  const GEO_LANGUAGE_KEY = "shopify_language";

  // Returns cached geo data or fetches fresh from the worker.
  // Resolves to { currency, country, language } in all cases.

  async function fetchGeoData() {
    const currency = localStorage.getItem(GEO_CURRENCY_KEY);
    const country = sessionStorage.getItem(GEO_COUNTRY_KEY);
    const language = sessionStorage.getItem(GEO_LANGUAGE_KEY);

    if (currency && country && language) {
      return { currency, country, language };
    }

    try {
      const res = await fetch("https://where.bongeats.workers.dev/");
      const data = await res.json();
      const resolvedCurrency = data.currency || "USD";
      const resolvedCountry = data.country || "US";
      const resolvedLanguage = "en";

      localStorage.setItem(GEO_CURRENCY_KEY, resolvedCurrency);
      sessionStorage.setItem(GEO_COUNTRY_KEY, resolvedCountry);
      sessionStorage.setItem(GEO_LANGUAGE_KEY, resolvedLanguage);

      return {
        currency: resolvedCurrency,
        country: resolvedCountry,
        language: resolvedLanguage,
      };

    } catch (err) {
      console.error("Geo fetch error:", err);
      return { currency: "USD", country: "US", language: "en" };
    }
  }



  function showPaymentSections(currency) {
    if (currency !== "usd") {
      $(".payment-block.usd").css("display", "none");
      $(`.payment-block.${currency}`).css("display", "block");
    }

    if (currency !== "inr") {
      $("#donate-btn-inr").css("display", "none");
      $("#donate-btn-global").css("display", "block");
    }
  }



  function showPlans(currency) {
    switch (currency) {
      case "eur": $(".plan-card.eur").css("display", "grid"); break;
      case "cad": $(".plan-card.cad").css("display", "grid"); break;
      case "aud": $(".plan-card.aud").css("display", "grid"); break;
      case "gbp": $(".plan-card.gbp").css("display", "grid"); break;
      case "inr": $(".plan-card.inr").css("display", "grid"); break;
      default: $(".plan-card.usd").css("display", "grid"); break;
    }
  }

  // Kick off geo fetch immediately — result is consumed by both
  // currency display and Shopify store init below.

  const geoDataPromise = fetchGeoData().then((geo) => {
    const currency = geo.currency.toLowerCase();
    showPaymentSections(currency);
    showPlans(currency);
    return geo;
  });
</script>



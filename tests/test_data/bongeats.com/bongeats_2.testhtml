.dropcap p:first-of-type:first-letter,
p.dropcap:first-letter {
    float: left;
    color: #258354;
    font-size: 6em;
    line-height: .85;
    font-family: serif;
    font-weight: 700;
    font-style: normal;
    margin-bottom: 0;
    padding-right: 10px;
}
p.invert.dropcap:first-letter {

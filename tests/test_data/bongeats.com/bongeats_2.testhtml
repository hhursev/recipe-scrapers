<!-- ============================================================
  Firebase — Auth & User State
============================================================ -->
<script type="module">
  import { initializeApp } from "https://www.gstatic.com/firebasejs/12.1.0/firebase-app.js";
  import {
    getAuth,
    isSignInWithEmailLink,
    signInWithEmailLink,
    onAuthStateChanged,
  } from "https://www.gstatic.com/firebasejs/12.1.0/firebase-auth.js";
  import {
    getFirestore,
    collection,
    query,
    where,
    getDocs,
  } from "https://www.gstatic.com/firebasejs/12.1.0/firebase-firestore.js";

  const firebaseConfig = {
    apiKey: "AIzaSyB48tV8Ts8DyLrFhDDwmPadJ2BYYmvrjE8",
    authDomain: "bong-eats-6e4a8.firebaseapp.com",
    projectId: "bong-eats-6e4a8",
    storageBucket: "bong-eats-6e4a8.firebasestorage.app",
    messagingSenderId: "518080170346",
    appId: "1:518080170346:web:71812c55babc1bc3f47d13",
  };

  const app = initializeApp(firebaseConfig);
  const auth = getAuth(app);
  const db = getFirestore(app);

  if (isSignInWithEmailLink(auth, window.location.href)) {
    let email = window.localStorage.getItem("emailForSignIn");
    if (!email) {
      email = window.prompt("Please provide your email for confirmation");
    }
    signInWithEmailLink(auth, email, window.location.href)
      .then((result) => {
        window.localStorage.removeItem("emailForSignIn");
      })
      .catch((error) => {
        console.error("Error during sign-in with email link:", error);
      });
  }

  onAuthStateChanged(auth, (user) => {
    if (user) {
      window.localStorage.setItem("userId", user.uid);
      (async () => {
        try {
          const usersRef = collection(db, "users");
          const q = query(usersRef, where("email", "==", user.email));
          const querySnapshot = await getDocs(q);

          if (!querySnapshot.empty) {
            const docData = querySnapshot.docs[0].data();
            const firstName = docData.firstName || docData.first_name || "";

            document.querySelectorAll(".js-hfp").forEach((el) => (el.style.display = "none"));
            document.getElementById("announcement-banner-txt").textContent = `Enjoy the ad-free version, ${firstName}`;
            document.getElementById("announcement-bar").classList.add("signed-in-user");
            document.getElementById("js-pm0").textContent = `${firstName}`;
            document.querySelectorAll(".js-sfp").forEach((el) => (el.style.display = "block"));
            document.getElementById("js-pm1").textContent = `Thank you for being a Patron and supporting the work we do, ${firstName}`;
          }
        } catch (err) {
          console.error("Error querying user document:", err);
        }
      })();
      console.log("user is signed in - ads removed by default");
    } else {
      console.log("user is signed out - checking geo for ads");
      
      // Wait for geoDataPromise to ensure we have the currency before loading Ads
      geoDataPromise.then((geo) => {
        const currency = geo.currency.toLowerCase();
        const blockedCurrencies = ['eur', 'gbp'];

        if (blockedCurrencies.includes(currency)) {
          console.log("AdSense blocked for visitor using currency:", currency);
        } else {
          console.log("AdSense allowed for currency:", currency);
          var s = document.createElement("script");
          s.async = true;
          s.crossOrigin = "anonymous";
          s.src = "https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-6352920390274476";
          document.body.appendChild(s);
        }
      });
    }
  });
</script><script>
/**
 * 1. DATA SETUP & JSON-LD
 * Assigns unique IDs to ingredients/steps and populates Schema.org data
 */
const recipeId = 'chocolate-cake';
const $ingredients = $('.recipe-ingredients li');
const $steps = $('.recipe-process li');

// Populate JSON-LD
const jsonLd = JSON.parse($('#recipe-jsonld').html());
$ingredients.each(function(i) {
    const id = `i-${String(i + 1).padStart(2, '0')}-${recipeId}`;
    $(this).attr('data-ingredient-id', id);
    jsonLd.recipeIngredient.push(this.innerText);
});
$steps.each(function(i) {
    const id = `s-${String(i + 1).padStart(2, '0')}-${recipeId}`;
    $(this).attr('data-step-id', id);
    jsonLd.recipeInstructions.push({ "@type": "HowToStep", text: this.innerText });
});
$('#recipe-jsonld').html(JSON.stringify(jsonLd));

/**
 * 2. INTERACTIVITY
 * Handles strikethroughs, persistence, and floating navigation
 */
function handleStrikethrough($el, storageKeyAttr) {
    const id = $el.data(storageKeyAttr);
    const isActive = $el.toggleClass('strikethrough').hasClass('strikethrough');
    isActive ? sessionStorage.setItem(id, 'true') : sessionStorage.removeItem(id);
}

// Restore & Click Events
$ingredients.each(function() {
    if (sessionStorage.getItem($(this).data('ingredient-id')) === 'true') $(this).addClass('strikethrough');
}).on('click', function() { handleStrikethrough($(this), 'ingredient-id'); });

$steps.each(function() {
    if (sessionStorage.getItem($(this).data('step-id')) === 'true') $(this).addClass('strikethrough');
}).on('click', function() { handleStrikethrough($(this), 'step-id'); });

// Floating Nav Observer
const fixedNav = document.querySelector('#recipe-nav-fixed');
if (fixedNav) {
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            const isBelow = !entry.isIntersecting && window.scrollY > (entry.boundingClientRect.top + window.scrollY);
            document.querySelector('#recipe-nav-floating').classList.toggle('visible', isBelow);
        });
    }, { threshold: 1 });
    observer.observe(fixedNav);
}

/**
 * 3. GEO-DEPENDENT PROMOS
 * Updates promos based on visitor country (India vs Global)
 */
geoDataPromise.then((geo) => {
    const isIndia = geo.country === "IN";
    const subSelector = isIndia ? ".moshla-promo-in" : ".moshla-promo-eu";

    function getPromo(selector) {
        const $html = $(selector).find(subSelector).html();
        return $html || "";
    }

    // Ingredient-level appends
    $ingredients.filter(":contains('bhaja masala'), :contains('bhaja moshla')").append(getPromo('#bhaja_moshla_promo'));
    $ingredients.filter(":contains('vindaloo masala')").append(getPromo('#vindaloo_moshla_promo'));
    $ingredients.filter(":contains('biryani masala'), :contains('biryani moshla 1')").append(getPromo('#biryani_moshla_promo'));

    // Heading-level inserts
    $(".recipe-ingredients-wrapper h3:contains('Vegetable Chop Spice mix')").after(getPromo('#vegchop_moshla_promo'));
    $(".recipe-ingredients-wrapper h3:contains('Alur Torkari Spice Mix')").after(getPromo('#kochuri_torkari_moshla_promo'));
    $(".recipe-ingredients-wrapper h3:contains('Biryani moshla 1'), h3:contains('biryani masala')").before(getPromo('#biryani_moshla_promo'));
    $(".recipe-ingredients-wrapper h3:contains('Tandoori moshla')").before(getPromo('#tandoori_moshla_promo'));

    // Garam Masala Logic
    $ingredients.each(function() {
        const text = $(this).text().toLowerCase();
        if (text.includes('garam masala') || text.includes('gorom moshla')) {
            const promoId = text.includes('shahi') ? '#shahi_gorom_moshla_promo' : '#gorom_moshla_promo';
            $(this).append(getPromo(promoId));
        }
    });
});
</script></body></html>
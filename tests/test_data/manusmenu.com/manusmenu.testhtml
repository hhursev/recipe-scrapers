	<script type="application/ld+json" class="yoast-schema-graph">{"@context":"https://schema.org","@graph":[{"@type":"Article","@id":"https://www.manusmenu.com/honey-hard-candy#article","isPartOf":{"@id":"https://www.manusmenu.com/honey-hard-candy"},"author":{"name":"Manu","@id":"https://www.manusmenu.com/#/schema/person/42904d9efab20bbd0a70d45a09729c14"},"headline":"Honey Hard Candy","datePublished":"2016-03-07T08:18:09+00:00","dateModified":"2026-01-16T05:52:18+00:00","wordCount":1104,"commentCount":34,"image":{"@id":"https://www.manusmenu.com/honey-hard-candy#primaryimage"},"thumbnailUrl":"https://www.manusmenu.com/wp-content/uploads/2016/03/honey-hard-candy-wrapped-candies.webp","keywords":["candy","DIY","honey","Italian","sugar","sweets"],"articleSection":["Candy","DIY","Italian"],"inLanguage":"en-US","potentialAction":[{"@type":"CommentAction","name":"Comment","target":["https://www.manusmenu.com/honey-hard-candy#respond"]}]},{"@type":["WebPage","FAQPage"],"@id":"https://www.manusmenu.com/honey-hard-candy","url":"https://www.manusmenu.com/honey-hard-candy","name":"Honey Hard Candy","isPartOf":{"@id":"https://www.manusmenu.com/#website"},"primaryImageOfPage":{"@id":"https://www.manusmenu.com/honey-hard-candy#primaryimage"},"image":{"@id":"https://www.manusmenu.com/honey-hard-candy#primaryimage"},"thumbnailUrl":"https://www.manusmenu.com/wp-content/uploads/2016/03/honey-hard-candy-wrapped-candies.webp","datePublished":"2016-03-07T08:18:09+00:00","dateModified":"2026-01-16T05:52:18+00:00","author":{"@id":"https://www.manusmenu.com/#/schema/person/42904d9efab20bbd0a70d45a09729c14"},"description":"Try this Honey Hard Candy recipe made with real honey and lemon. Crisp, golden, and dairy-free, a sweet homemade gift or soothing treat.","breadcrumb":{"@id":"https://www.manusmenu.com/honey-hard-candy#breadcrumb"},"mainEntity":[{"@id":"https://www.manusmenu.com/honey-hard-candy#faq-question-1759762711780"},{"@id":"https://www.manusmenu.com/honey-hard-candy#faq-question-1759762712864"},{"@id":"https://www.manusmenu.com/honey-hard-candy#faq-question-1759762758835"},{"@id":"https://www.manusmenu.com/honey-hard-candy#faq-question-1759762776224"}],"inLanguage":"en-US","potentialAction":[{"@type":"ReadAction","target":["https://www.manusmenu.com/honey-hard-candy"]}]},{"@type":"ImageObject","inLanguage":"en-US","@id":"https://www.manusmenu.com/honey-hard-candy#primaryimage","url":"https://www.manusmenu.com/wp-content/uploads/2016/03/honey-hard-candy-wrapped-candies.webp","contentUrl":"https://www.manusmenu.com/wp-content/uploads/2016/03/honey-hard-candy-wrapped-candies.webp","width":1000,"height":667,"caption":"Wrapped honey hard candies on parchment paper."},{"@type":"BreadcrumbList","@id":"https://www.manusmenu.com/honey-hard-candy#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://www.manusmenu.com/"},{"@type":"ListItem","position":2,"name":"Honey Hard Candy"}]},{"@type":"WebSite","@id":"https://www.manusmenu.com/#website","url":"https://www.manusmenu.com/","name":"Manu’s Menu","description":"Authentic Italian Home Cooking &amp; More","potentialAction":[{"@type":"SearchAction","target":{"@type":"EntryPoint","urlTemplate":"https://www.manusmenu.com/?s={search_term_string}"},"query-input":{"@type":"PropertyValueSpecification","valueRequired":true,"valueName":"search_term_string"}}],"inLanguage":"en-US"},{"@type":"Person","@id":"https://www.manusmenu.com/#/schema/person/42904d9efab20bbd0a70d45a09729c14","name":"Manu","image":{"@type":"ImageObject","inLanguage":"en-US","@id":"https://www.manusmenu.com/#/schema/person/image/","url":"https://secure.gravatar.com/avatar/4a41527f0a8d01ea10bb8b59fb0e98847060aa3cf70cddb804139e4a333eae62?s=96&d=identicon&r=g","contentUrl":"https://secure.gravatar.com/avatar/4a41527f0a8d01ea10bb8b59fb0e98847060aa3cf70cddb804139e4a333eae62?s=96&d=identicon&r=g","caption":"Manu"},"sameAs":["http://www.manusmenu.com"]},{"@type":"Question","@id":"https://www.manusmenu.com/honey-hard-candy#faq-question-1759762711780","position":1,"url":"https://www.manusmenu.com/honey-hard-candy#faq-question-1759762711780","name":"How can I tell when honey hard candy is done without a thermometer?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Drop a small amount of the syrup into cold water. If it hardens into brittle threads that snap easily, it’s ready. If it stays soft or sticky, return it to the heat and cook a little more.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https://www.manusmenu.com/honey-hard-candy#faq-question-1759762712864","position":2,"url":"https://www.manusmenu.com/honey-hard-candy#faq-question-1759762712864","name":"Can I add food colouring to my Honey Hard Candy recipe?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Yes, you can. Use a few drops of gel or liquid food colouring once the syrup reaches the correct temperature. Light-coloured honey works best if you want the colours to show clearly.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https://www.manusmenu.com/honey-hard-candy#faq-question-1759762758835","position":3,"url":"https://www.manusmenu.com/honey-hard-candy#faq-question-1759762758835","name":"What’s the best way to clean the pot after making candy?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Fill the pot with hot water and let it sit for a few minutes. The hardened sugar will dissolve easily, and you can then wash it as usual. Avoid scraping while it’s still hot to prevent damage.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https://www.manusmenu.com/honey-hard-candy#faq-question-1759762776224","position":4,"url":"https://www.manusmenu.com/honey-hard-candy#faq-question-1759762776224","name":"Can I use brown sugar instead of white sugar?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Yes, but the candy will turn darker and have a stronger caramel flavour. Brown sugar contains molasses, which changes both colour and taste slightly.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Recipe","name":"Honey Hard Candy","author":{"@type":"Person","name":"Manuela Zangara"},"description":"Need a sweet treat that’s both homemade and soothing? Honey Hard Candy is easy to make, looks lovely, and makes a thoughtful gift for any occasion.","datePublished":"2016-03-07T19:18:09+00:00","image":["https://www.manusmenu.com/wp-content/uploads/2016/03/honey-hard-candy-wrapped-candies.webp","https://www.manusmenu.com/wp-content/uploads/2016/03/honey-hard-candy-wrapped-candies-500x500.webp","https://www.manusmenu.com/wp-content/uploads/2016/03/honey-hard-candy-wrapped-candies-500x375.webp","https://www.manusmenu.com/wp-content/uploads/2016/03/honey-hard-candy-wrapped-candies-480x270.webp"],"recipeYield":["12"],"prepTime":"PT5M","cookTime":"PT20M","totalTime":"PT25M","recipeIngredient":["6 tbsp sugar","4 tbsp water","2 tbsp lemon juice","2 tbsp honey"],"recipeInstructions":[{"@type":"HowToStep","text":"In a pot, mix together the sugar, water, and lemon juice and put it on the fire on a medium flame.","name":"In a pot, mix together the sugar, water, and lemon juice and put it on the fire on a medium flame.","url":"https://www.manusmenu.com/honey-hard-candy#wprm-recipe-28962-step-0-0"},{"@type":"HowToStep","text":"When the mixture boils, decrease the flame to low and stir in the honey.","name":"When the mixture boils, decrease the flame to low and stir in the honey.","url":"https://www.manusmenu.com/honey-hard-candy#wprm-recipe-28962-step-0-1"},{"@type":"HowToStep","text":"Caramelise the mixture and cook it until it reaches the hard crack stage (146°C–155°C / 295°F–310°F) on a candy thermometer.","name":"Caramelise the mixture and cook it until it reaches the hard crack stage (146°C–155°C / 295°F–310°F) on a candy thermometer.","url":"https://www.manusmenu.com/honey-hard-candy#wprm-recipe-28962-step-0-2"},{"@type":"HowToStep","text":"Pour the hot caramel carefully into silicone moulds while it’s still liquid.","name":"Pour the hot caramel carefully into silicone moulds while it’s still liquid.","url":"https://www.manusmenu.com/honey-hard-candy#wprm-recipe-28962-step-0-3"},{"@type":"HowToStep","text":"Let the candy cool and harden completely at room temperature before unmoulding.","name":"Let the candy cool and harden completely at room temperature before unmoulding.","url":"https://www.manusmenu.com/honey-hard-candy#wprm-recipe-28962-step-0-4"}],"aggregateRating":{"@type":"AggregateRating","ratingValue":"4.8","ratingCount":"5","reviewCount":"1"},"review":[{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Turned out wonderful, did have a darker flavor but it was the honey that made it dark. \r\nDidnt last long everyone loved them.","author":{"@type":"Person","name":"Eileen"},"datePublished":"2019-04-02"}],"recipeCategory":["Candy"],"recipeCuisine":["Italian"],"keywords":"easy honey hard candy recipe, homemade honey hard candy, honey candy for sore throat, honey hard candy, how to make honey hard candy","@id":"https://www.manusmenu.com/honey-hard-candy#recipe","isPartOf":{"@id":"https://www.manusmenu.com/honey-hard-candy#article"},"mainEntityOfPage":"https://www.manusmenu.com/honey-hard-candy"}]}</script>

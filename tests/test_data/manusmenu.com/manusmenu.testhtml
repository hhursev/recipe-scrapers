			/* ==========================================================
   POST CONTENT + RECIPE + BREADCRUMBS + COMMENTS + FORM (FULL DESKTOP VERSION)
   ========================================================== */

/* ------------------ POST CONTENT ------------------ */
.single-post .entry-content p {
  font-size: 24px;
  line-height: 34px;
  color: #1A1A1A;
  font-weight: 400;
  margin-top: 35px;
  margin-bottom: 30px;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}
.single-post .entry-meta {
  margin-top: 4px; !important; 
}

.single-post .entry-title {
  font-size: 44px;
  font-weight: 700;
margin-bottom: 16px !important;  color: #000;
}

.single-post .entry-content h2 {
  font-size: 36px;
  color: #A51818;
  font-weight: 700;
  line-height: 36px;
  margin-top: 35px;
  margin-bottom: 15px;
}

.single-post .entry-content h3 {
  font-size: 30px;
  color: #A51818;
  font-weight: 600;
  line-height: 30px;
  margin-top: 25px;
  margin-bottom: 10px;
}

.single-post .entry-content li {
  font-size: 24px;
  font-weight: 400;
  line-height: 34px;
  color: #1a1a1a;
  margin-bottom: 6px;
}

/* ✅ Post Links */
.single-post .entry-content a {
  color: #A51818;
  font-weight: 500;
  text-decoration: underline;
}
.single-post .entry-content a:hover {
  color: #7c1111;
  text-decoration: none;
}

/* ==========================================================
   ENTRY META
   ========================================================== */
.entry-meta {
  font-family: "Source Sans Pro", "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 20px !important;
  font-weight: 500;
  color: #1a1a1a;
  margin-bottom: 24px !important; /* ✅ adjusted for balance after Twitter removal */
  line-height: 26px;
  display: block;
}
.entry-meta > *:not(:last-child)::after {
  content: " • ";
  color: #999;
  margin: 0 6px;
}
.entry-meta time {
  font-style: italic;
  color: #1a1a1a;
}
.entry-meta .meta-author,
.entry-meta .meta-comments a {
  color: #8B0000;
  font-weight: 600;
  text-decoration: underline;
}
/* Prevent first paragraph rule from affecting recipe summaries */
.single-post .entry-content p:first-of-type:not(.wprm-recipe-summary p:first-of-type) {
  clear: both !important;
  margin-top: 10px !important;
  display: block !important;
}

/* ==========================================================
   FAQ STYLING
   ========================================================== */
.single-post .schema-faq-section {
  margin-top: 30px;
}
.single-post .schema-faq-section .schema-faq-question {
  display: block;
  font-size: 24px;
  font-weight: 700;
  color: #A51818;
  padding: 14px 16px;
  border: 1px solid #f0f0f0;
  border-radius: 8px 8px 0 0;
  background-color: #fff;
}
.single-post .schema-faq-section .schema-faq-answer {
  font-size: 22px;
  line-height: 32px;
  color: #1A1A1A;
  font-weight: 400;
  border: 1px solid #f0f0f0;
  border-top: none;
  border-radius: 0 0 8px 8px;
  padding: 18px 20px;
  background-color: #fff;
}

/* ==========================================================
   RECIPE CARD
   ========================================================== */
.wprm-recipe {
  font-family: inherit;
  color: #1A1A1A;
}

/* ---------- RECIPE NAME + SUMMARY ---------- */
.wprm-recipe-name {
  font-size: 30px !important;
  line-height: 34px !important;
  font-weight: 700 !important;
  color: #A51818 !important;
  margin-bottom: 12px !important;
}
.wprm-recipe-summary {
  display: block !important;
  margin-top: 12px !important;
  margin-bottom: 18px !important;
  font-size: 24px !important;
  line-height: 32px !important;
  color: #1A1A1A !important;
  font-weight: 400 !important;
}

/* ---------- SECTION HEADERS ---------- */
.wprm-recipe-header {
  font-size: 26px !important;
  color: #A51818 !important;
  font-weight: 700 !important;
  margin-top: 30px !important;
  margin-bottom: 12px !important;
}
.wprm-recipe-group-name {
  font-size: 24px !important;
  font-weight: 700 !important;
  color: #A51818 !important;
  margin: 16px 0 8px !important;
}

/* ---------- INGREDIENTS ---------- */
.wprm-recipe-ingredients-container li,
.wprm-recipe-ingredient-name,
.wprm-recipe-ingredient-amount,
.wprm-recipe-ingredient-notes {
  font-size: 22px !important;
  line-height: 30px !important;
  color: #1A1A1A !important;
  font-weight: 400 !important;
  text-align: left !important;
  margin-top: 12px !important;
  margin-bottom: 12px !important;
}

/* ---------- INSTRUCTIONS ---------- */
.wprm-recipe-instructions-container li,
.wprm-recipe-instruction,
.wprm-recipe-instruction-text {
  font-size: 24px !important;
  line-height: 34px !important;
  color: #1A1A1A !important;
  font-weight: 400 !important;
  text-align: left !important;
  margin-top: 15px !important;
  margin-bottom: 20px !important;
}

/* ---------- INSTRUCTION IMAGE SPACING (LEFT-ALIGNED) ---------- */
.wprm-recipe-instruction img,
.wprm-recipe-instruction-image {
  display: block;
  margin: 12px 0 26px 0 !important;
  max-width: 100%;
  height: auto;
  border-radius: 6px;
  text-align: left;
}

/* ---------- ADDITIONAL SPACING BETWEEN STEPS ---------- */
.wprm-recipe-instruction {
  margin-bottom: 28px !important;
}

/* ---------- RECIPE DETAILS (COURSE, CUISINE, ETC.) ---------- */
.wprm-recipe .wprm-recipe-details-label {
  color: #A51818 !important;
  font-weight: 700 !important;
}

/* Time blocks: Prep / Cook / Total */
.wprm-recipe-times-container {
  margin-bottom: 10px !important; /* default is 16–20px; reduced for tighter layout */
}

.wprm-recipe-time-container {
  margin-bottom: 4px !important; /* tighter gap between time rows */
  line-height: 1.5 !important;
}

/* Course / Cuisine / Category */
.wprm-recipe-course-container,
.wprm-recipe-cuisine-container,
.wprm-recipe-details-container {
  font-size: 22px !important;
  line-height: 30px !important;
  color: #1A1A1A !important;
  font-weight: 500 !important;
  margin-bottom: 4px !important;
}

/* Label styling (e.g., “Course:” “Cuisine:”) */
.wprm-recipe-course-container .wprm-recipe-details-label,
.wprm-recipe-cuisine-container .wprm-recipe-details-label {
  color: #A51818 !important;
  font-weight: 700 !important;
  margin-right:6px !important;
}

/* ==========================================================
   BREADCRUMBS
   ========================================================== */
.breadcrumb {
  font-size: 18px;
  font-weight: 400;
  color: #8B4513;
  opacity: 0.9;
  margin-bottom: 28px;
}
.breadcrumb a {
  color: #8B4513;
  text-decoration: underline;
  font-weight: 500;
}
.breadcrumb a:hover {
  color: #8B0000;
  opacity: 1;
}

/* ==========================================================
   COMMENTS + COMMENT FORM (UPDATED)
   ========================================================== */
.comment-author {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  font-color: #1a1a1a;
  font-weight: 400;
  gap: 4px;
}
.comment-author a,
.comment-author .comment-author-name {
  color: #A51818 !important;
  font-weight: 700 !important;
  font-size: 20px !important;
  text-decoration: none !important;
  line-height: 1.2;
}
.comment-author a:hover,
.comment-author .comment-author-name:hover {
  color: #7c1111 !important;
  text-decoration: underline !important;
}
.comment-author .says {
  color: #555 !important;
  font-size: 18px !important;
  font-weight: 500 !important;
  margin-left: 2px;
  line-height: 1.2;
  display: inline-block;
  text-transform: lowercase;
}
.comment-meta {
  display: inline-block;
  border: 1px solid #A51818;
  padding: 8px 12px;
  border-radius: 4px;
  color: #A51818;
  background: #fff;
  font-weight: 600;
  font-size: 18px;
  margin-bottom: 12px !important;
}
.comment-meta a.comment-time-link {
  color: #7c1111 !important;
  text-decoration: none !important;
  font-weight: 600 !important;
}
.comment-meta a.comment-time-link:hover {
  color: #A51818 !important;
  text-decoration: underline !important;
}
.comment-content {
  font-size: 22px;
  line-height: 32px;
  color: #000 !important;
  font-weight: 500;
  margin-top: 6px;
  margin-bottom: 12px;
}
.comment-reply a {
  display: inline-block;
  background: #fff;
  border: 1px solid #A51818;
  color: #A51818 !important;
  font-size: 14px;
  font-weight: 700;
  text-transform: uppercase;
  padding: 5px 10px;
  border-radius: 4px;
  text-decoration: none !important;
  transition: all 0.2s ease-in-out;
}
.comment-reply a:hover {
  background: #A51818;
  color: #fff !important;
}
#commentform label {
  font-weight: 700;
  font-size: 17px;
  color: #1A1A1A;
}
#commentform input,
#commentform textarea {
  border: 1px solid #ccc;
  border-radius: 6px;
  font-size: 18px;
  color: #000 !important;
  background: #fff;
  width: 100%;
  padding: 8px 10px;
  margin-bottom: 12px;
}
#commentform input[type="submit"],
input#submit.submit {
  background: #A51818 !important;
  color: #fff !important;
  border: none;
  border-radius: 6px;
  padding: 10px 18px;
  font-size: 18px;
  font-weight: 700;
  text-transform: uppercase;
  cursor: pointer;
  transition: all 0.2s ease-in-out;
}
#commentform input[type="submit"]:hover {
  background: #7c1111 !important;
}

/* ==========================================================
   RECIPE RATING POPUP (WPRM)
   ========================================================== */
.wprm-popup-modal-user-rating textarea.wprm-user-rating-modal-comment {
  border: 1px solid #ccc !important;
  border-radius: 6px !important;
  font-size: 18px !important;
  line-height: 28px !important;
  color: #000 !important;
  font-family: inherit !important;
  padding: 10px 12px !important;
  width: 100% !important;
  box-sizing: border-box !important;
  background: #fff !important;
  resize: vertical !important;
}
.wprm-popup-modal-user-rating textarea.wprm-user-rating-modal-comment:focus {
  border-color: #A51818 !important;
  outline: none !important;
  box-shadow: 0 0 0 2px rgba(165, 24, 24, 0.2) !important;
}
.wprm-popup-modal .wprm-popup-modal-footer button {
  background: #A51818 !important;
  color: #fff !important;
  font-weight: 700 !important;
  border-radius: 6px !important;
  padding: 10px 18px !important;
  font-size: 16px !important;
  border: none !important;
  cursor: pointer !important;
  transition: all 0.2s ease-in-out !important;
}
.wprm-popup-modal .wprm-popup-modal-footer button:hover {
  background: #7c1111 !important;
}

/* ==========================================================
   JUMP TO RECIPE + PRINT RECIPE BUTTONS
   Outlined minimalist style — perfectly aligned under title/meta
   ========================================================== */
a.wprm-recipe-jump.wprm-recipe-link.wprm-block-text-normal,
a.wprm-recipe-print.wprm-recipe-link.wprm-block-text-normal {
  display: inline-block !important;
  background-color: transparent !important;
  color: #A51818 !important;
  font-size: 20px !important;
  font-weight: 700 !important;
  padding: 10px 22px !important;
  border: 2px solid #A51818 !important;
  border-radius: 8px !important;
  text-transform: uppercase !important;
  text-decoration: none !important;
  margin-top: 5px !important; /* balanced space below meta */
  margin-bottom: 28px !important;
  margin-right: 12px !important;
  transition: all 0.25s ease-in-out !important;
  line-height: 1.4 !important;
  text-align: center !important;
}

a.wprm-recipe-jump.wprm-recipe-link.wprm-block-text-normal:hover,
a.wprm-recipe-print.wprm-recipe-link.wprm-block-text-normal:hover {
  background-color: #A51818 !important;
  color: #fff !important;
  box-shadow: 0 3px 6px rgba(165, 24, 24, 0.25) !important;
}

.wprm-recipe-container,
.single-post .entry-content {
  text-align: left !important;
}

/* ✅ Center alignment with title/date restored */
a.wprm-recipe-jump.wprm-recipe-link.wprm-block-text-normal {
  margin-left: 0 !important; /* removed old negative offset */
}
/* ==========================================================
   FILED UNDER / TAGGED WITH – RESPONSIVE DESIGN
   ========================================================== */

/* ---------- GENERAL CONTAINER ---------- */
.post-taxonomies,
.entry-meta {
  font-family: 'Source Sans Pro', 'Helvetica Neue', Helvetica, Arial, sans-serif !important;
  font-size: 18px;
  line-height: 1.6;
  margin-top: 40px;
  color: #000;
}

/* ==========================================================
   CLEAN FILED UNDER / TAGGED WITH – SCOPED TO FOOTER ONLY
   ========================================================== */

/* Target only the bottom meta in footer, not the post header */
footer.entry-footer .entry-meta,
footer.entry-footer .post-taxonomies {
  font-family: 'Source Sans Pro', 'Helvetica Neue', Helvetica, Arial, sans-serif !important;
  font-size: 16px;
  line-height: 1.5;
  color: #000;
  max-width: 760px;
  margin: 35px auto 0 auto;
  padding: 0 15px;
}

/* ---------- TITLES ABOVE TAGS ---------- */
footer.entry-footer .entry-meta strong,
footer.entry-footer .post-taxonomies strong {
  display: block;
  font-weight: 700;
  color: #000;
  font-size: 17px;
  margin-bottom: 8px;
}

/* ---------- PILL TAGS ---------- */
footer.entry-footer .entry-meta a,
footer.entry-footer .post-taxonomies a {
  display: inline-block;
  margin: 3px 5px 6px 0;
  padding: 5px 10px;
  background: #fff5f5;
  color: #A51818 !important;
  border: 1px solid #A51818;
  border-radius: 18px;
  font-weight: 500;
  text-decoration: none !important;
  transition: all 0.25s ease-in-out;
  font-size: 15px;
}

/* ---------- HOVER ---------- */
footer.entry-footer .entry-meta a:hover,
footer.entry-footer .post-taxonomies a:hover {
  background: #A51818;
  color: #fff !important;
}

/* ---------- LAYOUT ---------- */
footer.entry-footer .entry-categories,
footer.entry-footer .entry-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 5px;
  margin-bottom: 18px;
}

/* ---------- REMOVE ALL SEPARATORS ---------- */
footer.entry-footer .entry-categories a::after,
footer.entry-footer .entry-tags a::after {
  content: none !important;
}
/* -------------------------------
   WPRM Recipe Servings Input Only
   ------------------------------- */
input.wprm-recipe-servings {
  width: 70px !important;
  height: 30px !important;
  padding: 4px 8px !important;
  text-align: center !important;
  font-size: 18px !important;
  font-weight: 600 !important;
  font-family: "Helvetica Neue", Arial, sans-serif !important;
  color: #1A1A1A !important;
  border: 1px solid #D8C7B0 !important;
  border-radius: 6px !important;
  background-color: #FFF9F6 !important;
  box-shadow: none !important;
  transition: all 0.2s ease-in-out;
}

/* Hover + Focus for better UX */
input.wprm-recipe-servings:hover,
input.wprm-recipe-servings:focus {
  border-color: #A51818 !important;
  background-color: #FFFFFF !important;
  outline: none !important;
}

/* Remove spinner arrows (desktop + mobile) */
input.wprm-recipe-servings::-webkit-outer-spin-button,
input.wprm-recipe-servings::-webkit-inner-spin-button {
  -webkit-appearance: none;
  margin: 0;
}
input.wprm-recipe-servings[type=number] {
  -moz-appearance: textfield; /* For Firefox */
}
/* ==============================================
   MANU'S MENU TABLE OF CONTENTS
  ============================================== */

.entry-content .simpletoc-wrapper,
.entry-content div[role="navigation"][aria-label="Table of Contents"] {
  background-color: #fffaf8 !important; /* lighter neutral background */
  border: 1px solid #f3d9d1 !important;
  border-radius: 14px !important;
  padding: 10px 24px !important; /* tighter padding */
  margin: 32px 0 !important;
  font-family: "Rubik", sans-serif !important;
  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.02) !important;
}

/* TOC Title */
.entry-content .simpletoc-wrapper .simpletoc-title,
.entry-content div[role="navigation"] .simpletoc-title {
  color: #A51818 !important;
  font-family: "Source Sans Pro", "Helvetica Neue", Helvetica, Arial, sans-serif !important;
  font-weight: 800 !important;
  font-size: 32px !important;
  text-transform: uppercase !important;
  margin-bottom: 16px !important;
  border: none !important;
  padding-bottom: 0 !important;
  letter-spacing: 0.4px !important;
}

/* TOC List */
.entry-content .simpletoc-wrapper ul.simpletoc-list,
.entry-content div[role="navigation"] ul.simpletoc-list {
  list-style-type: none !important;
  padding-left: 0 !important;
  margin: 0 !important;
}

/* List Items */
.entry-content .simpletoc-wrapper ul.simpletoc-list li,
.entry-content div[role="navigation"] ul.simpletoc-list li {
  line-height: 38px; !important;
}

/* TOC Links – underline visible always */
.entry-content .simpletoc-wrapper ul.simpletoc-list li a,
.entry-content div[role="navigation"] ul.simpletoc-list li a {
  color: #A51818 !important;
  text-decoration: underline !important;
  text-decoration-thickness: 4px !important;
  text-underline-offset: 8px !important;
  text-decoration-color: #c04c3a !important; /* softer clay tone */
  font-family: "Rubik", sans-serif !important;
  font-weight: 500 !important;
  font-size: 22px !important;
  display: inline-block !important;
  transition: color 0.25s ease, text-decoration-color 0.25s ease !important;
}

/* Hover – underline color deepens + text darkens */
.entry-content .simpletoc-wrapper ul.simpletoc-list li a:hover,
.entry-content div[role="navigation"] ul.simpletoc-list li a:hover {
  color: #7d1212 !important;
  text-decoration-color: #7d1212 !important; /* deeper underline */
}

/* Active Link – slightly thicker + darker underline */
.entry-content .simpletoc-wrapper ul.simpletoc-list li a.is-active,
.entry-content div[role="navigation"] ul.simpletoc-list li a.is-active {
  color: #6a0f0f !important;
  text-decoration: underline !important;
  text-decoration-thickness: 4px !important;
  text-underline-offset: 4px !important;
  text-decoration-color: #6a0f0f !important;
}

/* ==============================================
   MOBILE RESPONSIVE
   ============================================== */
@media (max-width: 768px) {
  .entry-content .simpletoc-wrapper {
    padding: 15px 18px !important;
    border-radius: 10px !important;
  }

  .entry-content .simpletoc-wrapper .simpletoc-title {
    font-size: 20px !important;
    margin-bottom: 12px !important;
  }

  .entry-content .simpletoc-wrapper ul.simpletoc-list li a {
    font-size: 17px !important;
    text-decoration-thickness: 2.5px !important;
    text-underline-offset: 3px !important;
  }

  .entry-content .simpletoc-wrapper ul.simpletoc-list li {
    margin: 6px 0 !important;
  }
}

/* ==========================================================
   FINAL FULL MOBILE CSS (COMPLETE + FIXED VERSION)
   ========================================================== */
@media (max-width: 768px) {

  /* ---------- HEADINGS + GENERAL POST CONTENT ---------- */
  h1, .single-post .entry-content h1, .single-post .entry-title {
    font-size: 30px !important;
    line-height: 30px !important;
    color: #A51818 !important;
    font-weight: 700 !important;
    margin-top: 28px !important;
    margin-bottom: 22px !important;
    text-align: left !important;
  }

  h2, .single-post .entry-content h2 {
    font-size: 28px !important;
    line-height: 30px !important;
    color: #A51818 !important;
    font-weight: 700 !important;
    margin-top: 26px !important;
    margin-bottom: 18px !important;
    text-align: left !important;
  }

  h3, .single-post .entry-content h3,
  .wprm-recipe-header, .wprm-recipe-group-name {
    font-size: 22px !important;
    line-height: 28px !important;
    color: #A51818 !important;
    font-weight: 600 !important;
    margin-top: 20px !important;
    margin-bottom: 8px !important;
    text-align: left !important;
  }

  .single-post .entry-content p,
  .single-post .entry-content li {
    font-size: 20px !important;
    line-height: 28px !important;
    color: #1A1A1A !important;
    text-align: left !important;
  }

  .single-post .entry-content a {
    color: #A51818 !important;
    text-decoration: underline !important;
    font-weight: 600 !important;
  }

  .single-post .entry-content a:hover {
    color: #7c1111 !important;
    text-decoration: none !important;
  }
  /* ---------- FAQ ---------- */
  .single-post .schema-faq-section {
    margin-top: 25px !important;
  }

  .single-post .schema-faq-section .schema-faq-question {
    font-size: 22px !important;
    line-height: 28px !important;
    color: #A51818 !important;
    padding: 12px 14px !important;
    border: 1px solid #f0f0f0 !important;
    border-radius: 6px 6px 0 0 !important;
    background: #fff !important;
  }

  .single-post .schema-faq-section .schema-faq-answer {
    font-size: 20px !important;
    line-height: 28px !important;
    padding: 14px 16px !important;
    border: 1px solid #f0f0f0 !important;
    border-top: none !important;
    border-radius: 0 0 6px 6px !important;
    background: #fff !important;
    color: #1A1A1A !important;
  }

  /* ---------- RECIPE CARD ---------- */
  .wprm-recipe {
    padding: 12px !important;
    color: #1A1A1A !important;
    background: #fff !important;
  }

  .wprm-recipe-name {
    font-size: 26px !important;
    line-height: 30px !important;
    color: #A51818 !important;
    font-weight: 700 !important;
    text-align: left !important;
    margin-bottom: 10px !important;
  }

  .wprm-recipe-summary {
    font-size: 20px !important;
    line-height: 28px !important;
    color: #1A1A1A !important;
    text-align: left !important;
    margin-bottom: 16px !important;
  }

  .wprm-recipe-header {
    font-size: 26px !important;
    line-height: 30px !important;
    color: #A51818 !important;
    margin-top: 25px !important;
    margin-bottom: 10px !important;
    font-weight: 700 !important;
    text-align: left !important;
  }

  .wprm-recipe-group-name {
    font-size: 22px !important;
    line-height: 26px !important;
    color: #A51818 !important;
    margin-top: 20px !important;
    margin-bottom: 8px !important;
    font-weight: 700 !important;
    text-align: left !important;
  }

  .wprm-recipe-ingredients-container li,
  .wprm-recipe-instruction,
  .wprm-recipe-ingredient-name,
  .wprm-recipe-ingredient-amount,
  .wprm-recipe-instruction-text,
  .wprm-recipe-ingredient-notes {
    font-size: 20px !important;
    line-height: 28px !important;
    color: #1A1A1A !important;
    text-align: left !important;
    margin-bottom: 8px !important;
  }

  .wprm-recipe-course-container,
  .wprm-recipe-cuisine-container,
  .wprm-recipe-details-container {
    font-size: 20px !important;
    line-height: 26px !important;
    color: #1A1A1A !important;
    font-weight: 500 !important;
    text-align: left !important;
    margin-bottom: 6px !important;
  }

  .wprm-recipe-course-container .wprm-recipe-details-label,
  .wprm-recipe-cuisine-container .wprm-recipe-details-label {
    color: #A51818 !important;
    font-weight: 700 !important;
    margin-right: 6px !important;
  }

  /* ---------- MOBILE FIX: RECIPE DETAILS SPACING ---------- */
  .wprm-recipe-details-container {
    display: block !important;
    margin-bottom: 12px !important;
    line-height: 28px !important;
  }

  .wprm-recipe-details-label {
    display: inline-block !important;
    margin-bottom: 4px !important;
    font-weight: 700 !important;
    color: #A51818 !important;
  }

  .wprm-recipe-details-container span,
  .wprm-recipe-details-container a {
    font-size: 20px !important;
    line-height: 26px !important;
    color: #1A1A1A !important;
  }

  .wprm-recipe-details-container:not(:last-child) {
    margin-bottom: 10px !important;
  }

  /* ---------- FIXED: JUMP + PRINT BUTTONS (UPDATED TO OUTLINE STYLE) ---------- */
  a.wprm-recipe-jump.wprm-recipe-link.wprm-block-text-normal,
  a.wprm-recipe-print.wprm-recipe-link.wprm-block-text-normal {
    display: block !important;
    width: 100% !important;
    font-size: 18px !important;
    font-weight: 700 !important;
    text-align: center !important;
    border: 2px solid #A51818 !important;
    border-radius: 10px !important;
    padding: 12px 0 !important;
    color: #A51818 !important;
    background: transparent !important;
    text-transform: uppercase !important;
    text-decoration: none !important;
    transition: all 0.25s ease-in-out !important;
  }

  a.wprm-recipe-jump.wprm-recipe-link.wprm-block-text-normal {
    margin-top: 22px !important;
    margin-right: 0 !important;
    margin-bottom: 14px !important;
    margin-left: 0 !important;
  }

  a.wprm-recipe-print.wprm-recipe-link.wprm-block-text-normal {
    margin-top: 0 !important;
    margin-right: 0 !important;
    margin-bottom: 20px !important;
    margin-left: 0 !important;
  }

  a.wprm-recipe-jump.wprm-recipe-link.wprm-block-text-normal:hover,
  a.wprm-recipe-print.wprm-recipe-link.wprm-block-text-normal:hover {
    background-color: #A51818 !important;
    color: #fff !important;
    transform: scale(1.02);
  }

  .wprm-recipe-print span,
  .wprm-recipe-print-link span {
    display: inline !important;
    visibility: visible !important;
    opacity: 1 !important;
    color: inherit !important;
    font-weight: 700 !important;
    font-size: 16px !important;
    text-transform: uppercase !important;
    line-height: 1 !important;
  }

  /* ---------- BREADCRUMBS ---------- */
  .breadcrumb {
    font-size: 16px !important;
    line-height: 22px !important;
    margin-bottom: 18px !important;
    color: #8B4513 !important;
    flex-wrap: wrap !important;
    text-align: left !important;
  }

  .breadcrumb a {
    color: #A51818 !important;
    font-size: 16px !important;
    text-decoration: underline !important;
    font-weight: 500 !important;
  }

  .breadcrumb a:hover {
    color: #8B4513 !important;
  }

  /* ---------- COMMENTS ---------- */
  #comments h3 {
    font-size: 22px !important;
    line-height: 28px !important;
    color: #A51818 !important;
    text-align: left !important;
  }

  .comment-author {
    font-size: 18px !important;
    font-weight: 700 !important;
    color: #800000 !important;
    text-align: left !important;
    line-height: 22px !important;
  }

  .comment-meta {
    font-size: 16px !important;
    line-height: 22px !important;
    color: #A51818 !important;
    border: 2px solid #A51818 !important;
    padding: 6px 10px !important;
    border-radius: 4px !important;
    background: #fff !important;
    font-weight: 600 !important;
    text-align: left !important;
  }

  .comment-meta a {
    color: #A51818 !important;
    text-decoration: none !important;
  }

  .comment-meta a:hover {
    text-decoration: underline !important;
  }

  .comment-content {
    font-size: 18px !important;
    line-height: 26px !important;
    color: #000 !important;
    text-align: left !important;
  }

  .comment-reply a,
  .comment-reply-link {
    background: #A51818 !important;
    color: #fff !important;
    border-radius: 4px !important;
    padding: 6px 12px !important;
    font-size: 14px !important;
    font-weight: 600 !important;
    text-transform: uppercase !important;
    text-decoration: none !important;
    display: inline-block !important;
  }

  .comment-reply a:hover,
  .comment-reply-link:hover {
    background: #7c1111 !important;
  }

  #commentform label {
    font-size: 16px !important;
    color: #1A1A1A !important;
  }

  #commentform input,
  #commentform textarea {
    font-size: 16px !important;
    line-height: 22px !important;
    padding: 8px 10px !important;
    border: 1px solid #ccc !important;
    border-radius: 6px !important;
    color: #000 !important;
    background: #fff !important;
    width: 100% !important;
  }

  #commentform input[type="submit"] {
    font-size: 16px !important;
    padding: 8px 14px !important;
    background: #A51818 !important;
    color: #fff !important;
    border-radius: 6px !important;
    border: none !important;
    font-weight: 700 !important;
    text-transform: uppercase !important;
  }

  #commentform input[type="submit"]:hover {
    background: #7c1111 !important;
  }

  .wprm-popup-modal-user-rating .wprm-popup-modal__content {
    padding: 15px !important;
  }

  .wprm-popup-modal-user-rating .wprm-user-rating-modal-field label {
    font-size: 15px !important;
    font-weight: 600 !important;
    color: #000 !important;
  }

  .wprm-popup-modal-user-rating input[type="text"],
  .wprm-popup-modal-user-rating input[type="email"],
  .wprm-popup-modal-user-rating textarea {
    font-size: 15px !important;
    padding: 8px 10px !important;
    border: 1px solid #ccc !important;
    border-radius: 6px !important;
    color: #1A1A1A !important;
    background-color: #fff !important;
  }

  .wprm-popup-modal-user-rating textarea {
    min-height: 80px !important;
    line-height: 22px !important;
  }

  .wprm-popup-modal__footer button,
  .wprm-popup-modal-user-rating input[type="submit"] {
    font-size: 15px !important;
    font-weight: 600 !important;
    padding: 10px 14px !important;
    background: #A51818 !important;
    border-radius: 6px !important;
    color: #fff !important;
    width: 100% !important;
  }

  .wprm-popup-modal__footer button:hover,
  .wprm-popup-modal-user-rating input[type="submit"]:hover {
    background: #7c1111 !important;
  }

} /* close first mobile block */


/* ---------- MOBILE ---------- */
@media (max-width: 768px) {
  footer.entry-footer .entry-meta,
  footer.entry-footer .post-taxonomies {
    font-size: 15px;
    margin-top: 28px;
    padding: 0 10px;
  }

  footer.entry-footer .entry-meta strong,
  footer.entry-footer .post-taxonomies strong {
    font-size: 16px;
    margin-bottom: 6px;
  }

  footer.entry-footer .entry-meta a,
  footer.entry-footer .post-taxonomies a {
    font-size: 14px;
    padding: 5px 9px;
    margin: 3px 4px;
    border-radius: 16px;
  }

  footer.entry-footer .entry-categories,
  footer.entry-footer .entry-tags {
    gap: 5px;
    margin-bottom: 14px;
  }
} /* close second mobile block */


/* Mobile adjustments */
@media (max-width: 768px) {
  input.wprm-recipe-servings {
    width: 60px !important;
    height: 28px !important;
    font-size: 16px !important;
  }
} /* close third mobile block */


/* ==============================================
   SIMPLETOC – MOBILE BULLETS + FONT FIX (FINAL)
   ============================================== */
@media (max-width: 768px) {

  .entry-content .simpletoc-wrapper,
  .entry-content div[role="navigation"][aria-label="Table of Contents"] {
    padding: 10px 16px !important;
    margin: 16px 0 28px 0 !important;
    border-radius: 10px !important;
  }

  .entry-content .simpletoc-wrapper .simpletoc-title,
  .entry-content div[role="navigation"] .simpletoc-title {
    font-size: 21px !important;
    margin-bottom: 12px !important;
    text-align: left !important;
  }

  .entry-content .simpletoc-wrapper ul.simpletoc-list,
  .entry-content div[role="navigation"] ul.simpletoc-list {
    list-style: none !important;
    padding: 0 !important;
    margin: 0 !important;
  }

  .entry-content .simpletoc-wrapper ul.simpletoc-list li,
  .entry-content div[role="navigation"] ul.simpletoc-list li {
    display: block !important;
    position: relative !important;
    margin: 6px 0 !important;
    padding-left: 18px !important;
    line-height: 1.6 !important;
  }

  .entry-content .simpletoc-wrapper ul.simpletoc-list li::before,
  .entry-content div[role="navigation"] ul.simpletoc-list li::before {
    content: "•";
    color: #A51818 !important;
    font-size: 17px !important;
    font-weight: 700 !important;
    position: absolute !important;
    left: 0 !important;
    top: 0.55em !important;
    line-height: 1 !important;
    display: inline-block !important;
  }

  .entry-content .simpletoc-wrapper ul.simpletoc-list li a,
  .entry-content div[role="navigation"] ul.simpletoc-list li a {
    font-family: "Rubik", sans-serif !important;
    font-size: 18px !important;
    font-weight: 500 !important;
    color: #A51818 !important;
    text-decoration: underline !important;
    text-decoration-thickness: 4px !important;
    text-underline-offset: 5px !important;
    text-decoration-color: #c04c3a !important;
    display: inline-block !important;
    transition: color 0.25s ease, text-decoration-color 0.25s ease !important;
  }

  .entry-content .simpletoc-wrapper ul.simpletoc-list li a:hover,
  .entry-content div[role="navigation"] ul.simpletoc-list li a:hover {
    color: #7d1212 !important;
    text-decoration-color: #7d1212 !important;
  }

  .entry-content .simpletoc-wrapper ul.simpletoc-list li a.is-active,
  .entry-content div[role="navigation"] ul.simpletoc-list li a.is-active {
    color: #6a0f0f !important;
    text-decoration-color: #6a0f0f !important;
  }

} /* close fourth mobile block */



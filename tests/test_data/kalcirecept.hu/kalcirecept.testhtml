        </div>
        

    
    <div x-data
    class="relative z-[151]"
    aria-label="Kosár"
    role="dialog"
    aria-modal="true">

    <div x-show="shoppingCart().isOpen"
        x-cloak
        class="transition-opacity' fixed inset-0 bg-gray-500 bg-opacity-75"
        x-transition:enter="ease-in-out duration-500"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
        x-transition:leave="ease-in-out duration-500"
        x-transition:leave-start="opacity-100"
        x-transition:leave-end="opacity-0"></div>

    <div class="fixed inset-0 overflow-hidden"
        :class="shoppingCart().isOpen ? '' : 'pointer-events-none'">
        <div class="absolute inset-0 overflow-hidden">
            <div class="pointer-events-none fixed inset-y-0 right-0 flex max-w-full sm:pl-10">
                <div x-show="shoppingCart().isOpen"
                    x-cloak
                    class="pointer-events-auto w-screen sm:max-w-lg"
                    @click.outside="shoppingCart().close()"
                    x-transition:enter="transform transition ease-in-out duration-500 sm:duration-700"
                    x-transition:enter-start="translate-x-full"
                    x-transition:enter-end="translate-x-0"
                    x-transition:leave="transform transition ease-in-out duration-500 sm:duration-700"
                    x-transition:leave-start="translate-x-0"
                    x-transition:leave-end="translate-x-full">
                    <div class="flex h-full flex-col overflow-y-auto rounded-bl-[25px] bg-white shadow-xl"
    id="cart-sidebar-content"
    hx-swap-oob="true">
    <div class="border-b border-b-[#FAF0E3] bg-white px-4 py-4 text-brand-dark shadow-md md:flex md:items-center md:gap-2">
    <div class="inline-flex w-full items-center justify-between gap-2">
        <span class="font-serif text-4xl">
            Kosár
                    </span>

        <span @click="shoppingCart().close()" class="cursor-pointer transition-all hover:scale-105 hover:text-brand">
            <i class="fal fa-times text-3xl"></i>
        </span>
    </div>
</div>

    <div class="space-y-2 overflow-auto px-4 py-4 md:scroll-smooth">
    </div>

    <div class="hidden justify-center">
    <button type="button"
        @click="window.Alpine.store('shoppingCart').isOpen = false"
        class="font-bold text-brand hover:text-brand-dark">
        Tovább vásárolok
        <i class="far fa-arrow-right"></i>
    </button>
</div>

<div class="mt-auto bg-secondary px-4 py-8 text-brand-text">
    <div class="flex flex-col gap-4 md:grid md:grid-cols-2 md:items-center md:justify-items-center">
        <div>
            <p class="text-sm">Összesen fizetendő</p>
            <p class="mt-1 text-3xl font-bold text-brand-dark">
                0 Ft
            </p>
        </div>
        <a href="https://www.kalcirecept.hu/hu/rendeles "class="button relative w-fit font-medium text-white px-[35.5px] py-[18px] tracking-widest uppercase font-sans transition-all before:bg-brand disabled:before:bg-brand/75 disabled:!text-white/70 disabled:!stroke-white/70 disabled:cursor-not-allowed block"><span
            class="relative">Megveszem</span></a>
    </div>
</div>
</div>
                </div>
            </div>
        </div>
    </div>
</div>
</body>

</html>

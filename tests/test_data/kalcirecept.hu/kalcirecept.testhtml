</section>

    <div class="container mx-auto px-6 mt-[75px] md:mt-[100px] lg:hidden">
    <img data-aos="zoom-in" data-aos-delay="100" class="rounded-[10px_30px_10px_30px] border border-secondary"
            src="https://fw.photos/t-qp1dulEBgK4wJ8coIvI8zXyuA=/1280x0/https%3A%2F%2Fwww.kalcirecept.hu%2Fuploads%2F01KFKKBA2A56N63AFB95109YGD.png" />

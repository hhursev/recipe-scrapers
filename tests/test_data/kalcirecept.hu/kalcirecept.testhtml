                <div class="mb-2 text-center font-sans font-semibold uppercase tracking-[5%] text-brand-light lg:text-left">
                    Hírlevél felirakozás</div>
                <p class="mb-2 text-center font-sans font-light tracking-[5%] text-white lg:text-left">
                    Szeretnél első kézből értesülni az új receptekről? </p>
                <button @click="toggle()"
                    class="mx-auto block rounded-[5px_20px_5px_20px] bg-red-robin px-5 py-3 font-medium uppercase tracking-[10%] text-white lg:mx-0">Feliratkozom!</button>
                <template x-teleport="body">

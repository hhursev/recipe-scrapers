.h-feat h3 a:before{top: -5px; left: -5px; right: -5px; bottom: -5px;content: ""; display: block; background: none; position: absolute; border: 1px solid #fff; z-index:-1;}

/* Homepage Blocks */

.cover-box  {
    background: #000000 !important;
 }


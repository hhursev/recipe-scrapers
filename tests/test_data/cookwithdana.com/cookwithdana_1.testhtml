n-1769170434228"},{"@id":"https://cookwithdana.com/korean-spicy-marinated-tofu/#faq-question-1769459162881"},{"@id":"https://cookwithdana.com/korean-spicy-marinated-tofu/#faq-question-1658401249599"}],"inLanguage":"en-US","potentialAction":[{"@type":"ReadAction","target":["https://cookwithdana.com/korean-spicy-marinated-tofu/"]}]},{"@type":"ImageObject","inLanguage":"en-US","@id":"https://cookwithdana.com/korean-spicy-marinated-tofu/#primaryimage","url":"https://cookwithdana.com/wp-content/uploads/2026/01/korean-spicy-marinated-tofu-lastphoto.jpg","contentUrl":"https://cookwithdana.com/wp-content/uploads/2026/01/korean-spicy-marinated-tofu-lastphoto.jpg","width":1200,"height":1600,"caption":"Sliced silken tofu in a spicy, savory Korean sauce with green onions and sesame seeds served in a glass bowl."},{"@type":"BreadcrumbList","@id":"https://cookwithdana.com/korean-spicy-marinated-tofu/#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Cook With Dana","item":"https://cookwithdana.com/"},{"@type":"ListItem","position":2,"name":"Recipes","item":"https://cookwithdana.com/recipes/"},{"@type":"ListItem","position":3,"name":"Side Dishes","item":"https://cookwithdana.com/category/recipes/side-dishes/"},{"@type":"ListItem","position":4,"name":"Korean Spicy Marinated Tofu"}]},{"@type":"WebSite","@id":"https://cookwithdana.com/#website","url":"https://cookwithdana.com/","name":"Cook With Dana","description":"","publisher":{"@id":"https://cookwithdana.com/#organization"},"potentialAction":[{"@type":"SearchAction","target":{"@type":"EntryPoint","urlTemplate":"https://cookwithdana.com/?s={search_term_string}"},"query-input":{"@type":"PropertyValueSpecification","valueRequired":true,"valueName":"search_term_string"}}],"inLanguage":"en-US"},{"@type":"Organization","@id":"https://cookwithdana.com/#organization","name":"Cook With Dana","url":"https://cookwithdana.com/","logo":{"@type":"ImageObject","inLanguage":"en-US","@id":"https://cookwithdana.com/#/schema/logo/image/","url":"https://cookwithdana.com/wp-content/uploads/2024/03/Untitled-design.jpg","contentUrl":"https://cookwithdana.com/wp-content/uploads/2024/03/Untitled-design.jpg","width":696,"height":696,"caption":"Cook With Dana"},"image":{"@id":"https://cookwithdana.com/#/schema/logo/image/"},"sameAs":["https://www.facebook.com/cookwithdanaa/"]},{"@type":"Person","@id":"https://cookwithdana.com/#/schema/person/cac00b1273a418e39df43d2117f3bc07","name":"Dana Rao","image":{"@type":"ImageObject","inLanguage":"en-US","@id":"https://cookwithdana.com/#/schema/person/image/","url":"https://secure.gravatar.com/avatar/987dca76cff46aec7797f079c1bcf2478a6b07fe43c6d764ccf492edaa486126?s=96&d=mm&r=g","contentUrl":"https://secure.gravatar.com/avatar/987dca76cff46aec7797f079c1bcf2478a6b07fe43c6d764ccf492edaa486126?s=96&d=mm&r=g","caption":"Dana Rao"},"sameAs":["https://cookwithdana.com/about/"],"url":"https://cookwithdana.com/author/cookwdanatest/"},{"@type":"Question","@id":"https://cookwithdana.com/korean-spicy-marinated-tofu/#faq-question-1769170204180","position":1,"url":"https://cookwithdana.com/korean-spicy-marinated-tofu/#faq-question-1769170204180","name":"Can I make this Korean marinated tofu vegan?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Yes, you can replace fish sauce with soy sauce or tamari for a vegan-friendly option that still gives the marinade a savory, umami kick.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https://cookwithdana.com/korean-spicy-marinated-tofu/#faq-question-1769170434228","position":2,"url":"https://cookwithdana.com/korean-spicy-marinated-tofu/#faq-question-1769170434228","name":"Can I use any types of tofu for Korean marinated tofu?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Yes, you can use soft tofu or regular tofu depending on what texture you like. I prefer the silken tofu because I love how silky and smooth it is! ","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https://cookwithdana.com/korean-spicy-marinated-tofu/#faq-question-1769459162881","position":3,"url":"https://cookwithdana.com/korean-spicy-marinated-tofu/#faq-question-1769459162881","name":"Can I meal prep Korean Marinated Tofu?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Yes, this recipe is <strong>great for meal prep</strong>. The flavors of the tofu become more salty and delicious as the days go by. The texture of the tofu doesn't change and can be kept in the fridge for up to 4 days in an airtight container. ","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https://cookwithdana.com/korean-spicy-marinated-tofu/#faq-question-1658401249599","position":4,"url":"https://cookwithdana.com/korean-spicy-marinated-tofu/#faq-question-1658401249599","name":"What’s the best way to serve marinated tofu?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Korean marinated tofu goes great with rice, nori, kimchi or noodles, and serving it alongside hearty dishes like <a href=\"https://cookwithdana.com/korean-pork-belly-samgyeopsal/\">Korean Pork Belly BBQ</a>, <a href=\"https://cookwithdana.com/kimchi-fried-rice-with-spam/\">One Pot Kimchi Fried Rice With Spam</a> or <a href=\"https://cookwithdana.com/japchae-potstickers/\">Japchae Potstickers</a> makes for a full Korean-inspired meal! ","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Recipe","name":"Korean Spicy Marinated Tofu","author":{"@id":"https://cookwithdana.com/#/schema/person/cac00b1273a418e39df43d2117f3bc07"},"description":"Korean Spicy Marinated Tofu is tofu marinated in a Korean sweet and spicy sauce inspired by the popular Yangnyeom (means spicy sauce) flavor. This recipe is made under 10 minutes and is perfect for vegetarians!","datePublished":"2026-02-03T02:00:51+00:00","image":["https://cookwithdana.com/wp-content/uploads/2026/01/korean-spicy-marinated-tofu-firstphoto.jpg","https://cookwithdana.com/wp-content/uploads/2026/01/korean-spicy-marinated-tofu-firstphoto-500x500.jpg","https://cookwithdana.com/wp-content/uploads/2026/01/korean-spicy-marinated-tofu-firstphoto-500x375.jpg","https://cookwithdana.com/wp-content/uploads/2026/01/korean-spicy-marinated-tofu-firstphoto-480x270.jpg"],"recipeYield":["2","2 people"],"prepTime":"PT5M","cookTime":"PT5M","recipeIngredient":["1  silken tofu","1  green onion","2  garlic (grated)","1.5 tablespoon  gochugaru  ((korean red pepper flakes))","1 tablespoon  honey","1.5 tablespoon  fish sauce (or sub with soy sauce)","1 tablespoon  sesame oil","sesame seeds"],"recipeInstructions":[{"@type":"HowToStep","text":"Slice green onions and grate garlic.","name":"Slice green onions and grate garlic.","url":"https://cookwithdana.com/korean-spicy-marinated-tofu/#wprm-recipe-14594-step-0-0"},{"@type":"HowToStep","text":"To make the sauce, combine gochugaru, honey, fish sauce (or soy sauce), sesame oil, sesame seeds, sliced green onions, and grated garlic until well combined.","name":"To make the sauce, combine gochugaru, honey, fish sauce (or soy sauce), sesame oil, sesame seeds, sliced green onions, and grated garlic until well combined.","url":"https://cookwithdana.com/korean-spicy-marinated-tofu/#wprm-recipe-14594-step-0-1"},{"@type":"HowToStep","text":"Boil silken tofu for in boiling water for 2 minutes.","name":"Boil silken tofu for in boiling water for 2 minutes.","url":"https://cookwithdana.com/korean-spicy-marinated-tofu/#wprm-recipe-14594-step-0-2"},{"@type":"HowToStep","text":"Strain the tofu well so the water doesn’t get into the sauce.","name":"Strain the tofu well so the water doesn’t get into the sauce.","url":"https://cookwithdana.com/korean-spicy-marinated-tofu/#wprm-recipe-14594-step-0-3"},{"@type":"HowToStep","text":"In a airtight container, add tofu and your sauce on top. Marinate for at least 1 hour to overnight for the best flavor. Enjoy with hot rice!","name":"In a airtight container, add tofu and your sauce on top. Marinate for at least 1 hour to overnight for the best flavor. Enjoy with hot rice!","url":"https://cookwithdana.com/korean-spicy-marinated-tofu/#wprm-recipe-14594-step-0-4"}],"aggregateRating":{"@type":"AggregateRating","ratingValue":"5","ratingCount":"1","reviewCount":"1"},"review":[{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Just tried this recipe and I love the sweet-spicy sauce, it is soo good with the tofu. I couldn’t stop snacking on it with rice. This is for sure going into my regular meal rotation!","author":{"@type":"Person","name":"Sam Lee"},"datePublished":"2026-02-04"}],"recipeCategory":["Appetizer","Main Course","Side Dish"],"recipeCuisine":["korean"],"keywords":"10 minute tofu, easy Korean tofu recipe, Korean marinated tofu, Korean tofu meal prep, spicy Korean tofu, tofu marinated in Korean sauce, Vegan Korean recipes, weeknight Korean tofu recipe","nutrition":{"@type":"NutritionInformation","calories":"122 kcal","carbohydrateContent":"14 g","proteinContent":"2 g","fatContent":"8 g","saturatedFatContent":"1 g","sodiumContent":"1160 mg","fiberContent":"2 g","sugarContent":"10 g","unsaturatedFatContent":"6 g","servingSize":"1 serving"},"@id":"https://cookwithdana.com/korean-spicy-marinated-tofu/#recipe","isPartOf":{"@id":"https://cookwithdana.com/korean-spicy-marinated-tofu/#article"},"mainEntityOfPage":"https://cookwithdana.com/korean-spicy-marinated-tofu/"}]}</script>

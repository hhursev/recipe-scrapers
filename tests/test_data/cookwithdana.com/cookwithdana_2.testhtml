tion-1691788026230"},{"@id":"https://cookwithdana.com/one-pot-creamy-garlic-chicken/#faq-question-1691788032523"},{"@id":"https://cookwithdana.com/one-pot-creamy-garlic-chicken/#faq-question-1691788047663"}],"inLanguage":"en-US","potentialAction":[{"@type":"ReadAction","target":["https://cookwithdana.com/one-pot-creamy-garlic-chicken/"]}]},{"@type":"ImageObject","inLanguage":"en-US","@id":"https://cookwithdana.com/one-pot-creamy-garlic-chicken/#primaryimage","url":"https://cookwithdana.com/wp-content/uploads/2023/08/IMG_9731.jpg","contentUrl":"https://cookwithdana.com/wp-content/uploads/2023/08/IMG_9731.jpg","width":996,"height":1200,"caption":"Creamy chicken on top of white rice on a grey plate with a spoon."},{"@type":"BreadcrumbList","@id":"https://cookwithdana.com/one-pot-creamy-garlic-chicken/#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Cook With Dana","item":"https://cookwithdana.com/"},{"@type":"ListItem","position":2,"name":"Recipes","item":"https://cookwithdana.com/recipes/"},{"@type":"ListItem","position":3,"name":"Meals Under 30 Minutes","item":"https://cookwithdana.com/category/recipes/meals-under-30-minutes/"},{"@type":"ListItem","position":4,"name":"One Pot Creamy Garlic Chicken"}]},{"@type":"WebSite","@id":"https://cookwithdana.com/#website","url":"https://cookwithdana.com/","name":"Cook With Dana","description":"","publisher":{"@id":"https://cookwithdana.com/#organization"},"potentialAction":[{"@type":"SearchAction","target":{"@type":"EntryPoint","urlTemplate":"https://cookwithdana.com/?s={search_term_string}"},"query-input":{"@type":"PropertyValueSpecification","valueRequired":true,"valueName":"search_term_string"}}],"inLanguage":"en-US"},{"@type":"Organization","@id":"https://cookwithdana.com/#organization","name":"Cook With Dana","url":"https://cookwithdana.com/","logo":{"@type":"ImageObject","inLanguage":"en-US","@id":"https://cookwithdana.com/#/schema/logo/image/","url":"https://cookwithdana.com/wp-content/uploads/2024/03/Untitled-design.jpg","contentUrl":"https://cookwithdana.com/wp-content/uploads/2024/03/Untitled-design.jpg","width":696,"height":696,"caption":"Cook With Dana"},"image":{"@id":"https://cookwithdana.com/#/schema/logo/image/"},"sameAs":["https://www.facebook.com/cookwithdanaa/"]},{"@type":"Person","@id":"https://cookwithdana.com/#/schema/person/cac00b1273a418e39df43d2117f3bc07","name":"Dana Rao","image":{"@type":"ImageObject","inLanguage":"en-US","@id":"https://cookwithdana.com/#/schema/person/image/","url":"https://secure.gravatar.com/avatar/987dca76cff46aec7797f079c1bcf2478a6b07fe43c6d764ccf492edaa486126?s=96&d=mm&r=g","contentUrl":"https://secure.gravatar.com/avatar/987dca76cff46aec7797f079c1bcf2478a6b07fe43c6d764ccf492edaa486126?s=96&d=mm&r=g","caption":"Dana Rao"},"sameAs":["https://cookwithdana.com/about/"],"url":"https://cookwithdana.com/author/cookwdanatest/"},{"@type":"Question","@id":"https://cookwithdana.com/one-pot-creamy-garlic-chicken/#faq-question-1691788026230","position":1,"url":"https://cookwithdana.com/one-pot-creamy-garlic-chicken/#faq-question-1691788026230","name":"Can I use chicken breast?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Yes, you can! Try to use 1.5 pound chicken breast so the proportions of the ingredients is the same as the recipe. You may need to increase the cooking time of the chicken to ensure that the chicken is cooked through. ","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https://cookwithdana.com/one-pot-creamy-garlic-chicken/#faq-question-1691788032523","position":2,"url":"https://cookwithdana.com/one-pot-creamy-garlic-chicken/#faq-question-1691788032523","name":"I am lactose intolerant. Can I use lactose-free milk or oat milk?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Yes, you can! Use your preferred type of milk. Parmesan cheese has low lactose content and can usually be tolerated by those with lactose intolerance. ","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https://cookwithdana.com/one-pot-creamy-garlic-chicken/#faq-question-1691788047663","position":3,"url":"https://cookwithdana.com/one-pot-creamy-garlic-chicken/#faq-question-1691788047663","name":"Can I add in veggies?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Yes, you can add some chopped spinach or mushrooms to the cream sauce. You can also added cooked pasta for an easy one pot meal!","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Recipe","name":"Creamy Garlic Chicken","author":{"@id":"https://cookwithdana.com/#/schema/person/cac00b1273a418e39df43d2117f3bc07"},"description":"This one pot creamy garlic chicken is made with parmesan, garlic and cilantro (or herb of choice) for a delicious 20 minute meal. All you have to do is throw everything in one skillet or pot and once cooked, you can taste the fragrant flavor. The juicy chicken thighs go great with white rice and side of veggies.","datePublished":"2023-08-11T23:02:39+00:00","image":["https://cookwithdana.com/wp-content/uploads/2023/08/IMG_9731.jpg","https://cookwithdana.com/wp-content/uploads/2023/08/IMG_9731-500x500.jpg","https://cookwithdana.com/wp-content/uploads/2023/08/IMG_9731-500x375.jpg","https://cookwithdana.com/wp-content/uploads/2023/08/IMG_9731-480x270.jpg"],"recipeYield":["2","2 people"],"prepTime":"PT5M","cookTime":"PT15M","totalTime":"PT20M","recipeIngredient":["1.5 pound chicken thighs (boneless and skinless)","1½ teaspoon salt","½ teaspoon black pepper","½ teaspoon garlic powder","½ teaspoon paprika","½ teaspoon cumin","1 tablespoon neutral oil (for frying the chicken)","1 tablespoon unsalted butter","1 cup half &amp; half*","4  garlic cloves (minced)","¼ cup shredded parmesan","12-20 sprigs cilantro (finely minced)"],"recipeInstructions":[{"@type":"HowToSection","name":"Season Chicken","itemListElement":[{"@type":"HowToStep","text":"Pat chicken thighs dry with a paper towel. Moisture will prevent the chicken from searing.","name":"Pat chicken thighs dry with a paper towel. Moisture will prevent the chicken from searing.","url":"https://cookwithdana.com/one-pot-creamy-garlic-chicken/#wprm-recipe-2300-step-0-0"},{"@type":"HowToStep","text":"Mix the following seasonings together in a bowl: 1½ teaspoon salt, 1/2 teaspoon black pepper, 1/2 teaspoon garlic powder, 1/2 teaspoon paprika, and 1/2 teaspoon cumin.","name":"Mix the following seasonings together in a bowl: 1½ teaspoon salt, 1/2 teaspoon black pepper, 1/2 teaspoon garlic powder, 1/2 teaspoon paprika, and 1/2 teaspoon cumin.","url":"https://cookwithdana.com/one-pot-creamy-garlic-chicken/#wprm-recipe-2300-step-0-1"},{"@type":"HowToStep","text":"Mince garlic and finely chop fresh cilantro.","name":"Mince garlic and finely chop fresh cilantro.","url":"https://cookwithdana.com/one-pot-creamy-garlic-chicken/#wprm-recipe-2300-step-0-2"}]},{"@type":"HowToSection","name":"Cook Chicken","itemListElement":[{"@type":"HowToStep","text":"Heat pan or pot to medium high heat. While the pan is getting hot, add seasonings on both sides of the chicken.","name":"Heat pan or pot to medium high heat. While the pan is getting hot, add seasonings on both sides of the chicken.","url":"https://cookwithdana.com/one-pot-creamy-garlic-chicken/#wprm-recipe-2300-step-1-0"},{"@type":"HowToStep","text":"Once the pan is hot and you see a little bit of smoke coming from it, add 1 tablespoon neutral oil. Next, add your chicken thighs on the pan and cook for 4-5 minutes on one side. Flip over and cook for 2-3 minutes. Both sides should be golden brown!","name":"Once the pan is hot and you see a little bit of smoke coming from it, add 1 tablespoon neutral oil. Next, add your chicken thighs on the pan and cook for 4-5 minutes on one side. Flip over and cook for 2-3 minutes. Both sides should be golden brown!","url":"https://cookwithdana.com/one-pot-creamy-garlic-chicken/#wprm-recipe-2300-step-1-1"},{"@type":"HowToStep","text":"When the chicken has browned, take it off of the pan in a separate plate. Turn the heat down to low.","name":"When the chicken has browned, take it off of the pan in a separate plate. Turn the heat down to low.","url":"https://cookwithdana.com/one-pot-creamy-garlic-chicken/#wprm-recipe-2300-step-1-2"}]},{"@type":"HowToSection","name":"Make Creamy Garlic Sauce","itemListElement":[{"@type":"HowToStep","text":"Add 1 tablespoon butter to the pan with your minced garlic. Cook for one minute. Then, add 1 cup half &amp; half. Stir occasionally.","name":"Add 1 tablespoon butter to the pan with your minced garlic. Cook for one minute. Then, add 1 cup half &amp; half. Stir occasionally.","url":"https://cookwithdana.com/one-pot-creamy-garlic-chicken/#wprm-recipe-2300-step-2-0"},{"@type":"HowToStep","text":"Add your shredded parmesan cheese to the cream and continue to stir occasionally. Keep the heat on low to ensure that the cheese sauce doesn’t curdle while cooking.","name":"Add your shredded parmesan cheese to the cream and continue to stir occasionally. Keep the heat on low to ensure that the cheese sauce doesn’t curdle while cooking.","url":"https://cookwithdana.com/one-pot-creamy-garlic-chicken/#wprm-recipe-2300-step-2-1"},{"@type":"HowToStep","text":"Once the cheese has melted and the cream sauce has thickened, add your chicken thighs (along with juices) in the pan and cook for 1 minute. Garnish with freshly chopped cilantro!","name":"Once the cheese has melted and the cream sauce has thickened, add your chicken thighs (along with juices) in the pan and cook for 1 minute. Garnish with freshly chopped cilantro!","url":"https://cookwithdana.com/one-pot-creamy-garlic-chicken/#wprm-recipe-2300-step-2-2"}]}],"aggregateRating":{"@type":"AggregateRating","ratingValue":"4.97","ratingCount":"30","reviewCount":"14"},"review":[{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Hands down one of the best chicken garlic cream sauces we have done!  The unique spices the chicken was flavored are really nice.  They were wonderful in scrapped into the sauce.  We substituted some of the half and half with skim milk for less calories still creamy with the cheese.  We doubled the garlic, just because we like garlic.  LOL  The cilantro on the top is a lovey bright flavor burst that was not over powering.  Creamy sauce, flavorful chicken, easy to do.  We will do this recipe, again.","author":{"@type":"Person","name":"Mary Crosby"},"datePublished":"2025-01-03"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Everyone loved this! I will admit, I struggled with the sauce curdling and had to remake it. Trying to do too many things at once! Will be making again very soon.","author":{"@type":"Person","name":"Whitney"},"datePublished":"2024-11-08"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"this looks and sounds amazing and i cant wait to buy some chicken and make this for my family!","author":{"@type":"Person","name":"annamarie dodge"},"datePublished":"2023-12-15"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"I made this last week for my husband and his family! It was SO good and flavorful :)\r\n\r\nIG: @jeanjiyoon","author":{"@type":"Person","name":"Jean"},"datePublished":"2023-12-15"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"I have not tried this recipe yet but it looks so good. I just got a bottle of heavy cream and have thawed chicken thighs in the fridge which will be perfect for this recipe.","author":{"@type":"Person","name":"Anna Kim"},"datePublished":"2023-12-15"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"I am just starting to get into cooking and was really nervous about giving this one a try. I will say it didn’t look exactly like yours, but the flavors were on point! Can’t wait to try another one out soon!","author":{"@type":"Person","name":"Kelsey F"},"datePublished":"2023-12-14"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"So much flavour for not a very complicated recipe. Love these one pot meals","author":{"@type":"Person","name":"Lucy"},"datePublished":"2023-12-14"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"This was delicious! I can’t wait to make it again!","author":{"@type":"Person","name":"Jennifer Cheng"},"datePublished":"2023-12-14"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Love this recipe! Soooo yummy! Gonna try to swap out the half and half for coconut milk next time!","author":{"@type":"Person","name":"Martina"},"datePublished":"2023-12-14"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"This recipe is so convenient for lazy days and absolutely delicious! Thank you so much!","author":{"@type":"Person","name":"Michelle"},"datePublished":"2023-12-14"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"I only had bone in skin on chicken thighs so it took a looong time to cook but well worth it! The cumin adds a nice flavor.","author":{"@type":"Person","name":"Ginger"},"datePublished":"2023-11-11"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"This was amazing. The entire family loved it.","author":{"@type":"Person","name":"Laura"},"datePublished":"2023-09-04"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"This recipe is pretty straightforward and very flavorful. My family loved it, will definitely be making it again and again.","author":{"@type":"Person","name":"Samantha"},"datePublished":"2023-08-30"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"I made this tonight for my family of 7!!! No left overs what so ever!!! This dish was by far the best we've had in a long time!!!","author":{"@type":"Person","name":"Jenn"},"datePublished":"2023-08-23"}],"recipeCategory":["Main Course"],"recipeCuisine":["American"],"keywords":"cilantro chicken, creamy garlic chicken, one pot creamy chicken","nutrition":{"@type":"NutritionInformation","calories":"814 kcal","carbohydrateContent":"5 g","proteinContent":"56 g","fatContent":"62 g","saturatedFatContent":"19 g","transFatContent":"1 g","cholesterolContent":"348 mg","sodiumContent":"2016 mg","fiberContent":"1 g","sugarContent":"0.3 g","unsaturatedFatContent":"37 g","servingSize":"1 serving"},"@id":"https://cookwithdana.com/one-pot-creamy-garlic-chicken/#recipe","isPartOf":{"@id":"https://cookwithdana.com/one-pot-creamy-garlic-chicken/#article"},"mainEntityOfPage":"https://cookwithdana.com/one-pot-creamy-garlic-chicken/"}]}</script>

			h1, h2, h3, h4, h5, h6 {
	text-transform: unset;
	letter-spacing: 1px;
}
.entry-content h2:after {
	background: #ac91a275!important;
}
.sidebar .feast-grid-half {
	grid-gap: 17px;
}
.sidebar .feast-grid-half .fsri-title {
	font-size: inherit;
}
.sidebar .feast-grid-half .fsri-title {
	margin-top: 0px;
}
body {
	line-height: 1.5;
}
h1, h2, h3, h4, h5, h6 {
	line-height: 1.2;
}
.sidebar-primary {
	font-size: inherit;
}
ul.feast-category-index-list a {
	text-decoration: none;
}
.enews-widget .widgettitle {
	line-height: 1.2;
}
.widgettitle {
	text-transform: capitalize;
}
section.enews-widget {
	background: #ac91a2;
	padding: 15px;
	text-align: center;
}
section.enews-widget h3 {
	color: #fff;
	text-align: center !important;
	margin-bottom: 15px !important;
}
.enews-widget p {
	color: #fff;
	line-height: 1.2;
	margin-bottom: 15px;
}
.site-inner {
	padding-top: 10px;
	margin-bottom: 0;
	padding-bottom: 0px;
}
article.entry {
	padding-bottom: 0;
}
.no-space a {
	margin: 0;
}
ul.wp-block-latest-posts__list.is-grid li {
	list-style: none;
	text-align: center;
}
ul.wp-block-latest-posts__list.is-grid li img {
	margin-bottom: 5px;
}
ul.wp-block-latest-posts__list.is-grid li a {
	text-decoration: none;
}
.shortcode-sidebar.enews-widget {
    background: #ac91a2;
    padding: 15px;
}
.shortcode-sidebar.enews-widget .enews {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
}
.shortcode-sidebar.enews-widget .enews > * {
    width: 50%;
    margin: 0;
    padding: 0 10px;
}
.shortcode-sidebar.enews-widget .enews h4.widgettitle {
    color: #fff;
}
.shortcode-sidebar.enews-widget input {
    width: 65%;
}
.shortcode-sidebar.enews-widget p input {
    width: 99%;
}
.entry-content h2 {
    margin-top: 25px;
}
@media only screen and (min-width: 1200px) {
	.modern-menu-desktop-social .simple-social-icons li:nth-child(n+4) {
		display: initial;
	}
	.modern-menu-desktop-social .simple-social-icons li:nth-child(n+5) {
		display: none;
	}
}
@media ( max-width: 940px ) {
	.shortcode-sidebar.enews-widget .enews > * {
		width: 100%;
		margin: 0;
		padding: 0 10px;
	}
	.shortcode-sidebar.enews-widget input {
		width: 100%;
	}
	.shortcode-sidebar.enews-widget p input {
		width: 100%;
	}
}
/* Mediavine CSS Adjustment */
@media only screen and (max-width: 359px) {
   .site-inner {
     padding-left: 10px !important;
     padding-right: 10px !important;
   }
  .entry-content > ul .mv-ad-box,   ol .mv-ad-box {
      margin-left: -10px !important;
   }
  .wprm-recipe-container > .wprm-recipe {
    padding-left: 0px !important;
    padding-right: 0px !important;
    border: unset !important;
   }
  .wprm-recipe-instruction-group > ul .mv-ad-box {
    margin-left: -32px !important;
   }
  .tiktok-embed {
    min-width: unset !important;
    padding-left: 0px !important;
   }
  .instagram-media {
    min-width: unset !important;
  }
} 

/* Mailerlite form fix */
.site-footer #mlb2-22923256.ml-form-embedContainer .ml-form-embedWrapper.embedForm {
	width: 100%;
	max-width: 1080px;
}

.site-footer #mlb2-22923256.ml-form-embedContainer .ml-form-embedWrapper.embedForm h4 {
	max-width: 45%;
	display: inline-block;
	float: left;
}

.site-footer #mlb2-22923256.ml-form-embedContainer .ml-form-embedWrapper.embedForm form {
	max-width: 45%;
	display: inline-block;
	float: right;
}

@media only screen and (max-width: 768px) {
	.site-footer #mlb2-22923256.ml-form-embedContainer .ml-form-embedWrapper.embedForm h4, .site-footer #mlb2-22923256.ml-form-embedContainer .ml-form-embedWrapper.embedForm form {
		max-width: 100%;
	}
